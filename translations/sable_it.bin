one"},{"#f":5}]}],{"#f":1}],"done":["^<<\"Addio, Glider.\">>","\n",{"->t->":"atomic_heart_content.should_return_to_sandip"},{"->":"END_SCENE"},{"#f":1}],"investigation_questions":[["ev",{"VAR?":"atomic_heart_interviewed_characters"},{"VAR?":"CAFE_OWNER_RITA"},"+",{"VAR=":"atomic_heart_interviewed_characters","re":true},"/ev",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^<<\"Non credo di poter essere di grande aiuto alla tua indagine.\">>","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Potrei fare più domande.","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Hai idea del perché qualcuno avrebbe rubato il nucleo?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Dov'eri quando è andata via la corrente?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Chi pensi sia stato?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Garay era nel tuo caffè quando è andata via la corrente?","/str",{"CNT?":"garay_conversation.investigation_questions.0.c-1"},"/ev",{"*":".^.c-3","flg":5},"ev","str","^Ok, ho finito qui.","/str",{"CNT?":".^.loop"},"/ev",{"*":".^.c-4","flg":5},{"c-0":["^ ","\n","^<<\"Qualunque sia la ragione, è stato terribile per gli affari.\">>","\n",{"->":".^.^.loop"},{"#f":5}],"c-1":["^ ","\n","^<<\"Lo stesso posto in cui sono ogni giorno. Qui, al caffè.\">>","\n",{"->":".^.^.loop"},{"#f":5}],"c-2":["^ ","\n","^<<\"In questa città c'è gente che va e viene ogni giorno. Potrebbe essere chiunque.\">>","\n",{"->":".^.^.loop"},{"#f":5}],"c-3":["^ ","\n","^Rita scuote la testa, il che rende la risposta una sorpresa.","\n","^<<\"Oh sì. Sì, era assolutamente qui...\">>","\n","^<<\"A combinarne delle solite: arrivare ubriaco, latrare un insulto a qualche povero cliente, e prima che me ne accorga, devo separare un'altra rissa.\">>","\n","^Questo chiude la questione: Garay ha un alibi. La ringrazio per l'informazione, e mi scuso per il disturbo.","\n","^<<\"Oh, nessun problema. Ma se vedi quel vecchio scemo in giro, digli che mi deve i soldi del vetro rotto.\">>","\n",{"->":".^.^.loop"},{"#f":5}],"c-4":["^ ","\n","ev","void","/ev","->->",{"->":".^.^.loop"},{"#f":5}],"loop":[{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"#f":1}],"shar_varana_conversation":["ev","str","^Sacerdote Atomico Shar Varana","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.17"},null],"#f":5}],"\n",{"->t->":".^.quest_content"},{"->":".^.done"},{"first_intro":["^Shar Varana si presenta. È il Sacerdote Atomico di Eccria.","\n","ev","void","/ev","->->",{"#f":1}],"default_intro":["^<<\"Salute, Glider.\">>","\n","ev","void","/ev","->->",{"#f":1}],"done":["^<<\"Addio, Glider.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"quest_content":[["ev",{"VAR?":"LLHOR_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"searching_for_llhor_content.quest_start"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"LLHOR_STARTED"},{"VAR?":"LLHOR_RETURNED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"searching_for_llhor_content.quest_in_progress"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"LLHOR_RETURNED"},{"VAR?":"LLHOR_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"searching_for_llhor_content.quest_complete"},{"->":".^.^.^.4"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.^.generic_chat"},{"->":".^.^.^.4"},null]}],"nop","\n","ev","void","/ev","->->",{"#f":1}],"generic_chat":["^Chiacchieriamo del tempo.","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"citra_conversation":["ev","str","^Mercante Citra","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev",{"VAR?":"NOZIS_NIBBLES_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_start"},{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"NOZIS_NIBBLES_STARTED"},{"VAR?":"NOZIS_NIBBLES_COMPLETED"},{"f()":"between"},{"f()":"have_enough_glowworms"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_active"},{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"NOZIS_NIBBLES_STARTED"},{"VAR?":"NOZIS_NIBBLES_COMPLETED"},{"f()":"between"},{"f()":"have_enough_glowworms"},"&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_completed"},{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.post_quest"},{"->":".^.^.^.10"},null]}],"nop","\n",{"done":["^Saluto Citra.","\n",{"->":"END_SCENE"},{"#f":1}],"quest_start":[["ev",{"VAR?":"NOZIS_NIBBLES_STARTED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Allora! È un'abitudine la tua, cercare di farti mangiare?\">>","\n","ev","str","^Mi dispiace!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Cos'era quello?","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Mi scuso in una raffica di mormorii di scuse. Ottiene uno scuotimento di testa.","\n","^<<\"Non chiedere scusa a me! Sei tu quella che cerca di farsi mordere da un Wyrm.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Chiedo cosa fosse a poco fa quasi a uccidermi.","\n","^<<\"Beh è un Wyrm, no?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Questa ragazza è Nozi e ha <i>una forza bestiale</i>. Non dovresti avvicinarti tanto a meno che tu abbia avuto un addestramento adeguato, o abbia cibo a portata di mano.\">>","\n","^<<\"Ma sei una Glider, no? Quindi <i>immagino</i> di poter perdonare un po' di goffaggine col wyrm. Mi chiamo Citra.\">>","\n","^Le dico che sono Sable, e fa un rapido complimento al mio nome, che placa quasi l'imbarazzo che mi brucia le orecchie. Dopodiché è tutta affari.","\n","^<<\"Allora cosa ti porta qui, Glider?\">>","\n","ev","str","^Posso aiutare in qualcosa?","/str","/ev",{"*":".^.c-2","flg":4},{"c-2":["^ ","\n","ev",{"VAR?":"NOZIS_NIBBLES_STARTED"},{"f()":"activate"},"pop","/ev","\n","^Ho la sensazione che se Citra fosse un animale, le si sarebbe rizzato il pelo alla mia domanda.","\n","^Mi torna un ricordo, in cui Jadi mi disse che a volte spiegare di che aiuto si ha bisogno è un lavoro in sé, e che dovrei cercare di vedere dove posso essere utile prima di chiedere.","\n","^Ma credo di aver già fatto abbastanza presentazioni.","\n","^<<\"Mi serve aiuto...\">>","\n","^Citra ci pensa un momento.","\n","^<<\"Sai che ti dico? Sì. Nozi adora i vermi luminosi hakoani come golosità. Se potessi trovargliene un po', te ne saremmo grate entrambe.\">>","\n","^Le dico che credo di poterlo fare, e decido che è meglio non chiedere altri dettagli. Sono sicura di trovare qualcosa.","\n",{"->":".^.^.^.^.^.done"},{"#f":5}],"#f":5}]}],{"#f":1}],"quest_active":["^<<\"Sto ancora aspettando quei vermi luminosi, Glider.\">>","\n",{"->":".^.^.done"},{"#f":1}],"quest_completed":["ev",{"VAR?":"NOZIS_NIBBLES_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^Dico a Citra che ho i vermi luminosi per lei.","\n","^<<\"Davvero? Sai, mi ero quasi dimenticata di averteli chiesti. Devo essere stata un po' distratta.\">>","\n",{"#":"inventory_remove: Glowworm, 5"},"^Le consegno i vermi luminosi.","\n","^<<\"Grazie! Stasera Nozi mangerà persino meglio di me.\">>","\n",{"#":"inventory_add: MerchantBadge"},"^Ecco un Distintivo del Mercante come ricompensa.","\n",{"->":".^.^.done"},{"#f":1}],"post_quest":["^<<\"Ci si rivede.\">>","\n",{"->":".^.^.done"},{"#f":1}],"#f":1}],"sandip_conversation":["ev","str","^Guardia Sandip","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev",{"VAR?":"ATOMIC_HEART_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_start"},{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"ATOMIC_HEART_SPARE_PART_READY"},{"VAR?":"ATOMIC_HEART_GOT_SPARE_PART"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.spare_part_ready"},{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"VAR?":"ATOMIC_HEART_RETURNED_AFTER_FIXING"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.return_after_fixing"},{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.default_intro"},{"->":".^.^.^.10"},null]}],"nop","\n",{"quest_start":[["ev",{"VAR?":"ATOMIC_HEART_STARTED"},{"f()":"activate"},"pop","/ev","\n","^La guardia mi torreggia sopra. Non capisco se in qualche modo abbia commesso qualche trasgressione mentre mi squadra.","\n","^Sembra contemplare una decisione di qualche tipo, e mormora qualcosa di incomprensibile sottovoce.","\n","ev","str","^C... ciao?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Chi sei?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Hai intenzione di fissarmi tutto il giorno?","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Sembra rifocalizzarsi mentre parlo, come a ricordarsi che sono un essere vivente.","\n","^<<\"Andrai bene. Ho qualcosa in mente per te.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Risponde secco.","\n","^<<\"Ispettore Detective Guardia Sandip.\">>","\n","^Fa una pausa, guardandosi intorno nella piazza per un istante prima di rifocalizzarsi su di me.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^Mi fissa con uno sguardo come se avessi fatto qualcosa di nascosto.","\n","^<<\"E come è da Glider inciampare goffamente nel mio territorio.\">>","\n","^<<\"Utile. Molto utile.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Mettiamoti a buon uso.\">>","\n","^Io? Gli chiedo come.","\n","^<<\"Beh, sei una Glider. Per natura un'estranea. Non appartieni a nulla e a nessuno. E quindi sei capace di un'oggettività inconsueta.\">>","\n","^Mi chiedo se condividere la miriade di mie opinioni popolari, impopolari o profondamente soggettive, ma decido di risparmiargli. Sembra che abbia molto altro da dire.","\n","^<<\"Mi chiamo Sandip. E sono in mezzo a un'indagine molto seria. Sono in pochi quelli di cui posso fidarmi. Forse hai notato che... siamo senza energia, sì?\">>","\n","ev","str","^L'ho notato sì!","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Davvero?","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Mi piace. È rustico.","/str","/ev",{"*":".^.c-5","flg":4},{"c-3":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-5":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Non è un incidente. Qualcuno ha rubato il nucleo di potenza dal Cuore Atomico. E il colpevole mi sfugge ancora... ho pensato che forse potresti aiutarmi a risolvere questo crimine. E consegnare il ladro alla giustizia.\">>","\n","ev","str","^Ti aiuto!","/str","/ev",{"*":".^.c-6","flg":4},{"c-6":["^ ","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":["^Ho già iniziato a immaginarmi a sfrecciare dentro e fuori dalle ombre, a seguire l'elusivo ladro d'energia per la città. Nella mia mente sono velocità e fumo, una creatura di astuzia e destrezza.","\n","^Poi Sandip mi porge un mucchio arrugginito.","\n",{"#":"inventory_add: AtomicHeartPowerCoreBroken"},"^<<\"Questo è un vecchio nucleo di potenza. In pratica un rottame. Ma se me lo porti al Macchinista, può sistemarlo e possiamo rimettere in moto questa città.\">>","\n","^<<\"Ma! Mentre sei lì, voglio che gli chieda se ha idea di chi possa voler rubare una cosa simile... e perché. Lo chiederei io stesso ma...\">>","\n","ev","str","^Devi tenere l'indagine sotto silenzio?","/str","/ev",{"*":".^.c-7","flg":4},"ev","str","^La gente è meno propensa a parlare con le guardie?","/str","/ev",{"*":".^.c-8","flg":4},{"c-7":["^ ","\n",{"->":".^.^.^.g-3"},{"#f":5}],"c-8":["^ ","\n",{"->":".^.^.^.g-3"},{"#f":5}],"#f":5}],"g-3":["^<<\"Capisci. Vedo di aver fatto la scelta giusta. Riferiscimi quando avrai sistemato la cosa, sì? Sarò in attesa.\">>","\n",{"->":".^.^.^.^.done"},{"#f":5}]}],{"#f":1}],"spare_part_ready":[["ev",{"VAR?":"ATOMIC_HEART_SPARE_PART_READY"},{"VAR?":"ATOMIC_HEART_GOT_SPARE_PART"},{"f()":"between"},"!","/ev",[{"->":".^.b","c":true},{"b":["^ ","ev","void","/ev","->->",{"->":".^.^.^.7"},null]}],"nop","\n","^Sandip si dondola sulle punte e sui talloni, soddisfatto.","\n","^<<\"Buone notizie! Hamza ha finito di lavorare sul nucleo di scorta. Mi servirebbe il tuo aiuto se hai un momento?\">>","\n","ev","str","^Posso aiutare!","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev",{"VAR?":"ATOMIC_HEART_GOT_SPARE_PART"},{"f()":"activate"},"pop","/ev","\n","^<<\"Perfetto. Vorrei che tu portassi il nuovo nucleo al Cuore Atomico e lo inserissi. E mentre sei lì... vedi se riesci a raccogliere indizi su chi potrebbe aver rubato l'originale, sì?\">>","\n","ev","str","^Ti sei rivolto alla Glider giusta.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Indizi? Che tipo di indizi?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Oh, adoro un mistero!","/str","/ev",{"*":".^.c-3","flg":4},{"c-1":["^ ","\n","^Incrocio le braccia e gli faccio un cenno sicuro. Mi annuisce di rimando.","\n","^<<\"Avevo una sensazione su di te. Dal momento in cui ti ho vista. Quell'aria di mistero mi dice che sai seguire una pista. O scoprirne una tua.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-2":["^ ","\n","^<<\"Che tipo di indizi? Beh... sai. Qualcosa fuori posto.\">>","\n","^Chiedo come ci riesca, da guardia.","\n","^<<\"Ti piace l'arazzo, sì?\">>","\n","^Annuisco.","\n","^<<\"Hai mai guardato un grande, bellissimo, ornato arazzo, e sei rimasta così colpita dalla sua maestria... e poi all'improvviso ti sei accorta di un piccolo strappo? Una sola cosa, fuori posto?\">>","\n","^<<\"Gli indizi sono così.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n","^<<\"Finché non dura troppo, sì?\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":[{"#":"inventory_add: AtomicHeartKeycard"},"^<<\"Hamza ti ha lasciato una tessera. Ti servirà per sbloccare la porta principale.\">>","\n","^<<\"La camera centrale è protetta da un codice di sicurezza ma sono sicuro che troverai la tua via. Il ladro l'ha trovata in qualche modo.\">>","\n","^<<\"Per raggiungere il Cuore Atomico, vai alla sottostazione appena fuori città e segui il cavo che corre attraverso e sotto le sabbie.\">>","\n",{"#":"inventory_add: AtomicHeartPowerCoreRepaired"},"^<<\"A presto. Spero con notizie.\">>","\n",{"->":".^.^.^.^.done"},{"#f":5}]}],{"#f":1}],"return_after_fixing":[["ev",{"VAR?":"ATOMIC_HEART_RETURNED_AFTER_FIXING"},{"f()":"activate"},"pop","/ev","\n","^<<\"Ah, Glider! Hai fatto un lavoro brillante a far tornare la corrente! Non so se sei riuscita a sentirlo, ma c'è stato un fragore enorme. Tutta la città era felice.\">>","\n","ev","str","^Tutto in una giornata di lavoro.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non è stato facile...","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Il tuo lavoro è apprezzato e tu sei stimata. Ora!\">>","\n","^Si china in avanti.","\n","^<<\"E la nostra piccola indagine? Prove utili?\">>","\n",{"->":".^.^.^.^.opts"},{"#f":5}]}],{"#f":1}],"default_intro":["^Sandip saluta.","\n",{"->":".^.^.opts"},{"#f":1}],"opts":[["^<<\"Cosa posso fare per te, Sable?\">>","\n","ev","str","^Discuti delle prove fisiche.","/str",{"VAR?":"atomic_heart_all_clues"},{"f()":"reached_any"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Esamina i sospetti.","/str",{"VAR?":"atomic_heart_all_suspects"},{"f()":"reached_any"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Formula un'accusa.","/str",{"f()":"atomic_heart_ready_to_accuse"},"/ev",{"*":".^.c-2","flg":5},"ev","str","^Addio.","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.physical_clues"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.review_suspects"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.^.make_an_accusation"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.^.^.done"},{"#f":5}]}],{"#f":1}],"done":["^Saluto Sandip.","\n",{"->":"END_SCENE"},{"#f":1}],"physical_clues":[["^<<\"Cos'hai trovato quando hai perquisito il Cuore?\">>","\n","ev","str","^La finestra era rotta.","/str",{"VAR?":"ATOMIC_HEART_CLUE_GLASS"},{"f()":"reached"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^C'era una piuma sul pavimento.","/str",{"VAR?":"ATOMIC_HEART_CLUE_FEATHER"},{"f()":"reached"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Ho trovato una nota.","/str",{"VAR?":"ATOMIC_HEART_CLUE_NOTE"},{"f()":"reached"},"/ev",{"*":".^.c-2","flg":5},"ev","str","^Non c'erano danni all'alloggiamento.","/str",{"VAR?":"ATOMIC_HEART_CLUE_SOCKET"},{"f()":"reached"},"/ev",{"*":".^.c-3","flg":5},"ev","str","^Parla di qualcos'altro.","/str","/ev",{"*":".^.c-4","flg":4},{"c-0":["^ ","\n","^Gli dico che la finestra della sala di controllo del Cuore era stata frantumata, ed è presumibilmente come il colpevole sia entrato.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Gli parlo della piuma che ho visto sul pavimento del Cuore, e suggerisco che il colpevole possa averla lasciata cadere.","\n","^Dico che potrebbe essere stato un incidente... poi faccio una pausa drammatica e sussurro che potrebbe anche essere un biglietto da visita.","\n","^Sandip incrocia le braccia, annuendo con foga.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^Gli dico che ho trovato una nota sul pavimento, e che elencava i debiti nei confronti dei Mercanti. È stata lasciata di proposito, mi domando ad alta voce, o l'ha persa per sbaglio lo sciocco colpevole? Sandip giunge le dita incuriosito.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-3":["^ ","\n","^Spiego che l'alloggiamento del nucleo era in perfette condizioni, immacolato persino per uno come me che... non è di certo un'esperta. Ipotizzo che chi ha rimosso il nucleo sapesse cosa stava facendo, e non volesse danneggiarlo. Sandip sembra apprezzare l'idea.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-4":["^ ","\n",{"->":".^.^.^.^.opts"},{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"review_suspects":[["^<<\"Di chi vuoi parlare?\">>","\n","ev","str","^Macchinista Hamza.","/str",{"VAR?":"ATOMIC_HEART_SUSPECT_HAMZA"},{"f()":"reached"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Mercante Iria.","/str",{"VAR?":"ATOMIC_HEART_SUSPECT_IRIA"},{"f()":"reached"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Scalatore Garay.","/str",{"VAR?":"ATOMIC_HEART_SUSPECT_GARAY"},{"f()":"reached"},"/ev",{"*":".^.c-2","flg":5},"ev","str","^È stato un gruppo.","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Non ho ancora sospetti.","/str",{"f()":"fallback"},"/ev",{"*":".^.c-4","flg":5},"ev","str","^Parla di qualcos'altro.","/str","/ev",{"*":".^.c-5","flg":4},{"c-0":["^ ","\n",{"->t->":".^.^.^.^.review_hamza"},{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->t->":".^.^.^.^.review_iria"},{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->t->":".^.^.^.^.review_garay"},{"->":".^.^.g-0"},{"#f":5}],"c-3":["^ ","\n",{"->t->":".^.^.^.^.review_group"},{"->":".^.^.g-0"},{"#f":5}],"c-4":["^ ","\n","^<<\"Continua a chiedere in giro, allora. Il colpevole si rivelerà col tempo.\">>","\n",{"->":".^.^.^.^.opts"},{"->":".^.^.g-0"},{"#f":5}],"c-5":["^ ","\n",{"->":".^.^.^.^.opts"},{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"review_hamza":[["^<<\"Esaminiamo il caso contro Hamza.\">>","\n",["^<<\"Qual è il suo movente?\">>","\n","ev","str","^Aveva debiti.","/str",{"CNT?":"garay_conversation.investigation_questions.0.c-0"},{"VAR?":"ATOMIC_HEART_CLUE_NOTE"},{"f()":"reached"},"||","/ev",{"*":".^.c-0","flg":5},"ev","str","^Odia la tecnologia atomica.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non so.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Era in debito con i mercanti. Hanno mandato uomini a saccheggiargli l'officina per spaventarlo e farlo pagare.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-1":["^ ","\n","^<<\"Sembra improbabile, è un Macchinista. È lui che ha dovuto riparare il nucleo quando si è rotto.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-2":["^ ","\n","^<<\"Continua a indagare, allora.\">>","\n","ev","void","/ev","->->",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5,"#n":"g-0"}],{"g-1":["^<<\"Come l'ha fatto?\">>","\n","ev","str","^Aveva il codice di sicurezza e la tessera.","/str",{"VAR?":"ATOMIC_HEART_GOT_SPARE_PART"},{"f()":"reached"},"/ev",{"*":".^.c-3","flg":5},"ev","str","^Capisce le macchine.","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Non so.","/str","/ev",{"*":".^.c-5","flg":4},{"c-3":["^ ","\n","^Aveva il codice di sicurezza, gli bastava entrare dalla porta.","\n","ev",{"VAR?":"ATOMIC_HEART_CLUE_GLASS"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","^<<\"E la finestra rotta?\">>","\n","^È importante? Non so.","\n",{"->":".^.^.^.9"},null]}],"nop","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-4":["^ ","\n","^<<\"Questo non lo rende colpevole, è un Macchinista.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-5":["^ ","\n","^<<\"Pensaci su, allora.\">>","\n","ev","void","/ev","->->",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":["ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"review_iria":[["^<<\"Iria è molto potente. Faremmo molta fatica a costruire un caso solido contro di lei.\">>","\n","^<<\"Qual è il suo movente?\">>","\n","ev","str","^Trarre profitto dal panico.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Odia il Serai.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non ancora.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^<<\"Sì, da quando è successo la gente ha decisamente fatto scorte.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Sandip sembra poco convinto.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Continua a chiedere in giro.\">>","\n","ev","void","/ev","->->",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Come l'ha fatto?\">>","\n","ev","str","^Hamza le deve dei soldi.","/str",{"VAR?":"ATOMIC_HEART_CLUE_NOTE"},{"f()":"reached"},"/ev",{"*":".^.c-3","flg":5},"ev","str","^Ha fatto fare il lavoro a qualcun altro.","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Non ancora.","/str","/ev",{"*":".^.c-5","flg":4},{"c-3":["^ ","\n","^<<\"Capisco. Quindi gli ha fatto consegnare la chiave.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n","^<<\"Beh, non riesco a immaginarla farlo di persona, e ha un alibi.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-5":["^ ","\n","^<<\"Continua a scavare.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"review_garay":[["^<<\"Esaminiamo il caso contro Garay. Qual è il suo movente?\">>","\n","ev","str","^L'ha venduto.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Qualcuno l'ha pagato per farlo.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non ancora.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Continua a indagare, allora.\">>","\n","ev","void","/ev","->->",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Ha una brutta reputazione a Eccria. Si dice farebbe qualsiasi cosa per denaro. È una buona pista.\">>","\n","^<<\"Come l'ha fatto?\">>","\n","ev","str","^Ha rubato la chiave dall'officina di Hamza.","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^È uno scalatore, ha scalato!","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Non ancora.","/str","/ev",{"*":".^.c-5","flg":4},{"c-3":["^ ","\n","^<<\"Ah sì, l'officina è stata scassinata l'altro giorno.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n","^<<\"È possibile, mi sorprende che ce l'abbia fatta con le superfici metalliche scivolose del Cuore Atomico.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-5":["^ ","\n","^<<\"Pensaci su e tornami quando hai capito.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"review_group":[["^<<\"Pensi possa essere stato uno sforzo collettivo?\">>","\n","^<<\"Qual è il movente?\">>","\n","ev","str","^Far cadere Eccria.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non ne sono sicura.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^<<\"Sembra... improbabile. La mancanza di corrente è una difficoltà, sì. Ma temporanea.\">>","\n","^Sandip non sembra molto colpito dalla mia linea di pensiero.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"make_an_accusation":[["^<<\"Allora chi è il colpevole?\">>","\n","ev","str","^Non ho ancora deciso.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Accusa il Macchinista Hamza.","/str",{"VAR?":"ATOMIC_HEART_SUSPECT_HAMZA"},{"f()":"reached"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Accusa lo Scalatore Garay.","/str",{"VAR?":"ATOMIC_HEART_SUSPECT_GARAY"},{"f()":"reached"},"/ev",{"*":".^.c-2","flg":5},"ev","str","^Accusa la Mercante Iria.","/str",{"VAR?":"ATOMIC_HEART_SUSPECT_IRIA"},{"f()":"reached"},"/ev",{"*":".^.c-3","flg":5},{"c-0":["^ ","\n","^<<\"Prenditi il tuo tempo, non vogliamo sbagliare.\">>","\n",{"->":".^.^.^.^.opts"},{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","ev",{"list":{"atomic_heart.ATOMIC_HEART_ACCUSED_MACHINIST":17,"atomic_heart.ATOMIC_HEART_COMPLETED":20}},{"f()":"activate"},"pop","/ev","\n","^Spiego come Hamza dovesse soldi ai Mercanti, come abbia rubato il nucleo e tentato di inscenare la scena al Cuore Atomico.","\n","^Ha venduto il nucleo al mercato del Serai, ma non prima che la sua officina venisse saccheggiata.","\n","^<<\"Il nostro Macchinista! Non posso crederci. Quel mascalzone! Vado ad arrestarlo subito.\">>","\n","^<<\"Lo porterò alla prigione fuori città. Poi i Testimoni decideranno il suo destino.\">>","\n","^<<\"Grazie per il tuo aiuto.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","ev",{"list":{"atomic_heart.ATOMIC_HEART_ACCUSED_CLIMBER":18,"atomic_heart.ATOMIC_HEART_COMPLETED":20}},{"f()":"activate"},"pop","/ev","\n","^Spiego come Garay potrebbe aver rubato il nucleo, arrampicandosi attraverso il vetro rotto della finestra del Cuore Atomico.","\n","^<<\"Non c'è da stupirsi, quei Serai sfruttano la buona volontà dei cittadini di continuo! Risentono del comfort e dei lussi di Eccria. Questa è la punta dell'iceberg, ne sono sicuro. Prima ci sbarazzeremo di quei rifiuti, meglio sarà.\">>","\n","^<<\"Era ora che quel disgraziato avesse ciò che si meritava.\">>","\n","^<<\"Mi piacerà portarlo alla prigione fuori città. Poi i Testimoni decideranno il suo destino. Non saranno favorevoli a un Serai, di sicuro.\">>","\n","^Ho la sensazione di aver scatenato una tensione sottostante. Posso solo sperare di non doverlo rimpiangere.","\n","^<<\"Grazie per il tuo aiuto.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-3":["^ ","\n","ev",{"list":{"atomic_heart.ATOMIC_HEART_ACCUSED_IRIA":19,"atomic_heart.ATOMIC_HEART_COMPLETED":20}},{"f()":"activate"},"pop","/ev","\n","^Sono eccitata di spiegare come Iria abbia tratto vantaggio truccando i mercati dopo il blackout. Come abbia sfruttato la mancanza di corrente per creare scarsità e alzare i prezzi nella disperazione della gente.","\n","^La mia eccitazione viene smorzata dal modo in cui Sandip sospira a metà della spiegazione. Dico che non credo Iria stessa abbia commesso il crimine e lui sembra ancora più rassegnato. Il mio caso sembra crollare.","\n","^<<\"Hmmm, è una situazione delicata. Non posso arrestare Iria — non è così che funziona a Eccria.\">>","\n","^<<\"Anche se avessi prove inconfutabili — che non hai — non si va da nessuna parte.\">>","\n","^Mi sento sgonfia: mi è sfuggito qualcosa o era sin dall'inizio una causa persa?","\n","^<<\"Grazie comunque per l'aiuto, Glider. Forse è meglio se non dici a nessuno della nostra piccola scoperta qui.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"inventory_add: GuardsBadge"},"^<<\"Un'ultima cosa, per il disturbo.\">>","\n","^<<\"Stammi bene, Sable.\">>","\n",[{"->":"END_SCENE"},{"#f":5,"#n":"g-1"}],{"#f":5}]}],{"#f":1}],"#f":1}],"hamza_conversation":["ev","str","^Macchinista Hamza","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev",{"CNT?":".^.^.first_intro"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.first_loop"},{"first_intro":["^Hamza è il Macchinista di Eccria.","\n","^È impegnato a sistemare l'officina. Sembra che qualcuno abbia saccheggiato il posto.","\n","ev","void","/ev","->->",{"#f":1}],"default_intro":["^Hamza saluta.","\n","ev","void","/ev","->->",{"#f":1}],"first_loop":["^<<\"Cosa posso fare per te, Glider?\">>","\n",{"->":".^.^.opts"},{"#f":1}],"loop":["^<<\"Posso fare qualcos'altro per te?\">>","\n",{"->":".^.^.opts"},{"#f":1}],"opts":[["ev","str","^Cos'è successo qui?","/str",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"!","/ev",{"*":".^.c-0","flg":5},"ev","str","^Ho una consegna per te.","/str",{"VAR?":"ATOMIC_HEART_STARTED"},{"VAR?":"ATOMIC_HEART_DELIVERED_SPARE_PART"},{"f()":"between"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Ho qualche domanda sul blackout.","/str",{"f()":"atomic_heart_in_progress"},"/ev",{"*":".^.c-2","flg":5},"ev","str","^Personalizza hoverbike.","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Addio.","/str","/ev",{"*":".^.c-4","flg":4},{"c-0":["^ ","\n",{"#":"RansackedWorkshopCameraOn"},"^Hamza spiega che è successo qualche notte fa. Non ha idea di chi sia stato. Potrebbe essere legato al blackout?","\n",{"#":"RansackedWorkshopCameraOff"},"^Sembra più rassegnato che preoccupato di vedere l'officina saccheggiata e indica di non sapere chi o perché qualcuno avrebbe fatto una cosa del genere. Non sono sicura di credere alla sua ignoranza ma lascio perdere.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","ev",{"VAR?":"ATOMIC_HEART_DELIVERED_SPARE_PART"},{"f()":"activate"},"pop","/ev","\n",{"#":"inventory_remove: AtomicHeartPowerCoreBroken"},"^Hamza fa un sorrisetto, ma la sua espressione è calda.","\n","^<<\"Ti stanno facendo fare delle commissioni, eh?\">>","\n",["ev","str","^Mi piace tenermi occupata.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Sì, e sono un po' seccata.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Alla gente piace darmi commissioni.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^<<\"Oh, ti capisco. Se non continuo a lavorare, prima o poi dovrò pensare ad alcune cose che mi ronzano in questo strano cervello.\">>","\n","^<<\"E a nessuno serve, soprattutto a me.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Beh, immagino tu abbia imparato qualcosa di te durante il Volo: non ti piace il lavoro gratis.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Mm, sì, capita ai Glider. La gente li vede come se avessero quella libertà senza direzione, per cui non interrompono niente se gli chiedi di andare a prendere qualcosa.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Lo consegnerò a Sandip quando sarà pronto.\">>","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.^.investigation_questions"},{"->":".^.^.g-0"},{"#f":5}],"c-3":["^ ","\n",{"#":"StartCustomization"},"^<<\"Diamogli un'occhiata, sì?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-4":["^ ","\n",{"->":".^.^.^.^.done"},{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^.^.loop"},{"#f":5}]}],{"#f":1}],"done":["^Saluto Hamza.","\n",{"->t->":"atomic_heart_content.should_return_to_sandip"},{"->":"END_SCENE"},{"#f":1}],"investigation_questions":[["ev",{"VAR?":"atomic_heart_interviewed_characters"},{"VAR?":"MACHINIST_HAMZA"},"+",{"VAR=":"atomic_heart_interviewed_characters","re":true},"/ev","^Cosa voglio chiedere?","\n","ev","str","^Hai idea del perché qualcuno avrebbe rubato il nucleo?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Dov'eri quando è andata via la corrente?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Chi pensi sia stato?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Ok, ho finito qui.","/str",{"CNT?":".^.questions_loop"},"/ev",{"*":".^.c-3","flg":5},{"c-0":["^ ","\n","^Incrocia le braccia e guarda in basso, riflettendoci.","\n","^<<\"L'energia è la linfa di tutto ciò che facciamo, come Macchinisti. E il nostro lavoro esiste per esaltare il passato e mettere al sicuro il futuro: l'energia sostiene le macchine, e le macchine sono legate alle persone.\">>","\n","^Annuisco, in ascolto.","\n","^<<\"Se vuoi togliere il potere alle persone, vuoi renderle impotenti.\">>","\n","^Sembra triste, a questo punto.","\n","^<<\"Quindi credo che cercherai qualcuno cui importa poco delle persone comuni.\">>","\n",{"->":".^.^.questions_loop"},{"#f":5}],"c-1":["^ ","\n","^<<\"Ero in officina, a dormire. Lì faccio la maggior parte del mio sonno, ultimamente, a essere onesto.\">>","\n","^Fa spallucce.","\n","^<<\"In ogni caso, non mi sono accorto che qualcosa non andava.\">>","\n","^Chiedo perché no.","\n","^<<\"Perché sono un Macchinista, ecco perché. E nessuno di noi, per quanto possiamo sembrare diversi, sarebbe mai trovato morto senza un generatore di scorta. Quindi ho avuto qualche ora di buon sonno prima di accorgermene.\">>","\n","^Annuisco, accettando la sua risposta.","\n",{"->":".^.^.questions_loop"},{"#f":5}],"c-2":["^ ","\n","^<<\"Se... se dovessi dirlo?\">>","\n","^Si tocca il mento con una mano.","\n","^<<\"Iria, la mercante.\">>","\n","^Gli dico che lo sto ascoltando, e si avvicina trascinando i piedi. La sua voce si abbassa a un rombo basso.","\n","^<<Iria e i suoi simili gestiscono questa città; i mercati sono il loro fulcro di controllo, e hanno gli artigli nelle scorte alimentari. Ora immagina cosa succede quando va via la corrente.>>","\n","^<<\"All'improvviso la gente fa scorta di cibo, e Iria e i suoi alzano i prezzi. E nessuno del resto di noi può fare un cazzo.\">>","\n","^<<\"Dovresti indagare su Iria. La troverai tessere la sua tela di corruzione sopra il Mercato degli Scarabei dall'altra parte del ponte. Dovrai però convincere la sua guardia a farti passare.\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","ev",{"VAR?":"ATOMIC_HEART_SUSPECT_IRIA"},{"f()":"activate"},"pop","/ev","\n",{"#":"inventory_add: AtomicHeartSuspectIria"},"^Aggiungo la Mercante Iria alla mia lista dei sospetti.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n",{"->":".^.^.questions_loop"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.^.^.loop"},{"->":".^.^.questions_loop"},{"#f":5}],"questions_loop":[{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"#f":1}],"iria_conversation":["ev","str","^Mercante Iria","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Se Iria sia sorpresa, felice o scontenta di vedermi, è difficile dire. La guardia al suo fianco si irrigidisce mentre mi avvicino, ma Iria le fa cenno e si rilassa. La mia presenza è ammessa.","\n","^Per ora.","\n","^<<\"Quindi hai superato Yannis. Era una Melagrana? O semplici cuts? Non importa davvero, immagino.\">>","\n","^<<\"Beh, ora sei qui.\">>","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n",{"->":".^.opts"},{"opts":[["^<<\"Sì?\">>","\n","ev","str","^Ho qualche domanda sul blackout.","/str",{"f()":"atomic_heart_in_progress"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Come ottengo i Distintivi del Mercante?","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Vorrei comprare un Distintivo del Mercante.","/str",{"CNT?":".^.c-1"},"/ev",{"*":".^.c-2","flg":5},"ev","str","^Addio.","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^ ","\n",{"->t->":".^.^.^.^.investigation_questions"},{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Iria sembra completamente disinteressata alla mia domanda; non sono neanche sicura che mi abbia sentita. Sto per ripetere quando lascia uscire un grande sospiro.","\n","^<<\"Cosa pensi? Cosa fanno i Mercanti?\">>","\n","^<<\"Non rispondere. Puoi comprarli da me.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"StartTrading"},"^<<\"Molto bene.\">>","\n","^<<\"Altro?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.^.^.done"},{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"done":["^Saluto Iria.","\n",{"->t->":"atomic_heart_content.should_return_to_sandip"},{"->":"END_SCENE"},{"#f":1}],"investigation_questions":[["ev",{"VAR?":"atomic_heart_interviewed_characters"},{"VAR?":"MERCHANT_IRIA"},"+",{"VAR=":"atomic_heart_interviewed_characters","re":true},"/ev",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^<<\"Hai cinque minuti e poi voglio che tu te ne vada.\">>","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Potrei fare più domande.","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Hai idea del perché qualcuno avrebbe rubato il nucleo?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Dov'eri quando è andata via la corrente?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Chi pensi sia stato?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Ok, ho finito qui.","/str",{"CNT?":".^.loop"},"/ev",{"*":".^.c-3","flg":5},{"c-0":["^ ","\n","^C'è un sospiro profondamente irritato all'inizio del suo discorso, che esce come il sibilo di una vipera.","\n","^<<\"Due ragioni che mi vengono in mente. Una: hanno qualcosa da guadagnare a mettere in ginocchio la città.\">>","\n","^Ora un'inspirazione brusca, infastidita.","\n","^<<\"Due: i nuclei di potenza fruttano un prezzo notevole nei mercati illegali. Potrebbe essere una delle due, o entrambe, non lo so.\">>","\n",{"->":".^.^.loop"},{"#f":5}],"c-1":["^ ","\n","^Sento i suoi occhi stringersi su di me, e immagino la sua lingua trascinarsi contro i denti superiori. Non le piaccio per niente.","\n","^<<\"Ignorerò le implicazioni di quella domanda, <i>amica</i>, ma ero qui nel Mercato. Chiedi in giro se vuoi. Qualunque guardia confermerà per me.\">>","\n",{"->":".^.^.loop"},{"#f":5}],"c-2":["^ ","\n","^<<\"Sarà qualche disgraziato del Serai. Probabilmente quel tipo Scalatore. Garay. Dicono che sia... sai. 'Uno a cui parlare quando c'è un lavoro da fare'. Anche se non lo definirei discreto.\">>","\n","^<<\"Uno così non è il cervello dietro la cosa, ma se fossi una piccola nullità sgradevole, è la persona che ingaggerei per portare a termine il lavoro.\">>","\n","^<<\"Mi hanno detto che lo trovi sotto il ponte fuori dal cancello della città.\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","ev",{"VAR?":"ATOMIC_HEART_SUSPECT_GARAY"},{"f()":"activate"},"pop","/ev","\n",{"#":"inventory_add: AtomicHeartSuspectGaray"},"^Aggiungo Garay alla mia lista dei sospetti.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n",{"->":".^.^.loop"},{"#f":5}],"c-3":["^ ","\n","ev","void","/ev","->->",{"->":".^.^.loop"},{"#f":5}],"loop":[{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"#f":1}],"garay_conversation":["ev","str","^Scalatore Garay","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Garay è uno scalatore di Eccria. Puzza orribilmente, e la maschera gli sta per cadere.","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Garay grugnisce un saluto.","\n",{"->":".^.^.17"},null],"#f":5}],"\n",{"->":".^.opts"},{"opts":[["ev","str","^Ho qualche domanda sul blackout.","/str",{"f()":"atomic_heart_in_progress"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Addio.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->t->":".^.^.^.^.investigation_questions"},{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^.^.done"},{"#f":5}]}],{"#f":1}],"done":["^Saluto Garay.","\n",{"->t->":"atomic_heart_content.should_return_to_sandip"},{"->":"END_SCENE"},{"#f":1}],"investigation_questions":[["ev",{"VAR?":"atomic_heart_interviewed_characters"},{"VAR?":"CLIMBER_GARAY"},"+",{"VAR=":"atomic_heart_interviewed_characters","re":true},"/ev",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Si gratta e sputa per terra prima di farmi spallucce.","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Potrei fare più domande.","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Hai idea del perché qualcuno avrebbe rubato il nucleo?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Dov'eri quando è andata via la corrente?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Chi pensi sia stato?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Ho finito qui.","/str",{"CNT?":".^.loop"},"/ev",{"*":".^.c-3","flg":5},{"c-0":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Garay puzza.","\n","^Non è l'odore peggiore o più pungente; non è marciume né bile né nulla di così marcatamente orribile. No, l'odore di Garay è come polvere vecchia, tinta di olio stantio, intrisa nel tessuto di vecchi indumenti, o seppellita sotto le unghie.","\n","^Gli si attacca addosso, e mi giro un po' mentre mi risponde.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^<<\"Ho sentito di una grossa vendita al Serai di recente. Non so di cosa, ma ha creato... un certo trambusto, diciamo. Qualunque cosa sia, ora è sparita da un pezzo.\">>","\n","^Fa spallucce, quindi insisto un po' di più chiedendogli se ha idea di chi fosse il venditore.","\n","^<<\"Per quanto ho sentito, era un macchinista con un'abitudine ai funghi. Non so quanto sia vero, ma... diciamo che è uscito fuori più di una volta.\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","ev",{"VAR?":"ATOMIC_HEART_SUSPECT_HAMZA"},{"f()":"activate"},"pop","/ev","\n",{"#":"inventory_add: AtomicHeartSuspectHamza"},"^Questo macchinista potrebbe essere... Hamza? Lo aggiungo alla lista dei sospetti.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n",{"->":".^.^.loop"},{"#f":5}],"c-1":["^ ","\n","^<<\"Caffè.\">>","\n","^Incrocio le braccia, soprattutto per impazienza... ma sembra funzionare su Garay in qualche modo.","\n","^<<\"Va bene, mi sono cacciato in una piccola rissa, è questo che vuoi sentire? Niente a che fare con il resto e probabilmente non sono affari tuoi, ma certo. Ho fatto una rissa, è andata via la corrente, l'abbiamo interrotta.\">>","\n","^Tengo le braccia incrociate.","\n","^<<\"Fine della storia. Non ho altro.\">>","\n",{"->":".^.^.loop"},{"#f":5}],"c-2":["^ ","\n","^Mi fissa per qualche secondo e lo scambio per considerazione prima di rendermi conto che mi guarda come fossi stupida.","\n","^<<\"Non faccio nomi. E anche se lo facessi, non so chi sia stato. Ma più potere a loro, dico io.\">>","\n","^C'è una pausa e poi ride forte.","\n","^<<\"L'hai capita? Più potere a loro?\">>","\n",["ev","str","^Capita.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Molto divertente!","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non l'ho capita.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Gli dico che l'ho capita. Ridacchia e mi liquida.","\n",{"->":".^.^.^.^.loop"},{"#f":5}],"c-1":["^ ","\n","^Riesco a tirare una falsa risata, ma sembra quasi offenderlo. Mi liquida.","\n",{"->":".^.^.^.^.loop"},{"#f":5}],"c-2":["^ ","\n","^<<\"Non c'è da stupirsi che il colpevole sia ancora là fuori, con te a indagare.\">>","\n","^Tira su col naso e mi liquida.","\n",{"->":".^.^.^.^.loop"},{"#f":5}]}],{"#f":5}],"c-3":["^ ","\n","ev","void","/ev","->->",{"->":".^.^.loop"},{"#f":5}],"loop":[{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"#f":1}],"fabric_seller_kalia":["ev","str","^Venditrice di Stoffa Kalia","/str","/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.atomic_power_on"},{"->":".^.^.^.12"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.atomic_power_off"},{"->":".^.^.^.12"},null]}],"nop","\n",{"atomic_power_on":[["^<<\"Benvenuta da Kalia Abbigliamento! Come posso aiutarti oggi?\">>","\n","ev","str","^Posso vedere cosa hai?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Parlami di questo negozio.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non ho bisogno di nulla.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.begin_trading"},{"#f":5}],"c-1":["^  ","\n","^<<\"Questo è Kalia Abbigliamento, ed è il mio negozio!\">>","\n","^<<\"Sono Kalia. Nel caso non l'avessi capito.\">>","\n","^<<\"Sono arrivata a Eccria durante il mio Volo e ho visto una piccola pelletteria malridotta qui. A nessuno importava e non ho potuto fare a meno di fare un accordo con i vecchi proprietari per rilevarla.\">>","\n","^<<\"Ora, sto ancora imparando il mestiere ma i locali e i viaggiatori sembrano apprezzare ciò che vendo.\">>","\n","^<<\"Da poco ho persino iniziato a vendere abiti tradizionali eccrini, se li indossi qui sono certa che gli eccrini ti accoglieranno come una di loro.\">>","\n",{"->":".^.^.^.^.conversation_end"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.^.conversation_end"},{"#f":5}]}],{"#f":1}],"atomic_power_off":[["^<<\"Cosa farò? Che disastro.\">>","\n","ev","str","^Cosa sta succedendo?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ci si vede.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^  ","\n","^<<\"Normalmente vendo vestiti nel mio negozio sulla strada principale ma nessuno sembra interessato con la situazione attuale. Sono preoccupati per cose come cibo e acqua, invece.\">>","\n","^<<\"Ho qualche risparmio ma se non si sistema presto dovrò chiudere del tutto e andarmene dalla città.\">>","\n",{"->":".^.^.^.^.conversation_end"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.conversation_end"},{"#f":5}]}],{"#f":1}],"begin_trading":[{"#":"StartTrading"},"^<<\"Ecco la mia selezione. Fammi sapere se ti serve aiuto.\">>","\n","^<<\"Grazie di aver fatto acquisti da Kalia Abbigliamento!\">>","\n",{"->":".^.^.conversation_end"},{"#f":1}],"conversation_end":["^<<Alla prossima!>>","\n","end",{"#f":1}],"#f":1}],"yannis_conversation":["ev","str","^Guardia Yannis","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Sento la guardia mormorare di Melagrane tra sé mentre mi avvicino. Quando mi nota si zittisce e si mette sull'attenti.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^<<\"Posso aiutarti?\">>","\n",{"->":".^.opts"},{"opts":[["ev","str","^Devo parlare con Iria.","/str",{"VAR?":"ATOMIC_HEART_BRIBED_GUARD"},{"f()":"reached"},"!","/ev",{"*":".^.c-0","flg":5},"ev","str","^Hai detto qualcosa sulle Melagrane?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Sto solo passando.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^<<\"Iria è una persona molto importante. Se devo lasciare che una glider rompiscatole le interrompa la giornata, è meglio che ne valga la pena per me.\">>","\n","ev",{"x()":"inventory_get_money"},50,"<","/ev",[{"->":".^.b","c":true},{"b":["\n","^Non sono sicura di avere abbastanza cuts per una bustarella.","\n",{"->":".^.^.^.10"},null]}],"nop","\n",["ev","str","^Offri cento cuts.","/str",{"x()":"inventory_get_money"},100,">=","/ev",{"*":".^.c-0","flg":5},"ev","str","^Offri centocinquanta cuts.","/str",{"x()":"inventory_get_money"},150,">=","/ev",{"*":".^.c-1","flg":5},"ev","str","^Offri cinquanta cuts.","/str",{"x()":"inventory_get_money"},50,">=","/ev",{"*":".^.c-2","flg":5},"ev","str","^Offri una melagrana.","/str","str","^FallowPomegranate","/str",{"x()":"inventory_get_quantity","exArgs":1},0,">","/ev",{"*":".^.c-3","flg":5},"ev","str","^Non importa.","/str","/ev",{"*":".^.c-4","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"ATOMIC_HEART_BRIBED_GUARD"},{"f()":"activate"},"pop","/ev","\n",{"#":"subtract_money: 100"},"^<<\"Suppongo basti.\">>","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","ev",{"VAR?":"ATOMIC_HEART_BRIBED_GUARD"},{"f()":"activate"},"pop","/ev","\n","^Gli occhi della guardia si illuminano e mi pento subito di aver offerto così tanto.","\n",{"#":"subtract_money: 150"},"^<<\"Sì, va benissimo.\">>","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^Sento il disprezzo nel silenzio imbarazzante dopo la mia offerta.","\n",["ev","str","^Offri duecentocinquanta cuts.","/str",{"x()":"inventory_get_money"},250,">=","/ev",{"*":".^.c-0","flg":5},"ev","str","^Lascia stare.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"ATOMIC_HEART_BRIBED_GUARD"},{"f()":"activate"},"pop","/ev","\n",{"#":"subtract_money: 250"},"^<<\"Così va meglio!\">>","\n","^Non riesco a scrollarmi la sensazione di essermi appena fregata da sola con un'offerta così generosa. Qualunque cosa serva, suppongo.","\n",{"->":".^.^.^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-3":["^ ","\n","ev",{"VAR?":"ATOMIC_HEART_BRIBED_GUARD"},{"f()":"activate"},"pop","/ev","\n","^La guardia sembra felicissima della mia offerta.","\n","^<<\"Oh Rohana... è meraviglioso.\">>","\n",{"#":"inventory_remove: FallowPomegranate"},"^Mi strappa avidamente la melagrana dalle mani e mi indica che ora posso passare.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-4":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^La guardia sembra rianimarsi alla menzione della parola.","\n","^<<\"Sì, ne hai mai provata una?! Le vendono al Serai, fuori città. Sono incredibili. Magiche. Ogni chicco un'esplosione di freschezza acquosa.\">>","\n","^Continua a esprimere la sua chiara ossessione per il frutto e noto la mia stessa bocca che saliva un po'.","\n",{"->":".^.^.^"},{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^.^.done"},{"#f":5}]}],{"#f":1}],"done":["^<<\"Cammina, Glider.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"serai_biker_ahvid":[["ev","str","^Mercante di Hoverbike Ahvid","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Hai bisogno di qualcosa di veloce? Affidabile? Entrambe? Nessuna delle due?! Abbiamo ogni tipo di pezzo per hoverbike, proprio per te, Glider!\">>","\n","ev","str","^Vorrei commerciare.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Cosa sta succedendo?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non ho bisogno di nulla.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.begin_trading"},{"#f":5}],"c-1":["^  ","\n","ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","^<<\"La città è tornata a funzionare. La gente sembra molto più felice.\">>","\n","^<<\"Vendo un sacco di pezzi per hoverbike qui, ma ho sentito che c'è una Macchinista alla Stazione Sette Sorelle a Hakoa che sta studiando una tecnologia più... volatile per alimentarle.\">>","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n","^<<\"La corrente in città è giù, conviene avere un mezzo veloce per uscire adesso! Tante persone vogliono andarsene se le cose non tornano normali presto.\">>","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.conversation_end"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.conversation_end"},{"#f":5}]}],{"begin_trading":[{"#":"StartTrading"},"^<<\"Ecco cos'ho.\">>","\n","^<<\"Ci si rivede, Glider.\">>","\n",{"->":".^.^.conversation_end"},{"#f":1}],"conversation_end":["^<<\"Stammi bene!\">>","\n","end",{"#f":1}],"#f":1}],"aeyan_conversation":["ev","str","^Costruttrice di Campanelli Aeyan","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.17"},null],"#f":5}],"\n",["ev",{"VAR?":"HERCULES_BEETLE_RETURNED_TO_IFAA"},{"VAR?":"HERCULES_BEETLE_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.deliver_husks"},{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.default_conversation"},{"->":".^.^.^.10"},null]}],"nop","\n",{"->":".^.done"},{"first_intro":["^Incontro una costruttrice di campanelli chiamata Aeyan.","\n","ev","void","/ev","->->",{"#f":1}],"default_intro":["^Aeyan saluta.","\n","ev","void","/ev","->->",{"#f":1}],"deliver_husks":["ev",{"VAR?":"HERCULES_BEETLE_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Ah, hai le esuvie che mi ha promesso Ifaa.\">>","\n",{"#":"inventory_remove: LarvalHuskPackage"},{"#":"add_money: 100"},"^<<\"Ecco un piccolo qualcosa per il disturbo.\">>","\n","ev","void","/ev","->->",{"#f":1}],"default_conversation":["^Chiacchieriamo del lavoro di Aeyan.","\n","ev","void","/ev","->->",{"#f":1}],"done":["^<<\"Addio, Glider.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"serai_nomad_josh":[["ev","str","^Mercante del Serai Josh","/str","/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","^<<\"Sembra che tutti siano di nuovo di buonumore. La corrente è tornata! Ti va un po' di frutta fresca?\">>","\n",{"->":".^.^.^.12"},null]}],[{"->":".^.b"},{"b":["\n","^<<\"Tutta Eccria è sulle spine! Non è buono per gli affari, ti dico. Anche i miei abituali non vengono più.\">>","\n",{"->":".^.^.^.12"},null]}],"nop","\n","ev","str","^Vorrei commerciare.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Cosa sta succedendo?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non ho bisogno di nulla.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.begin_trading"},{"#f":5}],"c-1":["^  ","\n","ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","^<<\"Ho sentito che una Glider ha rimesso in moto la corrente, buona notizia per tutti. Ci serve che i Cittadini restino calmi se vogliamo vivere qui fuori in pace.\">>","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n","^<<\"C'è stato un po' di tafferuglio sull'energia per la città — non ce n'è!\">>","\n","^<<\"Girano voci di ogni tipo. Forse sono stati i Mercanti del mercato, forse un estraneo — sono sicuro che ai Cittadini piacerebbe incolpare noi Serai!\">>","\n","^<<\"Per fortuna il commercio di frutta con gli estranei procede, un po' più lento, ma noi Serai non dobbiamo preoccuparci troppo della corrente qui fuori.\">>","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.conversation_end"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.conversation_end"},{"#f":5}]}],{"begin_trading":[{"#":"StartTrading"},"^<<\"Ecco cos'ho.\">>","\n","^<<\"Ci si rivede, Glider.\">>","\n",{"->":".^.^.conversation_end"},{"#f":1}],"conversation_end":["^<<\"Addio!\">>","\n","end",{"#f":1}],"#f":1}],"wearing_machinist_mask":["ev",{"x()":"current_mask"},"str","^EngineerSetHelmet","/str","==","/ev","~ret","\n",{"#f":1}],"eccria_carlo_conversation":["ev","str","^Eccrino Carlo","/str","/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.atomic_power_on"},{"->":".^.^.^.12"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.atomic_power_off"},{"->":".^.^.^.12"},null]}],"nop","\n",{"atomic_power_off":["^<<\"Mi piace abbastanza quando manca la corrente, c'è un senso di pace.\">>","\n","end",{"#f":1}],"atomic_power_on":["^<<\"Oh, la corrente è tornata — sei stata tu?\">>","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"eccria_fin_conversation":["ev","str","^Eccrino Fin","/str","/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.atomic_power_on"},{"->":".^.^.^.12"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.atomic_power_off"},{"->":".^.^.^.12"},null]}],"nop","\n",{"atomic_power_off":["^<<\"È un disastro. Niente corrente significa niente acqua filtrata — l'acqua dell'Oasi non è abbastanza pulita da bere così.\">>","\n","end",{"#f":1}],"atomic_power_on":[["ev",{"f()":"wearing_machinist_mask"},"/ev",{"->":".^.b","c":true},{"b":["\n","^<<\"Una Macchinista, eh? Pensi potresti fare di meglio a tenere accesa la corrente in città se è quella la maschera che scegli?\">>","\n",{"->":".^.^.^.2"},null]}],[{"->":".^.b"},{"b":["\n","^<<\"Immagina cosa sarebbe potuto succedere se la corrente fosse rimasta spenta più a lungo? Credo avrei dovuto lasciare la città.\">>","\n",{"->":".^.^.^.2"},null]}],"nop","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"eccria_begger_lili":[["ev","str","^Eccrina Lili","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Hai dei cuts da darmi? Qualunque cifra sarebbe apprezzata, Glider.\">>","\n","ev","str","^Offri dieci cuts.","/str",{"x()":"inventory_get_money"},10,">","/ev",{"*":".^.c-0","flg":5},"ev","str","^Offri cinquanta cuts.","/str",{"x()":"inventory_get_money"},50,">","/ev",{"*":".^.c-1","flg":5},"ev","str","^Mi spiace.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"subtract_money: 10"},"^<<\"Grazie, gentilmente.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"subtract_money: 50"},"^<<\"Grazie, grazie infinite.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"shepherd_mel_conversation":["ev","str","^Pastore Mel","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Si chiama Reginauld III. Reginauld II era suo padre, e prima di lui c'era Reginauld I. I primi due erano creature molto socievoli e laboriose. Questo qui... non tanto.\">>","\n","^<<\"Non mi avvicinerei troppo, gli piace mordere e sputare.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"doctor_val_conversation":["ev","str","^Dottoressa Val","/str","/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.atomic_power_on"},{"->":".^.^.^.12"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.atomic_power_off"},{"->":".^.^.^.12"},null]}],"nop","\n",{"atomic_power_off":["^La dottoressa sembra preoccupata e frustrata.","\n","^<<\"Con questo blackout, tutta la nostra attrezzatura medica — allineamento protesi, uteri artificiali — esaurirà l'energia molto presto se non torna la corrente. Quelle Guardie e Macchinisti inutili!\">>","\n","end",{"#f":1}],"atomic_power_on":["^<<\"Benedica Rohana, la corrente è tornata appena in tempo. Avevo due bambini ai primi stadi nei grembi che potevano esaurirsi in pochi giorni.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"courier_joti_conversation":["ev","str","^Corriere Joti","/str","/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.atomic_power_on"},{"->":".^.^.^.12"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.atomic_power_off"},{"->":".^.^.^.12"},null]}],"nop","\n",{"atomic_power_off":["^<<\"Il blackout significa che molti affari si sono fermati del tutto, ma alcuni mercanti del Mercato sono riusciti a sfruttare la situazione e le consegne non sono mai state così intense.\">>","\n","^<<\"Iria e i suoi sembrano sempre saper cavare sangue dalle pietre, ma stavolta sembra che le cose siano andate troppo bene per loro.\">>","\n","^<<\"Forse non dirlo a nessuno che l'ho detto.\">>","\n","end",{"#f":1}],"atomic_power_on":["^<<\"Un corriere troverà sempre lavoro, le consegne di Iria saranno rallentate di nuovo ma tutto il resto degli affari è ripartito.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"glassblower_toto_conversation":["ev","str","^Soffiatore di Vetro Toto","/str","/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.atomic_power_on"},{"->":".^.^.^.12"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.atomic_power_off"},{"->":".^.^.^.12"},null]}],"nop","\n",{"atomic_power_off":["^<<\"Faccio il miglior vetro da questa parte del Seesplit. Beh, normalmente almeno.\">>","\n","^<<\"Il blackout ha messo la mia officina completamente fuori uso. Mi serve la fornace per lavorare.\">>","\n","^<<\"Non è come fondere piccoli vasi nella sabbia. Ho già un terribile arretrato di ordini! Pezzi di hoverbike, navi, vasi, architettura. Tutto quello che vuoi.\">>","\n","end",{"#f":1}],"atomic_power_on":["^Sembra troppo impegnato per essere interrotto. Guardarlo lavorare è ipnotico. Sabbie di diverse parti del mondo formano vetri di colori, texture e resistenze diversi.","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"dock_sitter_eleni_conversation":["ev","str","^Eccrina Eleni","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Ora che la corrente è tornata, mi sento di nuovo calma e rilassata. Adoro stare seduta qui a sentire l'acqua fredda dell'oasi sui piedi.\">>","\n","^<<\"Quella grossa roccia laggiù? È l'Occhio di Eccria. Si dice che alla fondazione della città l'acqua scorresse dalla roccia nell'Oasi.\">>","\n","^<<\"La statua all'ingresso della città, Eccrius — è un riflesso di quello.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"artist_costa_conversation":["ev","str","^Artista Costas","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Guarda le pozze d'acqua vorticose, la superficie scintillante del liquido che danza e riflette la luce!\">>","\n","^<<\"Ispiratore!\">>","\n","^Non capisco se parli con me o con sé stesso. Lo lascio stare. Sizo diceva sempre che gli Artisti sono un tipo strano.","\n",{"->":"END_SCENE"},{"#f":1}],"serai_nomad_yuuki_conversation":["ev","str","^Nomade del Serai Yuuki","/str","/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.atomic_power_on"},{"->":".^.^.^.12"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.atomic_power_off"},{"->":".^.^.^.12"},null]}],"nop","\n",{"atomic_power_off":["^<<\"Oh no... cosa farò?\">>","\n","^<<\"In città è andata via la corrente! I mercanti hanno alzato i prezzi, e ora non posso permettermi il tè!\">>","\n","end",{"#f":1}],"atomic_power_on":["^<<\"Pensavo che i prezzi del tè sarebbero scesi con il ritorno della corrente, ma i Mercanti non hanno ancora abbassato. È un disastro!\">>","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"eccrine_crowd_member_dramatic_conversation":["ev","str","^Folla Eccrina","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Devi fare qualcosa! La corrente è via da giorni ormai! Quando torneremo ad avere acqua potabile?!\">>","\n",{"->":"END_SCENE"},{"#f":1}],"eccrine_crowd_member_bemused_conversation":["ev","str","^Folla Eccrina","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Inutili. Completamente inutili. Com'è che siamo finiti in una situazione in cui quasi tutto su cui contiamo si ferma del tutto.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"eccrine_crowd_member_nervous_conversation":["ev","str","^Folla Eccrina","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Chi è stato? Avete scoperto chi è stato? Siamo sotto attacco?\">>","\n",{"->":"END_SCENE"},{"#f":1}],"eccrine_crowd_guard_conversation":["ev","str","^Guardia Eccrina","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Per favore, rimanete tutti calmi. Stiamo facendo tutto il possibile per ripristinare la corrente a Eccria.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"shade_of_eccria_shop_owner_milo":["ev","str","^Estraneo nel Muro","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev",{"f()":"wearing_shade_mask"},"/ev",{"->":".^.b","c":true},{"b":["\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->":".^.^.^.^.^.first_shade_wall_intro"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->":".^.^.^.^.^.shade_wall_convo"},{"->":".^.^.17"},null],"#f":5}],"\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n","^Vedo una maschera che sbircia dalla fessura con una immobilità da statua.","\n","^<<\"Mostrami gli occhi.\">>","\n","^Aspetto un momento, incerta di aver davvero sentito qualcosa. La maschera non aggiunge altro.","\n",{"->":"END_SCENE"},{"->":".^.^.^.8"},null]}],"nop","\n",{"first_shade_wall_intro":[[{"#":"StoreOpen"},"^<<\"Per la maschera di Rohana...!\">>","\n","^<<\"Sei tu.\">>","\n","^Non riconosco affatto questa persona.","\n","^<<\"L'Ombra di Eccria — una leggenda di questa orribile città.\">>","\n","^<<\"Sono assolutamente felicissimo di incontrarti finalmente. Aspetto a questa postazione da tanto tempo ormai.\">>","\n","^<<\"Oh, sembri sorpresa! Non ci siamo mai incontrati, ma hai lasciato tutta la tua roba dal nonno. Ricordi?\">>","\n","ev","str","^Posso... riavere la mia roba?","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n","^<<\"Certo! Non mi serve!\">>","\n","^<<\"È tutta tua a prezzi spaventosamente ragionevoli.\">>","\n","^Comincio a obiettare di dover ricomprare 'la mia' roba quando mi interrompe subito.","\n","^<<\"Aspetta.\">>","\n","^Il suo tono è passato da sdolcinato a diretto e concreto.","\n","^<<\"Primo.\">>","\n","^<<\"Non illuderti un attimo che non sappia che non sei l'Ombra originale.\">>","\n","^<<\"Secondo.\">>","\n","^<<\"La tua precedente 'incarnazione' ha mollato tutta questa roba qui dal nonno.\">>","\n","^<<\"Lui sarà stato innamorato dell'Ombra, ma io no. No, neanche un po'.\">>","\n","^<<\"Non puoi lasciare roba qui per chissà quanti anni e non aspettarti di pagare almeno interessi e spese di magazzino.\">>","\n","^Comincio a capire che quella che credevo gioia di vedere l'Ombra, era in realtà gioia per l'occasione di svuotarmi il portafoglio.","\n",{"->":".^.^.^.^.begin_trading"},{"#f":5}]}],{"#f":1}],"shade_wall_convo":[[{"#":"StoreOpen"},"^<<\"Ombra!\">>","\n","^<<\"Ne vuoi ancora?\">>","\n","^<<\"Cosa posso fare per te?\">>","\n","ev","str","^Cos'hai?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Sto bene così.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.begin_trading"},{"#f":5}],"c-1":["^ ","\n","^<<\"Tornerai!\">>","\n",{"->":".^.^.^.^.conversation_end"},{"#f":5}]}],{"#f":1}],"begin_trading":[{"#":"StartTrading"},"^<<\"Ecco cos'hai lasciato a mio nonno.\">>","\n","^<<\"Ci si rivede, Ombra.\">>","\n",{"->":".^.^.conversation_end"},{"#f":1}],"conversation_end":[{"#":"StoreClosed"},"^<<\"...\">>","\n","end",{"#f":1}],"#f":1}],"rin_conversation":["ev","str","^Testimone Rin","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev",{"CNT?":".^.^.first_intro"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.done"},{"done":["^Saluto Rin.","\n",{"->":"END_SCENE"},{"#f":1}],"first_intro":["^Rin è una Testimone.","\n","ev","void","/ev","->->",{"#f":1}],"default_intro":["^Rin saluta.","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"bashir_conversation":["ev","str","^Bashir","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev",{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_start_bashir"},{"->":".^.^.^.9"},null]}],["ev",{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_STARTED"},{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_in_progress"},{"->":".^.^.^.9"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.after_quest_complete"},{"->":".^.^.^.9"},null]}],"nop","\n",{"quest_start_bashir":[["^Sento l'energia nervosa dietro la sua maschera.","\n","^<<\"Glider! Potresti aiutarmi?\">>","\n",{"#":"gesture_sable: talking"},"^Gli dico che mi chiamo Sable e chiedo di cosa ha bisogno.","\n","^<<\"È il mio amico Micah. È... è <i>ossessionato</i> dalla caccia al tesoro, o a trovare sciocchi vecchi artefatti. Ogni settimana parte alla ricerca di qualcosa di nuovo.\">>","\n","^Chiedo se ha mai trovato qualcosa.","\n","^<<\"Nulla che non avresti da un Rottamatore qualunque, e va dappertutto! In grotte, scogliere, ovunque, senza preoccuparsi del pericolo.\">>","\n",{"#":"gesture_partner: explaining"},"^<<\"Continuo a dirgli, 'Micah, stai attento', ma se ne frega! Pensa di essere invincibile.\">>","\n","^<<\"E ora se n'è andato a chissà dove a sud e non è tornato! Oh, sono così contento che tu sia passata.\">>","\n","^<<\"Puoi ancora planare, sì? Così non rischierai di cadere giù da qualche parte.\">>","\n","ev","str","^È in un posto pericoloso?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Da quanto è via?","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Chiedo se Bashir si aspetta che Micah sia in pericolo.","\n",{"#":"gesture_partner: explaining"},"^<<\"Se si tratta di Micah, probabilmente sì. I posti dove sgattaiola sono di solito rovine, più vecchie meglio è, mezze crollate e coperte di polvere.\">>","\n","^<<\"Tendono a essere posti dove un passo falso ti fa male sul serio. Micah dice che è lì che si trovano i tesori migliori.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Chiedo da quanto sia via Micah.","\n","^<<\"L'altroieri, ma di solito torna molto più in fretta.\">>","\n",{"#":"gesture_partner: explaining"},"^<<\"Adora le scalate rischiose, però, quello sciocco... quindi attenta a quello. Se è un posto stupido, Micah potrebbe essere lì.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Per favore, Glider. Se lo vedi... digli che Bashir lo sta cercando.\">>","\n","^Dico a Bashir che terrò gli occhi aperti per il suo amico, e gli auguro il meglio mentre parto.","\n","ev",{"list":{"sometimes_a_well_is_just_a_well.SOMETIMES_A_WELL_IS_JUST_A_WELL_SPOKE_TO_BASHIR":1,"sometimes_a_well_is_just_a_well.SOMETIMES_A_WELL_IS_JUST_A_WELL_STARTED":2}},{"f()":"activate"},"pop","/ev","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"quest_in_progress":["^<<\"Hai visto Micah? Non ancora? Oh no...\">>","\n",{"->":"END_SCENE"},{"#f":1}],"after_quest_complete":["^Bashir sembra pronto ad abbracciarmi.","\n",{"#":"gesture_partner: thanks"},"^<<\"Grazie mille. Non so cosa gli abbia detto, ma ha detto che ha abbandonato le scalate da solo, a meno che non siano <i>molto</i> sicure.\">>","\n",{"#":"gesture_sable: talking"},"^Dico a Bashir che non ho detto granché a Micah per dissuaderlo; un po' di muschio scivoloso ha fatto il lavoro per me. Ride e mi ringrazia di nuovo.","\n","^<<\"Sono davvero felice di averlo a casa. Grazie.\">>","\n","^Auguro il meglio a Bashir e Micah e me ne vado.","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"merchant_habat":[["ev","str","^Mercante Habat","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Glider! Vorrei essere ancora in Volo. Essere grandi è terribile...\">>","\n","ev","str","^Vorrei commerciare.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Parlami di questo campo.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non ho bisogno di nulla.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.begin_trading"},{"#f":5}],"c-1":["^ ","\n","^<<\"Siamo solo nomadi di passaggio.\">>","\n","^<<\"Le Cinque Campane sono per chi cerca di evitare il via-vai di Eccria laggiù... troppe persone, troppo movimento.\">>","\n","^<<\"Preferisco la compagnia dei grilli.\">>","\n",{"->":".^.^.^.conversation_end"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.conversation_end"},{"#f":5}]}],{"begin_trading":[{"#":"StartTrading"},"^<<\"Ok! Ecco la mia roba!\">>","\n","^<<\"Grazie di aver controllato la merce!\">>","\n",{"->":".^.^.conversation_end"},{"#f":1}],"conversation_end":["^<<\"Ci si becca!\">>","\n","end",{"#f":1}],"#f":1}],"white_ring_monument":[{"->t->":".^.intro"},"ev",{"VAR?":"debug_found_white_monument"},0,"==","/ev",[{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.interaction_point"},{"->":".^.^.^.7"},null]}],"nop","\n",{"->":".^.done"},{"intro":["^Ti trovi al Monumento dell'Anello del Wash.","\n","ev","void","/ev","->->",{"#f":1}],"interaction_point":["^Entro nel monumento.","\n","ev",1,"/ev",{"VAR=":"debug_found_white_monument","re":true},"ev",{"VAR?":"RING_SHRINE_QUEST_WHITE_DESERT_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"->t->":"an_ancient_race_debug_pick_up_item"},"ev","void","/ev","->->",{"#f":1}],"done":["^Lascio il monumento dell'anello.","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"white_desert_camp_camel_herder_mateo_conversation":[["ev","str","^Pastore Mateo","/str","/ev",{"VAR=":"SpeakerName","re":true},{"#":"gesture_partner: sad"},"^Il pastore sembra piuttosto agitato.","\n","ev","str","^Cosa succede?","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n","^<<\"Sono completamente rovinato, non ne è rimasto uno! Tutti i miei cammelli sono spariti!\">>","\n",{"#":"gesture_partner: sad"},"^<<\"Sapevo che non avrei dovuto lasciare il clan. Avevano ragione, sono completamente inutile.\">>","\n","^Mi tolgo dalla situazione imbarazzante. Povero ragazzo.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"white_desert_camp_child_sofia_npc":["ev","str","^Sofia","/str","/ev",{"VAR=":"SpeakerName","re":true},{"#":"gesture_partner: fist_pump"},"^<<\"Non mi prendi! Sono veloce come una hoverbike!\">>","\n",{"->":"END_SCENE"},{"#f":1}],"white_desert_camp_child_leo_npc":["ev","str","^Leo","/str","/ev",{"VAR=":"SpeakerName","re":true},{"#":"gesture_partner: sad"},"^<<\"Non sarò mai veloce come Sofia, sono troppo piccolo...\">>","\n",{"->":"END_SCENE"},{"#f":1}],"white_desert_camp_ergert":["ev","str","^Ergert","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Il mio clan è sempre stato nel Wash, raramente ci avventuriamo oltre i suoi confini.\">>","\n","^<<\"Si dice che i cumuli di gesso fossero un tempo ossa di creature morte, uccise dalla Caduta della Whale e lasciate erodere col tempo.\">>","\n",{"#":"gesture_partner: trembling"},"^<<\"È un po' inquietante a pensarci, ma quella che mi mette davvero i brividi è la Foresta Pietrificata. Lì dentro a malapena vedi le mani davanti al viso...\">>","\n",{"->":"END_SCENE"},{"#f":1}],"white_desert_camp_doctor":["ev","str","^Dottoressa Sura","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Sto studiando diverse flore e faune in tutta Midden al momento. Possiamo curare molte cose usando la vecchia tecnologia, ma dobbiamo stare sempre più attenti a come la usiamo.\">>","\n","^<<\"Non è accessibile a tutti nelle dune, è difficile da spostare e se perdi corrente...\">>","\n","^<<\"Stiamo iniziando a fare progressi con rimedi più locali e non tecnologici, ma c'è ancora tanto da studiare là fuori!\">>","\n",{"->":"END_SCENE"},{"#f":1}],"white_desert_camp_scrapper_jivan":["ev","str","^Rottamatore Jivan","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Quella del Rottamatore non è una maschera facile da portare. È dannatamente pericolosa e mortalmente solitaria. Immagino sia per questo che lo facciamo, eh?\">>","\n","^<<\"Comunque sia, ogni Glider dovrebbe dare un'occhiata al vecchio cantiere di rottami su a Burnt Oak. Ti sistemerà con qualche distintivo o cuts se gli consegni qualunque rottame trovi nel viaggio.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"petrified_forest_wanderer_vera":[["ev","str","^Cacciatrice Vera","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Per la maschera di Rohana, questo posto. Odio questo posto.\">>","\n","ev","str","^Perché non te ne vai?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Cosa c'è in questo posto?","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^<<\"Non me ne vado perché lo odio! Devo soffrire, devo superare le mie paure!\">>","\n","^<<\"Non giudicarmi!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Semplicemente orribili, le cose che si vedono nelle nebbie. Niente di buono, di sicuro.\">>","\n","^<<\"Qualcuno mi ha detto di seguire le statue della cacciatrice, Afra, ma non ci casco!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"white_desert_vivarium_parent_tyra":["ev","str","^Tyra","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Ho portato Runa qui perché ho sentito che i pesci valgono la pena. Adora il posto.\">>","\n","^<<\"Non pensavo che mi sarebbe piaciuto anche a me così tanto.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"white_desert_vivarium_child_runa":["ev","str","^Runa","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Non posso <i>credere</i> che vivano tutti sotto la sabbia! Lì sotto tutto il tempo...\">>","\n","^<<\"In pianificazione.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"white_desert_vivarium_entertainer_edith":["ev","str","^Edith","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Oh, ciao Glider. Sai una cosa, sono in un piccolo blocco creativo ultimamente.\">>","\n","^<<\"Ma venire qui, vedere tutte queste creature incredibili... oserei dire che mi sento ispirata di nuovo!\">>","\n",{"->":"END_SCENE"},{"#f":1}],"white_desert_vivarium_architect_po":["ev","str","^Po","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Immagina: una volta era un vecchio edificio Atomico. E guarda cos'ha fatto del posto.\">>","\n","^<<\"Come Casii è riuscita a riusare tutta questa roba vecchia... fa girare la testa! Un giorno spero di costruire qualcosa di altrettanto ispirato.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"styllous_diary_one":["ev",{"VAR?":"speaker_diary"},"/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Raccolgo le pagine consunte e logorate lasciate nel piccolo accampamento. Non qualcosa che mi aspettavo di trovare qua sopra, e troppo tentante per ignorarle.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^<<\"Eccomi qui. Mi avevi detto di guardare a Pyrausta quando avessi perso tutto, ed eccomi qui con nulla e nessuno, sola alla fine di tutti i miei fallimenti.\">>","\n","^<<\"Mi siederò e penserò per un po', forse mi verrà in mente qualcosa. Altrimenti, mi lascerò cadere.\">>","\n","^<<\"Ana, so che non vorrai sentirmi ma devo dirtelo: Pyrausta mi ha parlato!\">>","\n","^<<\"Con una voce come tuoni rotolanti e brividi serali, mi ha scosso le ossa e mi ha detto che c'è di più di quel che so, e che devo guardare dentro la statua.\">>","\n","^<<\"Non ho modo di entrare, ma ne troverò uno. Dove il capriccio di Pyrausta mi conduce, là camminerò nella sua grande ombra.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"styllous_diary_two":["ev",{"VAR?":"speaker_diary"},"/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Altre note scritte. Pare siano anche riusciti a entrare.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^<<\"Ana! Sono dentro! Ce l'ho fatta! E ora vedo in questa oscurità sbadigliante perché Pyrausta mi ha chiamato! C'è qui un segreto che voleva che sapessi, ed è molto più di quanto avessi mai immaginato:\">>","\n","^<<\"Questo posto... questa creatura...\">>","\n","^<<\"È viva.\">>","\n","^<<\"Non come te e me, no, ma... alla maniera di cose lente e antiche, respirando e prosperando a un ritmo invisibile per chi vive in modo così veloce e breve come noi.\">>","\n","^<<\"Come un saggio albero antico, o una mappa di funghi sotto la terra, che vivono e si decompongono insieme, per secoli.\">>","\n","^<<\"È viva.\">>","\n","^<<\"Credo di poter proseguire, e andare più in profondità. Non so se potrò tornare per la stessa via, ma poche storie si raccontano di chi torna sui propri passi. Troverò una via per l'altro lato.\">>","\n","^Ci sono alcuni frammenti resi illeggibili dall'usura, ma trovo una voce più tarda appena leggibile, anche se mi servono diverse letture e qualche passo falso per decifrarla.","\n","^La parola 'gorgogliante' mi blocca un istante, e la leggo come 'ridacchiante' e 'molente' prima che abbia senso.","\n","^<<\"Sono accampata qui da due giorni ormai, Ana. Fa caldo, l'aria è vecchia e umida, ma c'è anche un buon sale dentro! La mia pelle si sente meglio in questo posto che sulle implacabili dune.\">>","\n","^<<\"Nelle mie esplorazioni ho lasciato cadere alcune cose senza importanza dentro Pyrausta. Rocce, piccole e grandi. Uno scarabeo. Mi chiedo, dovrei scendere ancora, e andare sotto io stessa?\">>","\n","^<<\"La voce di Pyrausta mi chiama, ma è coperta da altri rumori di acqua che scorre e un gorgogliare profondo, risonante. Tutto canta. E sempre di più, desidero.\">>","\n","^Ci sono righe di scarabocchi su quanto è scritto dopo, e poi riprende:","\n","^<<\"Cos'ho da perdere? Salterò nell'oscurità.\">>","\n","^<<\"Se non torno, sappi questo: ti amo, Ana.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"styllous_diary_three":["ev",{"VAR?":"speaker_diary"},"/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Questo pezzo è umido, e la muffa avanza sui bordi.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^<<\"Ana!\">>","\n","^<<\"Sono caduta così in fondo, scivolando e slittando, precipitando per un'eternità! Cosa ho visto nel turbinio dei muri che mi sfrecciavano accanto! Cosa ho sentito nei sussurri del vento impetuoso!\">>","\n","^<<\"Ana, Ana, Ana, se solo potessi sapere. Se solo potessi vedere.\">>","\n","^<<\"Ma la voce di Pyrausta non è per tutti.\">>","\n","^<<\"Alla fine della caduta, mi sono ritrovata in un nuovo mondo, e vivo qui da mezza giornata. Ora vedo perché mi ha chiamato. È una dea, ma sta chiedendo aiuto.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"styllous_diary_four":["ev",{"VAR?":"speaker_diary"},"/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Ho trovato un altro brano del diario.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^<<\"Ana, vivo, ma è una vita penosa. Ho perso la sua voce quaggiù, e ora c'è solo umidità e marcio nel silenzio. Una sola goccia in fondo a un tunnel cade come —\">>","\n","^Si ferma di colpo, a metà frase, e quando riprende, la scrittura appare più frettolosa che mai.","\n","^<<\"Ana non ci crederai! Oh, amore mio, mia cara, era questo il segreto! È quando sono perduta che lei mi trova, Ana, perché cos'è Pyrausta se non un'aiutante di chi è in difficoltà? Che sciocca sono! Che stupida!\">>","\n","^<<\"Stavo quasi per arrendermi. Ma l'ho appena risentita.\">>","\n","^<<\"So cosa vuole. Ha così, così tanta fame.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"styllous_diary_five":["ev",{"VAR?":"speaker_diary"},"/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Una nuova nota scritta in una grafia tremolante, infantile. Mi si gela il cuore alla vista, come avessi visto qualcosa di troppo vulnerabile, e non possa aiutare.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^<<\"Quindi i cammelli non erano abbastanza, Pyrausta? Cosa altro ti serve? Ti ho dato tutto e ancora mi chiedi di più?\">>","\n","^<<\"Oh, sei una dea bellissima e squisita, ma sei anche bisognosa e capziosa! Sto cogliendo il tuo vero significato, mia amata.\">>","\n","^<<\"Ti darò ciò che chiedi. Con gioia sconfinata e piangente.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"styllous_diary_six":[["ev",{"VAR?":"speaker_shrine"},"/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Il santuario, se così si può chiamare, mi manda brividi lungo la schiena; sento la presenza di <i>qualcosa</i>, ma qualunque cosa sia, non è una dea.","\n","^C'è qualcosa intagliato in un pezzo di legno, e si legge come un incantesimo:","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^L'incantesimo sul legno recita:","\n",{"->":".^.^.17"},null],"#f":5}],"\n","^<<\"Mi immergo, Pyrausta, nelle tue profondità. / Dal mio corpo costruisciti, perché tu possa rivivere.\">>","\n","ev",{"VAR?":"has_player_taken_sandwyrm_mask"},"/ev",[{"->":".^.b","c":true},{"b":["^ ",{"->":".^.^.^.end"},{"->":".^.^.^.12"},null]}],"nop","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Sopra l'incantesimo sta una maschera, repellente e segnata. Sembra fatta di un cucciolo di sandwyrm. I denti nella sua bocca sono... veri?","\n","^Nell'oscurità ascolto, cercando di sentire qualunque cosa l'autrice credesse fosse la voce di Pyrausta.","\n","^Non c'è nulla.","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^La maschera sta sopra il santuario.","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Prendi la maschera","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non fare nulla","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",1,"/ev",{"VAR=":"has_player_taken_sandwyrm_mask","re":true},{"#":"inventory_add: SandwormMask"},{"#":"on_sandwyrm_mask"},"^Mi protendo e prendo la maschera dal supporto.","\n",{"->":".^.^.end"},{"#f":5}],"c-1":["^ ","\n","^Decido di non prenderla. Che riposi qui, con la sua creatrice.","\n",{"->":".^.^.end"},{"#f":5}],"end":["^Mi allontano dalla piattaforma.","\n","^Dovrei cercare una via d'uscita.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"parasite_innkeeper_conversation":["ev","str","^Locandiera Ofuu","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.17"},null],"#f":5}],"\n",{"->":".^.first_loop"},{"first_intro":["^Questa è Ofuu, la locandiera del campo.","\n","ev","void","/ev","->->",{"#f":1}],"default_intro":["^<<\"Salute, Glider.\">>","\n","ev","void","/ev","->->",{"#f":1}],"first_loop":["^<<\"Cosa posso fare per te?\">>","\n",{"->":".^.^.opts"},{"#f":1}],"loop":["^<<\"Posso fare qualcos'altro per te?\">>","\n",{"->":".^.^.opts"},{"#f":3}],"opts":[["ev",{"^->":"searching_for_llhor_content.second_clue"},{"^->":"parasite_innkeeper_conversation.loop"},"/ev","thread",{"->":"thread_in_tunnel"},"ev",{"^->":"parasite_beetle_quest_content"},{"^->":"parasite_innkeeper_conversation.loop"},"/ev","thread",{"->":"thread_in_tunnel"},"ev","str","^Saluta.","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.done"},{"#f":5}]}],{"#f":1}],"done":["^<<\"Addio, Glider.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"kaalan_conversation":["ev",{"VAR?":"speaker_kaalan"},"/ev",{"VAR=":"SpeakerName","re":true},["ev",{"CNT?":".^.^.first_intro"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.^.6"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.^.6"},null]}],"nop","\n",{"->":".^.options"},{"first_intro":[[{"#":"gesture_partner: wave"},"^I Macchinisti non si spaventano facilmente, ma questo sussulta al mio saluto. Mi fa un cenno frenetico.","\n",{"#":"gesture_sable: greeting"},{"#":"gesture_partner: greeting"},"^<<\"Glider! Sì! Bello vederti. Conoscerti? Non ci siamo mai conosciuti, mi pare. Quindi sì, piacere di conoscerti, sono Kaalan.\">>","\n","^Kaalan dondola avanti e indietro, dalla punta al tallone. C'è in loro una rapidissima nervosità e le loro parole emergono come una raffica di vento troppo veloce, raccogliendo sassolini e ramoscelli mentre scorre sulle dune.","\n","^<<\"Come va la tua, ehm... vita?\">>","\n","ev","str","^Le cose sono molto eccitanti.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Le cose sono un po' difficili.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Le cose sono strane.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_partner: talking"},"^<<\"Eccitanti! Bene!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_partner: talking"},"^<<\"Difficili! Bene!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_partner: talking"},"^<<\"Strane! Bene!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^È molto evidente che Kaalan abbia a malapena registrato la mia risposta.","\n",{"#":"gesture_partner: explaining"},"^<<\"Vorrei che facessi qualcosa — se sei libera o, beh, se non lo sei — comunque sia. Vorrei che tu facessi qualcosa per me. Sarà un pochino divertente, te lo prometto! E ti farà guadagnare un Distintivo del Macchinista!\">>","\n",{"#":"gesture_partner: talking"},"^<<\"Rapido e al sodo, vedi? So che a voi Glider piace così. Velocità. E... cose. Così. Comunque!\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"default_intro":[{"#":"gesture_partner: greeting"},"^Kaalan saluta.","\n","ev","void","/ev","->->",{"#f":1}],"done":["^Saluto Kaalan.","\n",{"->":"END_SCENE"},{"#f":3}],"options":[["ev",{"^->":"an_eye_to_the_sky_content"},{"^->":"kaalan_conversation.done"},"/ev","thread",{"->":"thread_in_tunnel"},"ev","str","^Personalizza hoverbike","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Addio","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"#":"StartCustomization"},"^<<\"Diamogli un'occhiata, sì?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^.^.done"},{"#f":5}]}],{"#f":1}],"#f":1}],"mateo_conversation":["ev","str","^Mateo","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev",{"CNT?":".^.^.first_intro"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.^.8"},null]}],"nop","\n",{"->t->":".^.quest_content"},{"->":".^.done"},{"done":["^Saluto Mateo.","\n",{"->":"END_SCENE"},{"#f":1}],"first_intro":["^Mateo è un pastore al Campo dello Scarabeo Parassita.","\n","ev","void","/ev","->->",{"#f":1}],"default_intro":["^Mateo saluta.","\n","ev","void","/ev","->->",{"#f":1}],"quest_content":[["ev",{"VAR?":"A_SHEPHERD_WITHOUT_A_TRAIN_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"a_shepherd_without_a_train_content"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"REBUILDING_THE_TRAIN_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"rebuilding_the_train_content"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"REBUILDING_THE_TRAIN_COMPLETED"},{"f()":"reached"},{"VAR?":"WHERE_THE_CAMELS_ARE_STARTED"},{"f()":"reached"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"where_the_camels_are_content"},{"->":".^.^.^.4"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.^.generic_chat"},{"->":".^.^.^.4"},null]}],"nop","\n","ev","void","/ev","->->",{"#f":1}],"generic_chat":["^Faccio due chiacchiere con Mateo.","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"mask_caster_alia_conversation":[{"->":"mask_caster_asrar_conversation"},{"#f":1}],"merchant_thiago":[["ev","str","^Mercante Thiago","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Salute, Glider. Vuoi esaminare la mia merce?\">>","\n","ev","str","^Facciamo affari!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Parlami di questo posto.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non ho bisogno di nulla.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.begin_trading"},{"#f":5}],"c-1":["^  ","\n","^<<\"In pochi arrivano fin in questa parte del mondo.\">>","\n","^<<\"A molti non piacciono le ossa sparse nelle dune. Dicono che persino i depositi di gesso siano ossa antiche consumate dalle sabbie.\">>","\n","^<<\"Ma se ne hai voglia, non c'è paesaggio più suggestivo a Midden.\">>","\n",{"->":".^.^.^.conversation_end"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.conversation_end"},{"#f":5}]}],{"begin_trading":[{"#":"StartTrading"},"^<<\"Certo! Dai un'occhiata alla mia merce.\">>","\n","^<<\"Grazie del tuo passaggio.\">>","\n",{"->":".^.^.conversation_end"},{"#f":1}],"conversation_end":["^<<\"Addio!\">>","\n","end",{"#f":1}],"#f":1}],"black_ring_monument":[{"->t->":".^.intro"},"ev",{"VAR?":"debug_found_black_monument"},0,"==","/ev",[{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.interaction_point"},{"->":".^.^.^.7"},null]}],"nop","\n",{"->":".^.done"},{"intro":["^Ti trovi al Monumento dell'Anello del Deserto Nero.","\n","ev","void","/ev","->->",{"#f":1}],"interaction_point":["^Entro nel monumento.","\n","ev",1,"/ev",{"VAR=":"debug_found_black_monument","re":true},"ev",{"VAR?":"RING_SHRINE_QUEST_BLACK_DESERT_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"->t->":"an_ancient_race_debug_pick_up_item"},"ev","void","/ev","->->",{"#f":1}],"done":["^Lascio il monumento dell'anello.","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"black_desert_clan_merchant_trading":[["ev","str","^Mercante Hakoano Caimin","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<...>>","\n","ev","str","^Vorrei commerciare.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Parlami di questo campo.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non ho bisogno di nulla.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^  ","\n",{"->":".^.^.^.begin_trading"},{"#f":5}],"c-1":["^  ","\n","^<<...>>","\n","^<<...>>","\n","^Non sembrano interessati a rispondere. Il silenzio è intenso e a disagio.","\n","^<<\"Sono venuto qui anni fa... L'altopiano... Chiede di essere studiato...\">>","\n","^La loro voce è lenta ma deliberata e riflessiva.","\n",{"->":".^.^.^.conversation_end"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.conversation_end"},{"#f":5}]}],{"begin_trading":[{"#":"StartTrading"},"^<<...>>","\n",{"->":".^.^.conversation_end"},{"#f":1}],"conversation_end":["^<<...>>","\n","end",{"#f":1}],"#f":1}],"tohta_conversation":["ev",{"VAR?":"speaker_tohta"},"/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop",{"->t->":".^.^.^.first_intro"},{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n",{"->":".^.first_opts"},{"first_intro":[["^A prima vista, i Coltivatori di Cristalli sono così sorprendenti da farmi quasi sussultare.","\n","^La loro altezza è immensa e si muovono con tale calma che non posso fare a meno di attribuire loro una conoscenza superiore, o vedere la saggezza dell'età nelle curve delle loro schiene.","\n","^Ma poi mi ricordo: la mia lettura è informata dai segni che vedo tra la mia gente, le abbreviazioni di una cultura, e questi coltivatori non sono affatto vincolati alla mia interpretazione.","\n","^Mi chiedo cosa pensino di me.","\n","ev","str","^Saluti, Coltivatore di Cristalli!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Sto cercando Tohta.","/str",{"VAR?":"LIGHTNING_IN_A_SHARD_STARTED"},{"f()":"reached"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Conosci Tohta?","/str",{"VAR?":"LIGHTNING_IN_A_SHARD_STARTED"},{"f()":"reached"},"/ev",{"*":".^.c-2","flg":5},{"c-0":["^ ","\n",{"#":"gesture_sable: greeting"},"^<<\"Saluti, Glider! Mi chiamo Tohta. E tu?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"E lo hai trovato. Qual è il prossimo obiettivo?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Che domanda. Lo conosco metà di quanto dovrei, e il doppio di chiunque altro. Perché è me stesso.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Mi aspetto che la sua voce emerga come un raschio, ma invece scorre come seta da dietro la sua maschera cristallina. C'è una purezza nel suono che produce; ogni parola mi raggiunge nitida come un sussurro all'orecchio.","\n","ev",{"VAR?":"LIGHTNING_IN_A_SHARD_STARTED"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"gesture_sable: talking"},"^Parlo un po' più forte del normale, per assicurarmi che mi senta da lassù. Gli dico che mi chiamo Sable.","\n","ev","void","/ev","->->",{"->":".^.^.^.8"},null]}],"nop","\n",{"#":"gesture_sable: talking"},"^Parlo un po' più forte del normale, per assicurarmi che mi senta da lassù. Gli dico che mi chiamo Sable e che Zahra mi ha mandato a raccogliere cristalli, ma mi ha consigliato di parlare prima con lui.","\n","^Non ci sono occhi sul cristallo che indossa, ma si illumina al menzionare il suo nome, e so comunque dove guardare.","\n","^<<\"Che piacere sentire che sta bene. Sono settimane, se non mesi, da quando ho visto la cara Zahra. Dimmi, Sable, stai per diventare Macchinista?\">>","\n","ev","str","^Ci sto pensando.","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Non credo proprio.","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Non ho ancora deciso.","/str","/ev",{"*":".^.c-5","flg":4},{"c-3":["^ ","\n","^Gli dico che ci sto pensando e annuisce. La luce coglie la sua maschera e brilla a ogni nuovo movimento.","\n","^<<\"Se decidi di scalare quel picco, ci sono pochi mentori migliori di Zahra.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n","^<<\"No? Se fossi una Glider che incontra Zahra, potrei non aver resistito. I suoi passi fanno buoni appigli.\">>","\n","^Mi chiedo se sia un modo di dire tra i Coltivatori.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-5":["^ ","\n","^<<\"Allora è bene che tu non debba farlo. Lo scopo del Volo non è scegliere. La scelta è la fine del Volo. L'indecisione è la sua forma voluta.\">>","\n","^Dico che se è così, ne sono incredibilmente brava. La risata di Tohta scintilla attraverso la sua maschera.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Allora...\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"first_opts":["^<<\"Come posso aiutarti, Sable?\">>","\n",{"->":".^.^.opts"},{"#f":1}],"repeat_opts":["^<<\"Posso fare altro per te?\">>","\n",{"->":".^.^.opts"},{"#f":1}],"opts":[["ev","str","^Non ho mai incontrato un Coltivatore di Cristalli prima.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Che posto è questo?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Cosa sono quei grossi robot?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Come si raccolgono i cristalli?","/str",{"VAR?":"LIGHTNING_IN_A_SHARD_STARTED"},{"f()":"reached"},"/ev",{"*":".^.c-3","flg":5},"ev","str","^Addio","/str","/ev",{"*":".^.c-4","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: thinking"},"^Dico a Tohta che è il primo Coltivatore di Cristalli che abbia mai incontrato, e aggiungo che spero non sia maleducato menzionarlo. Sposta il peso e i cristalli sulla schiena si muovono pigramente con lui.","\n","^<<\"Oh! Dobbiamo sembrarti molto strani.\">>","\n",["ev","str","^Ehm...","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No! Assolutamente no.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Un po'.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: surprised_2"},"^Balbetto e Tohta ridacchia.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: explaining"},"^Protesto, ma fa solo ridacchiare Tohta.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_sable: shrug"},"^Ammetto che sembrano un po' strani, ma aggiungo che non è una cosa negativa.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Chiedo se sembro strana a <i>lui</i>.","\n","^<<\"Non sembri. Cosa che è in parte perché ho incontrato altre come te, ma anche perché <i>noi</i> siamo quelli diversi.\">>","\n","^Suggerisco che siamo <i>entrambi</i> diversi, e in qualche modo giuro che sorrida.","\n","^<<\"Non sono sicuro sia qualcosa che decidiamo noi.\">>","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Tohta solleva uno dei bastoni e lo punta verso il cielo per indicare il Crystal Plateau, inclinandosi con una forza impressionante.","\n","^<<\"Lo abbiamo costruito noi. È stato fatto per attirare le tempeste di fulmini lontano dal resto di Hakoa e concentrarle su quel picco.\">>","\n","^<<\"Come accade, un effetto collaterale di quella concentrazione fu la formazione di Cristalli Fulmine, carichi di elettricità.\">>","\n","^Disegna un cerchio nell'aria.","\n","^<<\"Non è una meraviglia? Abbiamo trasformato una rovina in una benedizione, e una benedizione in una cultura. Tutte le sostanze chimiche e le coincidenze che hanno cospirato per creare i Coltivatori di Cristalli.\">>","\n",{"#":"gesture_sable: yes"},"^Annuisco. E all'improvviso questo posto che credevo una fabbrica sembra più un luogo di culto.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Quelli sono il motivo per cui le mie spalle si lamentano e le mie ginocchia si stanno sgretolando. <i>Una volta</i> raccoglievano loro i Cristalli Fulmine. Ma ora dobbiamo farlo da soli. E non è un lavoro facile.\">>","\n","^Chiedo cosa sia successo.","\n","^<<\"Si sono fermati. Tutti insieme. Un giorno, dopo una tempesta che sembrava del tutto normale, semplicemente... <i>si sono fermati</i>. Alcuni sono caduti, altri sono rimasti in piedi, ma nessuno si è più mosso.\">>","\n","^Per empatia dico che dev'essere sembrato un terribile presagio. Scuote la testa ed è il movimento più veloce che gli abbia visto fare.","\n","^<<\"Oh, niente del genere, no. C'è una spiegazione nella meccanica o nella chimica, anche se non la conosciamo. E in questo, almeno, troviamo grande conforto.\">>","\n",{"#":"gesture_sable: yes"},"^Annuisco. E in qualche modo credo di capirlo meglio.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-3":["^ ","\n","ev",{"VAR?":"LIGHTNING_IN_A_SHARD_LEARNT_TO_HARVEST"},{"f()":"activate"},"pop","/ev","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Dico a Tohta che sono stata mandata a raccogliere Cristalli Fulmine e chiedo prima se mi è permesso, e poi come fare.","\n","^<<\"Sei la benvenuta a provarci. Se ti avesse mandata chiunque altro all'infuori di Zahra, considererei di dissuaderti, Sable. Ma lei conosce le persone. Quindi mi limiterò a spiegarti.\">>","\n","^Tohta annuisce verso il Plateau.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^<<\"Osserva e aspetta che un fulmine colpisca uno degli obelischi. Quando succede, vedrai cristalli formarsi sulla superficie. Devi salire sull'obelisco e staccare quanti più Cristalli Fulmine puoi.\">>","\n","^<<\"Dovrai essere veloce, però, e prenderli prima che si frantumino. Non che pensi avrai problemi. Hai una certa rapidità.\">>","\n",{"#":"gesture_sable: thanks"},"^Lo ringrazio per la fiducia.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-4":["^ ","\n",{"->":".^.^.^.^.done"},{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^.^.repeat_opts"},{"#f":5}]}],{"#f":1}],"done":["^<<\"Addio, Glider.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"black_desert_camp_dude_forest":["ev","str","^Forest","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Difficile non notare le Sette Sorelle, lassù sospese in aria. Niente male, eh?\">>","\n",{"#":"gesture_partner: laugh"},"^<<\"Ho visto uno o due scalatori provarci. Raramente finisce bene.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"black_desert_camp_courier_ireni":["ev","str","^Corriere Ireni","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Una consegna a Hakoa. Magnifico! Questa è l'ultima volta che accetto.\">>","\n","^<<\"Fumi che ti graffiano gli occhi.\">>","\n","^<<\"L'umidità è insopportabile.\">>","\n","^<<\"E tutto questo mentre trascini una borsa pesante su questo terreno.\">>","\n","^<<\"Per la maschera di Rohana, vorrei avere una hoverbike!\">>","\n",{"->":"END_SCENE"},{"#f":1}],"slicer_innkeeper_conversation":["ev","str","^Locandiera Afii","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.17"},null],"#f":5}],"\n",{"->":".^.first_loop"},{"first_intro":["^Questa è Afii, la locandiera del campo.","\n","ev","void","/ev","->->",{"#f":1}],"default_intro":["^<<\"Salute, Glider.\">>","\n","ev","void","/ev","->->",{"#f":1}],"first_loop":["^<<\"Cosa posso fare per te?\">>","\n",{"->":".^.^.opts"},{"#f":1}],"loop":["^<<\"Posso fare qualcos'altro per te?\">>","\n",{"->":".^.^.opts"},{"#f":3}],"opts":[["ev",{"^->":"nozis_nibbles_content.investigation"},{"^->":"slicer_innkeeper_conversation.loop"},"/ev","thread",{"->":"thread_in_tunnel"},"ev",{"^->":"searching_for_llhor_content.third_clue"},{"^->":"slicer_innkeeper_conversation.loop"},"/ev","thread",{"->":"thread_in_tunnel"},"ev",{"^->":"slicer_beetle_quest_content"},{"^->":"slicer_innkeeper_conversation.loop"},"/ev","thread",{"->":"thread_in_tunnel"},"ev","str","^Saluta.","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.done"},{"#f":5}]}],{"#f":1}],"done":["^<<\"Addio, Glider.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"#f":3}],"lightning_bike_available_to_buy":["ev","str","^LightningCrystalBikeFront","/str",{"x()":"inventory_get_quantity","exArgs":1},"str","^LightningCrystalBikeWings","/str",{"x()":"inventory_get_quantity","exArgs":1},"&&","str","^LightningCrystalBikeBooster","/str",{"x()":"inventory_get_quantity","exArgs":1},"&&","/ev",[{"->":".^.b","c":true},{"b":["\n","ev",0,"/ev","~ret",{"->":".^.^.^.18"},null]}],[{"->":".^.b"},{"b":["\n","ev",{"VAR?":"LIGHTNING_IN_A_SHARD_COMPLETED"},{"f()":"reached"},"/ev","~ret","\n",{"->":".^.^.^.18"},null]}],"nop","\n",{"#f":1}],"zahra_conversation":["ev",{"VAR?":"speaker_zahra"},"/ev",{"VAR=":"SpeakerName","re":true},["ev",{"CNT?":".^.^.first_intro"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.^.6"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.^.6"},null]}],"nop","\n",{"->":".^.options"},{"first_intro":["ev",{"VAR?":"speaker_machinist"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"gesture_partner: arms_crossed"},"^La Macchinista si muove lentamente, intenzionale in ogni gesto. Mentre mi avvicino, incrocia le braccia e inclina la testa indietro, guardandomi, valutandomi.","\n","^Metto una camminata strafottente nel mio passo, per sembrare un po' più disinvolta di quanto mi senta.","\n",{"#":"gesture_partner: yes"},{"#":"gesture_sable: yes"},"^Il suo saluto è un cenno silenzioso del mento. Le rispondo annuendo.","\n","^<<\"Come ti chiami?\">>","\n","^Ha una voce come ghiaia.","\n",{"#":"gesture_sable: talking"},"^Le dico il mio nome e mi tende la mano in segno di saluto.","\n","ev",{"VAR?":"speaker_zahra"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Zahra. Cosa cerchi?\">>","\n","ev","void","/ev","->->",{"#f":1}],"default_intro":[{"#":"gesture_sable: greeting"},"^Saluto Zahra. Annuisce.","\n","ev","void","/ev","->->",{"#f":1}],"options":[["ev",{"^->":"nozis_nibbles_content.investigation"},{"^->":"zahra_conversation.done"},"/ev","thread",{"->":"thread_in_tunnel"},"ev",{"^->":"lightning_in_a_shard_content"},{"^->":"zahra_conversation.done"},"/ev","thread",{"->":"thread_in_tunnel"},"ev","str","^Personalizza hoverbike","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Compra pezzi hoverbike","/str",{"f()":"lightning_bike_available_to_buy"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Addio","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"StartCustomization"},"^<<\"Apriamola.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"StartTrading"},"^<<\"Nessun problema. Dai un'occhiata.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^.^.done"},{"#f":5}]}],{"#f":1}],"done":["^Saluto Zahra.","\n",{"->":"END_SCENE"},{"#f":3}],"#f":1}],"mask_caster_ezekias_conversation":[{"->":"mask_caster_asrar_conversation"},{"#f":1}],"cartographer_niaz":[["ev","str","^Cartografa Niaz","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Saluto la Cartografa timidamente, un po' intimidita da quanto siamo sole quassù, e da quanto a volte ciò sembri intimo nonostante faccia parte del mio Volo.","\n","^Risponde con quello che sembra un caldo sorriso.","\n","^<<\"Salve, Glider! Grazie di esserti presa il tempo di salire fin quassù.\">>","\n","^<<\"Misurare diventa un po' solitario a volte, sai?\">>","\n","^Le dico che lo capisco, vista quanto sono sola sulle sabbie a volte. Spero Simoon non senta.","\n","^<<\"Allora. Di cosa hai bisogno?\">>","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^<<\"Posso aiutarti, Glider.\">>","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Posso comprare una mappa?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^C'è qualcosa che vale la pena vedere qui vicino?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Quali altre regioni ci sono qui vicino?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Grazie!","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^  ","\n",{"->":".^.^.^.begin_trading"},{"#f":5}],"c-1":["^  ","\n","^Chiedo se c'è qualcosa che vale la pena vedere qui vicino.","\n","^Ridacchia tra sé.","\n","^<<\"Certo! Non penserai che me ne stia qui sopra per niente, no? Sei stata già alla grande Torre del Vento? Da lassù si vede per ore!\">>","\n","^<<\"E anche Burnt Oak Station è vicina. Non indovinerai mai perché si chiama così.\">>","\n","^Ci penso, ma continua prima che io riesca a gridare la mia previsione.","\n","^<<\"E se sei un'appassionata di insetti, qui vicino c'è un enorme nido di Scarabei Ercole. Si dice che possano sollevare cento volte il loro peso!\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-2":["^ ","\n","^Chiedo quali altre regioni siano qui vicino.","\n","^<<\"Sono felice tu l'abbia chiesto! Vai a sud se vuoi vedere le sabbie bianche del Wash. A ovest troverai il Redsee e i suoi mille segreti. E a est ci sono le saline della Waste.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-3":["^  ","\n","^Ringrazio la cartografa per il suo tempo.","\n","^<<\"Nessun problema, Glider. Torna quando vuoi.\">>","\n",{"->":"END_SCENE"},{"#f":5}]}],{"begin_trading":[{"#":"StartTrading"},"^<<\"Certo!\">>","\n","^<<\"Grazie, Glider.\">>","\n","^<<\"Addio!\">>","\n","end",{"#f":1}],"#f":1}],"cartographer_talon":[["ev","str","^Cartografo Talon","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Saluto il Cartografo.","\n","^<<\"Ehilà!\">>","\n","^<<\"Sai, un sacco di gente si fa vedere qui sopra! Tra te e me, credo vogliano solo sentirsi alti.\">>","\n","^Decido subito che non gli serve sapere se sia il mio motivo o no.","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^<<\"Cosa posso fare per te, Glider?\">>","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Posso comprare una mappa?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Punti di interesse locali?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Quali altre regioni ci sono vicine?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Grazie!","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^   ","\n",{"->":".^.^.^.begin_trading"},{"#f":5}],"c-1":["^ ","\n","^Chiedo se ci sono punti di interesse vicini, e la sua risposta è rinfrescantemente non recitata. Posso solo immaginare quante volte i Cartografi debbano dare la stessa informazione ai visitatori, giorno dopo giorno.","\n","^<<\"La città di Eccria è vicina — ci sei già stata? E anche il Campo Cinque Campane non è lontano.\">>","\n","^Pensa.","\n","^<<\"La foresta di palme — dovresti darle un'occhiata, davvero. Soprattutto se ti piace il mistero. C'è una nave in rovina lì dentro che nessuno tocca da anni.\">>","\n","^<<\"E a proposito di navi in rovina... La Whale è qui vicino. Non troverai molte cose più antiche.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-2":["^ ","\n","^<<\"Le saline della Waste sono a nord-est. Poi, andando a sud, le sabbie iniziano a scurirsi mentre entri a Hakoa, il Deserto Nero. E a est trovi il Sansee.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-3":["^ ","\n","^Ringrazio il Cartografo per il suo tempo e parto.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"begin_trading":[{"#":"StartTrading"},"^<<\"Vediamo cos'ho...\">>","\n","^<<\"Spero sia stato utile!\">>","\n","^<<\"Addio!\">>","\n","end",{"#f":1}],"#f":1}],"cartographer_iliud":["ev","str","^Cartografo Iliud","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->":".^.^.^.first_meeting"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->":".^.^.^.second_meeting"},{"->":".^.^.17"},null],"#f":5}],"\n",{"first_meeting":[[["^Saluto il Cartografo.","\n","^<<\"Mi sorprende che tu non ti sia fatta male a salire fin qui. Immagino tu sia più forte di quanto sembri.\">>","\n","ev","str","^Come, scusa?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Cosa intendi con \"di quanto sembri\"?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Esatto! Sono <i>molto</i> forte.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Mi sporgo e chiedo al Cartografo di ripetere.","\n","^<<\"Ho detto <i>immagino tu sia più forte di quanto sembri</i>.\">>","\n","^Giusto. Decido di non insistere, e di ribollire liberamente dietro la maschera.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-1":["^ ","\n","^Chiedo al Cartografo di chiarire cosa intende.","\n","^<<\"Voglio dire che sembri un po' minuta, un po' goffa. Ma se sei arrivata fin qui? Devi avere più muscoli di quel che pare.\">>","\n","^Beh, immagino di avere la risposta.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-2":["^ ","\n","^Dico al Cartografo che ha ragione: sono tremendamente forte. Tantissimo.","\n","^Annuisce come se la strana fossi <i>io</i>.","\n","^<<\"Bene. Quindi cosa vuoi?\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5,"#n":"g-0"}],{"g-1":[{"->":".^.^.^.^.options"},{"#f":5}]}],{"#f":1}],"second_meeting":["^<<\"Bene. Quindi cosa vuoi?\">>","\n",{"->":".^.^.options"},{"#f":1}],"options":[["ev","str","^Posso comprare una mappa?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Qualcosa di interessante qui vicino?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Quali altre regioni ci sono vicine?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Grazie.","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^   ","\n",{"->":".^.^.^.^.begin_trading"},{"#f":5}],"c-1":["^ ","\n","^Risponde con una misurabile quantità di esasperazione, praticamente sbuffando nella risposta.","\n","^<<\"Beh, sei nel mezzo del Cantiere, se non era ovvio.\">>","\n","^<<\"Ci sono le Rocce dei Geyser qui vicino, ma non avvicinarti troppo.\">>","\n","^<<\"Le pozze di sale a nord-est ospitano gente decente, vai a trovarli se vuoi.\">>","\n",{"->":".^.^.^.^"},{"#f":5}],"c-2":["^ ","\n","^<<\"Non c'è molto in giro — per questo si chiama la Waste. Vai a ovest verso Redsee, o a sud-est verso Sansee.\">>","\n",{"->":".^.^.^.^"},{"#f":5}],"c-3":["^  ","\n","^Li ringrazio per il tempo e mi metto in cammino.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"begin_trading":[{"#":"StartTrading"},"^<<\"Ok, scambiamo.\">>","\n","^<<\"Addio, allora.\">>","\n","end",{"#f":1}],"#f":1}],"cartographer_sifi":[["ev","str","^Cartografa Sifi","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^La mia presenza sorprende la cartografa, che a sua volta sorprende me.","\n","^<<\"Wow! Da dove sbuchi? Non dovresti sbucare addosso alla gente così!\">>","\n","^Non vale la pena spiegare. Sono ovviamente arrivata dal basso.","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^<<\"Glider.\">>","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Posso comprare una mappa?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Cosa posso trovare in questa regione?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Quali altre regioni ci sono vicine?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Grazie.","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^   ","\n",{"->":".^.^.^.begin_trading"},{"#f":5}],"c-1":["^ ","\n","^Chiedo cosa posso trovare nella regione e sembra entusiasta di discuterne con me.","\n","^<<\"La Foresta Pietrificata è meravigliosa! Se ti avventuri dentro, potresti vedere alcune delle pietre geodesiche giganti. E chissà che creature divertenti potresti trovare in agguato lì vicino!\">>","\n","^<<\"Poi Marrow Bone Station è ben rifugiata, sotto le ossa di un antico gigante.\">>","\n","^Dice quell'ultima parte con un certo pathos. Apprezzo la sua teatralità.","\n","^<<\"Oh, e se non hai mai visto la Vedetta... Beh, lasciami dire che pochi capolavori d'ingegneria sono così... risonanti.\">>","\n","^<<\"E infine: Pyrausta, il Grande Verme. La maggior parte ti dirà che è solo un antico monumento, una specie di tributo a qualcosa...\">>","\n","^<<\"Ma io credo che un tempo possa essere stato vivo.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-2":["^ ","\n","^<<\"Se ti senti avventurosa, vai a ovest attraverso i Badlands fino alle sabbie nere di Hakoa. E a nord troverai il Sansee.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-3":["^ ","\n","^Ringrazio la Cartografa e mi rimetto in cammino.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"begin_trading":[{"#":"StartTrading"},"^<<\"Ecco cos'ho.\">>","\n","^<<\"Stammi bene!\">>","\n","end",{"#f":1}],"#f":1}],"cartographer_arzu":[["ev","str","^Cartografo Arzu","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Il Cartografo risponde al mio saluto con un grugnito, e immagino con qualche pratica alzata d'occhi.","\n","^<<\"Sei venuta fin quassù solo per disturbarmi, eh? Hai mai pensato che ci possa essere un motivo se sto quassù con tutte queste ossa?\">>","\n","^Gli dico che spero sia perché è un Cartografo?","\n","^Sbuffa, ma mi fa segno di proseguire.","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Il Cartografo a malapena mi degna di attenzione.","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Posso comprare una mappa?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Punti di interesse locali?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Quali altre regioni ci sono vicine?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Grazie.","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^  ","\n",{"->":".^.^.^.begin_trading"},{"#f":5}],"c-1":["^ ","\n","^Sembra ansioso di sbarazzarsi di me.","\n","^<<\"Dipende da cosa trovi interessante. Un paio di sciocchi hanno iniziato a passare del tempo nell'antico insediamento sulle Eyries.\">>","\n","^<<\"Dovrai scalare, ma pare tu non abbia problemi al riguardo, invitata o meno.\">>","\n","^<<\"C'è anche una nave naufragata che pende da una parete rocciosa lì, se hai il coraggio o la stupidità di provare a saccheggiarla.\">>","\n","^<<\"Oh, e anche il Ponte dei Traditi è qui vicino. È piuttosto sicuro, nonostante il nome.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-2":["^ ","\n","^<<\"Probabilmente vieni da nord, no? Torna in quella direzione per Sansee e Redsee. A est, il Wash e la Foresta Pietrificata. A ovest c'è Hakoa, ma dovrai saltare di scogliera in scogliera.\">>","\n","^Mi dà un'occhiata come per valutare il mio potenziale di salti.","\n","^<<\"Probabilmente starai bene.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-3":["^ ","\n","^Nonostante il tono, lo ringrazio prima di andare.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"begin_trading":[{"#":"StartTrading"},"^<<\"Bene.\">>","\n","^<<\"Addio.\">>","\n","end",{"#f":1}],"#f":1}],"cartographer_charifa":[["ev","str","^Cartografa Charifa","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^La cartografa mi saluta lentamente, come se non fosse sicura che io sia davvero lì.","\n","^<<\"Co-cosa? Oh. Giusto. Ciao.\">>","\n","^<<\"Hm. Hai fatto tanta strada, glider?\">>","\n","^La voce le trema un po'.","\n","^<<Benvenuta nel mare nero, Hakoa!>>","\n","^Le chiedo se stia bene.","\n","^<<\"Meglio che bene! Sono in forma smagliante.\">>","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^<<\"Benvenuta!\">>","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Posso comprare una mappa?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Cosa dovrei vedere qui vicino?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Quali altre regioni ci sono vicine?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Grazie.","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^  ","\n",{"->":".^.^.^.begin_trading"},{"#f":5}],"c-1":["^ ","\n","^Risponde come se dovessi già sapere cosa sta per dire.","\n","^<<\"Certo! Troverai riparo alla Stazione Sette Sorelle. Non sono sicura che troverai delle sorelle, però — figurarsi sette!\">>","\n","^Guarda in alto pensosamente.","\n","^<<\"Ooh, la Grotta dei Vermi Luminosi è un posto magico! Devi trovarci il tempo ora che sei qui. Strana da matti, ti piacerà.\">>","\n","^<<\"E c'è qualcosa di davvero speciale nel Crystal Plateau, anche se non sono riuscita a portarci la mia mongolfiera — non va d'accordo con i fulmini, capisci.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-2":["^ ","\n","^<<\"Sempre buona idea orientarsi. Adoro. A nord c'è il Redsee, e attraverso i Badlands a est troverai il Wash.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-3":["^ ","\n","^Ringrazio la Cartografa per il suo tempo prezioso e parto.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"begin_trading":[{"#":"StartTrading"},"^<<\"Certamente! Dai un'occhiata alla merce.\">>","\n","^<<\"Addio!\">>","\n","end",{"#f":1}],"#f":1}],"cartographer_jourdan":["ev",{"VAR?":"speaker_jourdan"},"/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.17"},null],"#f":5}],"\n",["ev",{"VAR?":"PURVEYOR_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.9"},null]}],["ev",{"VAR?":"PURVEYOR_STARTED"},{"VAR?":"PURVEYOR_JADI_GAVE_MONEY"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_in_progress"},{"->":".^.^.^.9"},null]}],["ev",{"VAR?":"PURVEYOR_JADI_GAVE_MONEY"},{"VAR?":"PURVEYOR_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_buy_map"},{"->":".^.^.^.9"},null]}],"nop","\n",{"->":".^.done"},{"first_intro":[["^Mi avvicino al Cartografo.","\n",{"#":"gesture_partner: greeting"},"^<<\"Ah! Salute, bambina!\">>","\n","^<<\"Ti ho vista guardare languidamente la mia grande mongolfiera. Bel lavoro, no?\">>","\n","ev","str","^Lo è davvero.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Languidamente?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^È più grande di quanto pensassi!","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: yes"},"^Annuisco con entusiasmo. È davvero un mezzo impressionante, per quanto mi venga il nervoso a immaginarmi lassù tutta sola. Mi chiedo se qualcuno sia mai caduto giù da una.","\n","^Meglio non chiederlo adesso.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_partner: uninterested"},"^Chiarisco che la guardavo <i>incuriosita</i> e che le mongolfiere non sono il mio veicolo ideale. Il nuovo arrivato fa spallucce.","\n","^<<\"Giusto! Immagino che quando ti puoi rifugiare in una piccola bolla tranquilla e fluttuare giù dal cielo, la mongolfiera perda parte del suo fascino.\">>","\n","^<<\"Ma accetterò la tua curiosità.\">>","\n","^Faccio alla mongolfiera un cenno di approvazione perché lui non si senta male.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^Cerco di spiegare che quando ho visto la mongolfiera la prima volta pensavo fosse molto piccola e <i>abbastanza</i> lontana, ma ora vedo che è piuttosto grande ed era <i>molto</i> lontana.","\n",{"#":"gesture_partner: yes"},"^Pasticcio nella spiegazione, però, e il Cartografo annuisce senza dire nulla.","\n",{"#":"gesture_sable: yes"},"^Annuisco a mia volta.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Bene! Piacere di conoscerti. E-- Oh! Dovrei presentarmi. Sono Jourdan.\">>","\n","^Gli dico che sono Sable.","\n","^<<\"Immagino che se sei venuta fin qui per vedermi, sia una mappa che cerchi, eh Sable?\">>","\n","ev","str","^Una mappa la prenderei volentieri!","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Sono venuta a vedere la mongolfiera!","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Mi serve una mappa?","/str","/ev",{"*":".^.c-5","flg":4},{"c-3":["^ ","\n","^Dico al Cartografo che vorrei volentieri una mappa.","\n","^<<\"Certo che sì. Saranno 50 cuts!\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n","^Dico al Cartografo che in realtà sono venuta a vedere la mongolfiera.","\n","^<<\"Ah! Non ti biasimo. Ma stai partendo per il tuo Volo, no? Ti vendo una mappa dell'Ewer per soli 50 cuts.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-5":["^ ","\n","^Chiedo al Cartografo se me ne serve una.","\n","^<<\"Ai cervi volanti piacciono i fichi?\">>","\n","^Non ne ho idea, ma dal contesto immagino la risposta sia sì.","\n","^<<\"Se parti per il Volo, Sable, ti servirà sicuramente una mappa dell'Ewer, almeno. Te la vendo per soli 50 cuts.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"default_intro":["^<<\"Salute, bambina.\">>","\n","ev","void","/ev","->->",{"#f":1}],"done":["^<<\"Addio, bambina.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"quest_start":["ev",{"list":{"purveyor_and_surveyor.PURVEYOR_STARTED":1,"purveyor_and_surveyor.PURVEYOR_EDGE_CASE":2}},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_sable: talking"},"^Alle mie orecchie è un prezzo equo per una mappa, ma troppo per una Glider pre-Volo con le tasche vuote. Dico a Jourdan che tornerò.","\n","^Dovrò chiedere a Jadi un po' di soldi.","\n","ev","void","/ev","->->",{"#f":1}],"quest_in_progress":["^<<\"Non posso darti la mappa gratis. Torna quando avrai dei cuts.\">>","\n","ev","void","/ev","->->",{"#f":1}],"quest_buy_map":[["ev","str","^Comprerò quella mappa!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Addio","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"#":"StartTrading"},"^<<\"Perfetto! Allora scambiamo.\">>","\n","ev","str","^CatEarCanyonMap","/str",{"x()":"inventory_get_quantity","exArgs":1},0,">","/ev",[{"->":".^.b","c":true},{"b":["^ ",{"->":".^.^.^.^.^.^.quest_complete"},{"->":".^.^.^.14"},null]}],"nop","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Saluto Jourdan con un cenno.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_complete":["ev",{"VAR?":"PURVEYOR_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^Ringrazio Jourdan per la mappa dell'Ewer, e tutte le sue vaste possibilità. Qualcosa rende tutto più... reale.","\n","^<<\"Buona fortuna per il tuo Volo, Sable! Ricordo ancora il mio.\">>","\n",{"#":"gesture_sable: talking"},"^Chiedo com'era.","\n","^<<\"Breve. Sapevo fin da ragazzino che la Cartografia faceva per me... Ma ho passato un po' di tempo extra là fuori, solo per godermi il mondo.\">>","\n","^<<\"A proposito, tieni d'occhio i cieli, eh? Là fuori ci sono molti miei colleghi, e avranno altre mappe da venderti, da Hakoa fino al Sodic Waste!\">>","\n",{"#":"gesture_sable: thanks"},"^Ringrazio Jourdan per il consiglio e lo saluto.","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"force_update_all_quest_states":["ev",{"VAR?":"nothing"},{"f()":"activate"},"pop","/ev","\n",{"#f":1}],"activate":[{"temp=":"x"},"ev",{"VAR?":"x"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"AllQuestStates"},{"VAR?":"x"},"+",{"VAR=":"AllQuestStates","re":true},"/ev",