ev","~ret","\n",{"#f":1}],"number_of_masks_unlocked":["ev",0,"/ev",{"temp=":"n"},"ev",{"f()":"got_ibex_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.8"},null]}],"nop","\n","ev",{"f()":"got_machinist_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.14"},null]}],"nop","\n","ev",{"f()":"got_guard_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.20"},null]}],"nop","\n","ev",{"f()":"got_shade_of_eccria_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.26"},null]}],"nop","\n","ev",{"f()":"got_atomic_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.32"},null]}],"nop","\n","ev",{"f()":"got_climbing_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.38"},null]}],"nop","\n","ev",{"f()":"got_entertainers_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.44"},null]}],"nop","\n","ev",{"f()":"got_fishing_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.50"},null]}],"nop","\n","ev",{"f()":"got_monumental_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.56"},null]}],"nop","\n","ev",{"f()":"got_sandworm_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.62"},null]}],"nop","\n","ev",{"f()":"got_scrappers_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.68"},null]}],"nop","\n","ev",{"f()":"got_beetle_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.74"},null]}],"nop","\n","ev",{"f()":"got_merchants_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.80"},null]}],"nop","\n","ev",{"f()":"got_chum_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.86"},null]}],"nop","\n","ev",{"f()":"got_cartographers_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"n"},1,"+",{"temp=":"n","re":true},"/ev",{"->":".^.^.^.92"},null]}],"nop","\n","ev",{"VAR?":"n"},"/ev","~ret",{"#f":1}],"collected_enough_masks_to_finish_the_game":["ev",{"f()":"number_of_masks_unlocked"},3,">=","/ev","~ret","\n",{"#f":1}],"collected_all_the_masks_in_the_game":["ev",{"f()":"got_ibex_mask"},{"f()":"got_machinist_mask"},"&&",{"f()":"got_guard_mask"},"&&",{"f()":"got_shade_of_eccria_mask"},"&&",{"f()":"got_atomic_mask"},"&&",{"f()":"got_climbing_mask"},"&&",{"f()":"got_entertainers_mask"},"&&",{"f()":"got_fishing_mask"},"&&",{"f()":"got_monumental_mask"},"&&",{"f()":"got_sandworm_mask"},"&&",{"f()":"got_scrappers_mask"},"&&",{"f()":"got_beetle_mask"},"&&","/ev","~ret","\n",{"#f":1}],"the_final_mask_content":[{"->":".^.the_gliding_message_from_jadi"},{"the_gliding_message_from_jadi":["ev",{"VAR?":"speaker_jadi"},"/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"THE_GLIDING_LETTER_READ"},{"f()":"activate"},"pop","/ev","\n","^<<\"Ciao, Sable. Riconosci la mia voce?\">>","\n","^Jadi. Il solo suono di lei mi raggiunge il petto e si avvolge calda, accogliente, attorno al cuore.","\n","^<<\"Sto scherzando. Non si scorda mai la voce che ti ha assegnato per la prima volta delle <i>faccende</i>, eh?\">>","\n","^<<\"Spero ti stia godendo il Volo, e che tu stia vedendo il mondo al tuo ritmo. Mi aspetto che ti sia comportata bene durante i viaggi.\">>","\n","^<<\"E spero anche che tu abbia provato a essere un po' birichina!\">>","\n","^<<\"Non <i>scortese</i> o <i>cattiva</i>, ma spero tu abbia piegato qualche regola e conosciuto le piccole gioie dei piccoli segreti furtivi.\">>","\n","^Forse <i>ho</i> piegato qualche regola, una o due volte. O forse mi sono solo <i>sentita</i> come se l'avessi fatto, che probabilmente è la parte migliore dell'essere un po' birichini, in fondo.","\n","^<<\"Sarò breve, Sable, perché anche se il mio cuore potrebbe riversarsi per ore, non voglio che resti là fuori troppo a lungo.\">>","\n","^<<\"Siamo tornati all'Ewer. Tutti noi. Il nostro periodo di pascolo è finito, e siamo esattamente dove ci hai lasciati, anche se credo un po' più tranquilli di quanto fossimo in quegli ultimi giorni.\">>","\n","^<<\"Non c'è assolutamente fretta di tornare, e se ti stai divertendo là fuori, spero tu continui. Il Volo è tuo da prolungare.\">>","\n","^<<\"Ma se e quando sarai pronta, sappi che ti aspettiamo, con braccia che ti accoglieranno qualunque sia la tua decisione.\">>","\n","^<<\"Ora devo andare. Hilal ci sta facendo una piccola lettura di poesie. Scommetto che ti dispiace perdertela, eh?\">>","\n","^<<\"Ci si vede a fine Volo, all'Ewer. Stammi bene.\">>","\n","^La registrazione finisce, ma sussurro comunque un saluto a Jadi come se potesse sentirmi.","\n","^È difficile non sentire l'impulso di andare da lei, da loro, subito. Ma capisco persino dal suo tono che non c'è pressione indebita né speranza mal nascosta.","\n","^Quando sarò pronta a concludere il Volo, tornerò dagli Ibexii.","\n","ev","void","/ev","->->",{"#f":1}],"confirmation":[[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Mentre il campo degli Ibexii si avvicina, la soglia immaginata tra casa e Volo è palpabile.","\n","^Mi ricorda il rientro da una tempesta di sabbia, così feroce che i granelli hanno attraversato l'aria e i vestiti.","\n","^Ti spogli degli strati di tessuto battuti dalla sabbia, e ti meravigli della polvere sulla pelle — i granelli che sono riusciti a passare nonostante ogni precauzione.","\n","^E anche se ti senti così grata di essere a casa, così confortata dalla sicurezza degli interni, non puoi fare a meno di sorridere, nostalgica, mentre lavi via la sabbia.","\n","^Che avventura hai avuto. Ed era solo per te.","\n","^...","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^Sono pronta a scegliere la mia Maschera adesso?","\n","^Non si torna indietro, se lo faccio.","\n","ev","str","^Sono pronta.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non ancora.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Credo di essere pronta.","\n",{"#":"gesture_sable: thinking"},"^Ma... lo sono <i>davvero</i>?","\n",["ev","str","^Sicuramente pronta.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Forse non ancora.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_RETURNED_HOME"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_sable: fist_pump"},"^Sì. Basta dubbi. So cosa voglio. Ed è ora di fare la mia scelta.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Penso che se devo farlo voglio esserne ben sicura. E adesso non lo sono.","\n","^Aspetterò.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non sono ancora del tutto pronta a concludere il Volo. E quando lo sarò, voglio esserne certa.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"jadi":[[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Tornare con gli Ibexii è più confortevole di quanto mi aspettassi. Credo pensassi che il Volo avrebbe cambiato ogni parte di me, e che sarei tornata a casa <i>diversa</i>.","\n","^Forse più matura o più disillusa, o almeno in grado di cogliere di più degli scherzi di Driss o della poesia di Hilal.","\n","^Il vero cambiamento è più sottile. È che, in qualche modo, nonostante abbia passato tanto tempo a scoprire il mondo esterno, non mi sono mai sentita così parte di questo clan.","\n","^E non riguarda l'<i>essere</i> Ibexii, o quale Maschera sceglierò alla fine.","\n","^È semplicemente che non mi sento più tanto indietro rispetto a tutti, o come se conoscessero qualche segreto da grandi che bramo capire. Mi sento... abbracciata. Pienamente, come la persona che sono.","\n","^Sable.","\n","^<<\"Ora abbiamo sentito le tue storie — o almeno quelle che hai voglia di raccontare.\">>","\n","^<<\"Vuol dire che è quasi ora.\">>","\n","^Il sospiro di Jadi è soddisfatto. Sospetto che fosse più preoccupata della mia esperienza del Volo che della grande scelta alla fine.","\n",{"#":"gesture_sable: thanks"},"^Per questo le sono grata.","\n",{"#":"gesture_partner: talking"},"^<<\"Sei pronta a scegliere?\">>","\n",{"#":"gesture_sable: thinking"},"^<i>Lo sono</i>?","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^C'è qualcosa di cui voglio parlare con Jadi?","\n",{"->":".^.^.17"},null],"#f":5}],"\n",["ev","str","^Forse dovrei scegliere la Maschera Ibex.","/str",{"f()":"got_ibex_mask"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Sono pronta a scegliere.","/str",{"VAR?":"THE_GLIDING_READY_TO_CHOOSE"},{"f()":"reached"},"!","/ev",{"*":".^.c-1","flg":5},"ev","str","^Parla con qualcun altro.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: talking"},"^Dico a Jadi che, dopo tutto, sto pensando di scegliere la Maschera Ibex e restare con il clan.","\n",{"#":"gesture_partner: talking"},"^<<\"Saresti ben accetta a restare con noi. So che c'è molta pressione per scegliere qualcos'altro — al punto che a volte sembra <i>noioso</i> scegliere la stessa Maschera con cui hai iniziato.\">>","\n",{"#":"gesture_partner: talking"},"^<<\"Ma siamo stati tutti Glider, una volta, e di certo non eravamo tutti Ibexii all'inizio. Siamo coloro che camminano sulle orme degli zoccoli, e cercano la propria libertà nel deserto.\">>","\n",{"#":"gesture_partner: talking"},"^<<\"Conosciamo il movimento, il flusso della migrazione, la gioia dei cieli che cambiano e delle sabbie che si spostano. Abbracciamo la differenza, celebriamo la connessione, allo stesso tempo. Sono fiera di essere Ibexii.\">>","\n","^<<\"E puoi esserlo anche tu.\">>","\n",{"#":"gesture_sable: thanks"},"^Ringrazio Jadi per averla espressa così bene. Si china per un sussurro:","\n","^<<\"E se non lo sei, puoi sempre venire a trovarci. Non lo dirò.\">>","\n",{"->":".^.^"},{"->":".^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","ev",{"VAR?":"THE_GLIDING_READY_TO_CHOOSE"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_partner: yes"},"^Dico a Jadi che sono pronta. Annuisce.","\n","^<<\"Non ti tratterrò, Sable. Se sai cosa vuoi, tutto ciò che desidero è scoprirlo e celebrarlo con te.\">>","\n","^<<\"Posso essere eccitata anch'io, no?\">>","\n",{"#":"gesture_partner: laugh"},"^Ridacchia.","\n",{"#":"temple_cam"},"^<<\"Quando sei pronta, vai al tempio.\">>","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_sable: talking"},"^Dico a Jadi che parlerò con alcuni degli altri prima di andare al tempio. Mi scaccia con un gesto.","\n","^<<\"Certo, vai!\">>","\n","^<<\"Torna quando sei pronta.\">>","\n",{"->":".^.^.^.g-0"},{"#f":5}],"#f":5,"#n":"choices"}],{"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"driss":[["^<<\"Ciao, Sable.\">>","\n",{"#":"gesture_sable: thinking"},"^C'è qualcosa di cui voglio parlare con Driss?","\n",["ev","str","^Come sta il clan?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Sto pensando di scegliere la Maschera del Rottamatore.","/str",{"f()":"got_scrappers_mask"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Vorrei riesumare l'incidente della Sandcutter.","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Parla con qualcun altro.","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: talking"},"^Chiedo a Driss com'è andata a gestire il clan mentre ero via.","\n","^<<\"Caotico come sempre! Cosa di cui dovresti essere abbastanza contenta!\">>","\n","^Chiedo a Driss perché pensa che lo vorrei per lui.","\n",{"#":"gesture_sable: surprised_1"},"^<<\"Perché significa che non eri tu!\">>","\n",["ev","str","^Cosa non ero io?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Beh certo che non lo ero!","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: talking"},"^Chiedo a Driss cosa intende.","\n",{"#":"gesture_partner: explaining"},"^<<\"Voglio dire che sei partita per il Volo e le cose sono rimaste caotiche come sempre! Il che vuol dire...\">>","\n",{"#":"gesture_sable: arms_crossed"},"^Scelgo <i>di non</i> suggerire che significa che Driss stesso è così sparpagliato che tutto sembrerà <i>sempre</i> caotico. Sono davvero maturata.","\n","^<<\"Non sei tu il problema!\">","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: arms_crossed"},"^Per rispetto, decido di non dire a Driss che è proprio <i>lui</i> al cuore di tanto caos. Mi limito ad affermare con chiarezza che non ero io.","\n",{"#":"gesture_partner: explaining"},"^<<\"Beh, non si sa mai. Sei ancora giovane! E la giovinezza di solito porta con sé la sua dose di caos. O almeno dovrebbe. Comunque, sei proverbialmente fuori dai guai.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Che bello per me.","\n",{"->":".^.^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Dico a Driss che sto considerando la Maschera del Rottamatore, e chiedo cosa ne pensa.","\n",{"#":"gesture_partner: surprised_2"},"^<<\"La Maschera del Rottamatore! Tu? Davvero!\">>","\n","^<<\"Ti dico, Sable, non te l'avrei mai detto, ma hai sempre avuto una bella immaginazione, vero?\">>","\n",["ev","str","^Più un monologo interiore.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Credo di sì!","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Sì, beh, credo sia una buona qualità per un Rottamatore. Devi saper vedere la bellezza nei rottami, capisci? E ci vuole un cervello molto creativo.\">>","\n","^<<\"Credo che molti vedano i Rottamatori e pensino siano solo raccoglitori di spazzatura, sai? Ma se sai guardare a qualcosa di vecchio e immaginare qualcosa di nuovo...\">>","\n","^<<\"Allora hai il talento. E ti sosterrò a ogni rottame del percorso!\">>","\n",{"#":"gesture_sable: thanks"},"^Ringrazio Driss per il consiglio.","\n",{"->":".^.^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_sable: explaining"},"^Chiedo a Driss, una volta per tutte, se in quel fatidico giorno del mio Volo aveva davvero dimenticato di aiutarmi con la hoverbike, e se il 'giro di prova' sulla Sandcutter era un astuto insabbiamento.","\n",{"#":"gesture_partner: thinking"},"^Inclina la testa.","\n","^<<\"Di cosa stai parlando?\">>","\n",["ev","str","^Sai di cosa sto parlando.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non importa.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^\t ","\n",{"#":"gesture_partner: no"},"^Dico a Driss che sa bene di cosa sto parlando, ma scuote la testa.","\n",{"#":"gesture_partner: explaining"},"^<<\"Nessuna idea! Ricordo che la storia della hoverbike è andata liscia. E hai portato fuori la Sandcutter senza nemmeno prendere fuoco un pochino. Roba grandiosa!\">>","\n","^Accetto la risposta di Driss. Suppongo che nemmeno il Volo possa essere la risposta a tutto.","\n",{"->":".^.^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: arms_crossed"},"^Decido di non insistere oltre, e di lasciare che il sospetto resti nel mio cuore e nella mia mente per tutta la vita, per sempre.","\n",{"->":".^.^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-3":["^ ","\n","^<<\"A dopo.\">>","\n",{"->":"END_SCENE"},{"->":".^.^.^.g-0"},{"#f":5}],"#f":5,"#n":"choices"}],{"g-0":[{"->":".^.^.choices"},{"#f":5}]}],{"#f":1}],"hilal":[[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"#":"gesture_partner: greeting"},"^<<\"Oh, Sable! È così bello averti a casa. Ho pensato tanto a te, immaginandomi tutta l'eccitazione!\">>","\n","^<<\"Ogni volta che passavamo accanto a una scogliera, pensavo 'scommetto che Sable starà planando ovunque'.\">>","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^<<\"Come stai, Sable?\">>","\n",{"->":".^.^.17"},null],"#f":5}],"\n",["ev","str","^Cosa pensi della Maschera dell'Arrampicata?","/str",{"f()":"got_climbing_mask"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Hai sentito parlare di Llhor la Favolatrice?","/str",{"VAR?":"LLHOR_FOUND"},{"f()":"reached"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Dovrei aggiornare gli altri.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: talking"},"^Chiedo a Hilal cosa pensa della Maschera dell'Arrampicata. Si illumina subito, cosa che immagino avrei dovuto aspettarmi.","\n","^<<\"Una Maschera <i>splendida</i>. Ce ne sono molte davvero buone, ovviamente, ma l'Arrampicata?\">>","\n","^<<\"Se chiedi a me, la cosa <i>peggiore</i> della fine del Volo è perdere la pietra del Perpetuo. Planare per sempre, non temere altezze né cadute — <i>quella</i> è una libertà rara! E devi rinunciarci!\">>","\n","^<<\"Per me, l'Arrampicata è la cosa più vicina al mantenere quella connessione tra sé e il Perpetuo. Proprio come la pietra, bandisce paura e rischio, ti permette di esplorare i grandi spazi verticali del mondo con conoscenza e fortezza.\">>","\n","^<<\"Credo sia una grande maschera. E sarebbe probabilmente stata la mia scelta, se non mi fossi innamorato così tanto degli Ibexii.\">>","\n",{"#":"gesture_sable: thanks"},"^Ringrazio Hilal per i suoi pensieri, e di nuovo per la pietra che mi ha dato tanto tempo fa.","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: talking"},"^Chiedo a Hilal se ha mai sentito parlare di Llhor la Favolatrice.","\n","^<<\"Oh, certo che l'ho sentita! Non amo molto viaggiare, sai, ma non due anni fa ho fatto un viaggio speciale a Eccria solo per vederla. Perché?\">>","\n","^Dico a Hilal che l'ho incontrata, nel deserto, e che abbiamo passato un'intera serata a parlare di vita e poesia. Aggiungo che credo di aver ispirato del lavoro originale.","\n",{"#":"gesture_partner: surprised_1"},"^<<\"È incredibile! Quindi pensi-- scusa, sono così eccitato!\">>","\n","^<<\"Quindi pensi sia possibile che la prossima volta che vedrò Llhor, lei legga davvero una poesia ispirata da <i>te</i>?\">>","\n",{"#":"gesture_sable: talking"},"^Dico di sì, che è molto possibile.","\n","^<<\"Ora <i>questo</i> sì che è un Volo. Chi se ne <i>frega</i> di che Maschera scegli! Hai planato per il mondo e hai ispirato Llhor la Favolatrice a scrivere una nuova poesia.\">>","\n","^<<\"Se fossi in te, mi metterei la maschera della <i>pensione</i> perché avrei finito!\">>","\n",{"#":"gesture_partner: laugh"},{"#":"gesture_sable: laugh"},"^Ridiamo insieme. E si sta davvero, davvero bene.","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Certo!\">>","\n",{"->":"END_SCENE"},{"->":".^.^.^.g-0"},{"#f":5}],"#f":5,"#n":"choices"}],{"g-0":[{"->":".^.^.choices"},{"#f":5}]}],{"#f":1}],"sizo":[[{"#":"gesture_sable: greeting"},"^Saluto Sizo.","\n",{"#":"gesture_partner: greeting"},"^<<\"Come stai, figlia del clan?\">>","\n",["ev","str","^Parla di Simoon.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ho incontrato molti dei tuoi amici Macchinisti!","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Pensi che dovrei scegliere la Maschera del Macchinista?","/str",{"f()":"got_machinist_mask"},"/ev",{"*":".^.c-2","flg":5},"ev","str","^Parla con qualcun altro.","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^ ","\n","^<<\"Com'è stata la tua compagna?\">>","\n",["ev","str","^Un volo fluido.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Abbiamo avuto qualche momento difficile.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Sarei stata sola senza Simoon.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^<<\"Felice di sentirlo. Simoon ha accompagnato e si è presa cura di generazioni di Ibexii, Jadi stessa cavalcò Simoon fino al Redsee durante il suo Volo.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Il segno di un rapporto forte è tornare tutta intera. Simoon deve essersi presa buona cura di te.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Certo, il deserto può essere un luogo desolato e rado. Viaggiare con una compagna è l'unico modo per mantenere la mente in pace.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev","str","^Che ne sarà di Simoon ora?","/str","/ev",{"*":".^.c-3","flg":4},{"c-3":["^ ","\n","^<<\"Beh, è quasi ora del Volo di Saima. Simoon probabilmente l'accompagnerà tra le dune.\">>","\n","^Sento una fitta di malinconia al pensiero di perdere Simoon. Doveva succedere un giorno: nessuno possiede davvero una hoverbike tra gli Ibexii, ne è semplicemente accompagnato. Sono grata di aver almeno avuto quella benedizione.","\n",{"->":".^.^.^.^.^.^.g-0"},{"#f":5}],"#f":5}]}],{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: talking"},"^Dico a Sizo che ho incontrato molti suoi amici durante i viaggi.","\n","^<<\"Lo so, e spero siano stati buoni con te e con Simoon.\">>","\n","^Le dico di sì e sembra trarne un po' di orgoglio, cosa rara da vedere in Sizo.","\n","^<<\"Alcuni Macchinisti davvero in gamba là fuori. Mi piacciono molto.\">>","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_sable: talking"},"^Chiedo se Sizo pensa che dovrei scegliere la Maschera del Macchinista, per unirmi al suo ordine. Incrocia le braccia e si prende del tempo per pensare.","\n",{"#":"gesture_partner: thinking"},"^<<\"Alcuni... ti diranno che la vita di un Macchinista è solitaria.\">>","\n",{"#":"gesture_partner: talking"},"^<<\"Non lo è. E non solo perché siamo assegnati ai clan, che spesso ci accolgono tra loro. No, è... è di più. È perché non siamo mai davvero soli.\">>","\n","^<<\"Come tu non sei mai stata davvero sola durante il Volo. Sei andata con Simoon.\">>","\n",{"#":"gesture_sable: thinking"},"^Penso ai momenti in cui sedevo guardando una mappa, o riparandomi dal maltempo, o cercando di superare un attacco improvviso di nostalgia fortissima, e Simoon emetteva un lieve ronzio che sentivo salire dalle gambe.","\n","^<<\"Hai una hoverbike molto speciale, Sable.\">>","\n",{"#":"gesture_sable: yes"},{"#":"gesture_partner: yes"},"^Annuisco insieme a Sizo.","\n","^<<\"Mentre tornavi, ero seduta sulla torre e ho sentito il fusa di Simoon crescere fino al ruggito, e in esso le tracce di coloro il cui lavoro ha contribuito a darle forma. Parla con molte voci, ora, e quella risonanza...\">>","\n","^Sizo sembra rabbrividire.","\n","^<<\"È per questo che facciamo ciò che facciamo.\">>","\n","^<<\"Quindi se questo ti attrae, allora... posso solo consigliartelo.\">>","\n",{"#":"gesture_sable: thanks"},"^Ringrazio Sizo per il suo consiglio.","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-3":["^ ","\n","^<<\"Addio.\">>","\n",{"->":"END_SCENE"},{"->":".^.^.^.g-0"},{"#f":5}],"#f":5,"#n":"choices"}],{"g-0":[{"->":".^.^.choices"},{"#f":5}]}],{"#f":1}],"saima":[[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^<<\"Quindi sei tornata.\">>","\n",{"#":"gesture_partner: arms_crossed"},"^Saima incrocia le braccia. Una sfida.","\n",{"#":"gesture_sable: explaining"},"^Dico a Saima che ho dovuto tornare perché quando sono partita, una <i>pesticciola</i> minuscola che caccia scarabei e ruba pezzi ha fatto un capriccio e non riusciva a smettere di piangere perché le mancavo tantissimo.","\n","^Annuisce.","\n",{"#":"gesture_partner: yes"},"^<<\"Sì, Jadi l'ha presa malissimo!\">>","\n",{"#":"gesture_sable: laugh"},"^Non posso farne a meno. Rido, e così facendo credo di lasciarla vincere. Le dico che mi è mancata.","\n","^<<\"Mi sei mancata anche tu, Sable! Sono felice che tu sia tornata.\">>","\n","^Anche se quasi vedo il broncio sotto la maschera, sono colpita da quanto riesca a suonare autentica:","\n","^<<\"Anche se finisci per non restare a lungo.\">>","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Fa piacere rivedere Saima.","\n",{"->":".^.^.17"},null],"#f":5}],"\n",["ev","str","^Piangerai se me ne vado di nuovo?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Sto pensando di scegliere la Maschera dello Scarabeo!","/str",{"f()":"got_beetle_mask"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Parla con qualcun altro.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: talking"},"^Chiedo a Saima se piangerà di nuovo se me ne vado.","\n","^<<\"Non credo. Per due ragioni!\">>","\n","^Le conta sulle dita.","\n",{"#":"gesture_partner: talking"},"^<<\"Uno: è già successo una volta quindi ora ci sono abituata.\">>","\n",{"#":"gesture_partner: fist_pump"},"^<<\"Due: presto sarà il <i>mio</i> Volo e ci resterò per sempre! Così potrò prendere la <i>mia</i> hoverbike e darti la caccia ovunque vai.\">>","\n",{"#":"gesture_sable: talking"},"^Dico a Saima che non può restare in Volo per sempre, e che dovrà scegliere una maschera.","\n",{"#":"gesture_partner: fist_pump"},"^<<\"Allora sceglierò la Maschera del <i>Cacciatore di Taglie</i>.\">>","\n",{"#":"gesture_sable: talking"},"^Dico che quella non è una Maschera vera.","\n",{"#":"gesture_partner: yes"},"^<<\"Sì che lo è.\">>","\n",{"#":"gesture_sable: no"},"^Dico che non lo è.","\n","^Fa spallucce.","\n",{"#":"gesture_partner: uninterested"},"^<<\"Significa che non l'hai trovata.\">>","\n",{"#":"gesture_sable: explaining"},"^Le dico <i>no</i>, non è vera. E che se fosse vera l'<i>avrei</i> trovata.","\n",{"#":"gesture_partner: arms_crossed"},"^<<\"Non credo. È molto difficile da trovare. Fa parte del gioco. Per diventare un Cacciatore devi <i>essere</i> un Cacciatore.\">>","\n",{"#":"gesture_sable: arms_crossed"},"^Preparo la mia prossima risposta, ma scelgo di trattenere la lingua per non perdere la maturità conquistata durante il Volo.","\n","^Saima fa un grande gesto che penso voglia imitare l'incoccare una freccia in un arco.","\n","^<<\"Buona fortuna, Sable.\">>","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: talking"},"^Chiedo a Saima cosa penserebbe se scegliessi la Maschera dello Scarabeo.","\n",{"#":"gesture_saima: arms_crossed"},"^<<\"Credo sembreresti piuttosto buffa.\">>","\n",{"#":"gesture_sable: laugh"},"^<<\"Ma sembreresti buffa in ogni maschera.\">>","\n","^Bene, mi piace. Lei mi è mancata di sicuro.","\n","^<<\"Penso... penso sarebbe come poter giocare tutto il tempo, e avere tanti animaletti. E forse potresti parlare la <i>lingua degli scarabei</i>!\">>","\n","^<<\"Vedo sempre gli scarabei avvicinarsi tra loro e fare balletti e ticchettare e sibilare e forse si stanno dicendo qualcosa.\">>","\n","^<<\"Quindi se vuoi parlare scarabeo, potresti farlo.\">>","\n",{"#":"gesture_partner: uninterested"},"^Fa spallucce.","\n","^<<\"Non so. Tutte le Maschere sono diverse e non importerà più, una volta che sarò in Volo e potrò venire a trovarti.\">>","\n",{"#":"gesture_sable: thinking"},"^Chiedo a Saima se intende venire a <i>importunarmi</i>.","\n","^<<\"Se ti dà fastidio, è un problema tuo. Ma io verrò a trovarti.\">>","\n",{"#":"gesture_sable: laugh"},"^Non posso fare a meno di ridere. Le dico che non vedo l'ora.","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Allora ciao.\">>","\n",{"->":"END_SCENE"},{"->":".^.^.^.g-0"},{"#f":5}],"#f":5,"#n":"choices"}],{"g-0":[{"->":".^.^.choices"},{"#f":5}]}],{"#f":1}],"elaria":[[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^<<\"Ehi Sable!\">>","\n","^È strano come i bambini cambino tanto in così poco tempo. Elaria è cresciuta, ma per me sarà sempre una bambina.","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Saluto Elaria.","\n",{"->":".^.^.17"},null],"#f":5}],"\n",["ev","str","^Sei cresciuta!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ho scalato molto là fuori.","/str",{"f()":"got_climbing_mask"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Parla con qualcun altro.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Elaria, inconsciamente, si raddrizza un po' più alta e fiera mentre lo dico, e non posso fare a meno di sorridere ricordando tutte le volte che gli adulti mi dicevano 'Oh come sei cresciuta!' da bambina.","\n","^<<\"Beh tu non sei cresciuta per niente.\">>","\n","^<<\"Non sono solo cresciuta, ora arrampico moooolto più in alto.\">>","\n","^<<\"Zeki la odia! È fantastico!\">>","\n",["ev","str","^Non tutta la crescita è esterna.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ci arriverai presto.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Sembra una frase vuota e difensiva, ma è anche vera. Elaria non sembra convinta.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Elaria non sembra impressionata.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Saima partirà presto per il suo Volo, ma almeno tu sarai tornata adesso!\">>","\n","^Non ho il cuore di dirle che potrei non restare con gli Ibexii. C'è ancora tempo per decidere, quindi mi trattengo.","\n",{"->":".^.^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^<<\"Oh!\">>","\n","^<<\"Quanto in alto sei salita?!\">>","\n","^<<\"Hai toccato una nuvola?\">>","\n","^<<\"Se avessi una Pietra del Volo, di sicuro toccherei una nuvola.\">>","\n","^Rivelo di aver ottenuto la Maschera dell'Arrampicata. Elaria sembra vibrare di eccitazione e gelosia.","\n","^<<\"Non ci credo!\">>","\n","^<<\"Devi sceglierla!\">>","\n","^<<\"La sceglierai vero?!\">>","\n","^<<\"Cioè, perché non dovresti? Sarebbe solo stupido...\">>","\n","^Non credo riuscirò a infilare una parola, quindi lascio che Elaria mi parli addosso effusivamente per un po', godendomi la sua passione per qualcosa di così particolare.","\n","^Essere una scalatrice è un'esistenza piuttosto solitaria per la maggior parte. Soprattutto raccogliere cose che crescono in alta quota, riparare o recuperare cose dalle navi in luoghi elevati.","\n","^Ma i panorami che vedi, i luoghi in cui arrivi — sarà come un Volo continuo a tratti.","\n","^Sarò a mio agio a quelle altezze senza la Pietra del Volo?","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Ciao!\">>","\n",{"->":"END_SCENE"},{"->":".^.^.^.g-0"},{"#f":5}],"#f":5,"#n":"choices"}],{"g-0":[{"->":".^.^.choices"},{"#f":5}]}],{"#f":1}],"zeki":[[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^<<\"Bambina mia, bentornata a casa.\">>","\n","^<<\"Ti sei presa cura di te? Sembri piuttosto magrolina. Stai bene?\">>","\n","^Zeki si preoccupa per me. Trovava sempre motivi per prendersi cura di noi.","\n","^<<\"Non va bene per niente, per niente. Dovremo rimetterti in sesto con un po' di stufato d'agnello di Jadi.\">>","\n","^Mi sta venendo l'acquolina solo al pensiero.","\n","^È bello essere tornata.","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Zeki mi saluta calorosamente.","\n",{"->":".^.^.17"},null],"#f":5}],"\n",["ev","str","^Dove sei stata?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Potrei scegliere la Maschera dell'Intrattenitore.","/str",{"f()":"got_entertainers_mask"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Parla con qualcun altro.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^<<\"Dopo che sei partita siamo andati in alcuni vecchi siti di accampamento Ibexii — posti che usavamo prima che tu nascessi!\">>","\n","^<<\"Tornarci è stato meraviglioso. La terra fiorisce se la lasci per così tanto. Ogni posto, trasformato dalla vita e abbondante di cose da raccogliere da quando eravamo lì.\">>","\n","^<<\"Una volta lasciato l'Ewer, non torneremo per molto tempo. Ha bisogno di tempo per riprendersi dal nutrirci.\">>","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Oh, una Maschera dell'Intrattenitore — vedo che sei stata tenuta impegnata con i piccoli anche durante il Volo.\">>","\n","^<<\"Tutti hanno bisogno di un po' di leggerezza ogni tanto, è una parte importante della vita, apprezzata da molti.\">>","\n","^<<\"Ma sai che gli Ibexii non sono in posizione di accogliere tali frivolezze, divertimento e giochi sono solo questo. Se scegli questa maschera, dovrai trovare un clan più ricco a cui unirti, non possiamo permettercelo.\">>","\n","^<<\"Spero ci pensi bene a quale maschera scegli, Sable.\">>","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Buona fortuna, Sable.\">>","\n",{"->":"END_SCENE"},{"->":".^.^.^.g-0"},{"#f":5}],"#f":5,"#n":"choices"}],{"g-0":[{"->":".^.^.choices"},{"#f":5}]}],{"#f":1}],"umar":[[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^<<\"Bentornata.\">>","\n","^Non ricordo l'ultima volta che ho sentito Umar parlare. Magari per gridare un avvertimento, ma mai per conversare. Mi ci vuole un attimo per pensare a una risposta.","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Umar mi saluta in silenzio.","\n",{"->":".^.^.17"},null],"#f":5}],"\n",["ev","str","^Come stai?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ti sono mancata?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Parla con qualcun altro.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Umar fa spallucce in silenzio. Credo sia tutto quello che otterrò da lui in proposito.","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Emette un grugnito basso e qualcosa che sembra una risata. Credo significhi che gli sono mancata.","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^Umar inchina leggermente il capo.","\n",{"->":"END_SCENE"},{"->":".^.^.^.g-0"},{"#f":5}],"#f":5,"#n":"choices"}],{"g-0":[{"->":".^.^.choices"},{"#f":5}]}],{"#f":1}],"choose_entertainer":[["^L'intrattenimento è per me?","\n","ev","str","^Decisamente!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Portare sorrisi sui volti, gioia e intrattenimento — cos'è la vita senza queste cose?","\n","^Potrei diventare una bardessa, o una favolatrice, o qualunque tipo di artista.","\n","^L'unica cosa che non potrò fare è restare con gli Ibexii. Sebbene l'intrattenimento sia cruciale per molti, non è considerato essenziale per il modo in cui viviamo.","\n","^Mi sosterrebbero se scegliessi questa strada? Sarebbero fieri? Forse preferirebbero una Macchinista o una Guardia...","\n","^Alla fine, devo scegliere per me.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^È questo che voglio?","\n",["ev","str","^Sì. Sono sicura.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No. Non ancora.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^A volte devi fare scelte per te stessa.","\n","^Spero capiscano.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_machinist":[["^Potrei essere una Macchinista?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Penso a Sizo, e a tutti i sussurratori di macchine che ho incontrato lungo la strada.","\n","^Sono così diversi, così unici e disparati, ma uniti dalla conoscenza, dall'appartenenza al clan e da una indefinita connessione con il mondo.","\n","^Ho amato l'indipendenza del Volo. E altrettanto ho amato incontrare nuove persone nel deserto, imparare un po' di loro prima di proseguire.","\n","^E di sicuro ho amato Simoon, e ogni tarda notte che ho passato rannicchiata al suo fianco. Ho amato il suo suono e la fluidità della sua guida.","\n","^Ho amato il suo senso dell'umorismo, che...","\n","^...mi rendo conto all'improvviso di non aver mai considerato prima.","\n","^E di certo non riesco a capire perché mi sia venuto in mente, a proposito di una hoverbike che non ha mai prodotto altro che <i>suoni</i>.","\n","^Ma lo sento.","\n","^O forse è solo la Maschera.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^Sono sicura?","\n",["ev","str","^Sì. Sono sicura.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No. Non ancora.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Indosso la Maschera del Macchinista.","\n","^Sa di acciaio e petricore.","\n","^E la adoro.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_guard":[["^La Maschera della Guardia mi guarda, e ricordo Eliisabet.","\n","^Potrei essere una Guardia?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Eliisabet era <i>pericolosa</i> e <i>audace</i>.","\n","^Non mi ha mai mostrato davvero quel lato di sé, ma con tutta la sua risata e luminosità, il suo charm umile, era evidente che si portava con una sicurezza che posso solo invidiare.","\n","^E so che è nata dal suo lavoro.","\n","^Potrei facilmente immaginare che Eliisabet avesse dato indicazioni e consigli gentili ai viaggiatori stanchi di Eccria.","\n","^Potrei vederla accompagnare bambini a casa, aiutarli a trovare i tutori o gli amici, o curare un ginocchio sbucciato.","\n","^E sapevo solo parlando con lei che era esperta nel parlare con ragione e pazienza, e nell'aiutare prima di ferire.","\n","^Ma sentivo anche il suo potere, e le cose che sarebbe stata disposta a fare per tenere al sicuro la sua gente.","\n","^Essere una guardia — una buona — non vuol dire amare la violenza né il conflitto, ma sapere che a volte sono necessari per proteggere chi ne ha più bisogno.","\n","^Ci deve essere ferocia nel lavoro, e ferocia nel cuore.","\n","^Potrei tenere quelle due cose in equilibrio, anche solo per metà bene come lei?","\n","^E se posso, è quella la strada che voglio percorrere? Dovrei diventare una Guardia?","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Sono sicura?","\n",{"->":".^.^.17"},null],"#f":5}],"\n",["ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Indosso la Maschera della Guardia.","\n","^Peccato che non lavorerò con Eliisabet... ma non vedo l'ora di rivederla.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_shade":[["^Voglio scegliere la Maschera dell'Ombra di Eccria?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^La più grande conoscenza che ho ricevuto durante il Volo non è venuta da una singola persona, ma da tutte loro.","\n","^Ed è che non c'è compito più nobile, e in verità nulla di più vitale al mondo, che <i>aiutare le persone</i>.","\n","^Oltre qualsiasi macchinazione ed economia che mantiene il delicato equilibrio e la struttura delle nostre vite, sostegno, gentilezza ed empatia devono essere al centro.","\n","^L'Ombra di Eccria toglie via tutto il resto.","\n","^L'Ombra cerca solo di raddrizzare i torti e aiutare chi ha bisogno. Cercano di cambiare il mondo in meglio <i>essendo</i> migliori. Fanno la differenza — reale e tangibile!","\n","^E vivono al di fuori di tutto il resto.","\n","^Maz ha percorso quella strada. E per di più con grazia... finché non ha trovato una nuova vocazione ed è stato costretto a mettere da parte l'Ombra.","\n","^Forse dovrei raccoglierla io?","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Sono sicura?","\n",{"->":".^.^.17"},null],"#f":5}],"\n",["ev","str","^Sì. Credo di sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No, non credo.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Raccolgo la Maschera dell'Ombra.","\n","^Non so come lo spiegherò a Jadi...","\n","^Ma sospetto capirà.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Ho fatto la mia scelta.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_chum":[["^Voglio scegliere la Maschera del Chum?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",["ev","visit",0,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"nop",{"s0":["pop","\n","^Una maschera insolita, non l'ho vista indossata da nessun altro. Mi sentirei certamente speciale indossandola mentre attraverso le dune raccogliendo sempre più chum per la Regina.","\n","^È il genere di cosa che gli altri capirebbero? O sarei un caso a parte, una strana ossessionata che insegue creature elusive e misteriose per un'antica creatura telepatica?","\n","^Dubito di certo che gli Ibexii sarebbero felici di accogliermi mentre vago in giro raccogliendo cose inutili.","\n","^Ma quando ripenso alla sensazione di riportare le piccole creature al loro covo, alle loro faccette gioiose che danzano e alla madre felice che si prende cura di loro, non posso fare a meno di sentire che forse questo mi darebbe un qualche senso più grande.","\n",{"->":".^.^.11"},null],"#f":5}],"\n","^È questo che voglio?","\n",["ev","str","^Sì. Credo di sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No, non credo.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Sento un fremito di eccitazione al pensiero di raccogliere ancora dozzine di uova tra le braccia, di vedere la gioia della Regina Chum mentre le riporto al loro covo.","\n","^Non si torna indietro adesso.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_ibex":[["^Voglio scegliere la Maschera Ibex?","\n","^Sarei più felice restando qui, con gli Ibexii?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Come potrei andare altrove, quando tutto ciò che voglio è qui?","\n","^Il Volo è libertà, e mille piccoli momenti con cento persone diverse, ma è anche solitario. E il viaggio vale davvero solo quanto coloro con cui viaggi.","\n","^Voglio percorrere la strada dell'Ibex, e voglio farlo con Jadi.","\n","^Con Driss.","\n","^Con Hilal, e Sizo...","\n","^...","\n","^...","\n","^E sì, anche con Saima.","\n","^È facile abituarsi a un posto e smettere di vederne la gioia. O immaginarsi gettati in una vita così noiosa da non valere la pena di essere esplorata oltre. Ma andare nel mondo esterno mi ha fatto amare di più quello piccolo che ho qui.","\n","^Non sarò solo Sable. Sarò Ibexii.","\n","^E ne sarò fiera.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^Credo sia quello che voglio.","\n",["ev","str","^Sì. È questo.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ripensandoci...","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Indosso la maschera degli Ibexii.","\n","^Calza alla perfezione.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_atomic":[["^Voglio scegliere la Maschera Atomica?","\n","^Lato negativo, potrei essere in ritardo di qualche centinaio d'anni per il lavoro.","\n","^Ma lato positivo... ci sto <i>davvero</i> bene.","\n","^Comunque, probabilmente non basta a trasformarsi in un'intera <i>vocazione</i>. Dovrei davvero scegliere questa Maschera?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Sono sicura?","\n",["ev","str","^Sì. Credo di sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ripensandoci...","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Raccolgo la Maschera Atomica.","\n","^Immagino dovrò tracciarmi il sentiero da sola, i dettagli li capirò dopo.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":"END_SCENE"},{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_wyrm":[[["^Ecco cosa so della Maschera del Sandwyrm.","\n","^Uno: l'ultimo a indossarla è morto.","\n","^Due: l'ho trovata in una grotta puzzolente vicino al corpo del suo creatore impazzito.","\n","^Tre: pare sia fatta della carne di cuccioli di wyrm.","\n","^È questa la Maschera che voglio scegliere?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Sono sicura?","\n",["ev","str","^Sì. Credo di sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ripensandoci...","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Raccolgo la Maschera del Wyrm.","\n","^...","\n","^Non sono del tutto sicura di cosa stia pensando, ma... sono certa di poter trovare qualche motivo per indossare una cosa così orribile...","\n",{"->":".^.^.^.^.^.g-1"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.^.g-1"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":"END_SCENE"},{"->":".^.^.^.g-1"},{"#f":5}],"#f":5,"#n":"g-0"}],{"g-1":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_scrapper":[["^Voglio scegliere la Maschera del Rottamatore?","\n","^Potrei vedermi là fuori, a trovare tesori tra le rovine?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Prima del Volo, c'erano così tante cose che non avevo mai visto. La maggior parte delle persone con cui avevo passato tempo vero erano Ibexii, come me, e fuori da questo c'erano viaggiatori e brevi visite, scambi o momenti fugaci di connessione.","\n","^La mia mente, prima di partire, era una tavola bianca.","\n","^Ora, da momenti disparati e incontri fugaci e piccole amicizie strette tra le sabbie, c'è tanto, tanto <i>di più</i> dentro. Tanti ricordi e idee e piccole creatività, un tutto fatto di pezzi.","\n","^E cos'è un Rottamatore, se non chi sa vedere il valore di ogni pezzo, e creare <i>qualcosa</i> da ciò che a prima vista sembra niente?","\n","^Voglio vedere le cose vecchie, le cose noiose, e trasformarle in ispirazione. Voglio vedere i frammenti dimenticati della storia, e usarli per costruire un futuro.","\n","^Voglio setacciare via la sabbia e vedere cosa c'è sotto.","\n","^Credo di voler essere una Rottamatrice.","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Sono sicura?","\n",{"->":".^.^.17"},null],"#f":5}],"\n",["ev","str","^Sì. È così.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^In realtà... forse no.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Indosso la Maschera del Rottamatore, e passo le mani sul suo volto.","\n","^Ricordo i distintivi che era prima.","\n","^E guardo con speranza alla vita che costruirò.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_climber":[["^Voglio scegliere la Maschera dell'Arrampicata?","\n","^Riesco a immaginare una vita di altezze così grandi?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Come le bestie che ci hanno dato il nome, gli Ibexii non sono estranei alle altezze né alle semplici scalate. Troppo spesso uno di noi ha dovuto inseguire un ibex errante su una scogliera meglio che poteva, aggrappato a piccole rocce sotto e chiamandolo speranzoso.","\n","^Ma quelle sono scalate diverse, così pratiche da risultare noiose. La vita di una Scalatrice, invece... è qualcosa di tanto <i>più</i>.","\n","^La pietra del Volo è un dono temporaneo. È pensata come guscio protettivo, per permettere alle Glider di fare qualche errore e avere qualche incidente mentre esplorano per la prima volta. Ma ci concede anche la capacità di <i>scalare</i> senza paura, e di assaporare il trionfo di una montagna ben scalata... e vedere il mondo in una nuova luce.","\n","^Il deserto è più grande di quanto avrei mai potuto immaginare. E anche se questo è sempre sembrato vero attraverso l'orizzonte, vederlo stendersi davanti a me dalla cima di una grande scogliera è stata un'esperienza completamente diversa.","\n","^Una che non sono contenta di abbandonare con la pietra.","\n","^Se indossassi la Maschera dell'Arrampicata, non sarebbe semplicemente per aiutare in tutti i compiti che richiedono di scalare — anche se ovviamente sarei felice di renderlo il mio dovere.","\n","^Piuttosto, se scelgo questa Maschera, è perché il Volo mi ha mostrato cosa desidera il mio cuore, e sono pronta al lavoro che serve per ottenerlo, senza aiuto.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^Credo sia quello che voglio?","\n",["ev","str","^Sì. È così.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^In realtà... forse no.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Prendo la Maschera dell'Arrampicata, e guardo nei suoi occhi vuoti.","\n","^Non vedo l'ora di vedere il mondo insieme.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_merchant":[["^Voglio scegliere la Maschera del Mercante?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Una Mercante. I Mercanti davvero di successo sono in costante movimento, scambiano beni rari e di valore tra clan, nomadi e cittadini.","\n","^Probabilmente sarei in grado di portare ricchezza e valore agli Ibexii, ma i giorni in cui godermi ciò che porta sarebbero pochi e radi.","\n","^Se volessi essere una Mercante efficace, la maggior parte dei giorni li passerei lontano dal clan. Incontrerei molte persone, la solitudine non sarebbe un problema, ma sarei transitoria in un mondo di sabbie mutevoli.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^È questo che voglio?","\n",["ev","str","^Sì. È così.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^In realtà... forse no.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Prendo la Maschera del Mercante.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_beetle":[["^Voglio scegliere la Maschera dello Scarabeo?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Gli scarabei sono incredibili. Creature ingegnose, resistenti, bellissime. Gioielli delle dune.","\n","^Prendere la maschera dello Scarabeo vorrebbe dire lasciare gli Ibexii per sempre e fare apprendistato a una Beetle Station, imparare i modi dell'ospitalità nomade mentre studio gli scarabei sul campo.","\n","^Accudire viaggiatori stanchi, incontrare ogni sorta di nomadi da tutto il mondo. Mi vedo distrarmi dai doveri quotidiani solo per ascoltare i loro racconti.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^È questo che voglio?","\n",["ev","str","^Sì. È così.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^In realtà... forse no.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Prendo la Maschera dello Scarabeo.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_cartographer":[["^Voglio scegliere la Maschera del Cartografo?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Ho scalato altezze incredibili da Glider, ma immagina il brivido di pilotare la mia mongolfiera! Le pure distanze che percorrerei, la prospettiva unica che avrei, guardando dall'alto persone planare nel deserto come piccoli scarabei tra le sabbie.","\n","^Sono certa ci siano ancora molti posti da mappare, storie da scoprire e annotare. Antiche città non ancora riportate alla luce dalle sabbie da rilevare, e paesaggi inimmaginabili ancora da scoprire.","\n","^Nonostante questo, non sono in molti a scegliere di diventare Cartografi. Si lascia molto dietro quando si sta tra le nuvole, immagino.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^Credo sia quello che voglio?","\n",["ev","str","^Sì. È così.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^In realtà... forse no.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Prendo la Maschera del Cartografo.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"choose_angler":[["^Voglio scegliere la Maschera del Pescatore?","\n","ev","str","^Sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Quando ripenso ai momenti sulle creste delle dune, gli occhi a seguire il dolce dondolio dell'esca, riesco a immaginare solo serenità.","\n","^Brezze leggere, il ronzio attenuato dei grilli e il sibilare delle sabbie mutevoli.","\n","^Poi... quello strappo improvviso e l'esplosione d'azione. La scossa esaltante di adrenalina mentre comincia la battaglia di astuzia e forza.","\n","^Quell'equilibrio tra pazienza e azione, c'è poco altro che ci si avvicini.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^Sono sicura sia ciò che voglio?","\n",["ev","str","^Sì. È così.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^In realtà... forse no.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"THE_GLIDING_CHOSEN_MASK"},{"f()":"activate"},"pop","/ev","\n","^Prendo la Maschera del Pescatore.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^Non credo.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"#f":1}],"the_gliding_quest_definition":[{"#":"name"},"^Il Volo","\n",{"#":"locations"},"^ibex_camp, mask_chamber","\n",{"#":"items"},"ev","str","^IbexiiSetMask","/str","out","/ev","^, ","ev","str","^EngineerSetHelmet","/str","out","/ev","^, ","ev","str","^GuardMask","/str","out","/ev","^, ","ev","str","^ShadeOfEccriaMask","/str","out","/ev","^, ","ev","str","^AtomicSuitHelmet","/str","out","/ev","^, ","ev","str","^ClimbingSetMask","/str","out","/ev","^, ","ev","str","^EntertainersMask","/str","out","/ev","^, ","ev","str","^FishingSetMask","/str","out","/ev","^, ","ev","str","^Monumental_Mask","/str","out","/ev","^, ","ev","str","^SandwormMask","/str","out","/ev","^, ","ev","str","^ScrappersMask","/str","out","/ev","^, ","ev","str","^HerculesBeetleMask","/str","out","/ev","^, ","ev","str","^ParasiteBeetleMask","/str","out","/ev","^, ","ev","str","^SlicerBeetleMask","/str","out","/ev","^, ","ev","str","^ChumMask","/str","out","/ev","^, ","ev","str","^CartographersMask","/str","out","/ev","\n",{"#":"status"},["ev",{"VAR?":"THE_GLIDING_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.122"},null]}],[{"->":".^.b"},{"b":["\n","^active","\n",{"->":".^.^.^.122"},null]}],"nop","\n","ev",{"f()":"got_ibex_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho ricevuto la Maschera Ibex dal Tempio di Rohana.","\n",{"->":".^.^.^.128"},null]}],"nop","\n","ev",{"f()":"got_machinist_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho ricevuto la Maschera del Macchinista dal Forgiatore di Maschere.","\n",{"->":".^.^.^.134"},null]}],"nop","\n","ev",{"f()":"got_guard_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho ricevuto la Maschera della Guardia dal Forgiatore di Maschere.","\n",{"->":".^.^.^.140"},null]}],"nop","\n","ev",{"f()":"got_shade_of_eccria_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato la Maschera dell'Ombra di Eccria nascosta in una grotta.","\n",{"->":".^.^.^.146"},null]}],"nop","\n","ev",{"f()":"got_atomic_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sarin mi ha dato la Maschera Atomica alla Whale.","\n",{"->":".^.^.^.152"},null]}],"nop","\n","ev",{"f()":"got_climbing_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho ricevuto la Maschera dell'Arrampicata dal Forgiatore di Maschere.","\n",{"->":".^.^.^.158"},null]}],"nop","\n","ev",{"f()":"got_entertainers_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho ricevuto la Maschera dell'Intrattenitore dal Forgiatore di Maschere.","\n",{"->":".^.^.^.164"},null]}],"nop","\n","ev",{"f()":"got_fishing_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho ricevuto la Maschera del Pescatore dal Forgiatore di Maschere.","\n",{"->":".^.^.^.170"},null]}],"nop","\n","ev",{"f()":"got_monumental_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato la Maschera Monumentale dentro un vecchio santuario.","\n",{"->":".^.^.^.176"},null]}],"nop","\n","ev",{"f()":"got_sandworm_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato la Maschera del Sandwyrm dentro il Wyrm.","\n",{"->":".^.^.^.182"},null]}],"nop","\n","ev",{"f()":"got_scrappers_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho ricevuto la Maschera del Rottamatore dal Forgiatore di Maschere.","\n",{"->":".^.^.^.188"},null]}],"nop","\n","ev",{"f()":"got_beetle_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho ricevuto una Maschera dello Scarabeo dal Forgiatore di Maschere.","\n",{"->":".^.^.^.194"},null]}],"nop","\n","ev",{"f()":"got_cartographers_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho ricevuto una Maschera del Cartografo dal Forgiatore di Maschere.","\n",{"->":".^.^.^.200"},null]}],"nop","\n","ev",{"f()":"got_chum_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho ricevuto una Maschera del Chum dalla Regina Chum.","\n",{"->":".^.^.^.206"},null]}],"nop","\n","ev",{"f()":"got_merchants_mask"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho ricevuto la Maschera del Mercante dal Forgiatore di Maschere.","\n",{"->":".^.^.^.212"},null]}],"nop","\n","ev",{"f()":"collected_enough_masks_to_finish_the_game"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Dovrei raccogliere altre maschere durante il mio Volo.","\n",{"->":".^.^.^.219"},null]}],"nop","\n","ev",{"f()":"collected_enough_masks_to_finish_the_game"},{"VAR?":"THE_GLIDING_LETTER_READ"},{"f()":"reached"},"!","&&","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Dovrei controllare una cassetta postale per vedere se Jadi mi ha mandato un messaggio.","\n",{"->":".^.^.^.229"},null]}],"nop","\n","ev",{"VAR?":"THE_GLIDING_LETTER_READ"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho ricevuto una lettera da Jadi. Ha detto che il clan è tornato dal pascolo e ha allestito il campo nel canyon.","\n",{"->":".^.^.^.236"},null]}],"nop","\n","ev",{"VAR?":"THE_GLIDING_LETTER_READ"},{"VAR?":"THE_GLIDING_RETURNED_HOME"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: ibex_camp"},"^Quando sarò pronta a concludere il mio Volo, dovrei tornare al clan all'Ewer.","\n",{"->":".^.^.^.244"},null]}],"nop","\n","ev",{"VAR?":"THE_GLIDING_RETURNED_HOME"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sono tornata al clan.","\n",{"->":".^.^.^.251"},null]}],"nop","\n","ev",{"VAR?":"THE_GLIDING_RETURNED_HOME"},{"VAR?":"THE_GLIDING_READY_TO_CHOOSE"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Dovrei parlare con Jadi quando sono pronta per la Cerimonia della Scelta.","\n",{"->":".^.^.^.259"},null]}],"nop","\n","ev",{"VAR?":"THE_GLIDING_READY_TO_CHOOSE"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: mask_chamber"},"^Dovrei andare al Tempio di Rohana e scegliere la mia maschera.","\n",{"->":".^.^.^.266"},null]}],"nop","\n","end",{"#f":1}],"eccria_water_fountain":["^Una fontana d'acqua che scorre attraverso la città. Un'evidente dimostrazione di ricchezza opulenta — non ho mai visto tanta acqua usata così frivolmente.","\n",{"->":"END_SCENE"},{"#f":1}],"eccria_workshop_shrine":["^Un piccolo santuario, nascosto come se la gente volesse dimenticarlo. Credo di preferirlo a quelli più grandi e altisonanti.","\n",{"->":"END_SCENE"},{"#f":1}],"eccria_tree_fountain_base":["^Un grande albero si erge al centro della fontana del cortile. Sembra rendere l'aria più fresca qui.","\n",{"->":"END_SCENE"},{"#f":1}],"eccria_tree_fountain_top":["^I rami dell'albero si estendono attraverso il foro nel terreno, ombreggiando il cortile sottostante.","\n",{"->":"END_SCENE"},{"#f":1}],"eccria_courtyard_statue_base":["^I piedi di una statua alta, i dettagli del suo volto mi sfuggono da quaggiù.","\n",{"->":"END_SCENE"},{"#f":1}],"eccria_courtyard_statue_face":["^Il volto della statua fissa in lontananza dietro di me.","\n",{"->":"END_SCENE"},{"#f":1}],"eccrian_glassblower_workshop":["^L'officina di una soffiatrice di vetro eccrina, nota in tutte le dune per l'impeccabile abilità di soffiare le sabbie in forme inimmaginabili.","\n",{"->":"END_SCENE"},{"#f":1}],"eccrian_chime_workshop":["^File di campanelli fusi sono incastonate in sabbie di dune diverse. La proprietà di ogni tipo di sabbia influisce sul timbro dei campanelli fusi al suo interno. Mi chiedo come suoni uno del Sansee.","\n",{"->":"END_SCENE"},{"#f":1}],"eccrian_beetle_market":["^Il Mercato Lavanda, così chiamato per lo Scarabeo che ne adorna l'ingresso. Ne ho sentito parlare anch'io: un posto dove ciò di cui hai bisogno lo puoi ottenere. Però potrebbe costarti qualche cut.","\n",{"->":"END_SCENE"},{"#f":1}],"eccria_serai_area":["^Una dimora fatiscente, semi-permanente. Non ho l'impressione che la gente del Serai sia ben accetta a Eccria.","\n","^Sembrano comunque trarne il meglio. Non capisco perché non vivano semplicemente come comuni nomadi.","\n",{"->":"END_SCENE"},{"#f":1}],"eccrian_docks":["^Vecchi moli di legno guardano l'Oasi. Restano vecchie rovine di un'antica struttura Hicarica.","\n",{"->":"END_SCENE"},{"#f":1}],"eccrian_water_bridge":["^Un piccolo ponte si affaccia sull'acqua corrente sotto la città.","\n",{"->":"END_SCENE"},{"#f":1}],"eccrian_hanging_clothes":["^Sembrano lavare i vestiti qui più che ovunque io abbia visto. Che spreco d'acqua. Scommetto che si lavano di più anche loro.","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_easterndune_01":["^N - The Dunboyne<br>E - The Ewer<br>SE - La Torre del Vento<br>NO - Burnt Oak Station","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_windtower":["^N - The Ewer<br> NE - Sodic Waste<br> O - \"CHUMS\" è inciso sopra altro testo.<br>NO - Burnt Oak Station","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_burnt_oak":["^E - The Dunboyne<br>SE - La Torre del Vento<br>SO - \"CHUMS\" scarabocchiato su questo cartello.<br>O - Eccria","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_western_dune_cartographer":["^E - Burnt Oak Station<br>S - Balfron Connection<br>SO - The Whale<br>O - Eccria","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_eccria":["^Benvenuti a Eccria","\n","^E - Burnt Oak Station<br>SE - Balfron Connection<br>S - The Whale<br>SO - Pozzo della Gazza Ladra","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_whale":["^N - Eccria<br>NE - Balfron Connection<br>E - Ponte dei Traditi<br>S - Stazione Sette Sorelle","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_seven_sisters":["^N - The Whale<br>SE - Carab's Hold<br>SO - Shadow of Neave<br>SO - Crystal Plateau","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_carabs_hold":["^N - Ponte dei Traditi<br>SO - Crystal Plateau<br>O - Shadow of Neave<br>NO - Stazione Sette Sorelle","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_bridge_betrayed":["^N - Balfron Connection<br>SE - Le Eyries<br>NO - Eccria<br>O - La Whale","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_eyries_ruins":["^E - Santuario<br>SE - Kemble's Cube<br>S - Rowley's Way<br>SO - Carab's Hold<br>O - Stazione Sette Sorelle","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_marrowbone":["^N - Foresta Pietrificata<br>SE - La Vedetta<br>S - Pyrausta's Ruin<br>SO - Centre of Brunswick","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_the_watch":["^N - Foresta Pietrificata<br>O - Centre of Brunswick<br>NO - Marrowbone Station<br>NO - Pyrausta's Ruin","\n",{"->":"END_SCENE"},{"#f":1}],"signpost_the_ewer":["^N - The Dunboyne<br>S - La Torre del Vento<br>O - \"Chums\" scritto rozzamente su un cartello<br>NO - Burnt Oak Station","\n",{"->":"END_SCENE"},{"#f":1}],"driss_conversation":["ev",{"VAR?":"speaker_driss"},"/ev",{"VAR=":"SpeakerName","re":true},{"->t->":"tutorial_beetles_generic"},["ev",{"VAR?":"TUT_BIKE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_start"},{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"TUT_BIKE_STARTED"},{"VAR?":"TUT_BIKE_OBJECTIVE"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_in_progress"},{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"TUT_BIKE_OBJECTIVE"},{"VAR?":"TUT_BIKE_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_complete"},{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"THE_GLIDING_RETURNED_HOME"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":"the_final_mask_content.driss"},{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.generic_chat"},{"->":".^.^.^.10"},null]}],"nop","\n",{"quest_start":[["^Anche se mi sono detta di non essere troppo ansiosa, è tutto quello che riesco a fare per non correre da Driss.","\n","^Driss è il responsabile del campo. Ultimamente è stato difficile da raggiungere, ma ora sospetto fortemente che stia lavorando alla mia hoverbike in segreto. Forse è particolarmente bella, o ha qualche caratteristica su misura.","\n","^Come si chiamerà, mi chiedo? Quanto sarà veloce? Mi faranno male le gambe o mi ci abituerò?","\n",{"#":"gesture_partner: surprised_2"},"^Driss si gira con un piccolo sussulto.","\n","^<<\"Sable! Ehm-- Ciao!\">>","\n","ev","str","^Ciao! Come va oggi?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Mi hanno detto che hai qualcosa di speciale per me...","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Jadi mi ha mandato a parlare con te.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Chiedo a Driss come sta.","\n","^<<\"Bene.\">>","\n","^Lascio la frase lì sospesa per un istante...","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Dico a Driss che mi hanno detto che ha qualcosa per me.","\n","^<<\"Qualcosa di speciale?\">>","\n","^Annuisco con grande significato, ma non sembra cogliere il suggerimento. Faccio un gesto allusivo, lento, cercando di essere perfettamente disinvolta e confidenziale...","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Davvero. Su cosa?\">>","\n","^Gli dico che era su <i>qualcosa di speciale</i> e poi faccio un gesto allusivo, lento, cercando di essere perfettamente disinvolta e confidenziale...","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"gesture_sable: talking"},"^Ma non ce la faccio. Sono troppo eccitata, e le parole escono: chiedo a Driss se per caso, magari, forse abbia una hoverbike per me.","\n","^<<\"La tua hoverbike!\">>","\n","^Lo grida come fosse un'idea che gli è appena venuta.","\n",{"#":"gesture_partner: explaining"},"^<<\"La tua hoverbike. Sì! Certo, giusto. Sì. La tua hoverbike. Che dovevo-- che ti ho preparato. Perché oggi è il tuo...\">>","\n","ev","str","^Volo, sì.","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Te ne sei dimenticato?","/str","/ev",{"*":".^.c-4","flg":4},{"c-3":["^ ","\n",{"#":"gesture_partner: yes"},"^Driss annuisce con me.","\n",{"#":"gesture_partner: explaining"},"^<<\"Sì, certo! Giusto. Sì. Sì, ce l'ho...>>","\n","^Mi si gela il sangue. Se ne è dimenticato?","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n","^Con orrore assoluto, gli chiedo gentilmente se possa essersene dimenticato.","\n",{"#":"gesture_partner: explaining"},"^<<\"Cosa? Cosa-- mai e poi mai! È... ovvio che ce l'ho la tua hoverbike.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Cioè te l'ho organizzata. In una... beh, è una specie di <i>tutorial</i> per te.\">>","\n","ev","str","^Un 'tutorial'?","/str","/ev",{"*":".^.c-5","flg":4},"ev","str","^Non è qui?","/str","/ev",{"*":".^.c-6","flg":4},"ev","str","^Te ne sei dimenticato?","/str","/ev",{"*":".^.c-7","flg":4},{"c-5":["^ ","\n","^<<\"Sì! Esatto. Un'esperienza di apprendimento.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-6":["^ ","\n","^<<\"Non proprio, ma è perché questa è <i>parte</i> del tuo Volo.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-7":["^ ","\n","^<<\"Te lo dico, non me ne sono dimenticato! Ho solo preso accordi diversi.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":[{"#":"gesture_sable: arms_crossed"},"^<<\"Vedi, Sable, prima di poter avere la propria hoverbike, bisogna dimostrare di saperne guidare una facendo... un giro di prova. Su un'altra hoverbike!\">>","\n",{"#":"gesture_sable: thinking"},"^Ci penso e mi accorgo di non aver mai sentito di questa parte del Volo, ma Driss sembra sincero. Più o meno.","\n",{"#":"sandcutter_cam_on"},"^<<\"Quindi invece di preoccuparti della <i>tua</i> hoverbike, vorrei che provassi <i>questa</i>! Come prova.\">>","\n",{"#":"sandcutter_cam_off"},"^Driss indica la sandcutter al suo fianco. È piuttosto vecchia e un po' malconcia. Un mezzo da rodaggio se mai ne ho visto uno.","\n","ev","str","^Ci provo.","/str","/ev",{"*":".^.c-8","flg":4},"ev","str","^Una prova.","/str","/ev",{"*":".^.c-9","flg":4},"ev","str","^Come si chiama la hoverbike?","/str","/ev",{"*":".^.c-10","flg":4},{"c-8":["^ ","\n",{"#":"gesture_partner: surprised_1"},"^<<\"Davvero? Cioè, sì! Bene! Vai piano, però. Questa sandcutter è più vecchia di Jadi. Trattala con rispetto!\">>","\n",{"->":".^.^.^.g-3"},{"#f":5}],"c-9":["^ ","\n","^<<\"Come potrai mai guidare la tua hoverbike se non hai... testato le tue abilità di guida? Su, Sable, fa parte del rito.\">>","\n",{"#":"gesture_partner: laugh"},"^Ride, debolmente. Non è convincente.","\n",{"->":".^.^.^.g-3"},{"#f":5}],"c-10":["^ ","\n",{"#":"gesture_partner: surprised_1"},"^Driss sembra scandalizzato.","\n","^<<\"È un po' personale, non credi? Per ora basta 'sandcutter'.\">>","\n","^<<\"I giovani di oggi, sempre a fare <i>domande</i>.\">>","\n",{"->":".^.^.^.g-3"},{"#f":5}],"#f":5}],"g-3":[{"#":"bike_quest_cam_on"},"^<<\"Ora! Cavalca la hoverbike attraverso l'anello e ritorno.\">>","\n",{"#":"bike_quest_cam_off"},"^<<\"E un consiglio per te, giovane Glider: non cadere!\">>","\n","ev",{"VAR?":"TUT_BIKE_STARTED"},{"f()":"activate"},"pop","/ev","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"quest_in_progress":["^<<\"Torna <i>dopo</i> aver guidato la sandcutter attraverso l'anello.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"quest_complete":[["ev",{"VAR?":"TUT_BIKE_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_partner: surprised_2"},"^Torno da Driss, che riesce in qualche modo a sembrare colto di sorpresa nonostante sapesse del mio arrivo.","\n","^<<\"Sable! Congratulazioni! Com'è stato il primo giro pre-Volo? Strani rumori? Sibili inspiegabili? Piccoli incendi?\">>","\n","ev","str","^In che senso, incendi?","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n",{"#":"gesture_partner: thinking"},"^<<\"Te ne accorgeresti di sicuro se prendessi fuoco, anche solo un pochino.\">>","\n",["ev","str","^Sì, assolutamente.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Era una possibilità?","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"g-0":["^<<\"Beh, ovviamente non è successo, quindi credo siamo a posto!\">>","\n","ev","str","^Driss, è pericolosa questa hoverbike?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Sembrava tutto normale.","/str","/ev",{"*":".^.c-2","flg":4},{"c-1":["^ ","\n","^<<\"Beh...\">>","\n","^Non finisce.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-2":["^ ","\n","^<<\"Beh, allora alla sandcutter piaci! Di solito è un po' più... irascibile con i piloti nuovi. Ma non sei nemmeno un po' in fiamme!\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["ev",{"VAR?":"TUT_HOVER_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.^.^.^.speak_to_sizo"},{"->":".^.^.^.6"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.^.^.^.speak_to_hilal"},{"->":".^.^.^.6"},null]}],"nop","\n",{"#f":5}]}],{"#f":1}],"speak_to_sizo":[["ev",{"VAR?":"TUT_MAIN_BIKE_AND_HOVER"},{"f()":"activate"},"pop","/ev","\n","^<<\"Comunque, immagino che questo chiuda la questione. Sei <i>pronta</i> per una hoverbike tua. E sono onorato, Sable, di essere quello che fa questo per te.\">>","\n","^Sto sorridendo così tanto dietro la maschera che credo di scoppiare. Sono le parole che aspettavo. Penso di chiedere se dovrei chiudere gli occhi, ma decido che voglio essere molto più matura in questo momento cruciale.","\n","^<<\"Vai a vedere Sizo.\">>","\n","ev","str","^Sizo?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Perché?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non avrò una hoverbike?","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"È un mio grande onore dirti che la tua hoverbike è con Sizo.\">>","\n",{"#":"gesture_sable: talking"},{"#":"gesture_partner: yes"},"^Dico a Driss che pensavo dovesse aver preso la hoverbike <i>da</i> Sizo <i>per</i> me. Annuisce.","\n","^<<\"Hmm, sì, beh, hai pensato male, eh?\">>","\n","^<<\"Vai da Sizo! Ti aiuterà. E ben fatto a provare la mia-- la sandcutter.\">>","\n","^<<\"Anzi, dato che impari in fretta, perché non la prendi in prestito un po'? Per fare più pratica.\">>","\n",{"#":"gesture_sable: thanks"},"^Anche se mi sento un po' delusa e molto incerta, ringrazio Driss per l'aiuto e la sua hoverbike e me ne vado.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"speak_to_hilal":[["^<<\"Sei già passata da Hilal?\">>","\n","ev","str","^Oh, giusto!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non avrò una hoverbike?","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Mi ero quasi dimenticata di Hilal, e ringrazio Driss per il promemoria... prima di stuzzicarlo almeno un po' sulla hoverbike. Gli chiedo se ne avrò comunque una.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Beh, ti dò l'uso di questa sandcutter! È qualcosa, eh? Puoi usarla per le tue commissioni.\">>","\n","^Le mie commissioni!","\n","^<<\"E anche Hilal ha qualcosa da mostrarti. Per aiutarti con un po' più di quella, ehm... <i>mobilità</i> che cerchi!\">>","\n","^Con la mia fiducia in questo esercizio solo leggermente intaccata, ringrazio Driss tanto per l'aiuto e la sua hoverbike, e parto verso Hilal.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"generic_chat":["^Driss mi pone una serie di domande sempre più strane prima che io trovi una scusa per congedarmi.","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"sizo_conversation":["ev",{"VAR?":"speaker_sizo"},"/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"TUT_ATOMIC_DELIVERED_PARTS"},{"VAR?":"TUT_ATOMIC_ASSEMBLED_BIKE"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":"tutorial_atomic_parts_content.bike_assembly"},{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"TUT_ATOMIC_ASSEMBLED_BIKE"},{"VAR?":"TUT_ATOMIC_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":"tutorial_atomic_parts_content.after_bike_assembled"},{"->":".^.^.^.18"},null]}],"nop","\n",{"->t->":"tutorial_beetles_generic"},["ev",{"list":{"tutorial_hover.TUT_HOVER_COMPLETED":3,"tutorial_bike.TUT_BIKE_COMPLETED":4}},{"VAR?":"TUT_ATOMIC_STARTED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"tutorial_atomic_parts_content.sizo_simoon_start"},{"->":".^.^.^.26"},null]}],["ev",{"VAR?":"TUT_ATOMIC_STARTED"},{"f()":"reached"},{"f()":"tut_atomic_found_all_parts"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"tutorial_atomic_parts_content.sizo_simoon_looking_for_parts"},{"->":".^.^.^.26"},null]}],["ev",{"f()":"tut_atomic_found_all_parts"},{"VAR?":"TUT_ATOMIC_DELIVERED_PARTS"},{"f()":"reached"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"tutorial_atomic_parts_content.sizo_simoon_deliver_parts"},{"->":".^.^.^.26"},null]}],["ev",{"VAR?":"THE_GLIDING_RETURNED_HOME"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"the_final_mask_content.sizo"},{"->":".^.^.^.26"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.generic_chat"},{"->":".^.^.^.26"},null]}],"nop","\n",{"->":"END_SCENE"},{"generic_chat":["^Sizo sembra occupata. Dovrei lasciarla in pace.","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"saima_conversation":["ev",{"VAR?":"speaker_saima"},"/ev",{"VAR=":"SpeakerName","re":true},["ev",{"CNT?":"saima_calibrator_stolen_back"},"!",{"list":{"tutorial_beetles.TUT_BEETLE_STARTED":1,"tutorial_beetles.TUT_BEETLE_STOLE_CALIBRATOR":4}},{"f()":"reached"},"&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"saima_calibrator_stolen_back"},{"->":".^.^.^.8"},null]}],["ev",{"CNT?":"saima_give_beetles"},"!",{"f()":"tutorial_beetles_has_enough"},"&&",{"VAR?":"TUT_BEETLE_STOLE_CALIBRATOR"},{"f()":"reached"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"saima_give_beetles"},{"->":".^.^.^.8"},null]}],["ev",{"VAR?":"THE_GLIDING_RETURNED_HOME"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"the_final_mask_content.saima"},{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.generic_chat"},{"->":".^.^.^.8"},null]}],"nop","\n",{"->":"END_SCENE"},{"generic_chat":["^Come fa Saima a contenere tanto caos e tanta verve in una forma così piccola?","\n","^Anche ora, dietro quella maschera si sta architettando <i>qualche</i> guaio. Lo so.","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"hilal_conversation":["ev",{"VAR?":"speaker_hilal"},"/ev",{"VAR=":"SpeakerName","re":true},{"->t->":"tutorial_beetles_generic"},["ev",{"VAR?":"TUT_MAIN_FIRST_ARRIVED_AT_CAMP"},{"VAR?":"TUT_HOVER_STARTED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"tutorial_hover_quest_content.hilal_hover_start"},{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"TUT_HOVER_STARTED"},{"VAR?":"TUT_HOVER_ACTIVATED_STONE"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"tutorial_hover_quest_content.hilal_hover_in_progress"},{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"TUT_HOVER_ACTIVATED_STONE"},{"VAR?":"TUT_HOVER_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"tutorial_hover_quest_content.hilal_hover_complete"},{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"THE_GLIDING_RETURNED_HOME"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"the_final_mask_content.hilal"},{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.hilal_generic_chat"},{"->":".^.^.^.10"},null]}],"nop","\n",{"->":"END_SCENE"},{"hilal_generic_chat":["^Hilal cita da una raccolta di oscure e liricamente mediocri ballate storiche degli Ibexii ogni volta che passo.","\n",["ev","visit",6,"%","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"ev","du",2,"==","/ev",{"->":".^.s2","c":true},"ev","du",3,"==","/ev",{"->":".^.s3","c":true},"ev","du",4,"==","/ev",{"->":".^.s4","c":true},"ev","du",5,"==","/ev",{"->":".^.s5","c":true},"nop",{"s0":["pop","\n","^<<\"C'è un grande verso,<br>che dice molto della nostra gente.<br>Sepolto sotto la sabbia...\">>","\n",{"->":".^.^.41"},null],"s1":["pop","\n","^<<\"Guardiamo al ciglio della scogliera,<br>i sicuri zoccoli dell'Ibex ancorati alla steppa.\">>","\n","^<<\"Sentinelle cornute,<br>che vegliano sull'altopiano.\">>","\n","^<<\"I nostri stivali trovano presa nella pietra,<br>e ricordiamo i giorni in cui non sapevamo planare\">>","\n",{"->":".^.^.41"},null],"s2":["pop","\n","^<<\"L'ospitalità Ibexii non è seconda a nessuno,<br>non c'è gente più gentile sotto il sole.\">>","\n","^<<\"I nostri canti e la nostra poesia sono imbattibili,<br>il nostro famoso jerky di capra è così affumicato e dolce.\">>","\n","^<<\"Se sei perso nelle sabbie e non trovi la via,<br>chiama l'Ibex, e salveremo la giornata.\">>","\n",{"->":".^.^.41"},null],"s3":["pop","\n","^<<\"Da perpetua e lontana stella,<br>non planammo, volammo da lontano.\">>","\n","^<<\"Erranti, nomadi, casa indefinita.<br>E quando cercammo appoggio, il deserto fu gentile.\">>","\n","^<<\"E così ora camminiamo, da una casa alla prossima,<br>viviamo come una volta, errando con l'Ibex.\">>","\n",{"->":".^.^.41"},null],"s4":["pop","\n","^<<\"E si dice<br>che la nostra gente prese la maschera dell'Ibex errante,<br>per mantenere la tradizione degli antenati.\">>","\n","^<<\"Troviamo casa nell'istante, e l'istante trova casa in noi.<br>Non c'è libertà più grande di quella della capra di montagna,<br>che sa solo dove poserà il prossimo passo.\">>","\n",{"->":".^.^.41"},null],"s5":["pop","\n","^<<\"Guerriero, guardia, macchinista, contadino,<br>collezionista d'insetti, rispettoso di debiti, mietitori d'acqua,\">>","\n","^<<\"Insegnante, tessitore, e colei che rompe la febbre,<br>costruttore, custode, trappolatore, saggio, e cercatore:\">>","\n","^<<\"Di tutte le maschere che ci compongono,<br>la nostra è la più sicura a riempire il tuo calice.\">>","\n",{"->":".^.^.41"},null],"#f":5}],"\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"jadi_conversation":["ev",{"VAR?":"speaker_jadi"},"/ev",{"VAR=":"SpeakerName","re":true},{"->t->":"tutorial_beetles_generic"},["ev",{"VAR?":"PURVEYOR_STARTED"},{"VAR?":"PURVEYOR_JADI_GAVE_MONEY"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"purveyor_and_surveyor_content.ask_jadi_for_money"},{"->":".^.^.^.11"},null]}],["ev",{"VAR?":"TUT_ATOMIC_COMPLETED"},{"VAR?":"PURVEYOR_STARTED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"purveyor_and_surveyor_content.jadi_suggests_you_buy_a_map"},{"->":".^.^.^.11"},null]}],["ev",{"list":{"purveyor_and_surveyor.PURVEYOR_JADI_GAVE_MONEY":3,"tutorial_atomic_parts.TUT_ATOMIC_COMPLETED":8}},{"VAR?":"PURVEYOR_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"purveyor_and_surveyor_content.jadi_waits_while_you_buy_a_map"},{"->":".^.^.^.11"},null]}],["ev",{"list":{"tutorial_atomic_parts.TUT_ATOMIC_COMPLETED":8,"purveyor_and_surveyor.PURVEYOR_COMPLETED":4}},{"VAR?":"TUT_MAIN_STARTED_MASK_CEREMONY"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"tutorial_main_content.jadi_ceremony_final"},{"->":".^.^.^.11"},null]}],["ev",{"VAR?":"THE_GLIDING_RETURNED_HOME"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"the_final_mask_content.jadi"},{"->":".^.^.^.11"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.jadi_generic_chat"},{"->":".^.^.^.11"},null]}],"nop","\n",{"->":"END_SCENE"},{"jadi_generic_chat":[["^Jadi mi saluta calorosamente.","\n","^<<\"Ciao, piccola Glider.\">>","\n","ev","str","^È così <i>strano</i> sentirmi chiamare così!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Per te è Glider Grande.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Com'era il tuo Volo?","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Dico a Jadi quanto sia strano essere chiamata 'Glider' invece di 'Sable' o anche 'figlia del clan'.","\n","^<<\"Cerco solo di farti abituare!\">>","\n","^Sembra che le piaccia davvero, e forse piace anche a me.","\n","^<<\"La mia piccola Glider!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Dico a Jadi che in realtà sono una <i>Glider Grande</i>. Ride.","\n","^<<\"Hai ragione. Lo sei.\">>","\n","^<<\"Sable, adulta riconosciuta e Glider Grande. Me lo annoto.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^Chiedo a Jadi del suo Volo.","\n","^<<\"Sai che ti dico? Te lo racconto quando torni.\">>","\n","^Incrocio le braccia in segno di protesta.","\n","^<<\"Imbroncia quanto vuoi! Non voglio rovinare nessuna sorpresa.\">>","\n","^Abbassa la voce a un sussurro.","\n","^<<\"Ma <i>ho</i> incontrato dei coltivatori di cristalli una volta.\">>","\n","^<i>Coltivatori di Cristalli!</i>","\n","^<<\"E questo è tutto quello che dirò. Dovresti andare.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"#f":1}],"zeki_conversation":["ev",{"VAR?":"speaker_zeki"},"/ev",{"VAR=":"SpeakerName","re":true},{"->t->":"tutorial_beetles_generic"},"ev",{"VAR?":"THE_GLIDING_RETURNED_HOME"},{"f()":"reached"},"_","/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":"the_final_mask_content.zeki"},{"->":".^.^.^.11"},null]}],"nop","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.17"},null],"#f":5}],"\n",{"->":"END_SCENE"},{"first_intro":[[{"#":"gesture_partner: sad"},"^Mentre guarda il paesaggio, le spalle di Zeki si abbassano un po'. Mi chiedo a cosa stia pensando.","\n","ev","str","^Hai qualcosa per la testa?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Sembri stanca.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Cosa stai guardando?","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"gesture_partner: no"},"^La voce di Zeki è debolmente incredula.","\n","^<<\"Non so come abbia fatto...\">>","\n","^<<\"Quella laggiù è Elaria.\">>","\n","^Seguo il suo sguardo fino a un puntino in lontananza, che ora capisco essere sua figlia Elaria.","\n","ev","str","^Vuoi che la riporti indietro?","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Le serve aiuto?","/str","/ev",{"*":".^.c-4","flg":4},{"c-3":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":[{"#":"gesture_partner: no"},"^Zeki scuote la testa.","\n","^<<\"No, sta bene, e la prendo io, è solo che...\">>","\n",{"#":"gesture_partner: shrug"},"^Fa spallucce.","\n","^<<\"Genitorialità.\">>","\n","^Suppongo ne saprò di più quando sarò più grande.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"default_intro":["^Zeki sembra preoccupata.","\n","^<<\"Elaria! Come hai fatto a salire fin lì?\">>","\n","^<<\"Quella piccola...\">>","\n","^<<\"I bambini non hanno paura.\">>","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"umar_conversation":["ev","str","^Umar","/str","/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"THE_GLIDING_RETURNED_HOME"},{"f()":"reached"},"_","/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":"the_final_mask_content.umar"},{"->":".^.^.^.12"},null]}],"nop","\n","^Umar è un uomo di poche parole. E se non altro, è coerente.","\n",{"->":"END_SCENE"},{"#f":1}],"elaria_conversation":["ev",{"VAR?":"speaker_elaria"},"/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"THE_GLIDING_RETURNED_HOME"},{"f()":"reached"},"_","/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":"the_final_mask_content.elaria"},{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"TUT_HOVER_ACTIVATED_STONE"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.before_carto"},{"->":".^.^.^.19"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.after_carto"},{"->":".^.^.^.19"},null]}],"nop","\n",{"before_carto":[["ev","visit",3,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"ev","du",2,"==","/ev",{"->":".^.s2","c":true},"ev","du",3,"==","/ev",{"->":".^.s3","c":true},"nop",{"s0":["pop","\n","^<<\"Adoro arrampicarmi!\">>","\n",{"->":".^.^.29"},null],"s1":["pop","\n","^<<\"Voglio salire più in alto, proprio fin dove va la mongolfiera!\">>","\n",{"->":".^.^.29"},null],"s2":["pop","\n","^<<\"Scommetto che non pensavi che riuscissi a salire così in alto, vero?\">>","\n",{"->":".^.^.29"},null],"s3":["pop","\n","^<<\"È fantastico.\">>","\n",{"->":".^.^.29"},null],"#f":5}],"\n",{"->":"END_SCENE"},{"#f":1}],"after_carto":[["ev","visit",2,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"ev","du",2,"==","/ev",{"->":".^.s2","c":true},"nop",{"s0":["pop","\n","^<<\"La mongolfiera era più divertente della persona dentro.\">>","\n",{"->":".^.^.23"},null],"s1":["pop","\n",{"#":"gesture_sable: laugh"},"^<<\"Voglio fare anche io la carnografa!\">>","\n",{"->":".^.^.23"},null],"s2":["pop","\n","^<<\"Quando andrò in Volo, farò la Scalatrice!\">>","\n",{"->":".^.^.23"},null],"#f":5}],"\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"tutorial_ship_cockpit_log":[["ev",{"VAR?":"speaker_ship_recording"},"/ev",{"VAR=":"SpeakerName","re":true},"^Non c'è niente di utile da trovare nella nave, ma noto una luce lampeggiante sul cruscotto della cabina di pilotaggio.","\n","ev","str","^Premi il pulsante.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Lascia stare","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Una voce gracchia dal macchinario davanti a me. Sembra una registrazione, è a malapena udibile.","\n","^<<\"...smettila di smanettare con quei pulsanti, idiota.\">>","\n","^<<\"Scusa, Ramin.\">>","\n","^<<\"Concentrati. Non credo di doverti ricordare quanta fatica per arrivare fin qui. Ci siamo quasi.\">>","\n","^<<\"Bene, vediamo se quel vecchio Macchinista aveva ragione. Se no, saranno guai.\">>","\n","^Sento il suono di regolazioni meccaniche. Tre click -- pulsanti premuti, forse?","\n","^<<\"Ok, quando spingo questo coso arancione, tira quella leva. Forte.\">>","\n","^<<\"Sì, Ramin.\">>","\n","^Il suono di un click e un grido, prima di uno schianto.","\n","^<<\"Oh, sulla Maschera di Rohana. Non <i>così</i> forte, l'hai strappata!\">>","\n","^All'improvviso gli altoparlanti si riempiono di fruscio, e di un rombo basso che cresce gradualmente in tonalità.","\n","^E poi il suono di qualcuno che esulta.","\n","^<<\"Ha funzionato! Stiamo volando!\">>","\n","^Altre esultanze. È il suono di qualcuno che balla?","\n","^<<\"Ok, ok. Concentriamoci. Questa cosa va veloce, dobbiamo rallentarla un po'.\">>","\n","^<<\"Come si fa, Ramin?\">>","\n","^<<\"Fammi controllare gli appunti del Macchinista...\">>","\n","^Una lunga pausa, il rombo di fruscio che è iniziato al decollo continua a crescere di tonalità.","\n","^<<\"Ramin?\">>","\n","^<<\"Quella leva, Toma! Quella che hai appena strappato...\">>","\n","^<<\"Stiamo andando troppo veloce, ci schianteremo. Dobbiamo provare a...\">>","\n","^La registrazione si interrompe lì.","\n",{"->":"END_SCENE"},{"#f":5}],"c-1":["^ ","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"gliding_stone_altar":[["^La pietra vibra come il battito di un cuore mentre mi avvicino all'altare.","\n","ev","str","^Ho paura?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Esaltata?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^O forse... sembra giusto?","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Sì. E no.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Sono pronta perché Rohana mi conosca. Sono pronta a conoscere me stessa.","\n",{"#":"gliding_stone_face_shot"},"^Sento la sua curiosità, in questo luogo sacro. So di essere sotto il suo sguardo.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"fir_conversation":["ev","str","^Macchinista Fir","/str","/ev",{"VAR=":"SpeakerName","re":true},"ev",{"f()":"ring_shrine_number_of_pedestals_activated"},"/ev",{"temp=":"num_pedestals"},"\n","ev",{"f()":"ring_shrine_number_of_pillars_activated"},"/ev",{"temp=":"num_pillars"},"\n",["ev",{"VAR?":"num_pedestals"},0,"==","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.before_pedestals_activated"},{"->":".^.^.^.23"},null]}],["ev",{"VAR?":"num_pedestals"},0,">",{"VAR?":"num_pillars"},0,"==","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.activated_pedestal_but_no_pillars"},{"->":".^.^.^.23"},null]}],["ev",{"VAR?":"num_pillars"},1,"==","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.one_pillar_active"},{"->":".^.^.^.23"},null]}],["ev",{"VAR?":"num_pillars"},2,"==","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.two_pillars_active"},{"->":".^.^.^.23"},null]}],["ev",{"VAR?":"num_pillars"},3,"==",{"VAR?":"RING_SHRINE_REPORT_TO_FIR"},{"f()":"reached"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.three_pillars_active"},{"->":".^.^.^.23"},null]}],["ev",{"VAR?":"RING_SHRINE_REPORT_TO_FIR"},{"VAR?":"RING_SHRINE_QUEST_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.working_on_bike"},{"->":".^.^.^.23"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.post_quest_dialogue"},{"->":".^.^.^.23"},null]}],"nop","\n",{"before_pedestals_activated":[["^Ogni volta che incontro un altro Macchinista, la mente torna a Sizo. Mi chiedo se senta dei miei viaggi, attraverso qualunque rete colleghi la loro corporazione.","\n","^Mi chiedo se sia fiera.","\n",{"#":"gesture_sable: greeting"},"^Penso a lei adesso, mentre saluto questa estranea.","\n","^<<\"Oh! Adoro incontrare le Glider! Vieni, vieni. Come ti chiami?\">>","\n",{"#":"gesture_sable: talking"},"^Mi avvicino e le dico che sono Sable.","\n","^<<\"Sable! Suona tanto come 'tavolo'. Te lo dicono spesso?\">>","\n","ev","str","^È la prima volta.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^No.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Oh, costantemente.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: talking"},"^Le dico che è la prima volta.","\n","^<<\"Davvero? Prima cosa che ho pensato. Prima cosa.\">>","\n","^<<\"Comunque, mi chiamo Fir. Suona come <i>'fear'</i>, vero?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: talking"},"^Le dico che non mi succede spesso.","\n","^<<\"Beh, sei in Volo. Più gente incontri, più te lo diranno.\">>","\n","^Suppongo possa avere ragione.","\n","^<<\"E io sono Fir. Suona come 'fear', no?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_sable: talking"},"^Le dico che mi chiamano <i>sempre</i> 'Tavolo'.","\n","^<<\"Lo sapevo. Mi chiamo Fir, che la gente pensa sempre sia <i>'fear'</i>.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev","str","^Suona anche come 'dear'.","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Suona anche come 'sheer'.","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Suona anche come 'pier'.","/str","/ev",{"*":".^.c-5","flg":4},{"c-3":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-5":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":[{"#":"gesture_partner: thinking"},"^Sembra pensosa.","\n","^<<\"Cioè, immagino...\">>","\n","^<<\"Comunque, non ti ho chiamato per parlare di rime. Ti ho chiamato per mostrarti qualcosa che <i>adorerai</i>.\">>","\n","^<<\"Sono molto presa dalla storia. Rovine, navi antiche, vecchi libri... tutti i resti dei Monumentalisti, capisci?\">>","\n",{"#":"gesture_sable: yes"},"^Annuisco.","\n","^<<\"Beh, di recente ho decifrato alcuni testi Monumentalisti, che parlano di una specie di... strutture sinergiche posizionate in tutto il mondo, in deserti diversi.\">>","\n","ev","str","^Cosa intendi con \"sinergiche\"?","/str","/ev",{"*":".^.c-6","flg":4},"ev","str","^Potrebbero essere punti di passaggio?","/str","/ev",{"*":".^.c-7","flg":4},{"c-6":["^ ","\n","^<<\"Voglio dire che i testi suggeriscono che siano... reattive. Più che semplici statue o lastre di roccia o quale che sia la loro forma, i testi suggeriscono che registrino dati o interagiscano in qualche modo con le persone.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-7":["^ ","\n","^Suggerisco a Fir che gli Ibexii hanno spesso posato pietre di passaggio nel deserto, come segnali per sé e per altri. Non sono sicura sia rilevante, ma una piccola fitta di nostalgia me l'ha fatto dire.","\n","^<<\"Interessante! Ne ho viste di quelle cose. Suppongo potrebbe valere anche qui...\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":["^<<\"Ma credo sia qualcos'altro. Qualcosa di <i>molto</i> più divertente.\">>","\n",{"#":"gesture_sable: talking"},"^Chiedo cosa pensa che siano.","\n",{"#":"gesture_partner: explaining"},"^<<\"Credo siano un gioco. Vedi-- abbiamo questa cosa. Tutti ce l'hanno. Guardiamo al passato e assumiamo che fosse tutto lavoro e niente svago. Perché tutto ciò che vediamo — tutto ciò che persiste — è il loro <i>lavoro</i>. Navi, registri, strumenti.\">>","\n","^<<\"Ma il divertimento... il divertimento è effimero. Le battute spariscono. Gli scarabocchi si perdono mentre l''arte' sopravvive. Quindi perdiamo tutto, e continuiamo a credere che non ne abbiano mai avuto.\">>","\n","^<<\"Quindi se hai tempo e voglia, Glider, ti consiglio di tenere d'occhio architetture Monumentaliste che sembrano... sospette o strane. E reattive in qualche modo.\">>","\n","^<<\"Direi che una Glider su una hoverbike è la persona perfetta per testare la mia teoria, se ne hai voglia.\">>","\n","ev","str","^Sembra divertente!","/str","/ev",{"*":".^.c-8","flg":4},"ev","str","^Farò del mio meglio.","/str","/ev",{"*":".^.c-9","flg":4},{"c-8":["^ ","\n",{"->":".^.^.^.g-3"},{"#f":5}],"c-9":["^ ","\n",{"->":".^.^.^.g-3"},{"#f":5}],"#f":5}],"g-3":["^<<\"Bene! Grazie! Cercherò di continuare a decifrare i miei documenti. Riferiscimi quello che trovi, per favore! E se risolvi il gioco, spero ti piaccia.\">>","\n",{"#":"gesture_sable: talking"},"^Le dico che lo farò.","\n",{"#":"gesture_partner: thanks"},"^<<\"Ottimo. Grazie, Tavolo. E buona fortuna.\">>","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"activated_pedestal_but_no_pillars":[{"#":"gesture_sable: talking"},"^Dico a Fir cosa ho trovato.","\n",{"#":"gesture_partner: fist_pump"},"^<<\"Sì! Magnifico! Hai sicuramente attivato qualcosa, ma... se l'aspetto è indizio — di solito lo è — te ne mancano altre. Se riesci a trovarne altre, lo apprezzerei tanto.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"one_pillar_active":[[{"#":"gesture_partner: surprised_1"},"^<<\"Sable! Cos'hai fatto?\">>","\n","ev","str","^Ehm...","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ho fatto comparire un pilastro, pare.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"gesture_parner: thinking"},"^<<\"C'è un'iscrizione qui. Dovrei riuscire a decifrarla, ma serve un po' di tempo. Magari mentre traduco tu attivi gli altri pilastri?\">>","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"two_pillars_active":[{"#":"gesture_partner: ecstatic"},"^<<\"Splendido! Eccellente! Bello!\">>","\n",{"#":"gesture_sable: fist_pump"},"^Fir è euforica e non posso fare a meno di emozionarmi con lei. Mi sembra che stiamo facendo qualcosa di importante.","\n",{"#":"gesture_partner: thinking"},"^<<\"Sto facendo discreti progressi sulla prima iscrizione. Qualcosa di 'vittoria' o... 'successo'? Non ne sono ancora sicura, ci sono molte sfumature.\">>","\n","^<<\"Do un'occhiata a questa roba nuova e tu vai a vedere cos'altro trovi!\">>","\n",{"->":"END_SCENE"},{"#f":1}],"three_pillars_active":["ev",{"VAR?":"RING_SHRINE_REPORT_TO_FIR"},{"f()":"activate"},"pop","/ev","\n","ev",{"x()":"day_counter"},"/ev",{"VAR=":"an_ancient_race_day_count_cache","re":true},"\n",{"#":"gesture_partner: explaining"},"^<<\"Sei una salvatrice, Sable. Sono tutte le iscrizioni. Le prime due suggeriscono che siano... istruzioni? Per costruire qualcosa, credo. Ma la terza parte sembra dove c'è tutta la roba buona.\">>","\n",{"#":"gesture_sable: talking"},"^Chiedo cosa intende per 'roba buona'.","\n","^<<\"Il 'perché' e il 'cosa' di tutto. Perché lo stiamo costruendo e cosa stiamo costruendo. Sospetto sia una specie di caccia al tesoro. E si è destinati a fabbricarsi il proprio premio.\">>","\n",{"#":"gesture_partner: thinking"},"^<<\"Nel qual caso parte del gioco è risolvere il terzo indizio.\">>","\n",{"#":"gesture_partner: fist_pump"},"^<<\"Quindi credo il <i>tuo</i> lavoro sia finito per ora, e il mio inizi! Dammi qualche giorno, Sable. Credo di poterla risolvere presto.\">>","\n",{"#":"gesture_sable: talking"},"^Dico a Fir che non vedo l'ora di vedere cosa ne tira fuori, e ci salutiamo per ora.","\n",{"->":"END_SCENE"},{"#f":1}],"working_on_bike":[["ev",{"f()":"fir_finished_building_bike"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n","^<<\"Ci sto ancora lavorando, torna presto.\">>","\n",{"->":"END_SCENE"},{"->":".^.^.^.5"},null]}],"nop","\n","ev",{"VAR?":"RING_SHRINE_QUEST_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_partner: ecstatic"},"^Vedendomi, Fir quasi salta dall'eccitazione.","\n",{"#":"gesture_partner: explaining"},"^<<\"Sable! Ti aspettavo. Ho decodificato l'ultima iscrizione!\">>","\n",{"#":"gesture_partner: fist_pump"},"^<<\"Avevamo ragione! <i>Era</i> un gioco. Una corsa! E l'hai completata esattamente come voluto. Sai cosa significa?\">>","\n","ev","str","^Ho vinto?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Sono davvero veloce!","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^<<\"Oh hai vinto di sicuro. O, più precisamente, ha vinto Simoon.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Beh-- beh, voglio dire, tecnicamente non è una misura di <i>velocità</i>... è più una questione di completamento. Ma sono sicura che Simoon ti abbia portato veloce!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Mi sfugge appena che usa \"Simoon\" pur non essendo stata presentata. E non faccio in tempo a farlo notare prima che continui.","\n",{"#":"gesture_partner: explaining"},"^<<\"C'è un <i>premio</i>. Vero! Una volta completata la corsa, i pilastri rivelano il testo. Traduci il testo e ottieni...\">>","\n",{"#":"gesture_partner: fist_pump"},"^<<\"Pezzi di hoverbike! Incredibili, dal design più antico di qualunque io abbia mai visto, ma di perfetta eleganza. <i>Devi</i> provarli, Sable. Devi.\">>","\n",{"#":"inventory_add: MonumentalRingBikeFront"},{"#":"inventory_add: MonumentalRingBikeWings"},{"#":"inventory_add: MonumentalRingBikeBooster"},"^<<\"Posso montare i pezzi sulla tua hoverbike se vuoi guidarla subito!\">>","\n","ev","str","^Sì grazie!","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Magari dopo.","/str","/ev",{"*":".^.c-3","flg":4},{"c-2":["^ ","\n",{"#":"StartCustomization"},"^<<\"Ok, diamogli un'occhiata.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Questa hoverbike... \">>","\n","^Fir scuote la testa e fa spallucce, ma in modo positivo. Come fai davanti a qualcosa di così grandioso e meraviglioso da farti sentire piccola e quasi inutile alla sua ombra.","\n","^<<\"Questa hoverbike è... meravigliosa.\">>","\n",{"#":"gesture_sable: thanks"},"^Le dico che sono d'accordo, e la ringrazio per l'opportunità di gareggiare in una corsa antica. Le spiego che giocando al loro vecchio gioco mi sono sentita più connessa al passato che ascoltando i pezzi più aridi di storia.","\n",{"#":"gesture_partner: thinking"},"^<<\"È fantastico. Davvero. È...\">>","\n",{"#":"gesture_partner: thinking"},"^<<\"Non so se sono solo una romantica, ma faccio sempre una fatica enorme a connettermi al passato senza connettermi alle <i>persone</i>. Strano, per una Macchinista, no?\">>","\n",{"#":"gesture_sable: thinking"},"^Ci penso. Suppongo sia strano per una Macchinista, in qualche modo, ma lo trovo anche confortante. C'è davvero spazio per ogni tipo di persona dietro a ogni maschera.","\n",{"#":"gesture_partner: thanks"},"^<<\"Voglio che tu tenga la hoverbike e... la porti in una nuova era. Falle vedere come è cambiato il mondo mentre dormiva.\">>","\n","^<<\"Io non ci vado in giro molto, ormai. Quindi sarà in buone mani con te. E io potrò darmi delle arie con gli altri Macchinisti, che è tutta la ricompensa che mi serve.\">>","\n",{"#":"gesture_sable: thanks"},"^Ringrazio Fir per la sua abilità e generosità, e me ne vado.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"post_quest_dialogue":[[{"#":"gesture_partner: laugh"},"^<<\"Salve, Stalla!\">>","\n",["ev","str","^Personalizza hoverbike.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Addio.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"#":"StartCustomization"},"^<<\"Diamole un'occhiata.\">>","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.g-0"},{"#f":5}],"#f":5,"#n":"customise_bike"}],{"g-0":["^Saluto Fir.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"#f":1}],"badlands_ring_monument":[{"->t->":".^.intro"},"ev",{"VAR?":"debug_found_badlands_monument"},0,"==","/ev",[{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.interaction_point"},{"->":".^.^.^.7"},null]}],"nop","\n",{"->":".^.done"},{"intro":["^Ti trovi al Monumento dell'Anello dei Badlands.","\n","ev","void","/ev","->->",{"#f":1}],"interaction_point":["^Entro nel monumento.","\n","ev",1,"/ev",{"VAR=":"debug_found_badlands_monument","re":true},"ev",{"VAR?":"RING_SHRINE_QUEST_BADLANDS_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"->t->":"an_ancient_race_debug_pick_up_item"},"ev","void","/ev","->->",{"#f":1}],"done":["^Lascio il monumento dell'anello.","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"eyries_boatworkshop_merchant_taima":[["ev","str","^Costruttore di Barche Jake","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Salve! Come posso aiutarti oggi?\">>","\n","ev","str","^Vorrei commerciare.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Che posto è questo?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non ho bisogno di nulla.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.begin_trading"},{"#f":5}],"c-1":["^ ","\n","^<<\"È un'antica rovina Hicarica, l'abbiamo trovata anni fa e da allora cerchiamo di rimetterla in funzione. Forte, no?\">>","\n","^<<\"Dopo aver attivato le torri degli uccelli, ho passato tanto tempo a capire come coltivare e ingegnerizzare quelle grandi ossa che si vedono per le Chales.\">>","\n","^<<\"È così che navighiamo tra le rocce, ci spostiamo. Se hai una hoverbike, ho dei pezzi interessanti da vendere.\">>","\n",{"->":".^.^.^.conversation_end"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.conversation_end"},{"#f":5}]}],{"begin_trading":[{"#":"StartTrading"},"^<<\"Magnifico! Dai un'occhiata alla mia merce.\">>","\n","^<<\"Grazie del passaggio.\">>","\n",{"->":".^.^.conversation_end"},{"#f":1}],"conversation_end":["^<<\"Se vedi Umi in giro, salutamela! È bello vedere qualcun altro quassù.\">>","\n","end",{"#f":1}],"#f":1}],"eyries_harvester_umi":[["ev","str","^Raccoglitrice Umi","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Hai viaggiato a lungo. Non capita spesso che vengano viaggiatori.\">>","\n","ev","str","^Perché sei qui fuori?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Vivi quassù?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Ci si vede.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^<<\"Sto solo raccogliendo un po' degli escrementi degli uccelli che otteniamo da queste torri.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-1":["^ ","\n","^<<\"Solo per parti dell'anno, i venti si fanno duri e diventa difficile restare. Meglio scendere sulle sabbie e vendere quel che possiamo nei mesi duri.\">>","\n","^<<\"Mi piace davvero stare quassù quando i venti sono stabili. Niente è come navigare in barca tra torri di roccia. La cacca degli uccelli è l'unico inconveniente. Almeno è redditizia.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-2":["^ ","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"micah_conversation":["ev","str","^Scalatore Micah","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev",{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.receive_key"},{"->":".^.^.^.12"},null]}],["ev",{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_SPOKE_TO_BASHIR"},{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_RECEIVED_KEY"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.receive_key_alt"},{"->":".^.^.^.12"},null]}],["ev",{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_RECEIVED_KEY"},{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_RESCUED_CLIMBER"},{"f()":"between"},{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_LIFTED_CRANE_HALFWAY"},{"f()":"reached"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.look_for_mechanism"},{"->":".^.^.^.12"},null]}],["ev",{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_RECEIVED_KEY"},{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_RESCUED_CLIMBER"},{"f()":"between"},{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_LIFTED_CRANE_HALFWAY"},{"f()":"reached"},"&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.crane_halfway"},{"->":".^.^.^.12"},null]}],["ev",{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_RESCUED_CLIMBER"},{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_complete"},{"->":".^.^.^.12"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.after_quest_complete"},{"->":".^.^.^.12"},null]}],"nop","\n",{"receive_key":["ev",{"list":{"sometimes_a_well_is_just_a_well.SOMETIMES_A_WELL_IS_JUST_A_WELL_STARTED":2,"sometimes_a_well_is_just_a_well.SOMETIMES_A_WELL_IS_JUST_A_WELL_RECEIVED_KEY":3}},{"f()":"activate"},"pop","/ev","\n","^<<\"Grazie. Grazie, grazie, grazie.\">>","\n","^Sembra parecchio provato, e c'è una profonda stanchezza nella sua voce, ma io provo solo sollievo. È chiaro che sta male, e rabbrividisco al pensiero di cosa gli sarebbe successo se non fossi arrivata.","\n","^<<\"Mi chiamo Micah. Sono sceso qui in cerca di qualcosa. E sono caduto.\">>","\n",{"#":"gesture_sable: talking"},"^Dico a Micah che mi chiamo Sable e gli chiedo se pensa di poter camminare.","\n",{"->":".^.^.receive_key_shared"},{"#f":1}],"receive_key_alt":[["ev",{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_RECEIVED_KEY"},{"f()":"activate"},"pop","/ev","\n","^<<\"Per favore! Aiuto!\">>","\n","^La voce di Micah è graffiata e ha l'aspetto di chi ha passato un po' troppo tempo in fondo a un pozzo, un po' sabbioso e cencioso.","\n","ev","str","^Sono qui per salvarti!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Cosa ti è venuto in mente di scendere qui?","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: talking"},"^Dico a Micah che sono qui per salvarlo, e che mi chiamo Sable.","\n","^<<\"Sable. Grazie. Grazie mille! Come sapevi che ero qui?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: explaining"},"^Chiedo a Micah cosa gli sia passato per la mente a scendere qui — soprattutto da solo.","\n","^<<\"Non so. Non stavo pensando, credo.\">> Sospira. <<\"Sono solo felice che tu sia arrivata quando sei arrivata.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Informo Micah che mi ha mandato Bashir.","\n","^<<\"Oh no...\">>","\n","ev","str","^Perché è una cosa brutta?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Bashir non è tuo amico?","/str","/ev",{"*":".^.c-3","flg":4},{"c-2":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Sono stato così <i>stupido</i> con lui. Solo... arrogante. Scortese. Mi dice sempre di stare attento, di non andare a caccia da solo... e io sono sempre stupido con lui.\">>","\n","^<<\"È così inutile. Ma mi sento sempre come se dovessi <i>dimostrare</i> qualcosa. Più mi dice di stare attento, meno mi va di farlo.\">>","\n","^<<\"Ma è senza ragione! Sono solo difficile per il gusto di esserlo.\">>","\n","ev","str","^Non essere troppo duro con te stesso.","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Lo faccio anch'io a volte.","/str","/ev",{"*":".^.c-5","flg":4},"ev","str","^Tiriamoti fuori da qui e basta.","/str","/ev",{"*":".^.c-6","flg":4},{"c-4":["^ ","\n",{"#":"gesture_sable: talking"},"^Cerco di dire a Micah di non essere troppo duro con sé stesso, ma mi interrompe.","\n","^<<\"Non so cosa mi prenda. Sono solo un grande stupido bambino che non--\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-5":["^ ","\n",{"#":"gesture_sable: talking"},"^Rassicuro Micah dicendo che spesso anch'io mi sono sentita un po' sotto pressione per dimostrare qualcosa, anche quando la pressione veniva da me stessa.","\n","^<<\"Lo so, ma tu sei-- sei una Glider. Sei giovane! Io dovrei saperlo meglio.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-6":["^ ","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":[{"#":"gesture_sable: talking"},"^Dico a Micah che non possiamo soffermarci adesso e gli chiedo se riesce a camminare.","\n",{"->":".^.^.^.^.receive_key_shared"},{"#f":5}]}],{"#f":1}],"receive_key_shared":["^<<\"No... non abbastanza per uscire da qui, almeno. Per questo mi sono trascinato fin qui, pensando di poter usare la gru.\">>","\n","^<<\"Ma non riesco ad accedere ai comandi.\">>","\n","^Mi chiedo ad alta voce se <i>io</i> potrei accedere ai comandi e Micah fruga nelle tasche finché non trova ciò che cerca: una chiave. La solleva.","\n","^<<\"Ho trovato questa chiave. Dovrebbe farti entrare. Da lì puoi usare la gru.\">>","\n",{"#":"gesture_sable: yes"},"^Annuisco.","\n","^<<\"Mi dispiace di non poter fare di più. Mi sento così inutile. Grazie, Sable. Sei davvero molto gentile.\">>","\n",{"#":"inventory_add: ThievingMagpiesWellDoorKey"},"^Gli dico che non importa e che non è inutile, poi prendo la chiave e vado.","\n",{"->":"END_SCENE"},{"#f":1}],"look_for_mechanism":["^<<\"Hai già trovato la via d'uscita?\">>","\n",{"->":"END_SCENE"},{"#f":1}],"crane_halfway":["^Micah saltella un po'.","\n","^<<\"Sable! Sì! Qualunque cosa tu stia facendo lì, sta funzionando! Continua!\">>","\n",{"->":"END_SCENE"},{"#f":1}],"quest_complete":[["ev",{"VAR?":"SOMETIMES_A_WELL_IS_JUST_A_WELL_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Sable.\">>","\n","^<<\"Come... potrò mai ringraziarti?\">>","\n","ev","str","^Vai a casa e scusati con Bashir!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Niente più scalate pericolose!","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non direi di no a un piccolo dono...","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: explaining"},"^Dico a Micah che deve tornare a casa e scusarsi con Bashir per tutta la preoccupazione che ha causato.","\n","^<<\"Oh, lo farò. Lo farò. Mi scuserò con Bashir per giorni. Se lo merita. E cercherò di non preoccuparlo mai più.\">>","\n","^<<\"Ma voglio almeno darti qualcosa.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: explaining"},"^Dico a Micah che può ringraziarmi evitando scalate pericolose. Non mi sfugge che avrei potuto facilmente trovare un cadavere.","\n","^<<\"Oh, su quello tranquilla. Eviterò sicuramente <i>tutte</i> le scalate da solo per un po', e quelle pericolose per sempre. Ho imparato la lezione.\">>","\n","^Fruga in tasca.","\n","^<<\"Ma voglio darti qualcos'altro.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_sable: talking"},"^Dico a Micah che non direi di no a un piccolo qualcosa. Ridacchia e fruga in tasca.","\n","^<<\"Beh, ho <i>questo</i> da darti.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"gesture_sable: thanks"},{"#":"inventory_add: ClimbingBadge"},"^Micah mi porge un Distintivo dell'Arrampicata e lo prendo con gratitudine.","\n","^<<\"Tornerò al campo delle Cinque Campane. Andrà tutto bene; camminare è un po' più facile dello scalare ora.\">>","\n","^<<\"Sei la mia salvatrice, Sable. Se mai dovessi decidere di diventare Scalatrice, hai la mia approvazione. Stammi bene, ok?\">>","\n","^Gli dico che lo farò, e ci salutiamo con affetto.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"after_quest_complete":["^<<\"Non potrò mai ringraziarti abbastanza per l'aiuto.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"salt_plains_ring_monument":[{"->t->":".^.intro"},"ev",{"VAR?":"debug_found_salt_plains_monument"},0,"==","/ev",[{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.interaction_point"},{"->":".^.^.^.7"},null]}],"nop","\n",{"->":".^.done"},{"intro":["^Ti trovi al Monumento dell'Anello delle Saline.","\n","ev","void","/ev","->->",{"#f":1}],"interaction_point":["^Entro nel monumento.","\n","ev",1,"/ev",{"VAR=":"debug_found_salt_plains_monument","re":true},"ev",{"VAR?":"RING_SHRINE_QUEST_SALT_PLAINS_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"->t->":"an_ancient_race_debug_pick_up_item"},"ev","void","/ev","->->",{"#f":1}],"done":["^Lascio il monumento dell'anello.","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"salt_plains_felix_conversation":["ev","str","^Raccoglitore di Sale Felix","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Benvenuta nelle Terre Desolate, Glider!\">>","\n",{"->":".^.first_meeting"},{"first_meeting":[["^<<\"Cosa posso fare per te?\">>","\n","ev","str","^Perché sei qui fuori?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Posso avere un po' di sale?","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Ci si vede.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^<<\"Beh, agli Eccrini piace il sale. Adorano quello rosa, quello blu, quello verde. Quindi noi lavoriamo qui, la pelle si scrosta lentamente perché loro possano leccarne un po'.\">>","\n","^<<\"La Waste è un posto duro ma paga bene ed è tranquillo. Non ci sono molti posti così a Midden, questo è certo.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-1":["^ ","\n","^<<\"A cosa ti serve il sale? Allo stato grezzo non è utilizzabile, va lavorato prima di essere commestibile.\">>","\n","^<<\"Se vuoi assaggiare il nostro sale nel cibo, devi andare a ovest nel Redsee fino a Eccria. Abbiamo un contratto esclusivo con i mercanti di lì. Non possiamo vendere a qualunque Glider passi di qua.\">>","\n",{"#":"inventory_add: SaltPlainPoolsPalette"},"^<<\"Hai fatto tanta strada, quindi farò di meglio. Ecco qualcosa per la tua hoverbike laggiù.\">>","\n","^<<\"Prego.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-2":["^ ","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"#f":1}],"salt_plains_harvester_dane":["ev","str","^Raccoglitore di Sale Dane","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Ah, una Glider! Non ne abbiamo avuta una qui da un po'!\">>","\n","^<<\"Sembra ieri che partivo per il mio Volo. Andai giù alla Marrowbone Station nel Wash.\">>","\n","^<<\"A vedere Pyrausta, quasi mi facevo addosso.\">>","\n","^<<\"Non ho mai capito se fosse una formazione rocciosa naturale o una statua scolpita. Sentii anche uno a Eccria che diceva che fosse viva!\">>","\n","^<<\"Un wyrm, così grosso! Te lo immagini?! Credo che se pensassi davvero potesse essere così, non dormirei tanto bene.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"plantweaver_rachel":["ev","str","^Tessitrice di Piante Rachel","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Oh, ciao.\">>","\n",{"->":".^.rachel_meeting"},{"rachel_meeting":[["ev","str","^Che posto è questo?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Chi sei?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Ci si vede.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^<<\"Queste terme sono antiche. Non ne avevo mai sentito parlare prima...\">>","\n","^<<\"Sembra usino il flusso delle acque calde dentro le rocce e le facciano circolare attraverso le terme.\">>","\n","^<<\"Immagina questo posto come delle terme? Doveva venir gente da ogni dove a riposare e ristabilirsi.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-1":["^ ","\n","^<<\"Mi chiamo Rachel. Sono una Tessitrice di Piante.\">>","\n","^Non ho mai sentito parlare di una Tessitrice di Piante. Quello è un... alberello dentro quella sfera di vetro?","\n","^<<\"Curiamo le piante, che si tratti di un Rijwur in difficoltà nel selvatico o di una germogliante prole di Funghi Malinconici in un giardino coltivato.\">>","\n","^<<\"Senza le piante, la vita cesserebbe di esistere.\">>","\n","^<<\"Sono venuta con la Scalatrice e il Cacciatore, ma credo resterò qui. Questo posto ha qualcosa di speciale. Credo che alcune flore inusuali prospererebbero qui; non ho mai visto certe cose crescere come qui.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-2":["^ ","\n","^<<\"Stammi bene.\">>","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"#f":1}],"eastern_ring_monument":[{"->t->":".^.intro"},"ev",{"VAR?":"debug_found_eastern_monument"},0,"==","/ev",[{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.interaction_point"},{"->":".^.^.^.7"},null]}],"nop","\n",{"->":".^.done"},{"intro":["^Ti trovi al Monumento dell'Anello delle Dune Orientali.","\n","ev","void","/ev","->->",{"#f":1}],"interaction_point":["^Entro nel monumento.","\n","ev",1,"/ev",{"VAR=":"debug_found_eastern_monument","re":true},"ev",{"VAR?":"RING_SHRINE_QUEST_EASTERN_DUNES_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"->t->":"an_ancient_race_debug_pick_up_item"},"ev","void","/ev","->->",{"#f":1}],"done":["^Lascio il monumento dell'anello.","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"angler_yolanda":[["ev",{"VAR?":"speaker_yolanda"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Salve! Come posso aiutarti oggi?\">>","\n","ev","str","^Vorrei commerciare!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Parlami di questo posto.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Che bella barca!","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Non ho bisogno di nulla.","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^ ","\n",{"#":"StartTrading"},"^<<\"Magnifico! Certo! Dai un'occhiata alla mia merce.\">>","\n","^<<\"Grazie, Glider. Torna quando vuoi.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Parlarti di questo posto?\">>","\n","^<<\"Beh, se hai mai mangiato pesce fresco entro un raggio di un'ora, c'è dal sessanta al settanta percento di probabilità che venisse proprio da qui. Forse ottanta nelle stagioni in cui abboccano <i>davvero</i>.\">>","\n","^È in effetti una percentuale notevole, e credo di rispondere con quel 'hmm!' acuto in fondo alla gola che merita.","\n","^<<\"Tante Glider passano di qua, come te. E se sono indicative, credo ti godrai il tempo da queste parti.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Oh, lo so. Splendida, vero? Qualcosa di così nobile e al tempo stesso rustico, e sapendo quanto fornisce! Ispiratrice. Ma personalmente?\">>","\n","^Abbassa un po' la voce, e poi recita un sussurro che copre una risata sfacciata.","\n","^<<\"Penso che il suo <i>capitano</i> sia ancora <i>più</i> bello! Vorrei stesse pescando <i>me</i>!\">>","\n","^Lascio andare un'esclamazione scherzosa.","\n","^<<\"Ma scherzo, scherzo...\">>","\n","^<<\"A meno che non sia interessato. Allora sono <i>profondamente</i> seria!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Addio!\">>","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"eastern_dunes_lia_conversation":[["ev","str","^Pastora Lia","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Ben trovata, Glider!\">>","\n","ev","str","^Avevamo capre nel mio clan","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Cosa c'è in quella fiala di vetro?","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^Che storia è quella della statua?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Ci si vede.","/str","/ev",{"*":".^.c-3","flg":4},{"c-0":["^ ","\n","^<<\"Ah, allora conosci il loro temperamento. Sei Ibexii suppongo? Salutami Umar e Jadi.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-1":["^ ","\n",{"#":"inventory_add: SaltPlainPoolsPalette"},"^<<\"Oh, l'ho fatta io. È una palette di colori per hoverbike, ispirata al mio lavoro di pastora. Tieni, prendine un po'. Insisto!\">>","\n","^<<\"Sarei molto fiera di vederti su una hoverbike con i miei colori, Sable!\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-2":["^ ","\n","^<<\"Ah, forse la riconosci, Oana. Era una grande pastora, di molte creature. Si dice venisse dalla Whale e abbia condotto gli antenati delle creature che pascoliamo oggi.\">>","\n","^<<\"Insegniamo che tenere la propria mandria vicino alle sue statue la manterrà unita, ben nutrita e sana.\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-3":["^ ","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"hercules_innkeeper_conversation":["ev","str","^Ifaa","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.17"},null],"#f":5}],"\n",{"->":".^.first_loop"},{"first_intro":["^Incontro Ifaa, la locandiera del campo.","\n","ev","void","/ev","->->",{"#f":1}],"default_intro":["^<<\"Salute, Glider.\">>","\n","ev","void","/ev","->->",{"#f":1}],"first_loop":["^<<\"Cosa posso fare per te?\">>","\n",{"->":".^.^.opts"},{"#f":1}],"loop":["^<<\"Posso fare qualcos'altro per te?\">>","\n",{"->":".^.^.opts"},{"#f":3}],"opts":[["ev",{"^->":"searching_for_llhor_content.first_clue"},{"^->":"hercules_innkeeper_conversation.loop"},"/ev","thread",{"->":"thread_in_tunnel"},"ev",{"^->":"hercules_beetle_quest_content"},{"^->":"hercules_innkeeper_conversation.loop"},"/ev","thread",{"->":"thread_in_tunnel"},"ev","str","^Saluta.","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.done"},{"#f":5}]}],{"#f":1}],"done":["^<<\"Addio, Glider.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"utarii_conversation":["ev",{"VAR?":"speaker_utarii"},"/ev",{"VAR=":"SpeakerName","re":true},["ev",{"CNT?":".^.^.first_intro"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.^.6"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.^.6"},null]}],"nop","\n",{"->":".^.options"},{"done":["^Saluto Utarii.","\n",{"->":"END_SCENE"},{"#f":3}],"first_intro":[["ev",{"VAR?":"speaker_machinist"},"/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"TUT_MAIN_MET_UTARII"},{"f()":"activate"},"pop","/ev","\n","^La Macchinista mi guarda da capo a piedi.","\n","^<<\"Sei in ritardo.\">>","\n","ev","str","^Per cosa?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non ti ho mai vista in vita mia.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Sono perfettamente puntuale!","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^<<\"Per il nostro incontro. Avresti dovuto arrivare prima.\">>","\n","^Chiedo alla Macchinista come fa a conoscermi.","\n","^<<\"Non ti conosco. Non ancora.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Mi avresti incontrata prima, se non fosse per il tuo ritardo. Ma ti perdono. Ogni amica di Sizo mi è cara all'istante e non me la prendo.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"No.\">>","\n",{"#":"gesture_partner: thinking"},"^Dico di sì. Almeno ci pensa.","\n",{"#":"gesture_partner: dismissive"},"^<<\"Hmm. No, sei in ritardo...\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Perplessa, aspetto che si spieghi, ma sembra aspettarsi la stessa cosa da me.","\n",{"#":"gesture_sable: thinking"},"^Brevemente provo un velo di vergogna nel ricordare le volte in cui sono stata in ritardo tra gli Ibexii, le cose in cui ho sbagliato.","\n",{"#":"gesture_sable: talking"},"^Ma scaccio i dubbi ricordando che non ho idea di chi sia questa strana Macchinista. Glielo chiedo.","\n","ev",{"VAR?":"speaker_utarii"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Mi chiamo Utarii. Ciò che ti riguarda subito è che sono un'amica di Sizo.\">>","\n",{"#":"gesture_sable: talking"},"^Chiedo allora se Sizo l'avesse avvisata del mio imminente arrivo. Forse veglia su di me, e dispone punti di passaggio e oasi lungo il mio Volo. Un pensiero confortante.","\n",{"#":"gesture_partner: explaining"},"^<<\"No, no, no. È stata la tua hoverbike. L'ho sentita per la prima volta mesi fa, e ho percepito la forma della sua voce — della <i>sua</i> voce, scusa.\">>","\n",{"#":"gesture_partner: dismissive"},"^Dico a Utarii che non era Simoon quella che ha sentito, perché Sizo e io l'abbiamo costruita solo pochi giorni fa. Mi liquida con un gesto frettoloso delle mani.","\n","^<<\"Sizo ti ha insegnato così poco? Le voci delle nostre macchine sono eterne, più antiche persino delle loro forme. Le sento. Come sempre. E pensavo che la tua sarebbe tornata da me prima. Ma... eccoci.\">>","\n","^<<\"Ora parliamo del <i>perché</i> sei venuta.\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"default_intro":[{"#":"gesture_partner: greeting"},"^Utarii mi saluta calorosamente.","\n","^<<\"Come posso aiutare?\">>","\n","ev","void","/ev","->->",{"#f":1}],"options":[["ev",{"VAR?":"A_STUBBORN_SNAG_FIXED_TOWER"},{"VAR?":"A_STUBBORN_SNAG_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->t->":"a_stubborn_snag_content"},{"->":".^.^.^.6"},null]}],"nop","\n","ev",{"^->":"a_stubborn_snag_content"},{"^->":"utarii_conversation.done"},"/ev","thread",{"->":"thread_in_tunnel"},"ev","str","^Personalizza hoverbike","/str",{"x()":"has_bike_parts"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Addio","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"#":"StartCustomization"},"^<<\"Diamogli un'occhiata, sì?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^.^.done"},{"#f":5}]}],{"#f":1}],"#f":1}],"eliisabet_conversation":["ev","str","^Eliisabet","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev",{"CNT?":".^.^.first_intro"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.^.8"},null]}],"nop","\n",{"->t->":".^.quest_content"},{"->":".^.done"},{"done":["^Saluto Eliisabet.","\n",{"->":"END_SCENE"},{"#f":1}],"first_intro":["^Eliisabet era una guardia di stanza a Eccria, ma ora viaggia.","\n","ev","void","/ev","->->",{"#f":1}],"default_intro":["^Eliisabet saluta.","\n","ev","void","/ev","->->",{"#f":1}],"quest_content":[["ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"daydreams_of_wanderlust_content"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"TOUGH_NUT_TO_CRACK_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":"tough_nut_to_crack_content"},{"->":".^.^.^.4"},null]}]