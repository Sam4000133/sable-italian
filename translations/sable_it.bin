pleted","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"WHERE_THE_CAMELS_ARE_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Mateo mi ha detto che hanno perso traccia della mandria.","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"WHERE_THE_CAMELS_ARE_STARTED"},{"VAR?":"WHERE_THE_CAMELS_ARE_ROUNDED_UP_CAMELS"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Ci sono tre cammelli da trovare.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"WHERE_THE_CAMELS_ARE_ROUNDED_UP_CAMELS"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sono riuscita a radunare tutti i cammelli.","\n",{"->":".^.^.^.32"},null]}],"nop","\n","ev",{"VAR?":"WHERE_THE_CAMELS_ARE_ROUNDED_UP_CAMELS"},{"VAR?":"WHERE_THE_CAMELS_ARE_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: quest_giver"},"^Dovrei tornare da Mateo.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","ev",{"VAR?":"WHERE_THE_CAMELS_ARE_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Mateo è molto grato che abbia trovato la sua mandria.","\n",{"->":".^.^.^.47"},null]}],"nop","\n","end",{"#f":1}],"tough_nut_num_butterflies":["ev",{"VAR?":"DEBUG"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"tough_nut_debug_butterfly_count"},"/ev","~ret",{"->":".^.^.^.5"},null]}],[{"->":".^.b"},{"b":["\n","ev","str","^NimoorButterflies","/str",{"x()":"inventory_get_quantity","exArgs":1},"/ev","~ret","\n",{"->":".^.^.^.5"},null]}],"nop","\n",{"#f":1}],"have_enough_butterflies":["ev",{"f()":"tough_nut_num_butterflies"},3,">=","/ev","~ret","\n",{"#f":1}],"eliisabet_parasite_conversation":["ev",{"VAR?":"speaker_eliisabet"},"/ev",{"VAR=":"SpeakerName","re":true},{"->t->":"tough_nut_to_crack_content"},{"->":"END_SCENE"},{"#f":1}],"tough_nut_to_crack_content":[["ev",{"VAR?":"TOUGH_NUT_TO_CRACK_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_start"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"TOUGH_NUT_TO_CRACK_STARTED"},{"VAR?":"TOUGH_NUT_TO_CRACK_COMPLETED"},{"f()":"between"},{"f()":"have_enough_butterflies"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_active"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"TOUGH_NUT_TO_CRACK_STARTED"},{"VAR?":"TOUGH_NUT_TO_CRACK_COMPLETED"},{"f()":"between"},{"f()":"have_enough_butterflies"},"&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_complete"},{"->":".^.^.^.4"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.post_quest_chat"},{"->":".^.^.^.4"},null]}],"nop","\n",{"quest_start":[["ev",{"VAR?":"TOUGH_NUT_TO_CRACK_STARTED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_partner: wave"},"^<<\"Beh, guarda chi c'è! La mia glider preferita. Stranamente, stavo proprio pensando a te.\">>","\n","ev","str","^Stavo pensando anch'io a te!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non ti avevo riconosciuta!","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"#":"gesture_partner: talking"},"^<<\"Davvero? Beh, sembra destino, a me. O almeno un po' di buona sorte, che francamente basta e avanza.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_partner: talking"},"^<<\"Ah! Beh, come potresti, vista quanto magra e nervosa sono diventata in questo secondo volo? Sto passando da forma da combattimento a forma da viaggio. Questo vecchio corpo non mi tradisce mai.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"gesture_partner: laugh"},"^Eliisabet ridacchia, le mani sui fianchi. Le chiedo perché pensava a me.","\n",{"#":"gesture_partner: thinking"},"^<<\"Perché stavo considerando tutte le cose che non sono riuscita a vedere durante il mio primo volo. Avevo una tale fretta di arrivare a Eccria e diventare guardia che il mio volo è stato più una... trafittura. Un colpo dritto verso la grande città.\">>","\n","^<<\"Prima che me ne accorgessi, erano passati anni del mio cammino e non avevo mai visto Hakoa, mai nuotato in laghi sotterranei, mai capito cosa c'è dentro una pianta Nimoor...\">>","\n","ev",{"f()":"have_enough_butterflies"},"/ev",[{"->":".^.b","c":true},{"b":["^ ",{"->":".^.^.^.^.^.^.edge_case"},{"->":".^.^.^.12"},null]}],"nop","\n","ev","str","^Ti piacerebbe?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Non credo di saperlo neanch'io.","/str","/ev",{"*":".^.c-3","flg":4},{"c-2":["^ ","\n",{"#":"gesture_sable: talking"},"^Le chiedo se vorrebbe vedere fino in fondo cosa c'è dentro le piante Nimoor.","\n",{"#":"gesture_partner: thinking"},"^<<\"Sai, mi piacerebbe!\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n","^Le dico che neanch'io so cosa ci sia dentro una pianta Nimoor.","\n","^<<\"Beh, mi piacerebbe scoprirlo!\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Sono sicura di averne incrociate alcune quando sono passata per la Foresta Pietrificata, ma era giorno, e il sole le fa richiudere subito.\">>","\n",{"#":"gesture_partner: laugh"},"^<<\"Anche se forse avevo troppa fretta per guardare davvero. Vecchie abitudini, eh?\">>","\n","^<<\"Comunque, non credo che tornerò di nuovo da quelle parti a breve, purtroppo. Quindi se per caso ti capita di imbatterti in una, magari potresti aprirla e farmi sapere cosa trovi?\">>","\n","^<<\"Qualcosa deve farla brillare, no?\">>","\n",{"#":"gesture_sable: talking"},"^Qualcosa in lei mi spinge all'azione e prometto troppo in fretta che gliela mostrerò. Mi sento spinta a impressionarla, anche solo un poco.","\n",{"#":"gesture_partner: thanks"},"^<<\"Cosa! Non devi farlo, io-- Oh, cosa sto dicendo? Sono in pensione, sto facendo il mio volo e voglio quello che voglio. Apri una pianta Nimoor e portami qualunque cosa ci sia dentro.\">>","\n",{"#":"gesture_partner: laugh"},"^<<\"E speriamo non sia qualche orrenda melma velenosa!\">>","\n","ev","str","^Lo spero anch'io.","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Sarebbe quasi divertente.","/str","/ev",{"*":".^.c-5","flg":4},"ev","str","^Scommetto che è esattamente quello.","/str","/ev",{"*":".^.c-6","flg":4},{"c-4":["^ ","\n",{"#":"gesture_sable: laugh"},"^Le dico che sì, anch'io spero di non aprire la pianta Nimoor solo per beccarmi una scarica di melma caustica. Sarebbe difficile, aggiungo, pilotare Simoon con dita di scheletro-- per non parlare del dover poi raccontarle com'è andata.","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-5":["^ ","\n",{"#":"gesture_sable: laugh"},"^Le dico che sarebbe quasi divertente scoprire che qualcosa di così carino nasconde un segreto mortale, ma che mi dispiacerebbe tornare da lei a dirle che sono morta nel tentativo.","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-6":["^ ","\n",{"#":"gesture_sable: laugh"},"^Dico che probabilmente <i>è</i> piena di veleno mortale, e chiedo se preferirebbe che evitassi di portargliela, se così fosse.","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":["^Eliisabet ride.","\n",{"#":"gesture_partner: laugh"},"^<<\"Sì, sarebbe un po' una delusione.\">>","\n","^Con i miei ordini di marcia, saluto Eliisabet e me ne vado.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_active":["^<<\"Hai scoperto cosa c'è dentro le piante Nimoor?\">>","\n","ev","void","/ev","->->",{"#f":1}],"edge_case":[{"#":"gesture_partner: surprised_1"},"^Ecco, qui posso aiutare! Prima che si abbandoni alla nostalgia, le dico che so già cosa c'è dentro una pianta Nimoor. Batte le mani.","\n","^<<\"Non è vero! O sì?\">>","\n","^Il pensiero di poter aiutare Eliisabet con qualcosa che ho trovato lungo il cammino mi scalda. È un piccolo promemoria del senso del Volo.","\n","^Le mostro le farfalle che ho raccolto.","\n","ev","void","/ev","->->",{"#f":1}],"quest_complete":[["ev",{"VAR?":"TOUGH_NUT_TO_CRACK_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_partner: ecstatic"},"^<<\"Incredibile!\">>","\n","^Eliisabet è rapita dallo stupore.","\n",{"#":"gesture_partner: laugh"},"^<<\"Farfalle. Chi l'avrebbe mai detto? Se mi avessero dato mille tentativi, non l'avrei mai indovinato. <i>Adoro</i> le farfalle, tu no?\">>","\n",{"#":"gesture_partner: explaining"},"^<<\"Volteggiano per il mondo lungo i loro piccoli sentieri, danzando da sole nel vento, ma sembrano così felici quando si incontrano.\">>","\n","^Come noi, penso.","\n",{"#":"gesture_sable: laugh"},{"#":"gesture_partner: laugh"},"^<<\"Un po' come noi, credo!\">>","\n",{"#":"gesture_partner: thinking"},"^Guarda di nuovo l'orizzonte.","\n",{"#":"gesture_sable: thanks"},"^<<\"Grazie, sei una meraviglia. E ti prego, prendi questo. Un altro distintivo per la giovane glider raccoglitrice di Nimoor e domatrice di farfalle che mi è stata di tanto aiuto.\">>","\n",{"#":"inventory_remove: NimoorButterflies, 3"},{"#":"inventory_add: GuardsBadge"},"^Prendo il distintivo e lo metto via. Ho sempre pensato che le guardie fossero severe e stoiche. Ma Eliisabet è luminosa, gioiosa. È una cosa potente.","\n","^<<\"Il prossimo nella mia lista è Hakoa; ho deciso che vale la pena fare il viaggio. Augurami buona fortuna, e io augurerò che i nostri sentieri si incrocino di nuovo.\">>","\n","ev","str","^Ho la sensazione che lo faranno.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Buona fortuna anche a te.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Spero succeda presto!","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"gesture_sable: wave"},"^Con un saluto, dico arrivederci a Eliisabet e mi metto in cammino.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"post_quest_chat":["^<<\"A presto, spero. Stammi bene, Sable.\">>","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"tough_nut_to_crack_quest_debug":[["ev","str","^Raccogli farfalle","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["\n","ev",3,"/ev",{"VAR=":"tough_nut_debug_butterfly_count","re":true},"^Raccolgo le farfalle per Eliisabet. Sarà felice di vederle.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":3}],"tough_nut_to_crack_quest_definition":[{"#":"name"},"^Un Osso Duro","\n",{"#":"locations"},"^quest_giver, petrified_forest","\n",{"#":"items"},"ev","str","^NimoorButterflies","/str","out","/ev","\n",{"#":"status"},["ev",{"VAR?":"TOUGH_NUT_TO_CRACK_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.18"},null]}],["ev",{"VAR?":"TOUGH_NUT_TO_CRACK_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.18"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.18"},null]}],"nop","\n","ev",{"VAR?":"TOUGH_NUT_TO_CRACK_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Eliisabet mi ha chiesto di scoprire cosa c'è dentro una pianta Nimoor.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"TOUGH_NUT_TO_CRACK_STARTED"},{"VAR?":"TOUGH_NUT_DISCOVERED_BUTTERFLIES"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: petrified_forest"},{"#":"status: active"},"^Dovrei andare alla Foresta Pietrificata e provare ad aprire una pianta Nimoor. Eliisabet dice che aprono i loro bulbi solo di notte.","\n",{"->":".^.^.^.33"},null]}],"nop","\n","ev",{"VAR?":"TOUGH_NUT_DISCOVERED_BUTTERFLIES"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho aperto una pianta Nimoor e ne sono volate fuori delle farfalle luminose! Ecco cosa le fa brillare.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","ev",{"VAR?":"TOUGH_NUT_DISCOVERED_BUTTERFLIES"},{"VAR?":"TOUGH_NUT_TO_CRACK_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"f()":"tough_nut_num_butterflies"},3,"<","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: petrified_forest"},"^Dovrei raccogliere tre farfalle per Eliisabet.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"locations: quest_giver"},{"#":"status: active"},"^Dovrei portare queste farfalle a Eliisabet.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.48"},null]}],"nop","\n","ev",{"VAR?":"TOUGH_NUT_TO_CRACK_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho mostrato le farfalle a Eliisabet.","\n",{"->":".^.^.^.55"},null]}],"nop","\n","end",{"#f":1}],"bones_of_rohana_content":[["ev",{"VAR?":"BONES_OF_ROHANA_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"BONES_OF_ROHANA_STARTED"},{"VAR?":"BONES_OF_ROHANA_OPENED_FACE_DOOR"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_active"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"BONES_OF_ROHANA_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_complete"},{"->":".^.^.^.3"},null]}],"nop","\n","ev","void","/ev","->->",{"quest_start":["ev",{"VAR?":"BONES_OF_ROHANA_STARTED"},{"f()":"activate"},"pop","/ev","\n","^<<\"È un po' imbarazzante, giovane glider, ma puoi aiutarmi a radunare la mia mandria?\">>","\n","ev","void","/ev","->->",{"#f":1}],"quest_active":["^<<\"Per favore, aiutami a trovare i miei cammelli!\">>","\n","ev","void","/ev","->->",{"#f":1}],"quest_complete":["ev",{"VAR?":"BONES_OF_ROHANA_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Grazie mille! È stato un viaggio, sarai d'accordo! Hah!\">>","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"bones_of_rohana_quest_definition":[{"#":"name"},"^Ossa di Rohana","\n",{"#":"locations"},"^quest_giver","\n",{"#":"status"},["ev",{"VAR?":"BONES_OF_ROHANA_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"BONES_OF_ROHANA_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"BONES_OF_ROHANA_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Mateo mi ha detto che hanno perso traccia della mandria.","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"BONES_OF_ROHANA_STARTED"},{"VAR?":"BONES_OF_ROHANA_OPENED_FACE_DOOR"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Ci sono tre cammelli da trovare.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"BONES_OF_ROHANA_OPENED_FACE_DOOR"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sono riuscita a radunare tutti i cammelli.","\n",{"->":".^.^.^.32"},null]}],"nop","\n","ev",{"VAR?":"BONES_OF_ROHANA_OPENED_FACE_DOOR"},{"VAR?":"BONES_OF_ROHANA_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: quest_giver"},"^Dovrei tornare da Mateo.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","ev",{"VAR?":"BONES_OF_ROHANA_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Mateo è molto grato che abbia trovato la sua mandria.","\n",{"->":".^.^.^.47"},null]}],"nop","\n","end",{"#f":1}],"num_glowing_mushrooms":["ev",{"VAR?":"DEBUG"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"glowing_mushrooms_debug_quantity"},"/ev","~ret",{"->":".^.^.^.5"},null]}],[{"->":".^.b"},{"b":["\n","ev","str","^GlowingMushrooms","/str",{"x()":"inventory_get_quantity","exArgs":1},"/ev","~ret","\n",{"->":".^.^.^.5"},null]}],"nop","\n",{"#f":1}],"have_enough_mushrooms":["ev",{"f()":"num_glowing_mushrooms"},5,">=","/ev","~ret","\n",{"#f":1}],"eliisabet_slicer_conversation":["ev",{"VAR?":"speaker_eliisabet"},"/ev",{"VAR=":"SpeakerName","re":true},{"->t->":"luminescent_adolescent_content"},{"->":"END_SCENE"},{"#f":1}],"luminescent_adolescent_content":[["ev",{"VAR?":"LUMINESCENT_ADOLESCENT_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"LUMINESCENT_ADOLESCENT_STARTED"},{"VAR?":"LUMINESCENT_ADOLESCENT_COMPLETED"},{"f()":"between"},{"f()":"have_enough_mushrooms"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_active"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"LUMINESCENT_ADOLESCENT_STARTED"},{"VAR?":"LUMINESCENT_ADOLESCENT_COMPLETED"},{"f()":"between"},{"f()":"have_enough_mushrooms"},"&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_complete"},{"->":".^.^.^.4"},null]}],[{"->":".^.b"},{"b":["\n","^<<\"A presto, spero. Stammi bene, Sable.\">>","\n",{"->":".^.^.^.4"},null]}],"nop","\n","ev","void","/ev","->->",{"quest_start":["ev",{"VAR?":"LUMINESCENT_ADOLESCENT_STARTED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_sable: greeting"},{"#":"gesture_partner: greeting"},"^<<\"Beh, guarda chi si vede! Che probabilità c'erano? Sembri stare bene, amica.\">>","\n",{"#":"gesture_sable: laugh"},"^Amica! Faccio l'aria disinvolta, e non può vedermi sorridere mentre le chiedo come sia capitata qui.","\n","^<<\"Beh, avevo pianificato di entrare a Hakoa per bene, ma per quanta fiducia abbia in queste vecchie ossa, non mi andava di vagare nelle terre desolate troppo a lungo.\">>","\n","^<<\"Peccato, però... speravo di prendere qualche fungo luminoso. Se riesci a superare le pozze sulfuree, fanno un bello spuntino.\">>","\n",{"#":"gesture_sable: talking"},"^Le dico che non sapevo fossero commestibili; ne avevo visti tra le provviste di Driss, una volta, e mi aveva detto che erano velenosi e di non toccarli mai.","\n",{"#":"gesture_partner: laugh"},"^<<\"Oh, sono eccome commestibili! L'ho scoperto durante una serata molto divertente a Eccria. Diciamo che c'è argomento per dire che questo è il mio <i>terzo</i> volo, se conto la nottata che ho passato come secondo.\">>","\n","^Ride al ricordo. E io rivaluto sfacciatamente diverse cose riguardo a Driss.","\n","^<<\"Hai già fatto abbastanza per me, ovviamente, ma... se ti capitasse di imbatterti in quei piccoli funghi luminosi, ne vorrei qualcuno. Crescono in una grotta alle pozze sulfuree, lontano a sud da qui.\">>","\n","ev","void","/ev","->->",{"#f":1}],"quest_active":["^<<\"Fammi sapere se trovi quei funghi!\">>","\n","ev","void","/ev","->->",{"#f":1}],"quest_complete":[["ev",{"VAR?":"LUMINESCENT_ADOLESCENT_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^Quando torno, Eliisabet sta affilando un coltello dall'impugnatura intagliata e canticchia una melodia che sembra al tempo stesso nuova e familiare. Il suono della sua voce è calmante, poi, ma esplode in un benvenuto.","\n",{"#":"gesture_partner: wave"},"^<<\"Ritorna! Trionfante, scommetto.\">>","\n","^Lo confermo con una manciata di funghi e lei se li avvicina al viso per annusarli. Mentre inspira, osservo i bordi consumati della sua maschera.","\n","^La fronte sbiancata dal sole, l'usura dell'età, i segni che si addicono a una guardia veterana. Ricordo che prima di tutto questo lei ha visto combattimenti. Pericolo. Avventura.","\n","^C'è una linea profonda e storta lungo la guancia dove deve averla ricomposta dopo una rottura, e mi chiedo cosa o chi le abbia fatto il danno.","\n","^Scommetto che pensavano di aver vinto, che fosse battuta, finché non hanno visto il sorriso di Eliisabet messo a nudo, sanguinante e pericoloso.","\n","^Mette via i funghi e tira fuori un terzo distintivo.","\n","^<<\"Un altro pegno della mia amicizia. E anche una piccola spinta, se mai decidessi di diventare guardia. Come me.\">>","\n","ev","str","^Credo che mi piacerebbe.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non sono sicura sia la cosa giusta per me.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^<<\"Oh davvero? Bene, bene, bene, che interessante! Non l'avevi mai detto in tutto questo tempo!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Potrebbe non esserlo, e da me non sentirai pressioni in nessuna direzione.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"gesture_partner: talking"},"^<<\"Per quel che vale, penso saresti brava. Hai un occhio attento, un atteggiamento d'aiuto, e abbastanza pazienza per ascoltare per secoli questa vecchia ciarlare! Il resto si impara.\">>","\n","^<<\"E sarei felice di insegnartelo.\">>","\n",{"#":"gesture_sable: thanks"},"^La ringrazio, e le dico che ci penserò.","\n","^<<\"Non pensarci troppo. So che ti sembra che qualunque cosa tu scelga sia tua per sempre, ma è una delle tante scelte che farai, e nemmeno la più grande.\">>","\n","^<<\"Questo volo che stai facendo è solo il primo. C'è ancora un sacco di vita da vivere.\">>","\n",{"#":"gesture_partner: laugh"},"^Le chiedo dove sia diretta. Ride.","\n","^<<\"In questi funghi, intanto.\">>","\n","^<<\"E poi, chissà? Ovunque mi senta spinta ad andare. Ma sono sicura che ci ritroveremo.\">>","\n",{"#":"inventory_remove: GlowingMushrooms, 5"},{"#":"inventory_add: GuardsBadge"},{"#":"gesture_sable: greeting"},"^Mi inchino a Eliisabet e la saluto per ora.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"#f":1}],"luminescent_adolescent_quest_debug":[["ev","str","^Raccogli funghi","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["\n","ev",5,"/ev",{"VAR=":"glowing_mushrooms_debug_quantity","re":true},"^Raccolgo dei funghi luminosi. Si vedono anche attraverso il tessuto.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":3}],"luminescent_adolescent_quest_definition":[{"#":"name"},"^Adolescente Luminescente","\n",{"#":"locations"},"^quest_giver, mushroom_cave","\n",{"#":"items"},"ev","str","^GlowingMushrooms","/str","out","/ev","\n",{"#":"status"},["ev",{"VAR?":"LUMINESCENT_ADOLESCENT_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.18"},null]}],["ev",{"VAR?":"LUMINESCENT_ADOLESCENT_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.18"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.18"},null]}],"nop","\n","ev",{"VAR?":"LUMINESCENT_ADOLESCENT_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Eliisabet voleva che trovassi dei funghi luminosi. Ha detto che crescono in una grotta vicino alle pozze sulfuree.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"LUMINESCENT_ADOLESCENT_STARTED"},{"VAR?":"LUMINESCENT_ADOLESCENT_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"f()":"have_enough_mushrooms"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: mushroom_cave"},{"#":"status: active"},"^Dovrei andare alle pozze sulfuree e raccogliere cinque funghi dalla grotta.","\n",{"->":".^.^.^.7"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"locations: quest_giver"},{"#":"status: active"},"^Dovrei riportare i funghi a Eliisabet.","\n",{"->":".^.^.^.7"},null]}],"nop","\n",{"->":".^.^.^.33"},null]}],"nop","\n","ev",{"VAR?":"LUMINESCENT_ADOLESCENT_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho riportato i funghi a Eliisabet.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","end",{"#f":1}],"num_lightning_crystals":["ev",{"VAR?":"DEBUG"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"lightning_crystals_debug_quantity"},"/ev","~ret",{"->":".^.^.^.5"},null]}],[{"->":".^.b"},{"b":["\n","ev","str","^LightningCrystal","/str",{"x()":"inventory_get_quantity","exArgs":1},"/ev","~ret","\n",{"->":".^.^.^.5"},null]}],"nop","\n",{"#f":1}],"have_enough_lightning_crystals":["ev",{"f()":"num_lightning_crystals"},3,">=","/ev","~ret","\n",{"#f":1}],"lightning_in_a_shard_content":[["ev",{"VAR?":"LIGHTNING_IN_A_SHARD_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.2"},null]}],["ev",{"VAR?":"LIGHTNING_IN_A_SHARD_STARTED"},{"VAR?":"LIGHTNING_IN_A_SHARD_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_active"},{"->":".^.^.^.2"},null]}],"nop","\n","ev","void","/ev","->->",{"quest_start":[["ev","str","^Chiedi un Distintivo del Macchinista","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"gesture_partner: laugh"},"^Ridacchia profondamente in petto.","\n","^<<\"Qualcuno ti ha detto che li regaliamo?\">>","\n","^<<\"Se vuoi un distintivo, devo sapere che sei qualcuno in grado di guadagnarselo.\">>","\n","ev","str","^Oh, lo sono.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Nessun problema!","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Sei venuta nel posto giusto.","/str","/ev",{"*":".^.c-3","flg":4},{"c-1":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":[{"#":"gesture_partner: arms_crossed"},"^Sento il sorrisetto. Non mi prende in giro, però, solo si diverte.","\n","^<<\"Non ci hai pensato due volte. Mi piace. Sei mai stata al Crystal Plateau?\">>","\n","ev","str","^Sì","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^No","/str","/ev",{"*":".^.c-5","flg":4},{"c-4":["^ ","\n","^Con tutta la disinvoltura possibile, dico di averlo visto.","\n","^<<\"Eh. Bene. Allora sarà una passeggiata per te, vero?\">>","\n",{"#":"gesture_partner: laugh"},"^Un'altra risatina.","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-5":["^ ","\n",{"#":"gesture_partner: laugh"},"^Scuoto la testa. Ride di nuovo.","\n","^<<\"Beh, non ti rovino la sorpresa.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":["^<<\"Fa' una scappata laggiù e raccoglimi qualche Cristallo Fulmine. Me ne porti tre, ti becchi un distintivo. E <i>io</i> riesco a finire i pezzi su cui sto lavorando.\">>","\n","^Annuisco e mi giro per andare, ma si schiarisce la voce per fermarmi.","\n","^<<\"Prima che tu vada... L'hai mai fatto prima?\">>","\n","ev","str","^Non proprio.","/str","/ev",{"*":".^.c-6","flg":4},"ev","str","^Ho raccolto altre cose!","/str","/ev",{"*":".^.c-7","flg":4},"ev","str","^Perché, cosa dovrei sapere?","/str","/ev",{"*":".^.c-8","flg":4},{"c-6":["^ ","\n",{"#":"gesture_partner: laugh"},"^Scuoto la testa e le dico che non ho molta esperienza nella raccolta di cristalli, ma che imparo in fretta. Ridacchia.","\n",{"->":".^.^.^.g-3"},{"#f":5}],"c-7":["^ ","\n",{"#":"gesture_sable: explaining"},"^Le dico che ho raccolto altre cose. Non mi chiede di che tipo, quindi non devo dirle che si trattava solo di radici, e penso che sia meglio così per tutti.","\n",{"->":".^.^.^.g-3"},{"#f":5}],"c-8":["^ ","\n","^Le chiedo cosa dovrei sapere sulla raccolta dei cristalli, e assumo la posa di una buona ascoltatrice.","\n",{"->":".^.^.^.g-3"},{"#f":5}],"#f":5}],"g-3":["^<<\"È un lavoro pericoloso. Prima di provare da sola, parla con Tohta — è il capo dei Coltivatori di Cristalli. Uomo di esperienza. E un amico.\">>","\n","^<<\"Lo troverai alla base dell'altopiano, a sud-ovest di qui. Punta verso i fulmini; non puoi sbagliare.\">>","\n",{"#":"gesture_sable: thanks"},"^La ringrazio per il consiglio.","\n","^<<\"Buona fortuna. Credo che ti servirà.\">>","\n","ev",{"VAR?":"LIGHTNING_IN_A_SHARD_STARTED"},{"f()":"activate"},"pop","/ev","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_active":[["^<<\"Hai preso quei cristalli?\">>","\n","ev","str","^Eccoli qui!","/str",{"f()":"have_enough_lightning_crystals"},"/ev",{"*":".^.c-0","flg":5},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev",{"VAR?":"LIGHTNING_IN_A_SHARD_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_partner: yes"},"^Le do i cristalli e annuisce in segno di approvazione, rigirandoseli tra le mani e ispezionando il bagliore crepitante di ognuno. Rimango impassibile, stavolta a braccia conserte.","\n","ev","str","^Allora. Cosa ne pensi?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Mica male, eh?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Sapevi esattamente in cosa mi stavi mandando, vero?","/str","/ev",{"*":".^.c-3","flg":4},{"c-1":["^ ","\n","^<<\"Penso che ti meriti un distintivo.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-2":["^ ","\n","^<<\"Niente male per niente. E un distintivo te lo sei guadagnato.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n","^<<\"E ce l'hai fatta. Quindi pare che avessi ragione a mandarti.\">>","\n","^Concedo con un'alzata di spalle; ha ragione.","\n","^<<\"E per il disturbo, ti sei guadagnata un distintivo.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^Zahra mi porge un Distintivo del Macchinista.","\n",{"#":"inventory_remove: LightningCrystal, 3"},{"#":"inventory_add: MachinistBadge"},{"#":"gesture_sable: thanks"},"^La ringrazio e le chiedo cosa intende fare con i cristalli.","\n","^<<\"Questa ti piacerà: sto costruendo pezzi per hoverbike. E sono felice di offrirli in baratto se hai voglia di fare qualcosa di grosso, veloce ed elettrico.\">>","\n","^Drizzo le orecchie.","\n","^<<\"Dovresti assemblarli tu stessa, ma... è così che leghi con una hoverbike, no? Mettendola insieme pezzo per pezzo.\">>","\n","^<i>Legare con una hoverbike.</i>","\n","^Penso al lieve ronzio statico che sento nelle mani quando il sole scalda la superficie di Simoon, e a come mi richiama alla mente una bestia che si crogiola. Leghiamo davvero, lei e io, no?","\n","^Dico a Zahra che sicuramente verrò dai Macchinisti la prossima volta che mi servirà roba del genere, e ci salutiamo.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"#f":3}],"lightning_in_a_shard_quest_debug":[["ev","str","^Raccogli cristalli fulmine","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["\n","ev",3,"/ev",{"VAR=":"lightning_crystals_debug_quantity","re":true},"^Salgo su un obelisco e raccolgo alcuni cristalli fulmine.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":3}],"lightning_in_a_shard_quest_definition":[{"#":"name"},"^Lampi nella Bottiglia","\n",{"#":"locations"},"^quest_giver, tohta, plateau","\n",{"#":"items"},"ev","str","^LightningCrystal","/str","out","/ev","\n",{"#":"status"},["ev",{"VAR?":"LIGHTNING_IN_A_SHARD_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.18"},null]}],["ev",{"VAR?":"LIGHTNING_IN_A_SHARD_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.18"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.18"},null]}],"nop","\n","ev",{"VAR?":"LIGHTNING_IN_A_SHARD_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Zahra, la Macchinista della Stazione Sette Sorelle, mi ha chiesto di prendere tre Cristalli Fulmine dal Crystal Plateau.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"LIGHTNING_IN_A_SHARD_STARTED"},{"VAR?":"LIGHTNING_IN_A_SHARD_LEARNT_TO_HARVEST"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: tohta"},{"#":"status: active"},"^Dovrei parlare con Tohta al Crystal Plateau per imparare come si raccolgono i cristalli.","\n",{"->":".^.^.^.33"},null]}],"nop","\n","ev",{"VAR?":"LIGHTNING_IN_A_SHARD_LEARNT_TO_HARVEST"},{"VAR?":"LIGHTNING_IN_A_SHARD_COMPLETED"},{"f()":"between"},{"f()":"have_enough_lightning_crystals"},"!","&&","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: plateau"},{"#":"status: active"},"^Devo raccogliere tre Cristalli Fulmine.","\n",{"->":".^.^.^.44"},null]}],"nop","\n","ev",{"f()":"have_enough_lightning_crystals"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sono andata al Plateau e ho raccolto i cristalli.","\n",{"->":".^.^.^.50"},null]}],"nop","\n","ev",{"VAR?":"LIGHTNING_IN_A_SHARD_LEARNT_TO_HARVEST"},{"VAR?":"LIGHTNING_IN_A_SHARD_COMPLETED"},{"f()":"between"},{"f()":"have_enough_lightning_crystals"},"&&","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: quest_giver"},{"#":"status: active"},"^Dovrei riportare i Cristalli Fulmine alla Macchinista Zahra.","\n",{"->":".^.^.^.60"},null]}],"nop","\n","ev",{"VAR?":"LIGHTNING_IN_A_SHARD_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho consegnato i Cristalli Fulmine alla Macchinista Zahra.","\n",{"->":".^.^.^.67"},null]}],"nop","\n","end",{"#f":1}],"a_stubborn_snag_content":[["ev",{"VAR?":"A_STUBBORN_SNAG_FIXED_TOWER"},{"VAR?":"A_STUBBORN_SNAG_STARTED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.edge_case"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"A_STUBBORN_SNAG_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"A_STUBBORN_SNAG_STARTED"},{"VAR?":"A_STUBBORN_SNAG_FIXED_TOWER"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_active"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"A_STUBBORN_SNAG_FIXED_TOWER"},{"VAR?":"A_STUBBORN_SNAG_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_complete"},{"->":".^.^.^.4"},null]}],"nop","\n","ev","void","/ev","->->",{"quest_start":[[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^<<\"I nostri bisogni convergono in cima alla Torre del Vento.\">>","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^<<\"Quel compito è ancora da svolgere, Glider.\">>","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Dimmi di più...","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"A_STUBBORN_SNAG_STARTED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Qualcosa ha fermato la Torre. Mancavano ore al mio andare a vedere di persona, ma alla fine sei arrivata tu con Simoon.\">>","\n","^<<\"Vai là, ripara ciò che è rotto o lenisci ciò che soffre... E io ti darò ciò che cerchi.\">>","\n",{"#":"gesture_sable: talking"},"^Chiedo a Utarii se sa cosa cerco. Ometto che potrei non saperlo neanch'io.","\n","^<<\"Una direzione.\">>","\n","^<<\"Ti aspetterò. Viaggia veloce e al sicuro.\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_active":["^<<\"Niente da fare con la Torre? Sono sicuro che la sistemerai presto. Il compito è fatto per te.\">>","\n","ev","void","/ev","->->",{"#f":1}],"quest_complete":[["ev",{"VAR?":"A_STUBBORN_SNAG_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^La gioia di Utarii è evidente, e la vedo già mentre mi avvicino. Irradia energia.","\n",{"#":"gesture_partner: ecstatic"},"^<<\"Ce l'hai fatta! Grazie, e ben fatto. Entrambe. Hai avuto molti problemi?\">>","\n","ev","str","^Nessuno!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Beh...","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"#":"gesture_partner: talking"},"^<<\"Certo che no. E perché dovresti? Eri destinata a farlo.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_partner: explaining"},"^<<\"Sei tornata illesa e luminosa. Quindi qualunque fosse il problema, era solo un ostacolo. Ricordatelo, la prossima volta che qualcosa <i>sembra</i> un guaio.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Ora, la tua... non dirò ricompensa. Ora, ciò che ti è dovuto.\">>","\n",[{"#":"gesture_sable: thanks"},{"#":"inventory_add: MachinistBadge"},"^Utarii estrae un Distintivo del Macchinista e me lo porge perché lo prenda.","\n","^<<\"Potresti essere arrivata tardi, ma sei qui dove sei destinata a essere.\">>","\n","^<<\"Ti do questo Distintivo non solo in riconoscimento di dove sei stata e di ciò che hai fatto, ma in onore di una delle tante possibilità.\">>","\n","^<<\"Che tu possa, se così desideri, diventare una di noi, che parlano la lingua inudita di Simoon e delle sue vaste connessioni.\">>","\n","^<<\"Questo Distintivo è solo uno, e dovrai guadagnarne altri, da altri che li portano. Ma se e quando lo farai, il Forgiatore saprà cosa hai scelto e potrai indossare la Maschera del Macchinista.\">>","\n",{"#":"gesture_sable: thinking"},"^Ringrazio Utarii e gli dico che ho molto su cui riflettere. Ma per un istante, sento un debolissimo squillo nell'orecchio sinistro, lontano e profondo, come un fiume sotto le sabbie.","\n","^<i>'Ascolta...'</i>","\n",{"->":"END_SCENE"},{"#f":5,"#n":"reward"}],{"#f":5}]}],{"#f":1}],"edge_case":["ev",{"list":{"a_stubborn_snag.A_STUBBORN_SNAG_STARTED":1,"a_stubborn_snag.A_STUBBORN_SNAG_COMPLETED":3}},{"f()":"activate"},"pop","/ev","\n","^<<\"Qualcosa ha fermato la Torre del Vento e-\">>","\n","^Fermo Utarii per spiegare che ho già aggiustato la Torre del Vento e vorrei poter vedere l'espressione sulla sua faccia.","\n",{"#":"gesture_partner: surprised_1"},"^<<\"L'hai già aggiustata?\">>","\n",{"#":"gesture_sable: fist_pump"},"^Mi dondolo sui talloni e dico di sì.","\n",{"#":"gesture_sable: laugh"},"^<<\"Beh perché non l'hai detto? Non sei in ritardo per niente, vero? Sei perfettamente puntuale e ti devo delle scuse. Spero le accetterai.\">>","\n","^Prima che possa dirgli se le accetto o no, mi travolge.","\n","^<<\"E <i>insisto</i> che tu accetti questo.\">>","\n",{"->":".^.^.quest_complete.0.g-0.reward"},{"#f":1}],"#f":3}],"a_stubborn_snag_quest_debug":[["ev","str","^Ripara il meccanismo della Torre del Vento","/str",{"VAR?":"A_STUBBORN_SNAG_FIXED_TOWER"},{"f()":"reached"},"!","/ev",{"*":".^.c-0","flg":5},{"c-0":["\n","ev",{"VAR?":"A_STUBBORN_SNAG_FIXED_TOWER"},{"f()":"activate"},"pop","/ev","\n","^Vedo dove il meccanismo si è inceppato e tiro un pezzo che sembra fuori posto.","\n","^Versa sabbia grossolana.","\n","^E poi con un sospiro che sembra di sollievo, ricomincia a girare. Sospiro anch'io, e ricordo una volta in cui mi tolsi una scheggia di vetro dal tallone.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":3}],"a_stubborn_snag_quest_definition":[{"#":"name"},"^Un Inceppo Testardo","\n",{"#":"locations"},"^quest_giver, wind_tower","\n",{"#":"status"},["ev",{"VAR?":"A_STUBBORN_SNAG_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"A_STUBBORN_SNAG_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"A_STUBBORN_SNAG_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Utarii mi ha parlato della torre del vento che è guasta. Dovrei andare a indagare.","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"A_STUBBORN_SNAG_STARTED"},{"VAR?":"A_STUBBORN_SNAG_FIXED_TOWER"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: wind_tower"},{"#":"status: active"},"^A quanto pare qualcosa ha fermato la turbina, quindi dovrei poter aggiustare la torre rimuovendolo.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"A_STUBBORN_SNAG_FIXED_TOWER"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho disincagliato la turbina e aggiustato la torre.","\n",{"->":".^.^.^.32"},null]}],"nop","\n","ev",{"VAR?":"A_STUBBORN_SNAG_FIXED_TOWER"},{"VAR?":"A_STUBBORN_SNAG_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: quest_giver"},"^Dovrei tornare da Utarii al campo.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","ev",{"VAR?":"A_STUBBORN_SNAG_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Utarii è stato felice che abbia aggiustato la torre.","\n",{"->":".^.^.^.47"},null]}],"nop","\n","end",{"#f":1}],"deliver_metal_scraps":["ev",{"VAR?":"metal_scraps_delivered"},"str","^ScrapMetal","/str",{"x()":"inventory_get_quantity","exArgs":1},"+",{"VAR=":"metal_scraps_delivered","re":true},"/ev","\n",{"#f":1}],"altyn_conversation":["ev","str","^Rottamatore Altyn","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev",{"VAR?":"TREASURE_SCRAPPERS_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.deliver_scrap"},{"->":".^.^.^.8"},null]}],"nop","\n","^Saluto Altyn.","\n",{"->":"END_SCENE"},{"quest_start":[["ev",{"VAR?":"TREASURE_SCRAPPERS_STARTED"},{"f()":"activate"},"pop","/ev","\n","^È difficile non vedere i rottamatori con una lente piuttosto romantica.","\n","^Da bambina, immaginando il mio Volo, mi vedevo come una viaggiatrice ricoperta di polvere, in esplorazione di posti strani e proibiti, in cerca di strane cose dimenticate.","\n","^Una cacciatrice di tesori, di oggetti antichi e arcani.","\n","^E anche se sono certa che il grind di setacciare sabbia e terra in cerca di attrezzi utili e di rimasugli possa logorare chiunque, non posso fare a meno di intessere un filo della mia fantasia nella realtà del mestiere.","\n","^<<\"Salve, Glider! Mi chiamo Altyn.\">>","\n",{"#":"gesture_sable: greeting"},"^Faccio un inchino e mi presento come Sable.","\n","^<<\"Trovi molti rottami di metallo là fuori, Sable?\">>","\n","ev","str","^Sempre!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Capita.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Bene, bene.\">>","\n","^Altyn si appoggia all'indietro e guarda il soffitto pensosamente.","\n","^<<\"Allora ho un compito per te. Se ti va.\">>","\n","^L'esitazione nella mia voce è frutto di una leggera intimidazione, ma resto dritta e casual abbastanza da sembrare pronta a tutto. Altyn sembra crederlo, abbastanza.","\n","^<<\"Mi servono rottami, Sable. E tanti.\">>","\n","^<<\"E tu là fuori che fai praticamente niente...\">>","\n","^Altyn ridacchia tra sé.","\n","^<<\"Non dovrei dirlo così. Il Volo è strano, eh? Non hai niente da fare, quindi hai tutto da fare. Chissà se qualcuno ha mai passato il proprio Volo a oziare!\">>","\n","ev","str","^Sarebbe più facile!","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Non so se conti come Volo.","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Morirei.","/str","/ev",{"*":".^.c-4","flg":4},{"c-2":["^ ","\n",{"#":"gesture_sable: talking"},"^Scherzo che sarebbe una vita più facile, trovare una grande roccia calda e fissare l'infinito, riposando per tutto il Volo.","\n","^Sbuffa divertito, ma capisco che l'idea di un pisolino prolungato gli sembra invitante. Forse pure a me.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n","^Dico con un sorrisetto che non credo conti come Volo, ma allo stesso tempo mi chiedo se qualcuno esca davvero, e usi il tempo semplicemente per stare con sé stesso in uno spazio sicuro e riflessivo.","\n","^Importerebbe altrettanto la maschera che scegliamo, se trovassimo il nostro scopo nel profondo?","\n",{"#":"gesture_sable: thinking"},"^Oh no. <i>Dovrei</i> fare così?","\n",{"#":"gesture_sable: surprised_1"},"^Altyn si schiarisce la voce e sono grata di essere scossa fuori dai miei pensieri.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n","^Dico ad Altyn che probabilmente appassirei se il mio Volo fosse così noioso, e che il mio scheletro sbiancato dal sole verrebbe trovato su una roccia, morta di noia.","\n","^Sbuffa una risata, e rido anch'io, così non saprà del mezzo secondo strillante che trascorro nella contemplazione terrorizzata della mia mortalità. Meglio non menzionarlo.","\n","^Si schiarisce la voce.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Comunque! Il compito! Vediamo se riesci a capirlo, eh? È un po' complesso.\">>","\n",{"#":"gesture_sable: talking"},"^Gli dico che sono pronta.","\n","^<<\"Esci. Trova rottami. Portameli.\">>","\n","ev","str","^Tutto qui?","/str","/ev",{"*":".^.c-5","flg":4},"ev","str","^Che tipo di rottami?","/str","/ev",{"*":".^.c-6","flg":4},"ev","str","^Quanti te ne servono?","/str","/ev",{"*":".^.c-7","flg":4},{"c-5":["^ ","\n",{"#":"gesture_sable: thinking"},"^Leggermente spiazzata, chiedo ad Altyn se è tutto.","\n","^<<\"Cosa vuol dire 'tutto qui'? Questo è il rottamaggio.\">>","\n","^<<\"Lo vuoi il lavoro o no?\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-6":["^ ","\n","^Chiedo ad Altyn che tipo di rottami vuole.","\n","^<<\"Di tutto! Rottami grandi, piccoli, medi. Se è di metallo ed è troppo rovinato per qualunque altra cosa, lo voglio.\">>","\n","^<<\"Credi di farcela?\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-7":["^ ","\n","^Chiedo ad Altyn quanto gliene servirà.","\n","^<<\"Quanto riesci a trasportare?\">>","\n",{"#":"gesture_sable: shrug"},"^Gli mostro braccia e tasche, per dargli un'idea.","\n","^<<\"Sì, mi serve tanto così, tutte le volte che puoi farlo.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":[{"#":"gesture_sable: talking"},"^Gli dico che sono felice di qualunque motivo per esplorare, e che tornerò con tutto ciò che trovo.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"deliver_scrap":[[["ev",{"x()":"current_mask"},"str","^ScrappersMask","/str","==",{"CNT?":".^.^.^.^.talk_about_scrappers_mask"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.^.^.talk_about_scrappers_mask"},{"->":".^.^.^.2"},null]}],[{"->":".^.b"},{"b":["\n","^Altyn a malapena alza lo sguardo verso di me.","\n",["ev","visit",7,"seq","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"ev","du",2,"==","/ev",{"->":".^.s2","c":true},"ev","du",3,"==","/ev",{"->":".^.s3","c":true},"ev","du",4,"==","/ev",{"->":".^.s4","c":true},"ev","du",5,"==","/ev",{"->":".^.s5","c":true},"ev","du",6,"==","/ev",{"->":".^.s6","c":true},"nop",{"s0":["pop","\n","^<<\"Trovato qualcosa di utile?\">>","\n",{"->":".^.^.47"},null],"s1":["pop","\n","^<<\"Hai rottami buoni?\">>","\n",{"->":".^.^.47"},null],"s2":["pop","\n","^<<\"Spero che questi rottami siano meglio di quelli dell'ultima volta. Anche quelli erano buoni, ma... sai. Si punta sempre al meglio.\">>","\n",{"->":".^.^.47"},null],"s3":["pop","\n","^<<\"Come va la raccolta di rottami?\">>","\n",{"->":".^.^.47"},null],"s4":["pop","\n","^<<\"Sembri un po' carica, Sable. Spero siano rottami!\">>","\n",{"->":".^.^.47"},null],"s5":["pop","\n","^<<\"È meglio che tu abbia qualcosa per me, Glider!\">>","\n",{"->":".^.^.47"},null],"s6":["pop","\n","^<<\"Ti ho sentita entrare; il dolce suono dei rottami in arrivo.\">>","\n",{"->":".^.^.47"},null],"#f":5}],"\n",{"->":".^.^.^.2"},null]}],"nop","\n","ev","str","^Vendi Rottami di Metallo.","/str","str","^ScrapMetal","/str",{"x()":"inventory_get_quantity","exArgs":1},0,">","/ev",{"*":".^.c-0","flg":5},"ev","str","^Non ancora..","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"f()":"deliver_metal_scraps"},"pop","/ev","\n",{"#":"treasure_scrappers_trade_scraps"},"^Tiro fuori tutto quello che ho trovato per lui, consegnandoglielo pezzo per pezzo.","\n",{"->t->":".^.^.^.^.badge_check"},{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Ah, beh, a volte va così. Se vedi qualcosa, sarò qui ad aspettare.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"talk_about_scrappers_mask":["^<<\"Eh. La Maschera del Rottamatore ti si addice; sembri proprio il tipo.\">>","\n","^<<\"Ora vediamo se <i>ti comporti</i> da rottamatrice. Cosa mi hai portato oggi?\">>","\n","ev","void","/ev","->->",{"#f":1}],"badge_check":[["ev",{"VAR?":"TREASURE_SCRAPPERS_COMPLETED"},{"f()":"reached"},"!",{"VAR?":"metal_scraps_delivered"},90,">=","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.^.third_badge"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"TREASURE_SCRAPPERS_GOT_SECOND_BADGE"},{"f()":"reached"},"!",{"VAR?":"metal_scraps_delivered"},60,">=","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.^.second_badge"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"TREASURE_SCRAPPERS_GOT_FIRST_BADGE"},{"f()":"reached"},"!",{"VAR?":"metal_scraps_delivered"},30,">=","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.^.first_badge"},{"->":".^.^.^.3"},null]}],"nop","\n","ev","void","/ev","->->",{"#f":1}],"first_badge":["^Altyn annuisce.","\n","^<<\"Niente male come inizio, Sable. Direi che ti sei meritata un Distintivo del Rottamatore.\">>","\n",{"#":"inventory_add: ScrappersBadge"},"^Altyn mi porge un distintivo leggermente incrostato di sabbia pallida.","\n","^<<\"Sì, scusa, quello stava in giro sotto la scrivania da una vita. Te ne darei uno pulito, ma...\">>","\n","^Lascia la frase a metà.","\n",{"#":"gesture_sable: thanks"},"^Lo ringrazio.","\n","ev",{"VAR?":"TREASURE_SCRAPPERS_GOT_FIRST_BADGE"},{"f()":"activate"},"pop","/ev","\n","ev","void","/ev","->->",{"#f":1}],"second_badge":[["ev",{"VAR?":"TREASURE_SCRAPPERS_GOT_FIRST_BADGE"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"inventory_add: ScrappersBadge"},"^<<\"Niente male, Sable. Direi che basta per il tuo secondo distintivo.\">>","\n","^Prendo il distintivo. È più pulito del primo, il che fa piacere.","\n","^<<\"Ora torna là fuori, Glider. Vedi se riesci a guadagnartene un terzo.\">>","\n",{"->":".^.^.^.2"},null]}],["ev",{"VAR?":"TREASURE_SCRAPPERS_GOT_FIRST_BADGE"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^Altyn alza lo sguardo al soffitto.","\n","^<<\"Devo dirlo... non mi aspettavo molto da te.\">>","\n","^Aspetto il seguito.","\n","^...per un attimo di troppo.","\n","^<<\"Ma questo è un <i>buon</i> bottino. Tieni. Prendi questi.\">>","\n",{"#":"inventory_add: ScrappersBadge, 2"},"^Altyn fruga in tasca e mi lancia due distintivi del Rottamatore. Uno è un po' sporco, ma fingo di non notarlo.","\n",{"#":"gesture_sable: thanks"},"^<<\"Ben fatto. Continua così.\">>","\n",{"->":".^.^.^.2"},null]}],"nop","\n","ev",{"list":{"treasure_scrappers.TREASURE_SCRAPPERS_GOT_FIRST_BADGE":2,"treasure_scrappers.TREASURE_SCRAPPERS_GOT_SECOND_BADGE":3}},{"f()":"activate"},"pop","/ev","\n","ev","void","/ev","->->",{"#f":1}],"third_badge":[[["ev",{"list":{"treasure_scrappers.TREASURE_SCRAPPERS_GOT_FIRST_BADGE":2,"treasure_scrappers.TREASURE_SCRAPPERS_GOT_SECOND_BADGE":3}},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"inventory_add: ScrappersBadge"},"^Altyn mi porge un terzo Distintivo del Rottamatore.","\n",{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"TREASURE_SCRAPPERS_GOT_FIRST_BADGE"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n","^<<\"Hm.\">>","\n","^Altyn tira su col naso attraverso la maschera e in qualche modo suona impressionato.","\n","^<<\"Bel bottino, Sable. Niente male.\">>","\n",{"#":"inventory_add: ScrappersBadge, 2"},"^Fruga in tasca e mi consegna <i>due</i> distintivi — e stavolta piuttosto puliti!","\n",{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"TREASURE_SCRAPPERS_GOT_FIRST_BADGE"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^Gli consegno tutti i miei rottami e Altyn riesce a sembrare sorpreso solo con un minuscolo movimento delle spalle.","\n","^<<\"Hai preso tutto questo?\">>","\n",{"#":"gesture_sable: yes"},"^Annuisco.","\n","^<<\"Vuoi accelerare le cose, eh? Molto da <i>Glider</i>, ma non posso dire che mi dispiaccia.\">>","\n",{"#":"inventory_add: ScrappersBadge, 3"},"^Altyn fruga nelle tasche e tira fuori qualche pezzo di metallo, un po' di lanugine... e <i>tre</i> Distintivi del Rottamatore. Me li fa scivolare attraverso la scrivania.","\n",{"->":".^.^.^.3"},null]}],"nop","\n",["^<<\"È questo che cercavi, allora?\">>","\n",{"#":"gesture_sable: talking"},"^Gli dico che sono venuta a portargli rottami, ma che questo è un bel bonus.","\n","^<<\"Mi piace l'atteggiamento. I rottami sono il vero lavoro, i distintivi sono... com'è la parola?\">>","\n","ev","str","^Un di più?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Bazzecole?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Belli?","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5,"#n":"g-0"}],{"g-1":["^<<\"Inutili! Per lo meno da soli. Ma proprio come i rottami, puoi fonderli in qualcosa di decente. <i>Una Maschera</i>.\">>","\n","^<<\"Saresti un'apprendista rottamatrice piuttosto brava, sai.\">>","\n","^<<\"Se trovi qualcuno disposto a prenderti!\">>","\n","^Ride.","\n","^<<\"Sto scherzando! Sei brava. Sarei felice di averti nella mia squadra un giorno.\">>","\n",{"#":"gesture_sable: thanks"},"^Prendo l'ultimo distintivo da Altyn e lo ringrazio con grande sincerità, cosa che credo lui detesti.","\n","^<<\"Beh non commuoverti adesso. Non è un grande <i>momento</i>. E sarò ancora qui se hai rottami da vendere.\">>","\n","^<<\"Ci si rivede, Sable.\">>","\n","ev",{"list":{"treasure_scrappers.TREASURE_SCRAPPERS_GOT_FIRST_BADGE":2,"treasure_scrappers.TREASURE_SCRAPPERS_GOT_SECOND_BADGE":3,"treasure_scrappers.TREASURE_SCRAPPERS_COMPLETED":4}},{"f()":"activate"},"pop","/ev","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"#f":1}],"treasure_scrappers_quest_definition":[{"#":"name"},"^Cacciatori di Rottami","\n",{"#":"locations"},"^altyn","\n",{"#":"items"},"ev","str","^ScrapMetal","/str","out","/ev","\n",{"#":"status"},["ev",{"VAR?":"TREASURE_SCRAPPERS_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.18"},null]}],["ev",{"VAR?":"TREASURE_SCRAPPERS_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.18"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.18"},null]}],"nop","\n","ev",{"VAR?":"TREASURE_SCRAPPERS_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Altyn mi ha chiesto di portargli qualsiasi rottame di metallo trovi nel deserto. Mi darà un prezzo equo.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"TREASURE_SCRAPPERS_STARTED"},{"VAR?":"TREASURE_SCRAPPERS_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: altyn"},{"#":"status: active"},"^Dovrei portare i rottami di metallo ad Altyn alla Burnt Oak Station.","\n",{"->":".^.^.^.33"},null]}],"nop","\n","ev",{"VAR?":"TREASURE_SCRAPPERS_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Altyn era molto soddisfatto del bottino. Mi ha dato abbastanza Distintivi del Rottamatore per guadagnarmi una Maschera del Rottamatore.","\n",{"#":"stage"},{"#":"status: active"},"^Posso ancora portare ad Altyn qualsiasi rottame trovi.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","end",{"#f":1}],"daydreams_of_wanderlust_content":[["ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_FOUND_LOCATION"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_active"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_SUGGESTED_LOCATION"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_suggest_location"},{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_complete"},{"->":".^.^.^.4"},null]}],"nop","\n","ev","void","/ev","->->",{"quest_start":[["ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_STARTED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Ci ho pensato fin troppo, e la parola che continuava a tornarmi in mente era 'spazio'. Una distesa ampia e arieggiata senza muri, odori di città o vicoletti tortuosi. Sai. L'opposto di Eccria.\">>","\n","ev",{"list":{"atomic_heart.ATOMIC_HEART_STARTED":1,"shade_of_eccria.SHADE_OF_ECCRIA_STARTED":1,"searching_for_llhor.LLHOR_STARTED":1,"hide_and_seek.HIDE_AND_SEEK_STARTED":1,"oasis_flower.OASIS_FLOWER_STARTED":1}},{"f()":"reached_any"},"!","/ev",[{"->":".^.b","c":true},{"b":["^ ",{"->":".^.^.^.continue"},{"->":".^.^.^.14"},null]}],"nop","\n","ev","str","^Oh, a me piace Eccria!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Capisco perfettamente.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["\n","^<<\"E io adoro Eccria. Sempre lo farò. Ma il mio tempo con lei è finito.\">>","\n",{"->":".^.^.continue"},{"#f":5}],"c-1":["\n","^<<\"Vero? Bel posto in cui stare per un po', certo, e ho tanti bei ricordi, ma...\">>","\n",{"->":".^.^.continue"},{"#f":5}],"continue":["^<<\"Per ora bramo le Dune Orientali. Voglio stare in alto, da qualche parte, contemplare il grande deserto, vederne tutti i piccoli rifugi di vita e gli enormi tratti dove non c'è altro che scarabei e ossa. Non è che conosci un posto del genere, vero?\">>","\n","ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_FOUND_LOCATION"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_SUGGESTED_LOCATION"},{"f()":"activate"},"pop","/ev","\n","^Con eccitazione, dico a Eliisabet che conosco il posto perfetto.","\n",{"->":".^.^.^.7"},null]}],"nop","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_active":["^<<\"Hai trovato un posto? No? Beh, neanch'io. Fammi sapere se ne trovi uno.\">>","\n","ev","void","/ev","->->",{"#f":1}],"quest_suggest_location":[["^<<\"Bello rivederti, glider. Trovato qualche vista invitante per me?\">>","\n","ev","str","^Sì! Ho trovato un posto!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non suggerire nulla.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["\n","ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_SUGGESTED_LOCATION"},{"f()":"activate"},"pop","/ev","\n","^<<\"Davvero? No, non dovrei dirlo così. Certo che l'hai trovato, una giovane glider in gamba come te. Raccontami tutto.\">>","\n","^Racconto a Eliisabet della vista trovata in cammino verso la Torre del Vento. Le sue spalle si alzano e in un attimo stiamo facendo piani approssimativi per ritrovarci là presto.","\n","ev","void","/ev","->->",{"#f":5}],"c-1":["\n","^<<\"Ancora niente? Ah, beh, abbiamo entrambe tutto il tempo per capirlo. Fammi sapere se trovi qualcosa.\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_complete":["ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Ah! Scommetto non pensavi che sarei arrivata quassù così in fretta, eh? Mi sono mantenuta arzilla in tutti questi anni, e poi la vista è tutta la motivazione di cui una vecchia coccinella ha bisogno. Grazie, piccola glider. Sei in gamba.\">>","\n","^<<\"Vorrei darti questo, con la mia gratitudine.\">>","\n","^Mi porge un Distintivo della Guardia e lo rigiro in mano, sfregando il pollice sulla sua faccia. La ringrazio. ",{"#":"inventory_add: GuardsBadge"},"\n","^<<\"Oh, è solo un piccolo gesto. Ma... immagina sia anche qualcosa su cui riflettere durante il tuo volo, eh? La vita della guardia mi ha trattata abbastanza bene, e se mai dovessi voler provare, quel distintivo ti porta un passo più vicina.>>","\n","^Mi immagino con la Maschera della Guardia. È strano, ma non assurdo. Sarei brava?","\n","^<<Stammi bene, amica. Magari ci ritroviamo nei miei prossimi viaggi. Sto pensando a una visita al Wash, sai, quindi se per caso ti capita di passare di lì...\">>","\n","^Le prometto allegramente che starò all'erta, e ci salutiamo calorosamente.","\n","ev","void","/ev","->->",{"#f":1}],"quest_on_location_found":["ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_FOUND_LOCATION"},{"f()":"activate"},"pop","/ev","\n",["ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_STARTED"},{"VAR?":"DAYDREAMS_OF_WANDERLUST_SUGGESTED_LOCATION"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n","^Che vista. Sarebbe un bel posto da mostrare a Eliisabet. Me lo segno per ricordarmelo.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n","^Ho trovato un bel posto in cui sedersi mentre andavo alla Torre del Vento. Da qui si vedono tutte le Dune Orientali.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"daydreams_of_wanderlust_quest_definition":[{"#":"name"},"^Sogni a Occhi Aperti","\n",{"#":"locations"},"^eliisabet_hercules, eliisabet_wind_tower","\n",{"#":"status"},["ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Eliisabet voleva sapere di un posto da visitare per vedere le Dune Orientali.","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_STARTED"},{"VAR?":"DAYDREAMS_OF_WANDERLUST_FOUND_LOCATION"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Dovrei tenere d'occhio qualche punto di riferimento interessante.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_FOUND_LOCATION"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato un posto che potrebbe essere interessante.","\n",{"->":".^.^.^.32"},null]}],"nop","\n","ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_FOUND_LOCATION"},{"VAR?":"DAYDREAMS_OF_WANDERLUST_SUGGESTED_LOCATION"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: eliisabet_hercules"},"^Dovrei parlare di questo posto a Eliisabet. Credo le piacerà.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_SUGGESTED_LOCATION"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sono tornata al campo e ho parlato a Eliisabet del posto. Si sta dirigendo lì.","\n",{"->":".^.^.^.47"},null]}],"nop","\n","ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_SUGGESTED_LOCATION"},{"VAR?":"DAYDREAMS_OF_WANDERLUST_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: eliisabet_wind_tower"},"^Forse potrei incontrarmi con Eliisabet nel posto che ho suggerito?","\n",{"->":".^.^.^.55"},null]}],"nop","\n","ev",{"VAR?":"DAYDREAMS_OF_WANDERLUST_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho incontrato Eliisabet e mi ha ringraziata per averle suggerito il punto. Sembra felice.","\n",{"->":".^.^.^.62"},null]}],"nop","\n","end",{"#f":1}],"hot_and_cold_quest_content":[["ev",{"VAR?":"HOT_AND_COLD_QUEST_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"HOT_AND_COLD_QUEST_STARTED"},{"VAR?":"HOT_AND_COLD_QUEST_WATER_DELIVERED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_active"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"HOT_AND_COLD_QUEST_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_complete"},{"->":".^.^.^.3"},null]}],"nop","\n","ev","void","/ev","->->",{"quest_start":[["^<<\"Giovane Glider! Sembri giovane e arzilla, ti va una prova della tua velocità?\">>","\n","ev","str","^Ti ascolto...","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["\n","ev",{"VAR?":"HOT_AND_COLD_QUEST_STARTED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Ho sentito che c'è un pozzo di acqua fresca qui vicino. Se riesci a prendere questo secchio, a recuperare l'acqua e a riportarmela prima che si scaldi del tutto, ti ricompenserò profumatamente.\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_active":["^<<\"Non riesci? Mi sorprende, giovane glider.\">>","\n","ev","void","/ev","->->",{"#f":1}],"quest_complete":["ev",{"VAR?":"HOT_AND_COLD_QUEST_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Ah ah! Ce l'hai fatta! Ben fatto, e prendi la tua ricompensa meritata!\">>","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"hot_and_cold_quest_definition":[{"#":"name"},"^Caldo e Freddo","\n",{"#":"locations"},"^quest_giver","\n",{"#":"status"},["ev",{"VAR?":"HOT_AND_COLD_QUEST_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"HOT_AND_COLD_QUEST_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"HOT_AND_COLD_QUEST_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Viivi mi ha sfidata a prendere dell'acqua da un'oasi vicina e a riportarla prima che diventi troppo calda.","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"HOT_AND_COLD_QUEST_STARTED"},{"VAR?":"HOT_AND_COLD_QUEST_WATER_DELIVERED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: wind_tower"},{"#":"status: active"},"^Devo prendere il secchio, recuperare l'acqua fredda e consegnarla prima che si scaldi.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"HOT_AND_COLD_QUEST_WATER_DELIVERED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho consegnato l'acqua fredda.","\n",{"->":".^.^.^.32"},null]}],"nop","\n","ev",{"VAR?":"HOT_AND_COLD_QUEST_WATER_DELIVERED"},{"VAR?":"HOT_AND_COLD_QUEST_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: quest_giver"},"^Dovrei dire a Viivi di aver completato la sfida.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","ev",{"VAR?":"HOT_AND_COLD_QUEST_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Viivi mi ha ricompensata per aver completato la sfida.","\n",{"->":".^.^.^.47"},null]}],"nop","\n","end",{"#f":1}],"eliisabet_hercules_conversation":["ev",{"VAR?":"speaker_eliisabet"},"/ev",{"VAR=":"SpeakerName","re":true},["ev",{"CNT?":".^.^.first_intro"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.first_intro"},{"->":".^.^.^.6"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.default_intro"},{"->":".^.^.^.6"},null]}],"nop","\n",{"->t->":"a_view_from_the_bridge_content"},{"->":"END_SCENE"},{"first_intro":[["^La guardia davanti a me sta alta, la postura modellata dal dovere, l'uniforme provata dagli anni.","\n",{"#":"gesture_partner: greeting"},"^<<\"Ciao, giovane glider!\">>","\n","^Sono quasi sorpresa dalla forza del suo saluto, ma la sua voce è confortante, in qualche modo. Calda e accogliente.","\n",{"#":"gesture_sable: greeting"},"^La saluto con l'entusiasmo accidentale di una viaggiatrice che trova un'amica. Sorride dietro la maschera, credo.","\n","^<<\"Sempre bello incontrare un'altra avventuriera, soprattutto adesso! Come te la stai cavando?\">>","\n","ev","str","^Il mondo è grande e mi sento molto piccola.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non mi sono mai sentita così libera.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Ho bisogno di dormire.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^<<\"Lo dici come fosse una brutta cosa! Non è una meraviglia la sua grandezza? Che puoi passare l'intera vita a vagare e trovare ancora altro da vedere?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Oh, che bello dev'essere. Normalmente sarei un po' gelosa, ma... le mie circostanze si stanno spalancando; sto per unirmi a te in quella libertà beata.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Non ne abbiamo tutte? Ma non ti senti fortunata di poterti fare un letto sotto le stelle?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"gesture_sable: thinking"},"^Penso al tessuto appallottolato e alla roccia spianata che faranno da prossimo cuscino, e da tanti a venire. Mi duole leggermente il collo al pensiero di quante notti passerò così.","\n","^<<\"È possibile che lo stia un po' romanzando.\">>","\n","^<<\"Vedi, mi sto preparando a partire per il mio <i>secondo</i> volo!\">>","\n","^Legge la confusione nel mio silenzio. Nessuno mi ha mai parlato del secondo volo?","\n","^<<\"Suppongo non sia un <i>vero</i> secondo volo, ma è così che lo vedo. Un'occasione di rivedere il mondo, e come è cambiato.\">>","\n","^<<\"Sono una guardia eccrina, vedi, o-- <i>ero</i> una guardia eccrina. Da tre giorni sono ufficialmente in pensione.\">>","\n",{"#":"gesture_partner: laugh"},"^<<\"Avresti dovuto vedere come mi guardavano gli altri!\">>","\n","^C'è una risata nella sua voce.","\n","^<<\"Erano tutti così sconcertati nel vedermi andare, a dirmi quanto mi sarebbe mancata la grande città...\">>","\n","^<<\"Alcuni mi compativano persino, come a dire cosa farei, ora che lo scopo della mia vita è compiuto? Te lo immagini?\">>","\n",{"#":"gesture_sable: no"},"^Ci provo, ma a malapena riesco a immaginare l'inizio del mio scopo, figuriamoci la fine. Scuoto la testa.","\n",{"#":"gesture_partner: talking"},"^<<\"Ho detto 'grazie a tutti per le strane condoglianze, ma domani sarà la prima volta in decenni che mi sveglierò la mattina senza avere la minima idea di cosa mi aspetta. E non sono mai stata così eccitata.'\">>","\n",{"#":"gesture_partner: talking"},"^<<\"Non fraintendermi: ho amato il mio lavoro. Ho amato persino il rumore e i guai di Eccria. Ma ho passato abbastanza vita a starmene in giro con aria dura. È tempo di esplorare!\">>","\n",{"#":"gesture_sable: talking"},"^La sua gioia è contagiosa. Le chiedo dove vorrebbe andare.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"default_intro":["^Eliisabet mi saluta.","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"a_view_from_the_bridge_content":[["ev",{"VAR?":"A_VIEW_FROM_THE_BRIDGE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_start"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"A_VIEW_FROM_THE_BRIDGE_STARTED"},{"VAR?":"A_VIEW_FROM_THE_BRIDGE_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.quest_complete"},{"->":".^.^.^.3"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.post_quest"},{"->":".^.^.^.3"},null]}],"nop","\n",{"quest_start":["ev",{"VAR?":"A_VIEW_FROM_THE_BRIDGE_STARTED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Sto andando ai Badlands, credo. Voglio vedere il Ponte dei Traditi!\">>","\n","^<<\"Se non l'hai già fatto, dovresti assolutamente andare a vederlo. Vuoi i Badlands settentrionali, a sud-ovest di qui.\">>","\n",{"#":"gesture_sable: yes"},"^Annuisco, cercando di tenere a mente le indicazioni, ed Eliisabet mi dà un colpetto.","\n","^<<\"Forse ci vediamo lassù.\">>","\n","ev","void","/ev","->->",{"#f":1}],"quest_complete":[["ev",{"VAR?":"A_VIEW_FROM_THE_BRIDGE_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_partner: wave"},"^<<\"Ah! Hai deciso di raggiungermi!\">>","\n","ev","str","^Volevo vederti!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Volevo vedere il panorama!","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Mi ero dimenticata che saresti stata qui!","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_partner: laugh"},"^Dico a Eliisabet che volevo rivederla, ed eccomi qui per il nostro secondo saluto. Sembra apprezzarlo e mi dà un colpetto sul braccio.","\n","^<<\"Anch'io volevo vederti! Non hai avuto problemi con la scalata, vero?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Allora hai buon gusto, e io ho una buona notizia! Anche se sono stata quassù ad assorbirla, c'è ancora un sacco di vista per te.\">>","\n",{"#":"gesture_sable: laugh"},"^Rido un po' e mi dà un colpetto sul braccio.","\n","^<<\"Spero tu non abbia avuto problemi con la scalata?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_partner: laugh"},"^Eliisabet ride forte e mi dà una pacca sulla spalla.","\n","^<<\"Buffo, no? I cattivi ricordi fanno belle coincidenze. Spero tu non abbia avuto problemi con la scalata?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"gesture_sable: no"},"^Le dico di no, e le chiedo come ha fatto lei.","\n","^<<\"Mi sono mantenuta arzilla in tutti questi anni, e poi la vista è tutta la motivazione di cui una vecchia coccinella ha bisogno. Grazie comunque, piccola glider. Sei in gamba.\">>","\n","^<<\"Vorrei darti questo, con la mia gratitudine. Data la nostra posizione attuale, forse sembra un po' troppo a tema, ma...\">>","\n",{"#":"inventory_add: GuardsBadge"},{"#":"gesture_sable: thanks"},"^Con un rapido cenno alle grandi statue che incombono dietro di lei, Eliisabet mi porge un Distintivo della Guardia. Lo rigiro in mano, sfregando il pollice sulla faccia, e la ringrazio.","\n","^<<\"Oh, è solo un piccolo gesto. Ma... immagina sia anche qualcosa su cui pensare durante il tuo volo, eh?\">>","\n","^<<\"La vita della guardia mi ha trattato abbastanza bene, e se mai dovessi voler provare, quel distintivo ti porta un passo più vicina.\">>","\n",{"#":"gesture_sable: thinking"},"^Mi immagino con la Maschera della Guardia. È strano, ma non assurdo. Sarei brava?","\n","^<<\"Stammi bene, amica. Magari ci ritroviamo nei miei prossimi viaggi. Sto pensando a una visita al Wash, sai, quindi se per caso ti capita di passare di lì...\">>","\n",{"#":"gesture_sable: yes"},"^Le prometto allegramente che starò all'erta.","\n","^<<\"Un'ultima cosa. Se prendi davvero la strada della Guardia?\">>","\n","^Mi rianimo. Si volta e indica di nuovo le statue.","\n",{"#":"guard_statue_cam"},"^<<\"Punta a essere quella in alto. Per come è angolato, il tipo che arriva dal basso non ha scampo.\">>","\n",{"#":"guard_statue_cam_reset"},"^Ci salutiamo calorosamente e me ne vado.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"post_quest":["^<<\"Ci si vede.\">>","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"a_view_from_the_bridge_quest_definition":[{"#":"name"},"^Una Vista dal Ponte","\n",{"#":"locations"},"^eliisabet_hercules, bridge_of_the_betrayed","\n",{"#":"status"},["ev",{"VAR?":"A_VIEW_FROM_THE_BRIDGE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"A_VIEW_FROM_THE_BRIDGE_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"A_VIEW_FROM_THE_BRIDGE_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho incontrato Eliisabet, una guardia eccrina in pensione, alla Burnt Oak Station. Ha detto che era diretta al Ponte dei Traditi, e ha suggerito che lo vedessi anch'io.","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"A_VIEW_FROM_THE_BRIDGE_COMPLETED"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: bridge_of_the_betrayed"},{"#":"status: active"},"^Dovrei andare a trovare Eliisabet al Ponte dei Traditi. È a sud-ovest della Burnt Oak Station, nei Badlands settentrionali.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"A_VIEW_FROM_THE_BRIDGE_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sono salita al ponte e ho incontrato Eliisabet lì.","\n",{"->":".^.^.^.32"},null]}],"nop","\n","end",{"#f":1}],"tutorial_main_content":[{"->":".^.jadi_intro_cutscene"},{"jadi_intro_cutscene":[["ev",{"VAR?":"speaker_jadi"},"/ev",{"VAR=":"SpeakerName","re":true},"^Sento Jadi sorridere dietro la sua maschera, proprio come so che lei sente la mia smorfietta a denti scoperti dietro la mia.","\n","^Sono nervosa, e lei è dolcemente, soavemente divertita. Ai suoi occhi, probabilmente non ho granché di cui preoccuparmi.","\n","^<<\"Lo sai che non hai nulla di cui preoccuparti, vero, Sable?\">>","\n","ev","str","^Eppure...","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Lo so, lo so...","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non sono preoccupata!","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: shrug"},{"#":"gesture_partner: laugh"},"^Faccio spallucce, ma ogni tentativo di sembrare disinvolta è inutile. Il movimento è scattoso, e credo di non essere mai stata così consapevole delle mie spalline. Lei ride.","\n","^<<\"Dico sul serio!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_partner: laugh"},"^Dico a Jadi che lo so, ma che non l'ho ancora del tutto realizzato. Ridacchia.","\n","^<<\"Te lo prometto, Sable! Stai bene.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_sable: uninterested"},"^Le dico che non sono preoccupata per niente, ed è probabilmente la cosa meno convincente che abbia mai detto.","\n","^<<\"Puoi dirlo, amore mio...\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Ma so come sei. Sarai nervosa finché non avrai iniziato, e poi farai come se l'avessi fatto per tutta la vita.\">>","\n","^<<\"Ricordi la prima volta che hai guidato una hoverbike?\">>","\n","^<<\"Non mi lasciavi neanche metterti sul sellino, avevi così paura. Le tue mani erano come piccoli artigli aggrappati a me...\">>","\n","^Sento il ricordo nelle dita.","\n","^<<\"Ma poi ti ho promesso che sarebbe andato tutto bene. Ti ho detto quanto avevo amato cavalcare la mia hoverbike da giovane, e quanto fosse meraviglioso il vento sul tessuto...\">>","\n","^<<\"All'improvviso, eccoti lì. Ti sei seduta. Ti sei sporta in avanti, hai messo quegli artigliucci sui manubri ed eri partita.\">>","\n","^<<\"E ricordo di aver pensato, solo... guardandoti sfrecciare sulla sabbia...\">>","\n","^<<\"Guardala. Può fare tutto ciò che vuole.\">>","\n","^Jadi allunga la mano e la posa sul bordo della mia maschera.","\n","^<<\"E puoi farlo, Sable.\">>","\n","^Prendo fiato.","\n","ev","str","^Credo di essere pronta.","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Non so da dove cominciare.","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Ho cambiato idea. Resto.","/str","/ev",{"*":".^.c-5","flg":4},{"c-3":["^ ","\n",{"#":"gesture_sable: thanks"},"^Ringrazio Jadi per l'incoraggiamento, e con un cenno le dico che credo di essere pronta.","\n","^<<\"Lo so. Allora facciamoti partire.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n",{"#":"gesture_sable: sad"},"^La storia di Jadi mi scalda, ma mi sento troppo sopraffatta per lasciarla sedimentare. Con un sospiro le dico che non so da dove cominciare. Lei ridacchia.","\n","^<<\"Beh, su quello posso aiutarti.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-5":["^ ","\n",{"#":"gesture_partner: laugh"},"^Beh, è stato un tentativo nobile. Dico a Jadi che apprezzo la lezione, ma che la sua storia mi ha resa nostalgica e ora vorrei tantissimo rimanere qui, al sicuro a casa nostra. Lei ride.","\n","^<<\"Dai! Sei in ritardo.\">>","\n","^Cedo con un sospiro abbastanza rumoroso perché lo senta.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Dovrai parlare con Hilal e Driss. Driss dovrebbe aver già preparato la tua hoverbike, e Hilal condividerà qualcosa... beh, diciamo tanto utile quanto divertente, mh?\">>","\n","^Credo di sospettare cosa intende Jadi, ma sto zitta.","\n","^<<\"Dopodiché, immagino ti accompagneremo alla partenza.\">>","\n","ev","str","^Tornerò presto.","/str","/ev",{"*":".^.c-6","flg":4},"ev","str","^E se scegliessi la strada sbagliata?","/str","/ev",{"*":".^.c-7","flg":4},{"c-6":["^ ","\n","^Dico a Jadi che tornerò presto.","\n","^<<\"Sable, non programmare il ritorno prima ancora di partire. Prenditi tutto il tempo che ti serve. È una grande decisione quella che farai là fuori.\">>","\n","^Le dico che è proprio per questo che ho tanta fretta di prenderla. Per scegliere bene e in fretta, e non spingermi troppo lontano sulla strada sbagliata.","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-7":["^ ","\n","^Chiedo a Jadi cosa ne sarà di me se scelgo la strada sbagliata.","\n","^<<\"Non ci sono strade sbagliate, Sable. Né giuste. Sarò felice se sceglierai di restare con gli Ibexii, ma... a dirla tutta, sarò felice in ogni caso. Purché tu sia felice.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":["^<<\"Qualunque cosa tu decida, lo fai con la mia benedizione. Quindi non provare a usarmi come scusa per tornare a casa in anticipo, eh?\">>","\n","^Mi conosce.","\n",{"#":"hilal_cam"},"^<<\"Ora vai a parlare con Hilal. Sarò lì alla partenza.\">>","\n",{"#":"driss_cam"},"^<<\"E parla anche con Driss! Gli ho detto di preparare la tua hoverbike con Sizo, ma sai com'è fatto.\">>","\n",{"#":"reset_cam"},{"#":"gesture_partner: greeting"},{"#":"inventory_add: Compass"},"^<<\"Ho qualcosa da darti. Una bussola per aiutarti nel viaggio. È la stessa che usavo io durante il mio Volo, un cimelio si potrebbe dire.\">>","\n",{"#":"sable_compass"},"^Prendo il dispositivo nel palmo. Vi calza naturalmente, perfettamente bilanciato e lavorato. Ogni componente si incastra con una precisione incredibile, soddisfacente.","\n","ev","str","^Grazie.","/str","/ev",{"*":".^.c-8","flg":4},{"c-8":["^ ","\n","^<<\"Vai, vai. È quasi ora!\">>","\n",{"->":"END_SCENE"},{"#f":5}],"#f":5}]}],{"#f":1}],"jadi_ceremony_final":[["^Torno da Jadi con una nuova leggerezza...","\n","^...E rende il peso della mia partenza ancora più pesante. Che strana giornata.","\n","^<<\"Sable! Quello che hai è un distintivo?\">>","\n","ev","str","^Me l'ha dato Sizo!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Guardami, Jadi! Sto già volando!","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Dico a Jadi che Sizo mi ha dato il distintivo.","\n","^<<\"Allora deve essertelo meritato. Ben fatto.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Prendo il distintivo e lo offro al suo esame ravvicinato. Così vicino che Jadi ridacchia e deve fare un piccolo passo indietro.","\n","^<<\"Sizo dev'essere convinto che te lo sei meritato. Ben fatto.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Faccio un inchino di ringraziamento.","\n","^<<\"Bene, Sable! Se continui così, sarai dal Forgiatore di Maschere in un batter d'occhio!\">>","\n","^Provo a pensare di andare da un Forgiatore di Maschere, ma sembra incredibilmente lontano. Immagina <i>scegliere chi voglio essere</i>?","\n","^Immagina scegliere chi voglio essere... <i>per sempre</i>?!","\n","^<<\"So a cosa pensi, ma non preoccuparti. Otterrai un sacco di distintivi là fuori, e quando ne avrai tre uguali, potrai scambiarli per la maschera corrispondente.\">>","\n","^<<\"Ma non pensare che la tua prima maschera sia la scelta definitiva. Il Volo riguarda la libertà e l'esplorazione. Ti consiglio di prendere tutte le maschere che vuoi!\">>","\n","^<<\"Solo alla cerimonia finale ti sarà chiesto di sceglierne una.\">>","\n","ev","str","^Come la sceglierò?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Quale dovrei scegliere?","/str","/ev",{"*":".^.c-3","flg":4},{"c-2":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Dovrai sentirla. Ma quando lo saprai, lo saprai.\">>","\n","^<<\"Ora.\">>","\n","^Il tono del suo \"ora\" rimette le farfalle nel mio stomaco. Fatto tutto questo, resta una sola cosa.","\n",{"#":"temple_cam"},"^<<\"È il momento, no? Il momento di varcare la Porta dei Volti al Tempio di Rohana...\">>","\n","^<<\"Lì assemblerai la tua maschera del Volo...\">>","\n",{"#":"cam_reset"},"^<<\"...e andrai.\">>","\n","^Ci sono cose che vorrei comunicare a Jadi qui, profondità di amore e gratitudine e paura e preoccupazione e speranza. E anche se mi ritrovo incapace di esprimerne nessuna a parole, so che lei capisce.","\n","^<<\"Prima che tu parta, bambina mia.\">>","\n",{"#":"inventory_add: IbexiiSetTop"},{"#":"inventory_add: IbexiiSetTrousers"},"^<<\"Ti ho fatto questi. Sono tinti del tradizionale rosso scuro Ibexii, e spero ti diano grande conforto nel deserto.\">>","\n","^<<\"Quando partirai oggi, non sarai più Sable, figlia del clan degli Ibexii. Sarai semplicemente Sable, e il resto verrà.\">>","\n","^<<\"Ma qualunque cosa tu sia, ovunque ti porti il viaggio, ti riconoscerò sempre. Ti amerò sempre.\">>","\n","^<<\"E ti rivedrò.\">>","\n","^Non so dove finirà il mio viaggio, ma so dove deve iniziare.","\n","^E sono pronta.","\n","ev",{"VAR?":"TUT_MAIN_STARTED_MASK_CEREMONY"},{"f()":"activate"},"pop","/ev","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"message_from_family":["ev",{"VAR?":"speaker_jadi"},"/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"TUT_MAIN_RETURNED_TO_CAMP"},{"f()":"activate"},"pop","/ev","\n","^La voce di Jadi echeggia stranamente attraverso la macchina, ma mi scalda lo stesso.","\n","^<<\"Bene, Sable... ci siamo.\">>","\n","^<<\"Quando sentirai questo messaggio, saremo già partiti. Il Volo è un viaggio che deve iniziare da soli.\">>","\n","^C'è una certa sfumatura che si perde nella trasmissione, e per questo sono grata. Sarebbe troppo sentire le incrinature nella sua voce e non correre piangendo tra le sue braccia per restare per sempre.","\n","^Ma sono pronta. E così chiudo gli occhi e ascolto.","\n","^<<\"Ma anche se vai da sola, non sei senza amici. Non sei senza famiglia. Non sei senza amore. Queste cose le porterai sempre con te, come fai con la tua maschera.\">>","\n","^<<E so che non dovrei fare così... ma se fossi in te, andrei a trovare Utarii. È la Macchinista alla Burnt Oak Station, e tra gli amici più cari di Sizo.>>","\n","^<<\"Utarii è un buon contatto da avere durante il Volo, e un buon modo per ottenere un altro distintivo del Macchinista se ti va. È solo un suggerimento, però.\">>","\n","^<<\"Quanto a noi, ti manderò un altro messaggio quando saremo tornati all'Ewer, quindi tieni d'occhio le cassette postali. E cerca di non dimenticarci.\">>","\n","^Prende un lungo respiro e dimentico che cose facili come respirare possano esistere.","\n",{"#":"face_shot"},"^<<\"Il mondo ti aspetta, Sable.\">>","\n","^<<\"Buona fortuna.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"tutorial_main_quest_definition":[{"#":"name"},"^La Cerimonia","\n",{"#":"locations"},"^camp, driss, hilal, sizo, jadi, gate, utarii, mask_temple","\n",{"#":"status"},["ev",{"VAR?":"TUT_MAIN_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"TUT_MAIN_MET_UTARII"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"TUT_MAIN_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_MAIN_FIRST_ARRIVED_AT_CAMP"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: camp"},{"#":"status: active"},"^Dovrei tornare al campo.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho parlato con Jadi al campo. Ha detto che Hilal e Driss hanno dei compiti per me.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"TUT_MAIN_FIRST_ARRIVED_AT_CAMP"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_MAIN_BIKE_AND_HOVER"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: hilal, driss"},{"#":"status: active"},"^Devo completare i compiti di Hilal e Driss.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho completato i compiti di Driss e Hilal.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.24"},null]}],"nop","\n","ev",{"VAR?":"TUT_MAIN_BIKE_AND_HOVER"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_MAIN_ATOMIC_COMPLETED"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: sizo"},{"#":"status: active"},"^Sizo ha un compito per me.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho completato il compito di Sizo.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.31"},null]}],"nop","\n","ev",{"VAR?":"TUT_MAIN_ATOMIC_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_MAIN_STARTED_MASK_CEREMONY"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: jadi"},{"#":"status: active"},"^Dovrei parlare con Jadi della cerimonia finale del Volo.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Jadi mi ha detto di tornare al Tempio di Rohana per iniziare il mio Volo.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.38"},null]}],"nop","\n","ev",{"VAR?":"TUT_MAIN_STARTED_MASK_CEREMONY"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_MAIN_COMPLETED_MASK_CEREMONY"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: mask_temple"},{"#":"status: active"},"^Dovrei andare al tempio per iniziare il mio Volo.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho completato la cerimonia e ricevuto la mia maschera Ibex.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.45"},null]}],"nop","\n","ev",{"VAR?":"TUT_MAIN_COMPLETED_MASK_CEREMONY"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_MAIN_RETURNED_TO_CAMP"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: camp"},{"#":"status: active"},"^Torna al campo.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Quando sono tornata al campo, il clan aveva impacchettato tutto ed era partito senza di me.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.52"},null]}],"nop","\n","ev",{"VAR?":"TUT_MAIN_RETURNED_TO_CAMP"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_MAIN_LEFT_CANYON"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: gate"},{"#":"status: active"},"^Lascia il canyon.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho lasciato il canyon e ho iniziato il mio Volo.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.59"},null]}],"nop","\n","ev",{"VAR?":"TUT_MAIN_LEFT_CANYON"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_MAIN_MET_UTARII"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: utarii"},{"#":"status: active"},"^Dovrei parlare con Utarii, la Macchinista alla Burnt Oak Station.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sono arrivata alla Burnt Oak Station e ho parlato con Utarii.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.66"},null]}],"nop","\n","end",{"#f":1}],"tutorial_bike_quest_definition":[{"#":"name"},"^Sabbie Taglienti","\n",{"#":"locations"},"^quest_giver, objective","\n",{"#":"status"},["ev",{"VAR?":"TUT_BIKE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"TUT_BIKE_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n",["ev",{"VAR?":"TUT_BIKE_STARTED"},{"VAR?":"TUT_USED_BIKE"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: bike"},{"#":"status: active"},"^Cavalca la sandcutter. Non è assolutamente una prova.","\n",{"->":".^.^.^.15"},null]}],["ev",{"VAR?":"TUT_USED_BIKE"},{"VAR?":"TUT_BIKE_OBJECTIVE"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: objective"},{"#":"status: active"},"^Cavalca la sandcutter attraverso l'Anello e ritorno.","\n",{"->":".^.^.^.15"},null]}],["ev",{"VAR?":"TUT_BIKE_OBJECTIVE"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho cavalcato una hoverbike per la prima volta e non ho preso fuoco.","\n",{"->":".^.^.^.15"},null]}],"nop","\n","ev",{"VAR?":"TUT_BIKE_OBJECTIVE"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_BIKE_COMPLETED"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: quest_giver"},{"#":"status: active"},"^Dovrei parlare con Driss.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Driss mi ha dato la sandcutter da guidare.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.22"},null]}],"nop","\n","end",{"#f":1}],"tutorial_hover_quest_content":[{"->":".^.hilal_hover_start"},{"hilal_hover_start":[["ev",{"VAR?":"TUT_HOVER_STARTED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_sable: wave"},"^Mentre mi avvicino a Hilal, mi saluta con entusiasmo. Ho sempre apprezzato la verve e il vigore di Hilal, e in un giorno come questo, sono pronta a metterli alla pari — con un tocco di nervosismo per bilanciare.","\n",{"#":"give_stone"},{"#":"inventory_add: GlidingStone01"},"^<<\"Sable! Prendi questa.\">>","\n","^Hilal mi porge una piccola pietra rotonda. Mentre si annida nel mio palmo, sento un calore che non viene dalle mani di Hilal, ma emana dall'interno. Ci passo sopra il pollice e la trovo lievemente elettrica, come la statica sul tessuto.","\n","ev","str","^Cos'è?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Grazie!","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non ho portato nulla per <i>te</i>!","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Cerco di sembrare meno confusa di quanto sia, e chiedo a Hilal cos'è.","\n","^<<\"Oh, Sable, non puoi partire senza!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: thanks"},"^Lo ringrazio per la pietruzza vellutata.","\n","^<<\"Oh, Sable, non sai cos'è, vero?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_partner: laugh"},"^Hilal lascia uscire una risata cristallina.","\n","^<<\"Oh, Sable. Mi farai un regalo quando un giorno tornerai.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Quella che ti ho appena dato è una Pietra del Volo. Cosa senti?\">>","\n","^Dico a Hilal che sento...","\n","ev","str","^Connessione?","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Solletico?","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Elettricità?","/str","/ev",{"*":".^.c-5","flg":4},{"c-3":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-5":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Allora la stai usando giusto. Quello che senti in quella pietra è... apertura.\">>","\n","^Guardo la pietra. Mi sembra piuttosto chiusa.","\n","^<<\"Le Pietre del Volo sono contenitori del Perpetuo. Ne assorbono il potere come piccole spugne, e lo tengono lì perché tu lo possa incanalare.\">>","\n","^<<\"Adesso è vuota, o dormiente, e aspetta che tu la riempia.\">>","\n","^Chiedo come posso farlo.","\n",{"#":"gliding_stone_cam_on"},"^<<\"Portala alle rovine del Tempio al margine del canyon. Lì potrai attivarla.\">>","\n",{"#":"gliding_stone_cam_off"},"^Hilal batte le mani due volte e si dondola un poco. Apprezzo il suo buonumore in un momento come questo.","\n","^<<\"Tornami quando l'avrai fatto. Voglio sapere tutto!\">>","\n","ev",{"VAR?":"TUT_BIKE_STARTED"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n","^Mentre sto per andarmene, Hilal mi ferma.","\n","^<<\"Oh, non hai ancora la tua hoverbike, vero? È una bella camminata fino al Tempio, quindi vai da Driss. Doveva preparartela, no?\">>","\n","^Ricordo ora le parole di Jadi e dico a Hilal che andrò da Driss.","\n",{"->":".^.^.^.24"},null]}],"nop","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"hilal_hover_in_progress":["^<<\"Vai al Tempio, Sable. Te lo prometto, varrà il viaggio!\">>","\n","ev","void","/ev","->->",{"#f":1}],"hilal_hover_complete":[["ev",{"VAR?":"TUT_HOVER_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^Quando torno da Hilal, è chiaro che sa cosa ho appena provato. È eccitato per me in un modo che me lo fa già rimpiangere prima ancora di partire.","\n",{"#":"gesture_partner: explaining"},"^<<\"Non è incredibile? Come ti senti?\">>","\n","ev","str","^Eccitante! Libertà vera!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Strano. Mi sento un po' nauseata.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Al sicuro. Come un abbraccio caldo.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: explaining"},"^Dico a Hilal che planare è eccitante, e divago un momento su tutte le cose che potrò fare quando sarò là fuori nel mondo.","\n","^Quasi tutte prevedono che cada di testa senza farmi male, ma sono sicura che ne troverò altre in pratica.","\n","^<<\"Vero? Puoi fare tutto quello che vuoi!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: thinking"},"^Dico a Hilal che c'è qualcosa di un po' disorientante, e che non ho ancora capito bene come usarla al meglio.","\n","^<<\"Beh, non preoccupartene. C'è un sacco di tempo e in poco tempo ti lancerai dalle scogliere con impunità!\">>","\n","^È una cosa buona?","\n","^<<\"Fidati. Ti piacerà un sacco.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^Dico a Hilal che mi sento quasi abbracciata dal Perpetuo, calda e al sicuro nella mia piccola bolla. Si commuove.","\n","^<<\"Oh, è un modo davvero bello di descriverlo.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^L'umore di Hilal non si oscura, ma il sospiro che si lascia sfuggire ha un velo di tristezza.","\n","^<<\"Sei molto fortunata, sai. Mi manca tanto, quella sensazione. Solo... fluttuare nella brezza.\">>","\n","^<<\"Ma immagino sia meglio che svanisca con l'età, eh? Altrimenti non sarei mai tornato dal mio Volo! Starei ancora là fuori a gettarmi giù nei burroni.\">>","\n","ev","str","^Mi getterò nei burroni <i>per</i> te.","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Faresti davvero così?","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Vorrei potessimo farlo tutti.","/str","/ev",{"*":".^.c-5","flg":4},{"c-3":["^ ","\n",{"#":"gesture_partner: laugh"},"^Dico a Hilal che mi getterò in mille burroni per suo conto, e ridacchia.","\n","^<<\"Ecco quello che mi piace sentire.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n","^Ci pensa.","\n","^<<\"Perché no? Se ne avessi il potere, perché non usarlo?\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-5":["^ ","\n","^Dico a Hilal che vorrei fosse una cosa da poter mantenere... <i>perpetuamente</i>.","\n","^<<\"Anch'io, Sable. Anch'io.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"So che alcuni riescono a mantenerla, ma non credo di avere il tempo di esercitarmi come loro. Serve una concentrazione davvero seria.\">>","\n",{"#":"gesture_partner: laugh"},"^Hilal ride, anche se c'è un velo di rimpianto.","\n","^<<\"E quella di sicuro non ce l'ho.\">>","\n","^<<\"Comunque, immagino il Volo non significherebbe granché se fosse tutto guadagno e niente perdita, eh?\">>","\n",{"#":"gesture_sable: thinking"},"^Ci penso, ma decido che ho già troppa perdita in mente per considerarla oltre. Sto dicendo addio al mio clan, alla mia famiglia, alla mia casa, alla mia infanzia.","\n","^Perdere il Perpetuo è un sacrificio per un'altra volta.","\n","^<<\"Ti piacerà tanto là fuori, Sable. Anche quando non ti piacerà.\">>","\n","^<<\"Il mio consiglio? Prova a divertirti. Si può dire molto su rituale, indipendenza e tutto il resto là fuori, ma... il mondo è un posto più facile se metti la gioia al primo posto.\">>","\n","^Ringrazio Hilal per il consiglio e per l'aiuto, e gli dico che mi mancherà.","\n","^<<\"Finirà prima che te ne accorga.\">>","\n","^Un avvertimento e una rassicurazione, tutto in uno.","\n","^Saluto Hilal.","\n","ev",{"VAR?":"TUT_BIKE_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_MAIN_BIKE_AND_HOVER"},{"f()":"activate"},"pop","/ev","\n",{"#":"sizo_tower_cam"},"^Prima che vada, Hilal indica la torre: pare che Sizo voglia vedermi prima che lasci il clan.","\n",{"->":".^.^.^.31"},null]}],"nop","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"#f":1}],"tutorial_hover_quest_definition":[{"#":"name"},"^Pietre Sussurranti","\n",{"#":"locations"},"^quest_giver, temple","\n",{"#":"status"},["ev",{"VAR?":"TUT_HOVER_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"TUT_HOVER_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"TUT_HOVER_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_HOVER_ACTIVATED_STONE"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: temple"},{"#":"status: active"},"^Attiva la Pietra del Volo all'altare.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho attivato la Pietra del Volo. Posso incanalare il Perpetuo attraverso di essa.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"TUT_HOVER_ACTIVATED_STONE"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_HOVER_COMPLETED"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: quest_giver"},{"#":"status: active"},"^Mostra a Hilal la Pietra del Volo attivata.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Hilal mi ha dato la sua benedizione per il Volo.","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.24"},null]}],"nop","\n","end",{"#f":1}],"tut_atomic_found_all_parts":["ev",{"VAR?":"atomic_parts"},{"f()":"reached"},"/ev","~ret","\n",{"#f":1}],"tutorial_atomic_parts_content":[{"->":".^.sizo_simoon_start"},{"sizo_simoon_start":[["^Sizo è un'estranea agli Ibexii, ma la conosco da quasi quanto ricordo, e la considero più una specie di parente lontana che un'estranea qualsiasi.","\n","^Mi è stato detto che ai Macchinisti vengono assegnati i posti, e per la loro formazione e il loro codice devono andare dove servono, ma Sizo è tra di noi da così tanto tempo che è facile dimenticare che si tratta innanzitutto di un incarico.","\n","^Per quel che ci riguarda, è una di noi.","\n","^Credo ci sia una percezione tra gli altri clan che gli Ibexii siano piuttosto chiusi, o che la nostra distinzione tra \"Ibexii\" e \"estranei\" suggerisca un nervoso allontanamento di chi non è come noi.","\n","^Ma in pratica, queste cose sono più il risultato della nostra natura nomade; cerchiamo di sapere chi viaggerà con noi e chi dobbiamo lasciare indietro, ma tutti sono i benvenuti a unirsi.","\n","^E sono sempre felice che Sizo lo abbia fatto.","\n",{"#":"gesture_partner: greeting"},"^<<\"Sable. Come stai, figlia del clan?\">>","\n","^Riesco a pensare a una cosa sola:","\n","ev","str","^Meglio adesso che avrò una hoverbike!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Eccitata! Per la mia hoverbike!","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Un po' preoccupata. Avrò davvero una hoverbike?","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"gesture_partner: laugh"},"^Sizo ha una voce gutturale, che rimbomba attraverso la maschera quando ride. È una persona piuttosto seria di solito, e sono sempre divisa tra orgoglio e allarme quando riesco a farla ridacchiare.","\n","^<<\"Sì. Jadi mi ha detto quanto eri eccitata.\">>","\n","^Sizo tira su col naso.","\n","^<<\"Mi ha anche detto che Driss sarebbe venuto a montarti la hoverbike, ma credo possa aver--\">>","\n",{"#":"gesture_sable: talking"},"^Lo sapevo.","\n","^<<\"Cosa?\">>","\n",{"#":"gesture_sable: surprised_1"},"^Non volevo dirlo a voce alta, quindi le dico che mi stavo solo schiarendo la voce.","\n","^<<\"Non incolpo Driss della sua smemoratezza; se avessi così tante cose da gestire, sarei distratta anch'io. E poi, questa sarà una cosa buona per te.\">>","\n","^<<\"Voglio che recuperi tu stessa i pezzi della hoverbike.\">>","\n","ev","str","^Costruirò la mia hoverbike?","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Sembra un'avventura!","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Tecnicamente, non dovrebbe farlo Driss?","/str","/ev",{"*":".^.c-5","flg":4},{"c-3":["^ ","\n","^Chiedo a Sizo se devo fare la mia hoverbike da sola.","\n","^<<\"No, non <i>creerai</i> la tua hoverbike, la <i>costruirai</i>.\">>","\n",["ev","str","^Certo...","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Qual è la differenza?","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Creare implica fare qualcosa di nuovo. Ma la tua hoverbike esiste già; semplicemente non ha ancora preso forma.\">>","\n",{"->":".^.^.^.^.^.g-1"},{"#f":5}]}],{"#f":5}],"c-4":["^ ","\n","^Dico a Sizo che mi piace come suona; una piccola avventura prima di quella grande.","\n","^<<\"È più significativo di quanto tu creda. Legare con la propria hoverbike prima che abbia preso forma è più un privilegio che una fatica.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-5":["^ ","\n","^Sizo si dà un colpetto sulla guancia della maschera, divertita.","\n","^<<\"E lasciare a lui il privilegio di legare con la tua hoverbike prima che sia composta? No, no, no. Questo è riservato a te.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Tieni, prendi questo.\">>","\n",{"#":"inventory_add: Navigator"},"^Sizo mi porge qualcosa.","\n","^<<\"Questo è un Navigatore. Puoi usarlo per segnare punti di riferimento sulla bussola. Dovrebbe esserti utile per trovare i vecchi pezzi.\">>","\n","^Chiedo a Sizo da dove potrei iniziare a cercare.","\n",{"#":"capacitor_ship_cam"},"^<<\"Le nostre hoverbike rinascono nelle navi in rovina, in frammenti sparsi. Un buon punto di partenza è la nave laggiù vicino al campo...\">>","\n",{"#":"tower_ship_cam"},"^<<\"Ne troverai un'altra in cima a quella grande roccia, vicino all'altro lato del canyon.\">>","\n",{"#":"old_dam_cam"},"^<<\"E un'altra dietro la vecchia diga sulla collina.\">>","\n",{"#":"cam_reset"},"^<<\"Usa il Navigatore per segnartelo se serve.\">>","\n","^<<\"Dovrai recuperare un <i>Pannello di Controllo</i>, un <i>Alimentatore</i> e un <i>Calibratore</i>.\">>","\n","ev","str","^Tornerò prima che te ne accorga!","/str","/ev",{"*":".^.c-6","flg":4},"ev","str","^È un bel po' di lavoro.","/str","/ev",{"*":".^.c-7","flg":4},"ev","str","^Le Glider di solito si fanno la propria hoverbike?","/str","/ev",{"*":".^.c-8","flg":4},{"c-6":["^ ","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-7":["^ ","\n",{"#":"gesture_sable: thinking"},"^Dico a Sizo che mi sembra un bel po' di lavoro, soprattutto perché mi servirà energia per il Volo.","\n","^<<\"Ci sono compiti che danno energia e compiti che la tolgono. Questo è il primo tipo.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-8":["^ ","\n","^Chiedo a Sizo se davvero la maggior parte delle Glider si fa la propria hoverbike.","\n","^<<\"Solo quelle fortunate.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":["^Dico a Sizo che la vedrò presto, e parto in cerca dei componenti.","\n","^<<\"Insieme creeremo qualcosa di nuovo dal vecchio.\">>","\n","ev",{"VAR?":"TUT_ATOMIC_STARTED"},{"f()":"activate"},"pop","/ev","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"sizo_simoon_looking_for_parts":["^Sizo aspetta i pezzi.","\n","ev",{"VAR?":"TUT_ATOMIC_FOUND_CALIBRATOR"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"capacitor_ship_cam"},"^Devo ancora trovare un <i>Calibratore Atomico</i>.","\n",{"->":".^.^.^.8"},null]}],"nop","\n","ev",{"VAR?":"TUT_ATOMIC_FOUND_POWER_SUPPLY"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"tower_ship_cam"},"^Devo ancora trovare un <i>Alimentatore Atomico</i>.","\n",{"->":".^.^.^.16"},null]}],"nop","\n","ev",{"VAR?":"TUT_ATOMIC_FOUND_CONTROL_PANEL"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"old_dam_cam"},"^Devo ancora trovare un <i>Pannello di Controllo</i>.","\n",{"->":".^.^.^.24"},null]}],"nop","\n",{"#":"cam_reset"},{"->":"END_SCENE"},{"#f":1}],"sizo_simoon_deliver_parts":[["^Torno da Sizo con i pezzi e mentre mi fa cenno di avvicinarmi sento una fitta di tristezza al petto. Quando la rivedrò, dopo che sarò partita?","\n","^<<\"Ben fatto, Sable. Sì. Abbiamo tutto ciò che serve.\">>","\n",["^<<\"Sei pronta ad assemblare la tua hoverbike?\">>","\n","ev","str","^Sono pronta.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Veramente, ci sono delle cose che devo fare prima.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"TUT_ATOMIC_DELIVERED_PARTS"},{"f()":"activate"},"pop","/ev","\n","^<<\"Allora andiamo all'officina.\">>","\n",{"->":"END_SCENE"},{"#f":5}],"c-1":["^ ","\n","^<<\"Molto bene. Torna da me quando sei pronta.\">>","\n",{"->":"END_SCENE"},{"#f":5}],"#f":5,"#n":"workshop_choice"}],null],{"#f":1}],"bike_assembly":["ev",{"VAR?":"speaker_sizo"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"inventory_remove: ControlPanel"},{"#":"inventory_remove: Calibrator"},{"#":"inventory_remove: PowerSupply"},"^Sizo si rilassa in officina. Non è che di solito sia particolarmente rigida o ansiosa, ma c'è una certa bellezza calma che si apprezza davvero solo quando Sizo è nel suo elemento.","\n","^Mi chiedo se sia così per tutti i Macchinisti.","\n","^<<\"Ciò che devi capire, Sable, è che i componenti che hai recuperato... si incastrano. Non per caso, non per sforzo, ma per natura. Le appartengono.\">>","\n","^<<\"Le sono sempre appartenuti.\">>","\n","^<<\"Stiamo solo assemblandola, da ciò che è già stata.\">>","\n","^Annuisco, e sento un lieve ronzio nelle orecchie.","\n","^<<\"Tra il mio clan, crediamo che le macchine abbiano nomi, custoditi per epoche come segreti profondi, inascoltati da chi non è in grado di ascoltarli.\">>","\n","^<<\"Troveremo insieme il nome di questa.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"after_bike_assembled":[["^<<\"Ascolta.\">>","\n","^Sizo inclina la testa per un momento, sporgendosi verso...","\n","^Simoon.","\n","^All'improvviso so il nome della hoverbike. Simoon. Lo dico in un sussurro per farlo sapere a Sizo.","\n","^<<\"Simoon. Si-moon. Ben fatto, Sable.\">>","\n","ev","str","^Che tipo di nome è?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Cosa significa?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Vuole venire con me?","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Chiedo a Sizo che tipo di nome sia, e se appartenga a un clan o a una cultura particolare.","\n","^<<\"Se sì, io non lo so. Forse lo scoprirai durante il tuo viaggio.\">>","\n","^Sizo fa spallucce, soprattutto a sé stessa.","\n","^<<\"O forse no. Ma non credo importi molto. Siete legate comunque.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Cosa significa? Dovresti chiederlo a lei.\">>","\n","^Sizo è del tutto seria. La hoverbike, con mia perdurante sorpresa, non dice nulla, neanche quando mi avvicino.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Sì, figlia del clan.\">>","\n","^<<\"Simoon ha uno spirito errante. Come te, credo.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Dico a Simoon che non vedo l'ora di conoscerla meglio, e Sizo ci guarda con orgoglio entrambe.","\n","^<<\"Sei pronta, dunque, per il Volo. Che tutti gli Dei distolgano i volti da te, Sable.\">>","\n","^Una benedizione strana, forse, ma Sizo è incline a queste cose e dal tono capisco che era detta con dolcezza.","\n","^<<\"Devi imparare ad ascoltare Simoon, a prendertene cura. Cerca i miei compagni Macchinisti nei tuoi viaggi, Sable. Ti insegneranno l'arte di sussurrare alle macchine.\">>","\n",{"#":"inventory_add: MachinistBadge"},"^<<\"Oh, e tieni, prendi questo.\">>","\n","^<<\"È un distintivo del Macchinista. Incontrerai molti dei miei simili durante il Volo; mostragli il tuo valore e te ne daranno altri.\">>","\n",{"#":"gesture_sable: thanks"},"^Ringrazio Sizo due volte per sicurezza, e faccio un inchino.","\n","^Sono pronta.","\n","ev",{"list":{"tutorial_atomic_parts.TUT_ATOMIC_COMPLETED":8,"tutorial_main.TUT_MAIN_ATOMIC_COMPLETED":4}},{"f()":"activate"},"pop","/ev","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"#f":1}],"tutorial_atomic_parts_quest_definition":[{"#":"name"},"^Navi di un Tempo","\n",{"#":"locations"},"^sizo_tower, sizo_workshop","\n",{"#":"status"},["ev",{"VAR?":"TUT_ATOMIC_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"TUT_ATOMIC_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"TUT_ATOMIC_STARTED"},{"f()":"reached"},{"f()":"tut_atomic_found_all_parts"},"!","&&","/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"TUT_ATOMIC_FOUND_CONTROL_PANEL"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Trova un Pannello di Controllo.","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato un Pannello di Controllo.","\n",{"->":".^.^.^.8"},null]}],"nop","\n","ev",{"VAR?":"TUT_ATOMIC_FOUND_POWER_SUPPLY"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Trova un Alimentatore.","\n",{"->":".^.^.^.17"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato un Alimentatore.","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"TUT_ATOMIC_FOUND_CALIBRATOR"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Trova un Calibratore Atomico.","\n",{"->":".^.^.^.26"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato un Calibratore Atomico.","\n",{"->":".^.^.^.26"},null]}],"nop","\n",{"->":".^.^.^.20"},null]}],"nop","\n","ev",{"f()":"tut_atomic_found_all_parts"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sono riuscita a trovare tutti i pezzi della lista.","\n","ev",{"VAR?":"TUT_ATOMIC_DELIVERED_PARTS"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: sizo_tower"},{"#":"status: active"},"^Consegna i pezzi a Sizo.","\n",{"->":".^.^.^.12"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho consegnato tutti i pezzi a Sizo. Mi ha chiesto di aiutarla a riparare la macchina su cui sta lavorando.","\n",{"->":".^.^.^.12"},null]}],"nop","\n",{"->":".^.^.^.26"},null]}],"nop","\n","ev",{"VAR?":"TUT_ATOMIC_DELIVERED_PARTS"},{"VAR?":"TUT_ATOMIC_ASSEMBLED_BIKE"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Assembla la macchina.","\n",{"->":".^.^.^.34"},null]}],"nop","\n","ev",{"VAR?":"TUT_ATOMIC_ASSEMBLED_BIKE"},{"VAR?":"TUT_ATOMIC_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: sizo_workshop"},{"#":"status: active"},"^Parla con Sizo.","\n",{"->":".^.^.^.42"},null]}],"nop","\n","ev",{"VAR?":"TUT_ATOMIC_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sizo e io abbiamo assemblato la macchina insieme.","\n",{"->":".^.^.^.49"},null]}],"nop","\n","end",{"#f":1}],"tutorial_beetles_completed":["ev",{"list":{"tutorial_beetles.TUT_BEETLE_STOLE_CALIBRATOR":4,"tutorial_beetles.TUT_BEETLE_GAVE_TO_SAIMA":5}},{"f()":"reached_any"},"/ev","~ret","\n",{"#f":1}],"tutorial_beetles_has_enough":["ev","str","^YellowElephantBeetle","/str",{"x()":"inventory_get_quantity","exArgs":1},3,">=","/ev","~ret","\n",{"#f":1}],"saima_intro_cutscene":[["ev",{"VAR?":"speaker_saima"},"/ev",{"VAR=":"SpeakerName","re":true},"ev",{"VAR?":"TUT_BEETLE_STARTED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Stai cercando un Calibratore?\">>","\n","ev",{"VAR?":"TUT_BEETLE_STOLE_CALIBRATOR"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","^Molto dolcemente, chiedo a Saima se intende il calibratore che ho trovato nella grotta sotto il campo.","\n","^Non sembra contenta di me, il che mi fa pensare di aver fatto qualcosa di giusto.","\n",{"->":"END_SCENE"},{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"TUT_ATOMIC_STARTED"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n","^Dico a Saima che non ho idea di cosa parli. Sembra seccata, ma... in genere è il suo modo.","\n",{"->":".^.^.^.end"},{"->":".^.^.^.25"},null]}],"nop","\n","^Sono immediatamente sulla difensiva. Saima è sempre stata una piccola peste, e ha tratto enorme piacere dal tormentarmi. In teoria, sono più grande, più esperta, e dovrei essere più che in grado di sopportarla.","\n","^In pratica...","\n","^<<\"Qui non lo troverai. L'ho nascosto! Non lo troverai mai! Mai! Mai!\">>","\n","^...non manca mai di farmi infuriare.","\n","ev","str","^Restituiscilo, Saima!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Posso averlo, per favore?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Sei una bambina orribile.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Ordino a Saima di restituirmelo. Io sono in età da Volo e lei è una <i>bambina</i>.","\n","^<<\"No. Non credo proprio.\">>","\n",{"->":".^.^.end"},{"#f":5}],"c-1":["^ ","\n","^Decido di essere gentile, e le chiedo per favore se posso averlo.","\n","^<<\"Posso <i>per favore</i> averlo?\">>","\n","^Mi imita orribilmente — tutto acuto e stridulo. Nonostante i miei sforzi, ribollo.","\n","^<<\"Oh beh, peccato! Forse lo troverai da sola. Ma io non credoooo.\">>","\n",{"->":".^.^.end"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.end"},{"#f":5}],"end":["^Saima scaccia la mia irritazione con una risata, ma non ho intenzione di darle la soddisfazione. Incrocio le braccia e cerco di cambiare la situazione.","\n","^<<\"Te lo do il Calibratore!\">>","\n","^Tendo la mano, orgogliosa di me per essere rimasta dritta davanti a Saima.","\n","^<<\"Se mi dai degli scarabei!\">>","\n","^<<\"È uno scambio equo, no? Qualcosa che vuoi tu, per qualcosa che voglio io!\">>","\n","^Provo a decidere se sia più maturo spintonarla e rubare il Calibratore, oppure cedere.","\n","^Ma poi soffoco un sospiro e le stringo la manina.","\n","^Forse qualcuno degli adulti al campo sa dove posso trovarne.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"tutorial_beetles_generic":[["ev",{"VAR?":"TUT_BEETLE_STARTED"},{"f()":"reached"},{"f()":"tutorial_beetles_completed"},"!","&&","/ev",{"temp=":"can_ask_about_beetles"},"\n","ev",{"VAR?":"can_ask_about_beetles"},"!","/ev",[{"->":".^.b","c":true},{"b":["^ ","ev","void","/ev","->->",{"->":".^.^.^.14"},null]}],"nop","\n","^Potrei chiedere come catturare gli scarabei per quella orribile piccola Saima.","\n","ev","str","^Sai dove posso trovare degli scarabei?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Conosci il nascondiglio di Saima?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non chiedere","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^<<\"C'è un nido di scarabei appena a est di qui. Però non puoi semplicemente andare e prenderne uno.\">>","\n","^<<\"Ci sono dei semi che crescono sulle rocce attorno al nido. Lascia cadere un seme a terra e lo scarabeo inizierà a mangiarlo, allora puoi avvicinarti di soppiatto e afferrarlo.\">>","\n","ev",{"VAR?":"TUT_BEETLE_LEARNED_HOW_TO_CATCH"},{"f()":"activate"},"pop","/ev","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"So che passa molto tempo nella grotta sotto il campo. Potresti dare un'occhiata laggiù.\">>","\n","ev",{"VAR?":"TUT_BEETLE_LEARNED_ABOUT_HIDING_PLACE"},{"f()":"activate"},"pop","/ev","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"saima_give_beetles":[["ev",{"list":{"tutorial_beetles.TUT_BEETLE_GAVE_TO_SAIMA":5,"tutorial_atomic_parts.TUT_ATOMIC_FOUND_CALIBRATOR":4}},{"f()":"activate"},"pop","/ev","\n",{"#":"saima_quest_completed"},{"#":"inventory_remove: YellowElephantBeetle, 3"},{"#":"inventory_add: Calibrator, 1"},"^Mi sento imbarazzantemente vendicata mentre porgo gli scarabei a Saima, ma invece di vantarsi, mi consegna il Calibratore e... scoppia a piangere.","\n","^Cos'ho fatto?","\n","^<<\"Te ne vai! Te ne vai e non tornerai mai!\">>","\n","ev","str","^Consolala.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Lasciala piangere.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Si soffia il naso e poi si pulisce la mano sulla tunica.","\n","^<<\"Yaara non è più tornata dopo l'ultimo Volo. Non sei triste? Eri sua amica.\">>","\n",["ev","str","^Mi manca anche a me.","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Magari un giorno tornerà a trovarci.","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^La gente va via. È la loro scelta.","/str","/ev",{"*":".^.c-4","flg":4},{"c-2":["^ ","\n","^Ogni tanto è arrivata una lettera. Ma sempre a <i>noi</i>, mai a me. Non sono amareggiata, ma... spero di non essere così.","\n",{"->":".^.^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n","^Dico a Saima che Yaara probabilmente verrà a trovarci un giorno, proprio come farò io se dovessi scegliere un altro clan.","\n","^<<\"Ma come ci troverai? A quel punto ci saremo trasferiti un milione di volte!\">>","\n","^Le rispondo che troverò sempre gli Ibexii, qualunque cosa accada.","\n",{"->":".^.^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n","^Dico a Saima che Yaara è libera di fare ciò che vuole, e che se la sua scelta è andarsene, dobbiamo rispettarla.","\n","^Mi chiedo se si accorga che metto un po' di peso in più nella voce, sperando suoni come saggezza dell'età.","\n","^<<\"Tu non andresti via per sempre, vero?\">>","\n",["ev","str","^Beh...","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non per sempre!","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Comincio a parlare, ma Saima mi interrompe con un lamento.","\n",{"->":".^.^.^.^.^.^.g-1"},{"#f":5}]}],{"#f":5}],"#f":5,"#n":"opts"}],{"#f":5}],"g-1":["^<<\"Ti prego, non andartene!\">>","\n","^Dico a Saima di non preoccuparsi, che tornerò prima di quanto creda, e sono sicura che tira il broncio dietro la maschera.","\n","^E aggiungo che se <i>non</i> dovessi tornare presto, allora a quel punto sarà pronta per il suo Volo e potrà venire a darmi fastidio lei stessa.","\n","^<<\"Promesso?\">>","\n","^Dico di sì.","\n","^<<\"Bene. Allora suppongo di poter venire a salutarti alla partenza.\">>","\n","^La ringrazio e la saluto per ora.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"saima_calibrator_stolen_back":["^Saima strilla quando vede il calibratore in mano mia, e poi scoppia a piangere sotto la maschera.","\n","^<<\"Te ne andrai. Te ne andrai per il Volo e non tornerai mai!\">>","\n","^<<\"Proprio come ha fatto Yaara!\">>","\n","^<<\"Non ti manca anche a te? Eri sua amica, prima che se ne andasse.\">>","\n",{"->":"saima_give_beetles.0.g-0.opts"},{"#f":1}],"tutorial_beetles_quest_definition":[{"#":"name"},"^Deviazione Scarabeo","\n",{"#":"locations"},"^saima, camp, beetle_rock","\n",{"#":"items"},"ev","str","^YellowElephantBeetle","/str","out","/ev","\n",{"#":"status"},["ev",{"VAR?":"TUT_BEETLE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.18"},null]}],["ev",{"f()":"tutorial_beetles_completed"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.18"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.18"},null]}],"nop","\n","ev","str","^YellowElephantBeetle","/str",{"x()":"inventory_get_quantity","exArgs":1},"/ev",{"temp=":"numBeetles"},"\n","ev",{"VAR?":"numBeetles"},0,">","/ev",{"temp=":"foundBeetles"},"ev",{"VAR?":"TUT_BEETLE_LEARNED_HOW_TO_CATCH"},{"f()":"reached"},"!",{"VAR?":"foundBeetles"},"&&","/ev",{"temp=":"foundBeetlesWithoutLearningHow"},"\n","ev",{"VAR?":"TUT_BEETLE_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato Saima mentre cercavo un Calibratore Atomico. Dice di averne trovato uno, ma lo ha nascosto. Me lo darà se le porto tre scarabei.","\n",{"->":".^.^.^.48"},null]}],"nop","\n",["ev",{"VAR?":"TUT_BEETLE_STARTED"},{"f()":"reached"},{"VAR?":"TUT_BEETLE_LEARNED_HOW_TO_CATCH"},{"f()":"reached"},{"f()":"tutorial_beetles_completed"},"||",{"f()":"tutorial_beetles_has_enough"},"||","!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: camp"},{"#":"status: active"},"^Chiedi al campo come catturare gli scarabei.","\n",{"->":".^.^.^.52"},null]}],["ev",{"VAR?":"TUT_BEETLE_LEARNED_HOW_TO_CATCH"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho chiesto al campo e ho saputo che c'è un nido di scarabei poco a est. Gli scarabei hanno paura delle persone. Per catturarne uno dovrò distrarlo con del cibo.","\n",{"->":".^.^.^.52"},null]}],"nop","\n","ev",{"VAR?":"TUT_BEETLE_LEARNED_ABOUT_HIDING_PLACE"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Chiedendo in giro al campo, ho saputo che Saima ha nascosto il Calibratore Atomico nella grotta sotto il campo. Potrei semplicemente andare a riprenderglielo.","\n",{"->":".^.^.^.59"},null]}],"nop","\n","ev",{"VAR?":"TUT_BEETLE_STOLE_CALIBRATOR"},{"f()":"reached"},"!",{"VAR?":"TUT_BEETLE_LEARNED_HOW_TO_CATCH"},{"f()":"reached"},{"VAR?":"foundBeetlesWithoutLearningHow"},"||","&&","/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"numBeetles"},3,"<","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: beetle_rock"},{"#":"status: active"},"^Raccogli scarabei - ","ev",{"VAR?":"numBeetles"},"out","/ev","^/","ev",3,"out","/ev","\n",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Raccogli scarabei - ","ev",3,"out","/ev","^/","ev",3,"out","/ev","\n","ev",{"VAR?":"TUT_BEETLE_GAVE_TO_SAIMA"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: saima"},{"#":"status: active"},"^Consegna gli scarabei a Saima. Le piace giocare nella grotta sotto il campo.","\n",{"->":".^.^.^.20"},null]}],"nop","\n",{"->":".^.^.^.8"},null]}],"nop","\n",{"->":".^.^.^.72"},null]}],"nop","\n","ev",{"VAR?":"TUT_BEETLE_GAVE_TO_SAIMA"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho dato gli scarabei a Saima e lei mi ha dato il Calibratore Atomico.","\n",{"->":".^.^.^.79"},null]}],"nop","\n",["ev",{"VAR?":"TUT_BEETLE_LEARNED_ABOUT_HIDING_PLACE"},{"VAR?":"TUT_BEETLE_GAVE_TO_SAIMA"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Riprendi il Calibratore Atomico da Saima.","\n",{"->":".^.^.^.83"},null]}],["ev",{"VAR?":"TUT_BEETLE_STOLE_CALIBRATOR"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato dove Saima aveva nascosto il Calibratore Atomico e gliel'ho ripreso.","\n",{"->":".^.^.^.83"},null]}],"nop","\n","end",{"#f":1}],"purveyor_balloon_is_active":["ev",{"VAR?":"TUT_HOVER_ACTIVATED_STONE"},{"VAR?":"TUT_MAIN_COMPLETED_MASK_CEREMONY"},{"f()":"between"},"/ev","~ret","\n",{"#f":1}],"purveyor_and_surveyor_content":[{"->":".^.jadi_suggests_you_buy_a_map"},{"jadi_suggests_you_buy_a_map":["ev",{"list":{"purveyor_and_surveyor.PURVEYOR_STARTED":1,"purveyor_and_surveyor.PURVEYOR_JADI_GAVE_MONEY":3}},{"f()":"activate"},"pop","/ev","\n","^<<\"Sable! Quel cartografo ha fatto atterrare la mongolfiera mentre eri via.\">>","\n",{"#":"gesture_partner: talking"},"^<<\"Dovresti andargli a parlare; vedi se riesci a procurarti una mappa.\">>","\n","^Annuisco e mi metto in cammino, ma Jadi mi fa cenno di tornare e mi mette qualcosa in mano.","\n",{"#":"add_money: 200"},"^<<\"Ecco un po' di soldi per iniziare il viaggio. Usali soprattutto con saggezza. E un po' senza saggezza quando ne hai voglia.\">>","\n","^<<\"È bene conoscere il valore del denaro, ma mai farsi governare da esso.\">>","\n",{"#":"gesture_sable: thanks"},"^Ringrazio Jadi calorosamente e mi metto in cammino.","\n","ev","void","/ev","->->",{"#f":1}],"jadi_waits_while_you_buy_a_map":["^<<\"Torna a parlarmi quando avrai comprato quella mappa dal cartografo.\">>","\n","ev","void","/ev","->->",{"#f":1}],"ask_jadi_for_money":["ev",{"VAR?":"PURVEYOR_JADI_GAVE_MONEY"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_sable: talking"},"^Dico a Jadi che il Cartografo vuole 50 cuts per una mappa dell'Ewer. Cerco di esprimermi con cautela, perché non sono sicura se sia troppo, troppo poco o esattamente il suo valore.","\n","^Mi dice di non preoccuparmi.","\n",{"#":"add_money: 200"},"^<<\"Ecco un po' di soldi per iniziare il viaggio. Usali soprattutto con saggezza. E un po' senza saggezza quando ne hai voglia.\">>","\n","^<<\"È bene conoscere il valore del denaro, ma mai farsi governare da esso.\">>","\n",{"#":"gesture_sable: thanks"},"^Ringrazio Jadi calorosamente e mi metto in cammino.","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"purveyor_and_surveyor_quest_definition":[{"#":"name"},"^Mappatore e Misuratore","\n",{"#":"locations"},"^jadi, jourdan","\n",{"#":"status"},["ev",{"VAR?":"PURVEYOR_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"PURVEYOR_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"PURVEYOR_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Un Cartografo di nome Jourdan ha fatto atterrare la mongolfiera al campo Ibexii.","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"list":{"purveyor_and_surveyor.PURVEYOR_STARTED":1,"purveyor_and_surveyor.PURVEYOR_EDGE_CASE":2}},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Il Cartografo ha detto che mi venderebbe una mappa dell'Ewer, se ho i cuts per pagarla.","\n","ev",{"VAR?":"PURVEYOR_JADI_GAVE_MONEY"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: jadi"},{"#":"status: active"},"^Dovrei parlare con Jadi per avere dei cuts.","\n",{"->":".^.^.^.11"},null]}],"nop","\n",{"->":".^.^.^.24"},null]}],"nop","\n","ev",{"VAR?":"PURVEYOR_JADI_GAVE_MONEY"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Jadi mi ha dato dei cuts per pagare una mappa.","\n",{"->":".^.^.^.31"},null]}],"nop","\n","ev",{"VAR?":"PURVEYOR_JADI_GAVE_MONEY"},{"VAR?":"PURVEYOR_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: jourdan"},{"#":"status: active"},"^Dovrei comprare una mappa dal Cartografo Jourdan.","\n",{"->":".^.^.^.39"},null]}],"nop","\n","ev",{"VAR?":"PURVEYOR_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho comprato una mappa dell'Ewer dal Cartografo.","\n",{"->":".^.^.^.46"},null]}],"nop","\n","end",{"#f":1}],"num_larval_husks":[["ev",{"VAR?":"DEBUG"},"/ev",{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"debug_larval_husk_amount"},"/ev","~ret",{"->":".^.^.^.2"},null]}],[{"->":".^.b"},{"b":["\n","ev","str","^LarvalHusk","/str",{"x()":"inventory_get_quantity","exArgs":1},"/ev","~ret","\n",{"->":".^.^.^.2"},null]}],"nop","\n",{"#f":1}],"collected_larval_husks":["ev",{"f()":"num_larval_husks"},3,">=","/ev","~ret","\n",{"#f":1}],"hercules_beetle_quest_content":["ev",{"f()":"num_larval_husks"},3,">=","/ev",{"temp=":"enoughBeetles"},"\n",["ev",{"VAR?":"HERCULES_BEETLE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.9"},null]}],["ev",{"VAR?":"HERCULES_BEETLE_STARTED"},{"VAR?":"HERCULES_BEETLE_RETURNED_TO_IFAA"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_in_progress"},{"->":".^.^.^.9"},null]}],"nop","\n","ev","void","/ev","->->",{"quest_start":[["ev","str","^Hai qualche compito da farmi fare?","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev",{"VAR?":"HERCULES_BEETLE_STARTED"},{"f()":"activate"},"pop","/ev","\n","^Prima ancora che finisca la domanda, Ifaa esclama.","\n","^<<\"Esuvie di larva!\">>","\n",{"#":"gesture_sable: talking"},"^Le ripeto le parole, come per chiarimento. Annuisce.","\n","^<<\"Mi servono delle esuvie di larva. Sono-- quanto ne sai degli scarabei?\">>","\n","ev","str","^Un pochino.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Sono un'esperta di scarabei.","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Cos'è davvero uno scarabeo?","/str","/ev",{"*":".^.c-3","flg":4},{"c-1":["^ ","\n","^<<\"Beh, non so se rientra in quel pochino, ma le esuvie di larva sono ciò che le larve di scarabeo lasciano quando crescono. Bellissimi gusci, davvero resistenti.\">>","\n","^<<\"Se non ti dispiace, ti sarei grata se potessi raccogliermene un po'.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-2":["^ ","\n","^<<\"Oh, allora non devo spiegarti cos'è un'esuvia di larva!\">>","\n",["ev","str","^Certo che no!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Rinfrescami la memoria.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^\t ","\n","^<<\"Le esuvie di larva sono... come dirlo a un'esperta? I gusci scartati quando una larva di scarabeo entra in un'altra fase della sua crescita.\">>","\n",{"#":"gesture_sable: yes"},"^Annuisco, mano sul mento, e le dico che ne sono più che a conoscenza.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Se non ti dispiace, ti sarei grata se potessi raccogliermene un po'.\">>","\n",{"->":".^.^.^.^.^.g-1"},{"#f":5}]}],{"#f":5}],"c-3":["^ ","\n","^<<\"Ah. Un po' filosofa.\">>","\n",{"#":"gesture_partner: thinking"},"^Fa una pausa.","\n",{"#":"gesture_partner: talking"},"^<<\"Sarò sincera: non so come rispondere a questa.\">>","\n","^<<\"Ma se non ti dispiace aiutarmi a recuperare delle esuvie di larva — i gusci secchi che le larve in crescita si lasciano dietro — te ne sarei grata.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Quelle che cerco sono di scarabei Ercole. Non dovrai andare lontano, ma il nido è sorvegliato dalla madre. Dovrai trovare un modo per superarla.\">>","\n","ev",{"f()":"collected_larval_husks"},"/ev",[{"->":".^.b","c":true},{"b":["^ ",{"->":".^.^.^.^.^.^.already_have_husks"},{"->":".^.^.^.6"},null]}],"nop","\n","ev",{"CNT?":".^.^.g-0.c-2"},"/ev",[{"->":".^.b","c":true},{"b":["\n","^<<\"Ma sono sicura che un'esperta non avrà problemi!\">>","\n",{"->":".^.^.^.12"},null]}],"nop","\n","^Le dico che farò del mio meglio.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_in_progress":[["ev","str","^Ho le Esuvie di Larva che mi hai chiesto!","/str",{"f()":"collected_larval_husks"},"/ev",{"*":".^.c-0","flg":5},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev",{"VAR?":"HERCULES_BEETLE_RETURNED_TO_IFAA"},{"f()":"activate"},"pop","/ev","\n","^Ifaa ha iniziato ad applaudire nel momento in cui i nostri occhi si sono incrociati.","\n","^<<\"Ah, le hai prese! Spero che la vecchia mamma Scarabeo non ti abbia dato troppi problemi.\">>","\n","^Le porgo le esuvie, leggere come l'aria ma forti come l'acciaio, e le ripone in un sacchetto di tela.","\n",{"#":"inventory_remove: LarvalHusk, 3"},{"#":"inventory_add: BeetleBadge"},"^<<\"Mi torneranno davvero utili. Grazie.\">>","\n",[{"#":"inventory_add: LarvalHuskPackage"},"^<<\"In realtà, c'è un'altra cosa che potresti fare per me. Puoi portare queste esuvie a Eccria e consegnarle a Aeyan nell'officina del costruttore di campanelli?\">>","\n","ev","void","/ev","->->",{"#f":5,"#n":"deliver_husks_to_eccria"}],{"#f":5}]}],{"#f":1}],"already_have_husks":["ev",{"VAR?":"HERCULES_BEETLE_RETURNED_TO_IFAA"},{"f()":"activate"},"pop","/ev","\n","^Dico a Ifaa che in realtà ho alcune esuvie di larva con me.","\n",{"#":"inventory_remove: LarvalHusk, 3"},{"#":"inventory_add: BeetleBadge"},"^Consegno le esuvie in cambio di un distintivo.","\n",{"->":".^.^.quest_in_progress.0.g-0.deliver_husks_to_eccria"},{"#f":1}],"#f":3}],"hercules_beetle_diary":[["ev","str","^Il Diario","/str","/ev",{"VAR=":"SpeakerName","re":true},"^C'è un vecchio taccuino consumato vicino alla tenda.","\n","ev","str","^Leggilo.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Lascialo stare.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^<<\"Dopo tutto il mio viaggiare, la strada all'interno del nido è bloccata. Lo Scarabeo Ercole, ostruisce il passaggio e si rifiuta di muoversi!\">>","\n","^Continuo a sfogliare gli scarabocchi di appunti.","\n","^<<\"Sono alla fine del mio ingegno. La creatura dorme e dorme e non si muove. Ho tentato di attaccare la bestia, ma il suo guscio è duro come il metallo e non mi degna nemmeno di uno sguardo.\">>","\n","^Ci sono altri appunti.","\n","^<<\"C'è una pianta insolita che ha ricoperto la torre di fronte al nido. Intendo investigare; gli scarabei più piccoli sembrano attratti dalla pianta.\">>","\n","^Un ultimo scarabocchio sul retro del libro.","\n","^<<\"La scalata è stata molto faticosa. Se solo avessi ancora la mia vecchia Pietra del Volo. Comunque, ce l'ho fatta!\">>","\n","^<<Tenere in mano il frutto che cresce sulla pianta gigante sembra agitarla e farle emettere un gas innocuo di qualche tipo. Gli scarabei si radunano attorno mentre lo faccio. Proverò la mia teoria con la madre.>>","\n","^Gli appunti finiscono.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"hercules_beetle_quest_debug":[["ev","str","^Raccogli Esuvie di Larva","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["\n","ev",3,"/ev",{"VAR=":"debug_larval_husk_amount","re":true},"^Raccogli alcune Esuvie di Larva.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":3}],"hercules_beetle_quest_definition":[{"#":"name"},"^Resti del Mutamento","\n",{"#":"locations"},"^quest_giver, beetle_nest, chime_maker","\n",{"#":"items"},"ev","str","^LarvalHusk","/str","out","/ev","\n",{"#":"status"},["ev",{"VAR?":"HERCULES_BEETLE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.18"},null]}],["ev",{"VAR?":"HERCULES_BEETLE_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.18"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.18"},null]}],"nop","\n","ev",{"VAR?":"HERCULES_BEETLE_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ifaa mi ha chiesto di recuperare delle esuvie di larva dal nido di scarabei vicino al suo campo.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"HERCULES_BEETLE_STARTED"},{"VAR?":"HERCULES_BEETLE_RETURNED_TO_IFAA"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"f()":"num_larval_husks"},"/ev",{"temp=":"numBeetles"},"\n","ev",{"VAR?":"numBeetles"},3,"<","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: beetle_nest"},{"#":"status: active"},"^Raccogli esuvie di larva: ","ev",{"VAR?":"numBeetles"},"out","/ev","^/","ev",3,"out","/ev","\n",{"->":".^.^.^.13"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Raccogli esuvie di larva: ","ev",{"VAR?":"numBeetles"},"out","/ev","^/","ev",3,"out","/ev","\n",{"#":"stage"},{"#":"locations: quest_giver"},{"#":"status: active"},"^Dovrei riportare le esuvie di larva a Ifaa.","\n",{"->":".^.^.^.13"},null]}],"nop","\n",{"->":".^.^.^.33"},null]}],"nop","\n","ev",{"VAR?":"HERCULES_BEETLE_RETURNED_TO_IFAA"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato delle esuvie e le ho riportate a Ifaa.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","ev",{"VAR?":"HERCULES_BEETLE_RETURNED_TO_IFAA"},{"VAR?":"HERCULES_BEETLE_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: chime_maker"},{"#":"status: active"},"^Ifaa mi ha chiesto di portare le esuvie e consegnarle a Aeyan, una costruttrice di campanelli a Eccria.","\n",{"->":".^.^.^.48"},null]}],"nop","\n","ev",{"VAR?":"HERCULES_BEETLE_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho consegnato le esuvie a Aeyan a Eccria.","\n",{"->":".^.^.^.55"},null]}],"nop","\n","end",{"#f":1}],"slicer_beetle_count":["ev",{"VAR?":"DEBUG"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"debug_slicer_beetle_count"},"/ev","~ret",{"->":".^.^.^.5"},null]}],[{"->":".^.b"},{"b":["\n","ev","str","^SlicerBeetlePoo","/str",{"x()":"inventory_get_quantity","exArgs":1},"/ev","~ret","\n",{"->":".^.^.^.5"},null]}],"nop","\n",{"#f":1}],"slicer_beetle_quest_content":["ev",{"f()":"slicer_beetle_count"},3,">=","/ev",{"temp=":"enoughBeetles"},"\n",["ev",{"VAR?":"SLICER_BEETLE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.9"},null]}],["ev",{"VAR?":"SLICER_BEETLE_STARTED"},{"VAR?":"SLICER_BEETLE_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_complete"},{"->":".^.^.^.9"},null]}],"nop","\n","done",{"quest_start":[[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^<<\"Hai tempo per aiutarmi con una cosa?\">>","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^<<\"Mi serve ancora aiuto, se puoi.\">>","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Cosa ti serve?","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev",{"VAR?":"SLICER_BEETLE_STARTED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_partner: laugh"},"^La locandiera sembra quasi euforica.","\n",{"#":"gesture_sable: surprised1"},"^<<\"Mi servirebbe che tu raccogliessi della Cacca di Scarabeo Tagliatore?\">>","\n","ev","str","^Della <i>cosa</i>?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Vuoi che raccolga cacca.","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Sembra parecchio puzzolente.","/str","/ev",{"*":".^.c-3","flg":4},{"c-1":["^ ","\n","^Mi sporgo in avanti, pensando di aver capito male.","\n","^<<\"Cacca di Scarabeo Tagliatore! Sai. Cibo entra, cacca esce.\">>","\n",{"#":"gesture_sable: arms_crossed"},"^Le dico che so cos'è la cacca.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-2":["^ ","\n","^Le chiedo se davvero vuole che raccolga della cacca.","\n","^<<\"Di scarabei, sì!\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n","^<<\"Non lo è! La loro dieta, ha quasi un buon odore.\">>","\n","^Resto scettica, ma non serve che lei lo sappia.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Sto cercando di far crescere più fiori in questi giorni, e sai come si dice: 'potere ai fiori, cacca agli scarabei'.\">>","\n","ev","str","^Chi lo dice?","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Un'espressione classica.","/str","/ev",{"*":".^.c-5","flg":4},{"c-4":["^ ","\n",{"#":"gesture_partner: uninterested"},"^<<\"Tanta gente.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-5":["^ ","\n",{"#":"gesture_partner: laugh"},"^<<\"Una delle mie preferite.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":["^<<\"Gli Scarabei Tagliatori sono piuttosto docili, ma per fargli uscire la cacca dovrai spaventarli.\">>","\n","^<<\"Saltargli sulla schiena di solito funziona. Ma costa fatica farli stare fermi. Sono sicura che capirai come fare. E non preoccuparti, non è crudele.\">>","\n",{"#":"gesture_sable: thinking"},"^Penso brevemente a come definirei la cosa se qualcuno mi salisse in groppa e mi spaventasse fino a farmela addosso.","\n",{"#":"gesture_sable: shrug"},"^<<\"O, beh, non fa loro male. Sono fatti di stoffa robusta. E supereranno. Ci siamo passate tutte, eh?\">>","\n","^<<\"Comunque, me ne serviranno tre palline.\">>","\n","^<<\"C'è un loro nido sotto Carab's Hold, a sud-est di qui, quindi è probabilmente lì che dovresti cercare.\">>","\n","^Le dico che me ne occupo e la saluto.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_complete":[["ev","str","^Ho la cacca per te.","/str",{"f()":"slicer_beetle_count"},3,">=","/ev",{"*":".^.c-0","flg":5},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev",{"VAR?":"SLICER_BEETLE_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"#":"inventory_remove: SlicerBeetlePoo, 3"},{"#":"gesture_partner: ecstatic"},"^Dico alla locandiera di avere la sua cacca. È estasiata.","\n","^<<\"Ben fatto! Grazie mille, Glider, è davvero meraviglioso da parte tua. Ti sei divertita?\">>","\n","ev","str","^Sì, in realtà.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non la definirei 'divertimento'.","/str","/ev",{"*":".^.c-2","flg":4},{"c-1":["^ ","\n","^Le dico che il compito mi è piaciuto mio malgrado e sembra contenta.","\n","^<<\"Avevo la sensazione che ti sarebbe piaciuto!\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_sable: shrug"},"^Le dico che non lo definirei proprio 'divertimento', ma il lavoro è fatto.","\n","^<<\"E te ne sono molto grata.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":[{"#":"gesture_partner: thanks"},"^<<\"Grazie di averlo fatto, Glider. I miei fiori sono molto grati!\">>","\n",{"#":"inventory_add: BeetleBadge"},"^<<\"Quindi a loro nome, vorrei darti questo. È un Distintivo dello Scarabeo, che direi ti sei guadagnata in virtù di tutta la... gestione cacca.\">>","\n","^Lo prendo volentieri.","\n","^Offro i miei ringraziamenti, faccio un saluto e me ne vado.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"#f":3}],"slicer_beetle_quest_definition":[{"#":"name"},"^La Caduta Lunga","\n",{"#":"locations"},"^quest_giver, beetle_nest","\n",{"#":"items"},"ev","str","^SlicerBeetlePoo","/str","out","/ev","\n",{"#":"status"},["ev",{"VAR?":"SLICER_BEETLE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.18"},null]}],["ev",{"VAR?":"SLICER_BEETLE_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.18"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.18"},null]}],"nop","\n","ev",{"VAR?":"SLICER_BEETLE_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Afii, la locandiera della Stazione Sette Sorelle, mi ha chiesto di recuperare della cacca di scarabeo tagliatore. Pare che gli scarabei svuotino le viscere quando salti loro sulla testa.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"SLICER_BEETLE_STARTED"},{"VAR?":"SLICER_BEETLE_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"f()":"slicer_beetle_count"},"/ev",{"temp=":"numPoo"},"\n",["ev",{"VAR?":"numPoo"},0,"==","/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: beetle_nest"},{"#":"status: active"},"^Dovrei andare a Carab's Hold e raccogliere tre palline di cacca.","\n",{"->":".^.^.^.9"},null]}],["ev",{"VAR?":"numPoo"},0,">",{"VAR?":"numPoo"},3,"<","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: beetle_nest"},{"#":"status: active"},"^Raccogli cacca - ","ev",{"VAR?":"numPoo"},"out","/ev","^/","ev",3,"out","/ev","\n",{"->":".^.^.^.9"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"locations: beetle_nest"},{"#":"status: completed"},"^Raccogli cacca - ","ev",3,"out","/ev","^/","ev",3,"out","/ev","\n","ev",{"VAR?":"SLICER_BEETLE_COMPLETED"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: quest_giver"},{"#":"status: active"},"^Ho raccolto abbastanza cacca. Dovrei riportarla a Afii alla Stazione Sette Sorelle.","\n",{"->":".^.^.^.21"},null]}],"nop","\n",{"->":".^.^.^.9"},null]}],"nop","\n",{"->":".^.^.^.33"},null]}],"nop","\n","ev",{"VAR?":"SLICER_BEETLE_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato della cacca e l'ho riportata alla locandiera Afii.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","end",{"#f":1}],"parasite_beetle_found_enough":["ev","str","^OrangeWingBeetle","/str",{"x()":"inventory_get_quantity","exArgs":1},3,">=","/ev","~ret","\n",{"#f":1}],"parasite_beetle_quest_content":[["ev",{"VAR?":"PARASITE_BEETLE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"PARASITE_BEETLE_STARTED"},{"VAR?":"PARASITE_BEETLE_COMPLETED"},{"f()":"between"},{"f()":"parasite_beetle_found_enough"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_in_progress"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"PARASITE_BEETLE_STARTED"},{"VAR?":"PARASITE_BEETLE_COMPLETED"},{"f()":"between"},{"f()":"parasite_beetle_found_enough"},"&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_complete"},{"->":".^.^.^.3"},null]}],"nop","\n","done",{"quest_start":[[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^<<\"Glider! Ho un lavoretto che puoi fare per me.\">>","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^<<\"Ho ancora quel lavoretto per te, se vuoi.\">>","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Qual è il lavoro?","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev",{"VAR?":"PARASITE_BEETLE_STARTED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Mi servono degli Scarabei dagli Anelli Arancioni. Tre. E ho pensato che non ci sia nessuno migliore di una Glider a cui chiederlo.\">>","\n","ev",{"f()":"parasite_beetle_found_enough"},"/ev",[{"->":".^.b","c":true},{"b":["^ ",{"->":".^.^.^.^.^.^.already_have_beetles"},{"->":".^.^.^.12"},null]}],"nop","\n","ev","str","^Vero!","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Il nostro amore per i compiti è molto esagerato.","/str","/ev",{"*":".^.c-2","flg":4},{"c-1":["^ ","\n",{"#":"gesture_sable: laugh"},"^<<\"Davvero, è l'unica cosa che mi manca del mio Volo. Aiuti tanta gente e impari tante cose! Il resto è solo sabbia nelle parti basse.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-2":["^ ","\n","^<<\"Davvero? Quando ero in Volo, avevo fame di cose da fare! Amavo incontrare persone, fare tutti i piccoli favori e sapere quanto stavo aiutando.\">>","\n",{"#":"gesture_sable: laugh"},"^<<\"Francamente è l'unica cosa che mi piaceva. Il resto è solo sabbia nelle parti basse.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":[{"#":"gesture_sable: talking"},"^Il Volo: solo sabbia nelle parti basse. Chiedo dove potrei trovare gli scarabei.","\n","^<<\"C'è un nido a nord-est di qui che dovrebbe averne qualcuno. Ma se non hai mai raccolto Scarabei dagli Anelli Arancioni prima, ti dico una cosa: sono nervosi!\">>","\n","^<<\"Appena ti avvicini, si scaveranno una via di fuga. Dovrai attirarli verso un posto... non scavabile.\">>","\n","^Le dico che farò del mio meglio.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_in_progress":["^<<\"Ancora a caccia di Scarabei? Riportameli quando hai finito.\">>","\n","ev","void","/ev","->->",{"#f":1}],"quest_complete":["ev",{"VAR?":"PARASITE_BEETLE_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_partner: ecstatic"},"^Porgo alla locandiera gli Scarabei raccolti e batte un po' le mani prima di prenderli e metterli delicatamente da parte.","\n",{"#":"inventory_remove: OrangeWingBeetle, 3"},{"#":"inventory_add: BeetleBadge"},"^<<\"Ben fatto! Spero ti sia divertita. E se no, beh... ti sei comunque guadagnata un bel distintivo per il disturbo.\">>","\n",{"#":"gesture_sable: thanks"},"^Ringrazio la locandiera per il distintivo e me ne vado.","\n",{"->":"END_SCENE"},{"#f":1}],"already_have_beetles":["ev",{"VAR?":"PARASITE_BEETLE_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^Dico alla locandiera che in realtà ho con me degli Scarabei dagli Anelli Arancioni <i>proprio</i> per questa occasione.","\n","^<<\"Incredibile! Posso averli?\">>","\n",{"#":"inventory_remove: OrangeWingBeetle, 3"},"^Glieli consegno.","\n","^<<\"Bene! Stavo cercando di dare a una Glider un compitino divertente, e tu l'hai già fatto! Fantastico, grazie.\">>","\n",{"#":"inventory_add: BeetleBadge"},"^<<\"Spero accetterai comunque questo distintivo. Tecnicamente hai dovuto lavorarci, no?\">>","\n","^Ringrazio la locandiera per il distintivo e me ne vado.","\n",{"->":"END_SCENE"},{"#f":1}],"#f":3}],"parasite_beetle_quest_definition":[{"#":"name"},"^Delizie dagli Anelli Arancioni","\n",{"#":"locations"},"^quest_giver, beetle_nest","\n",{"#":"items"},"ev","str","^OrangeWingBeetle","/str","out","/ev","\n",{"#":"status"},["ev",{"VAR?":"PARASITE_BEETLE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.18"},null]}],["ev",{"VAR?":"PARASITE_BEETLE_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.18"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.18"},null]}],"nop","\n","ev",{"VAR?":"PARASITE_BEETLE_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ofuu, la locandiera della Marrow Bone Station, mi ha chiesto di recuperare degli Scarabei dagli Anelli Arancioni dal nido nel Wash nord-orientale.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"PARASITE_BEETLE_STARTED"},{"VAR?":"PARASITE_BEETLE_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"f()":"parasite_beetle_found_enough"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: beetle_nest"},{"#":"status: active"},"^Dovrei andare al nido e raccogliere tre Scarabei dagli Anelli Arancioni.","\n",{"->":".^.^.^.7"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"locations: quest_giver"},{"#":"status: active"},"^Ho abbastanza scarabei, dovrei riportarli a Ofuu.","\n",{"->":".^.^.^.7"},null]}],"nop","\n",{"->":".^.^.^.33"},null]}],"nop","\n","ev",{"VAR?":"PARASITE_BEETLE_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato degli scarabei e li ho riportati a Ofuu.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","end",{"#f":1}],"chum_collection_reward_stages":["ev",{"VAR?":"chum_collection"},"LIST_ALL",{"list":{"chum_collection.CHUM_COLLECTION_STARTED":1,"chum_collection.CHUM_COLLECTION_COMPLETED":21}},"-","/ev","~ret","\n",{"#f":1}],"chum_collection_current_quest_stage":["ev",{"f()":"chum_collection_reward_stages"},"/ev",{"temp=":"reward_stages"},"\n","ev",{"VAR?":"reward_stages"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"CHUM_COLLECTION_COMPLETED"},"/ev","~ret",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"reward_stages"},{"VAR?":"reward_stages"},{"f()":"reached_any"},"-","LIST_MIN","/ev","~ret","\n",{"#f":1}],"chum_collection_current_target_number":["ev",{"f()":"chum_collection_current_quest_stage"},"LIST_VALUE","/ev","~ret","\n",{"#f":1}],"chum_collection_current_target_milestone":["ev",{"f()":"chum_collection_reward_stages"},{"f()":"reached_any"},"/ev",{"temp=":"reached_stages"},"\n","ev",{"VAR?":"reached_stages"},"LIST_COUNT",1,"+","/ev","~ret","\n",{"#f":1}],"chum_collection_has_enough_chums":["ev","str","^Chum","/str",{"x()":"inventory_get_quantity","exArgs":1},{"f()":"chum_collection_current_target_number"},">=","/ev","~ret","\n",{"#f":1}],"chum_collection_unlocked_all_upgrades":["ev",{"f()":"chum_collection_reward_stages"},{"f()":"reached"},"/ev","~ret","\n",{"#f":1}],"chum_collection_opened_all_doors":["ev",{"VAR?":"chum_lair_second_door_open"},{"VAR?":"chum_lair_third_door_open"},"&&","/ev","~ret",{"#f":1}],"queen_chum_conversation":["ev","str","^Regina Chum","/str","/ev",{"VAR=":"SpeakerName","re":true},["ev",{"VAR?":"CHUM_COLLECTION_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.first_intro"},{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"CHUM_COLLECTION_STARTED"},{"VAR?":"CHUM_COLLECTION_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.default_intro"},{"->":".^.^.^.10"},null]}],["ev",{"f()":"chum_collection_opened_all_doors"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.after_quest_complete"},{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n",{"->":"after_opening_all_doors"},{"->":".^.^.^.10"},null]}],"nop","\n",{"first_intro":[["ev",{"VAR?":"CHUM_COLLECTION_STARTED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_sable: surprised_1"},"^Vedendo il francamente immenso Chum che regge i resti di un'antica torre di pietra, quasi salto fuori dalla pelle.","\n",{"#":"gesture_sable: thinking"},"^Prima che riesca a riprendermi, sento una voce che tuba... nella mia testa?","\n","^<<\"Ah, salve, viandante!\">>","\n","^<<\"Ti prego, non spaventarti.\">>","\n","^Il Chum gigante inclina la testa verso di me e cinguetta.","\n","ev","str","^Stai parlando con me?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^È reale?","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: talking"},"^Mentre chiedo, mi rendo conto che la domanda è per me stessa.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: thinking"},"^Esprimo la mia esitante incredulità di fronte a questa scena.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Ti sto 'parlando', per quanto io possa parlare...\">>","\n","^<<\"E tu sei in grado di percepire i miei pensieri.\">>","\n","^<<\"Ma ti assicuro, sono reale tanto quanto te.\">>","\n","ev","str","^Chum","/str",{"x()":"inventory_get_quantity","exArgs":1},0,">","/ev",[{"->":".^.b","c":true},{"b":["\n","^<<\"Ho saputo che porti con te alcuni dei miei figli!\">>","\n","^Sento le uova contorcersi nella mia borsa al loro nome.","\n","^Mi rilasso all'improvviso, confortata dall'assurdità della situazione.","\n",{"->":".^.^.^.16"},null]}],[{"->":".^.b"},{"b":["\n","^<<\"Hai vagato molto lontano da casa, vero?\">>","\n","^Ridacchio alla scelta delle parole, all'improvviso rilassata.","\n","^Soprattutto per aver appena incontrato una gigantesca lumaca-di-sabbia telepatica.","\n",{"->":".^.^.^.16"},null]}],"nop","\n","^<<\"Il tuo nome è... antico... e vasto. Come il deserto!\">>","\n",{"#":"gesture_sable: talking"},"^Articolo le sillabe in silenzio mentre lei cinguetta senza voce.","\n","^<<\"Sable!\">>","\n","^<<\"Che bello! Io non ho un nome vero e proprio.\">>","\n","^<<\"Ma sono la Regina dei Chum. Puoi chiamarmi Regina Chum. O Chum Regina. Come preferisci.\">>","\n",{"#":"gesture_sable: greeting"},"^Inchino il capo educatamente.","\n","ev","str","^È un onore conoscerti, Regina.","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Come posso esserti utile?","/str","/ev",{"*":".^.c-3","flg":4},{"c-2":["^  ","\n","^La Regina sembra sorpresa dalla mia formalità.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^  ","\n","^La Regina sembra colta alla sprovvista dalla mia domanda.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Oh mio! Sei una piccola umana così educata!\">>","\n","^<<\"Beh, il fatto che tu sia qui sembra davvero una gran fortuna!\">>","\n","^<<\"Forse potresti aiutarci?\">>","\n","^<<\"Le nostre uova sono sparse per i deserti, ma devono essere piantate in un posto sicuro.\">>","\n","^<<\"Portamele qui, piccolina; potrò darti qualcosa per il tuo favore.\">>","\n",{"#":"gesture_sable: fist_pump"},"^La mia risposta arriva senza esitazione, un gran sì.","\n","^<<\"Sei una lumachina gentile, vero?\">>","\n","^<<\"Credo che mi piacerai, Sable.\">>","\n","^<<\"Per cominciare, portamene cinque.\">>","\n","ev","str","^Ce le ho già con me!","/str",{"f()":"chum_collection_has_enough_chums"},"/ev",{"*":".^.c-4","flg":5},"ev","str","^Addio.","/str","/ev",{"*":".^.c-5","flg":4},{"c-4":["^ ","\n",{"->":".^.^.^.^.^.quest_give_chum_logic"},{"#f":5}],"c-5":["^ ","\n",{"->":"END_SCENE"},{"#f":5}],"#f":5}]}],{"#f":1}],"default_intro":[[{"#":"gesture_sable: greeting"},"^Saluto la Regina Chum.","\n","^La Regina mi chiede se ho le uova per lei.","\n","ev","str","^Consegna uova.","/str",{"f()":"chum_collection_has_enough_chums"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Addio.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->t->":".^.^.^.^.quest_give_chum_logic"},{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Saluto la Regina.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"quest_give_chum_logic":["ev",{"f()":"chum_collection_current_quest_stage"},"/ev",{"temp=":"current_quest_stage"},"\n","ev",{"VAR?":"chums_delivered"},{"f()":"chum_collection_current_target_number"},"+",{"VAR=":"chums_delivered","re":true},"/ev","\n","ev",{"VAR?":"current_quest_stage"},"/ev",["du","ev",{"VAR?":"CHUM_REACHED_FIRST_MILESTONE"},"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^<<Sei stata occupata! Già così tanti di noi insieme!>>","\n",{"#":"gesture_sable: ecstatic"},"^<<Ottimo lavoro, giovane Sable.>>","\n","^La regina mi tuba addosso mentre la sua voce gentile risuona nella mia testa.","\n","^<<\"Che fortuna per noi che ti sia interessata a noi!\">>","\n",{"#":"gesture_sable: flirty"},"^Mi ritrovo a sorridere a questo magnanimo complimento.","\n","^<<\"Sei un esemplare raro in quest'epoca...\">>","\n","^>>> SCENA <<< ",{"#":"chum_cutscene"},"\n","^<<\"Bene, mi hai fatta commuovere!\">>","\n","^<<\"Per tua fortuna, le lacrime di un Chum portano grande potere.\">>","\n","^<<\"Ma ti suggerisco di tenere questa informazione per te.\">>","\n",{"#":"gesture_sable: arms_crossed"},"^Annuisco solennemente, risparmiandole ogni elaborazione sul suggerimento.","\n","^La lacrima sembra un dono; mi sento più forte, più resiliente.","\n","^<<\"Adesso portamene quindici!\">>","\n",{"->":".^.^.^.22"},null]}],["du","ev",{"VAR?":"CHUM_REACHED_SECOND_MILESTONE"},"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^<<\"Giovane Sable, è gentile da parte tua tornare a trovarmi!\">>","\n","^<<\"Ci hai aiutato a diventare una bella piccola comunità!\">>","\n","^La sua voce immaginaria è come un asciugamano fresco sulla nuca.","\n","^<<\"Tutti i piccoli che hai riportato a casa sono così entusiasti di far parte ora di una famiglia.\">>","\n","^>>> SCENA <<< ",{"#":"chum_cutscene"},"\n","^<<\"Li hai risparmiati da una vita di solitudine e vagabondaggi lontani.\">>","\n",{"#":"gesture_sable: fist_pump"},"^<<\"Sono così grati, anche ora nella loro giovinezza.\">>","\n","^Sento il potere delle lacrime della Regina vibrare dentro di me, anche mentre trattengo le mie.","\n","^<<\"Ora me ne serviranno venti.\">>","\n",{"->":".^.^.^.22"},null]}],["du","ev",{"VAR?":"CHUM_REACHED_THIRD_MILESTONE"},"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^<<Bentornata, Sable!>>","\n","^La Regina si dimena mentre mi saluta in silenzio.","\n","^<<\"Hai riportato altri dei miei figli a casa...\">>","\n","^<<\"È una vera gentilezza. Noi Chum non riceviamo spesso tanta premura.\">>","\n","^<<\"La tua dedizione verso di noi è davvero una benedizione!\">>","\n","^Anche se ho il viso coperto, sono sicura che la Regina percepisca il mio sorriso immenso.","\n","^<<\"Che sorriso genuino hai!\">>","\n","^<<\"Oh basta, mi sto commuovendo di nuovo...\">>","\n","^>>> SCENA <<< ",{"#":"chum_cutscene"},"\n","^La Regina tuba alla sua prole. Sembrano davvero più felici qui, anche se non saprei dire come faccio a notarlo.","\n","^Mi sento ancora più forte ora con un'altra lacrima della Regina.","\n","^<<\"Altri venti, per favore!\">>","\n",{"->":".^.^.^.22"},null]}],["du","ev",{"VAR?":"CHUM_REACHED_FOURTH_MILESTONE"},"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^<<\"Ciao di nuovo lumachina.\">>","\n","^Non sono sicura di come prendere il soprannome 'lumachina', ma chi sono io per mettere in dubbio un essere che proietta i suoi pensieri telepaticamente nella mia mente.","\n","^Mi sta sentendo adesso?","\n","^Consegno le uova con un po' di esitazione.","\n","^<<\"Su su lumachina, non temere. Stai facendo a me e al mio covo di Chum un favore di enorme portata. Ti adoriamo.\">>","\n","^>>> SCENA <<< ",{"#":"chum_cutscene"},"\n","^Un suono di soddisfazione vibra su per il corpo della Regina, scuotendo lievemente polvere e detriti dalla torre che regge.","\n","^<<\"E altri venti, se non ti dispiace...\">>","\n",{"->":".^.^.^.22"},null]}],["du","ev",{"VAR?":"CHUM_REACHED_FIFTH_MILESTONE"},"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^<<\"Oh oh, portatrice d'uova.\">>","\n","^<<\"I miei figli danzano d'eccitazione per i tesori che porti — più amici con cui ballare e giocare!\">>","\n","^Devo ammettere che raccogliere chum è stato un compito più appagante di quanto pensassi all'inizio.","\n","^Consegno la prossima partita di uova con entusiasmo.","\n","^Ora, penso tra me, mi prenderò una di quelle lacrime preziose, grazie.","\n","^<<\"Su su, bambina. Un po' di pazienza.\">>","\n","^>>> SCENA <<< ",{"#":"chum_cutscene"},"\n","^Il calore della lacrima del Chum pulsa nel mio petto e si diffonde nelle mie membra.","\n","^<<\"Altri venti per favore. Prometto che è l'ultima partita!\">>","\n",{"->":".^.^.^.22"},null]}],["du","ev",{"VAR?":"CHUM_REACHED_SIXTH_MILESTONE"},"==","/ev",{"->":".^.b","c":true},{"b":["pop","\n","^<<\"Ce l'hai fatta! Sei la nostra campionessa!\">>","\n",{"#":"gesture_sable: ecstatic"},"^Sento eccitazione e orgoglio salire dentro di me.","\n","^<<\"Ora bambina, apri il tuo cuore a me.\">>","\n","^>>> SCENA <<< ",{"#":"chum_cutscene"},"\n",{"->":".^.^.^.22"},null]}],[{"->":".^.b"},{"b":["pop","\n","^<<\"Questo è un fallback perché la missione non si sgretoli!\">>","\n","^>>> SCENA <<< ",{"#":"chum_cutscene"},"\n","^<<\"Continua a portarmeli, Sable!\">>","\n",{"->":".^.^.^.22"},null]}],"nop","\n","ev",{"VAR?":"current_quest_stage"},{"f()":"activate"},"pop","/ev","\n","ev",{"f()":"chum_collection_unlocked_all_upgrades"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.^.main_quest_complete"},{"->":".^.^.^.35"},null]}],[{"->":".^.b"},{"b":["\n",{"->":"END_SCENE"},{"->":".^.^.^.35"},null]}],"nop","\n",{"#f":1}],"main_quest_complete":["ev",{"VAR?":"CHUM_COLLECTION_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Ben fatto, Sable. Credo di non aver più lacrime da piangere.\">>","\n","^<<\"Non te ne rendi conto, ma ci hai reso un bel servizio.\">>","\n","^<<\"Non c'erano stati così tanti Chum riuniti da secoli!\">>","\n","^<<\"E dato che sei stata così d'aiuto, useremo il nostro potere collettivo per darti un dono...\">>","\n","^>>> SCENA <<< ",{"#":"chum_lair_first_door"},"\n","^<<\"Nel forziere troverai una maschera, ti aiuterà a trovare ancora più dei miei figli.\">>","\n","^<<\"Portamene quanti ne trovi!\">>","\n","^<<\"Qui abbiamo una casa felice, adesso, grazie a te!\">>","\n",{"#":"gesture_sable: fist_pump"},"^Ringrazio la Regina profusamente e celebro la mia nuova acquisizione.","\n",{"->":"END_SCENE"},{"#f":1}],"after_quest_complete":[["ev","str","^Chum","/str",{"x()":"inventory_get_quantity","exArgs":1},"/ev",{"temp=":"held_chums"},"\n","^<<\"Hai altre uova per me, Sable?\">>","\n","ev","str","^Consegna uova.","/str",{"VAR?":"held_chums"},0,">","/ev",{"*":".^.c-0","flg":5},"ev","str","^Addio.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"chums_delivered"},{"VAR?":"held_chums"},"+",{"VAR=":"chums_delivered","re":true},"/ev",{"#":"inventory_remove_all: Chum"},"^Consegno le mie Uova di Chum alla Regina.","\n",["ev",{"VAR?":"chums_delivered"},165,">=",{"VAR?":"chum_lair_second_door_open"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.^.^.^.open_both_doors"},{"->":".^.^.^.15"},null]}],["ev",{"VAR?":"chums_delivered"},130,">=",{"VAR?":"chum_lair_second_door_open"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.^.^.^.open_second_door"},{"->":".^.^.^.15"},null]}],["ev",{"VAR?":"chums_delivered"},165,">=",{"VAR?":"chum_lair_second_door_open"},"&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.^.^.^.open_third_door"},{"->":".^.^.^.15"},null]}],[{"->":".^.b"},{"b":["\n","^<<\"Grazie, Sable. Continua a cercare altre uova.\">>","\n",{"->":".^.^.^.15"},null]}],"nop","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Saluto la Regina.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"open_second_door":["ev",1,"/ev",{"VAR=":"chum_lair_second_door_open","re":true},"^<<\"Hai fatto bene, Sable!\">>","\n","^<<\"Ci hai reso così fieri...\">>","\n","^<<\"I miei figli mi raccontano tutti storie su di te.\">>","\n",{"#":"gesture_sable: thanks"},"^Sento il viso arrossire, in parte lusingata, in parte allarmata al pensiero di uova telepatiche.","\n","^<<\"Oh non preoccuparti, niente di imbarazzante!\">>","\n","^<<\"In ogni caso, ecco!\">>","\n","^>>> SCENA <<< ",{"#":"chum_lair_second_door"},"\n","^<<\"Sembra che questi doni fossero forse destinati a te, mia cara.\">>","\n",{"#":"gesture_sable: surprised_1"},"^<<\"Che bella piccola Chum stai diventando!\">>","\n","^<<\"Continua a cercare altre uova!\">>","\n",{"->":"END_SCENE"},{"#f":1}],"open_third_door":["ev",1,"/ev",{"VAR=":"chum_lair_third_door_open","re":true},{"->t->":".^.^.final_door_start"},"^<<\"Per favore, prendi questo, e vieni a stare con noi quando vuoi.\">>","\n","^>>> SCENA <<< ",{"#":"chum_lair_third_door"},"\n",{"#":"gesture_sable: fist_pump"},"^<<\"Sei a tutti gli effetti una chum ora, piccola Sable, in tutto tranne che nel corpo.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"open_both_doors":["ev",1,"/ev",{"VAR=":"chum_lair_second_door_open","re":true},"ev",1,"/ev",{"VAR=":"chum_lair_third_door_open","re":true},{"->t->":".^.^.final_door_start"},"^<<\"Per favore prendi questo.\">>","\n","^>>> SCENA <<< ",{"#":"chum_lair_second_door"},"\n","^<<\"E anche questo, e vieni a stare con noi quando vuoi.\">>","\n","^>>> SCENA <<< ",{"#":"chum_lair_third_door"},"\n",{"#":"gesture_sable: fist_pump"},"^<<\"Sei a tutti gli effetti una chum ora, piccola Sable, in tutto tranne che nel corpo.\">>","\n","^<<\"Questi sono i miei ultimi doni per te, Sable. Grazie di tutto l'aiuto.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"final_door_start":["^<<\"Sable! Mia piccola chum, ce l'hai fatta!\">>","\n","^<<\"Ci hai trovati tutti!\">>","\n","^Sento un'onda di sollievo invadermi mentre la sua voce echeggia nella mia testa.","\n","^Se sia sua o mia, non saprei dire, ma spero entrambe le cose.","\n","^<<\"Non ho mai dubitato di te.\">>","\n","^<<\"Oh non riusciremo mai a ringraziarti davvero, ma spero che basti.\">>","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"after_opening_all_doors":["^Trascorro un momento con la Regina.","\n",{"->":"END_SCENE"},{"#f":1}],"chum_collection_quest_definition":[{"#":"name"},"^Costruire un Reginato","\n",{"#":"locations"},"^chum_queen","\n",{"#":"items"},"ev","str","^Chum","/str","out","/ev","\n",{"#":"status"},["ev",{"VAR?":"CHUM_COLLECTION_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.18"},null]}],["ev",{"VAR?":"CHUM_COLLECTION_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":"