\n",{"#":"stage"},{"#":"status: completed"},"^Hamza è il Macchinista cittadino. La sua storia regge?","\n",{"->":".^.^.^.35"},null]}],"nop","\n","ev",{"VAR?":"ATOMIC_HEART_SUSPECT_IRIA"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Iria gestisce il Mercato di Eccria, potrebbe essere coinvolta nel guasto?","\n",{"->":".^.^.^.42"},null]}],"nop","\n","ev",{"VAR?":"ATOMIC_HEART_SUSPECT_GARAY"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Garay fa parte del Serai, e vive sotto il ponte che porta a Eccria. È lui il colpevole?","\n",{"->":".^.^.^.49"},null]}],"nop","\n","ev",{"VAR?":"has_clues"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^<b>Prove fisiche nell'indagine:</b>","\n",{"->":".^.^.^.55"},null]}],"nop","\n","ev",{"VAR?":"ATOMIC_HEART_CLUE_GLASS"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Chiaro come il sole, si vede che la finestra alta è stata frantumata, ed è abbastanza larga perché ci passi un adulto-- anche se dovrebbe essere piuttosto atletico. La maggior parte del vetro è all'esterno della camera: potrebbe essere stata rotta dall'interno.","\n",{"->":".^.^.^.62"},null]}],"nop","\n","ev",{"VAR?":"ATOMIC_HEART_CLUE_NOTE"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Un pezzetto di carta giace abbandonato sul pavimento, e quando lo raccolgo vedo che è un pagherò: qualcuno, forse il colpevole, deve dei soldi ai Mercanti. È possibile che il colpevole l'abbia perso, ma chi potrebbe essere così sbadato sulla scena del proprio crimine? Mi chiedo se sia un'esca, lasciata per depistarmi.","\n",{"->":".^.^.^.69"},null]}],"nop","\n","ev",{"VAR?":"ATOMIC_HEART_CLUE_FEATHER"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Una grande piuma dentro la camera nucleare; sembra una distrazione ma potrebbe essere un indizio?","\n",{"->":".^.^.^.76"},null]}],"nop","\n","ev",{"VAR?":"ATOMIC_HEART_CLUE_SOCKET"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Il colpevole ha rimosso il nucleo con cura. Ha senso. Se dovessi rubare qualcosa di così prezioso, anch'io sarei delicata. Ma perché i cavi strappati? Mi sembra quasi una messinscena.","\n",{"->":".^.^.^.83"},null]}],"nop","\n","ev",{"VAR?":"has_suspects"},{"VAR?":"has_clues"},"||","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^<b>Eventi della missione:</b>","\n",{"->":".^.^.^.91"},null]}],"nop","\n","ev",{"VAR?":"ATOMIC_HEART_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho parlato con Sandip, una guardia di Eccria. Vuole che aiuti con l'indagine sul Cuore Atomico — la centrale eccrina che è stata recentemente sabotata.","\n",{"->":".^.^.^.98"},null]}],"nop","\n",["ev",{"VAR?":"ATOMIC_HEART_STARTED"},{"VAR?":"ATOMIC_HEART_DELIVERED_SPARE_PART"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: hamza"},"^Consegna il nuovo nucleo di potenza a Hamza, il Macchinista di Eccria.","\n",{"->":".^.^.^.102"},null]}],["ev",{"VAR?":"ATOMIC_HEART_DELIVERED_SPARE_PART"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho consegnato il nucleo di scorta a Hamza per le riparazioni.","\n",{"->":".^.^.^.102"},null]}],"nop","\n",["ev",{"VAR?":"ATOMIC_HEART_SPARE_PART_READY"},{"VAR?":"ATOMIC_HEART_GOT_SPARE_PART"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: sandip"},{"#":"status: active"},"^Controlla con Sandip se il nucleo di scorta è pronto.","\n",{"->":".^.^.^.106"},null]}],["ev",{"VAR?":"ATOMIC_HEART_GOT_SPARE_PART"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sandip mi ha dato un nucleo di potenza di ricambio per il Cuore Atomico, e anche una chiave per la porta.","\n",{"->":".^.^.^.106"},null]}],"nop","\n",["ev",{"VAR?":"ATOMIC_HEART_GOT_SPARE_PART"},{"VAR?":"ATOMIC_HEART_FOUND_HEART"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: sub_station"},"^Segui il cavo gigante da Eccria fino al Cuore Atomico.","\n",{"->":".^.^.^.110"},null]}],["ev",{"VAR?":"ATOMIC_HEART_FOUND_HEART"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato la strada per il Cuore Atomico.","\n",{"->":".^.^.^.110"},null]}],"nop","\n",["ev",{"VAR?":"ATOMIC_HEART_FOUND_HEART"},{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: atomic_heart"},"^Installa il nuovo nucleo nel Cuore Atomico.","\n",{"->":".^.^.^.114"},null]}],["ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho installato il nucleo di ricambio e l'energia è tornata.","\n",{"->":".^.^.^.114"},null]}],"nop","\n",["ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"VAR?":"ATOMIC_HEART_RETURNED_AFTER_FIXING"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: sandip"},"^Dovrei tornare da Sandip ora che l'energia è tornata.","\n",{"->":".^.^.^.118"},null]}],["ev",{"VAR?":"ATOMIC_HEART_RETURNED_AFTER_FIXING"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sono tornata a Eccria e ho parlato con Sandip dopo il ritorno dell'energia.","\n",{"->":".^.^.^.118"},null]}],"nop","\n","ev",{"VAR?":"ATOMIC_HEART_STARTED"},{"VAR?":"ATOMIC_HEART_GOT_SPARE_PART"},{"f()":"between"},{"VAR?":"ATOMIC_HEART_RETURNED_AFTER_FIXING"},{"VAR?":"ATOMIC_HEART_COMPLETED"},{"f()":"between"},"||","/ev",