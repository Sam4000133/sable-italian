t->":"badlands_ring_monument"},"\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^"},{"#f":5}]}],{"#f":3}],"bridge_of_the_betrayed":[["^Ti trovi al Ponte dei Traditi.","\n","thread",{"->":".^.^.^"},"ev","str","^Guardia Eliisabet","/str",{"VAR?":"A_VIEW_FROM_THE_BRIDGE_STARTED"},{"VAR?":"A_VIEW_FROM_THE_BRIDGE_COMPLETED"},{"f()":"between"},"/ev",{"*":".^.c-0","flg":5},{"c-0":["^ ",{"->t->":"eliisabet_hercules_conversation"},"\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"crystal_plateau":["^Ti trovi al Crystal Plateau.","\n","thread",{"->":".^.^"},"ev",{"^->":"lightning_in_a_shard_quest_debug"},{"^->":"debug_player.crystal_plateau"},"/ev","thread",{"->":"thread_in_tunnel"},"done",{"#f":3}],"atomic_heart_location":["^Ti trovi al Cuore Atomico.","\n","ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["^ La corrente è accesa. ",{"->":".^.^.^.8"},null]}],[{"->":".^.b"},{"b":["^ La corrente è spenta. ",{"->":".^.^.^.8"},null]}],"nop","\n","thread",{"->":".^.^"},"ev",{"^->":"atomic_heart_quest_debug"},{"^->":"debug_player.atomic_heart_location"},"/ev","thread",{"->":"thread_in_tunnel"},"done",{"#f":3}],"llhors_camp":[["^Ti trovi al campo di Llhor.","\n","thread",{"->":".^.^.^"},"ev",{"VAR?":"LLHOR_RETURNED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","^Non c'è nessuno qui.","\n","done",{"->":".^.^.^.9"},null]}],"nop","\n","ev","str","^Llhor","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ",{"->t->":"llhor_conversation"},"\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"western_dunes":[["^Ti trovi nelle Dune Occidentali.","\n","thread",{"->":".^.^.^"},"ev","str","^Sarin","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Visita il Monumento dell'Anello delle Dune Occidentali","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ",{"->t->":"sarin_conversation"},"\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ",{"->t->":"western_ring_monument"},"\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"hercules_beetle_nest":["^Ti trovi al Nido dello Scarabeo Ercole.","\n","thread",{"->":".^.^"},"ev",{"^->":"hercules_beetle_quest_debug"},{"^->":"debug_player.hercules_beetle_nest"},"/ev","thread",{"->":"thread_in_tunnel"},"done",{"#f":3}],"salt_plains":[["^Ti trovi nelle Saline.","\n","thread",{"->":".^.^.^"},"ev","str","^Visita il Monumento dell'Anello delle Saline","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Raccoglitore di Sale Felix","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ",{"->t->":"salt_plains_ring_monument"},"\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ",{"->t->":"salt_plains_felix_conversation"},"\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"puzzle_ships":["thread",{"->":".^.^"},"ev",{"^->":"historical_reconnection_quest_debug"},{"^->":"debug_player.puzzle_ships"},"/ev","thread",{"->":"thread_in_tunnel"},"done",{"#f":3}],"#f":1}],"angler_yoshi":["ev",{"VAR?":"speaker_yoshi"},"/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Più volte Simoon ha rallentato su una duna senza che glielo chiedessi, o ha preso una curva inaspettata ma dolce attorno a qualcosa di invisibile, e mi sono chiesta se attingesse al ricordo di un tempo passato.","\n","^Ma ultimamente mi sono chiesta se si stia sintonizzando su un flusso diverso del tutto: i movimenti dei pesci che nuotano sotto le sabbie.","\n","^Mi avvicino al Pescatore con questo in mente, e penso a quanto debba essere interessante trovare la propria vocazione nella pesca, nel tendere verso cose che non si possono vedere. Potrebbe persino insegnarmi un po' di pazienza.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","^<<\"Ehilà, Glider! Cosa posso fare per te?\">>","\n",{"->":".^.choices"},{"choices":[["^Di cosa voglio parlare?","\n","ev","str","^Vorrei imparare a pescare!","/str",{"VAR?":"FISHING_QUEST_STARTED"},{"f()":"reached"},"!","/ev",{"*":".^.c-0","flg":5},"ev","str","^Ho quei pesci che mi hai chiesto.","/str",{"f()":"fishing_quest_ready_to_deliver"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Dove posso imparare di più sui pesci?","/str",{"VAR?":"FISHING_QUEST_STARTED"},{"f()":"reached"},{"CNT?":"researcher_casii"},"!","&&","/ev",{"*":".^.c-2","flg":5},"ev","str","^Casii ti saluta!","/str",{"CNT?":"researcher_casii"},"/ev",{"*":".^.c-3","flg":5},"ev","str","^Addio.","/str","/ev",{"*":".^.c-4","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.start_quest"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.deliver_fish"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.^.go_to_vivarium"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.^.^.talk_about_casii"},{"#f":5}],"c-4":["^ ","\n",{"->":".^.^.^.^.end"},{"#f":5}]}],{"#f":1}],"end":["^<<\"Buona fortuna là fuori.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"start_quest":[["ev",{"VAR?":"FISHING_QUEST_STARTED"},{"f()":"activate"},"pop","/ev","\n","^Il Pescatore annuisce.","\n","^<<\"Vuoi la Maschera del Pescatore, eh? Spero tu sia più paziente di alcune di queste Glider...\">>","\n","ev","str","^Sono molto paziente! Molto!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ci... sto lavorando.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^  ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Sono <i>certa</i> che sorrida.","\n","^<<\"Hmm. Beh, in ogni caso, la prima cosa che ti servirà è una canna da pesca, e te ne darò una delle mie vecchie. Buona per un'apprendista.\">>","\n",{"#":"inventory_add: BasicFishingRod"},"^<<\"Prendi questa.\">>","\n","^<<\"Puoi usarla per lanciare ovunque trovi della sabbia.\">>","\n","ev","str","^<i>Ovunque?</i>","/str","/ev",{"*":".^.c-2","flg":4},{"c-2":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Ovunque. Se prendi qualcosa o no è un altro discorso, ma è il bello di fare il Pescatore. Sentirla.\">>","\n","^Annuisco.","\n","^<<\"Quindi se vuoi guadagnarti la Maschera, è così che si fa. Non sono qui a perdere il tuo tempo se tu non sei qui a perdere il mio.\">>","\n","^<<\"Per il primo distintivo, mi basterà vedere qualche pesce di qui dal Sansee. Portami un <b>Guppy Mantice</b>, un <b>Pesce Ciottolo</b> e un <b>Pesce Pillola</b> e siamo a posto.\">>","\n","^<<\"E ricorda — ogni specie ha il suo habitat, quindi dovrai cercare in giro per scoprire dove vivono. Un consiglio da chi sa: molti pesci sopravvivono mordicchiando le radici delle piante — è un buon punto di partenza.\">>","\n","^Lo ringrazio e parto.","\n",{"->":".^.^.^.^.end"},{"#f":5}]}],{"#f":1}],"deliver_fish":[["ev",{"VAR?":"FISHING_QUEST_STARTED"},{"VAR?":"FISHING_QUEST_GOT_FIRST_BADGE"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.^.first_delivery"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"FISHING_QUEST_GOT_FIRST_BADGE"},{"VAR?":"FISHING_QUEST_GOT_SECOND_BADGE"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.^.second_delivery"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"FISHING_QUEST_GOT_SECOND_BADGE"},{"VAR?":"FISHING_QUEST_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.^.third_delivery"},{"->":".^.^.^.3"},null]}],"nop","\n",{"#f":1}],"first_delivery":["ev",{"VAR?":"FISHING_QUEST_GOT_FIRST_BADGE"},{"f()":"activate"},"pop","/ev","\n","^<<\"Bene bene! Bel lavoro, Glider. Primo passo completato.\">>","\n",{"#":"inventory_add: AnglerBadge"},"^<<\"Te lo sei guadagnato.\">>","\n","^<<\"Ma pescare è tutta questione di pazienza, no? Vediamo quanta ne hai ancora. Per il prossimo compito, voglio che tu vada al Wash.\">>","\n","^<<\"Portami un <b>Calciatore</b>, una <b>Vongola Occhio Gonfio</b> e una <b>Gelatina Inutile</b>.\">>","\n",{"->":".^.^.end"},{"#f":1}],"second_delivery":["ev",{"VAR?":"FISHING_QUEST_GOT_SECOND_BADGE"},{"f()":"activate"},"pop","/ev","\n","^<<\"Un altro bottino riuscito. Eccellente! Potresti davvero esserti messa d'impegno, eh?\">>","\n","^Gli dico che sono seria come un Calciatore, che spero sia una caratteristica del pesce, perché farebbe sembrare me molto esperta se così fosse. Ridacchia, ma non capisco come.","\n",{"#":"inventory_add: AnglerBadge"},"^<<\"Bene, ecco un altro distintivo per il tuo duro lavoro.\">>","\n","^<<\"Ora, Glider. Un ultimo compito prima che la maschera sia tua, e questo ti porterà a ovest nel <i>Redsee</i>.\">>","\n","^<<\"Portami... un <b>Pesce Tempesta</b>, una <b>Razza di Sabbia</b> e un <b>Ronzante</b>.\">>","\n",{"->":".^.^.end"},{"#f":1}],"third_delivery":[["ev",{"VAR?":"FISHING_QUEST_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Ah!\">>","\n","^Yoshi sembra meno sorpreso di quanto mi aspettassi, ma più felice.","\n","^<<\"Bene! Hai sentito il richiamo delle sabbie, vero, Sable? Ben fatto con questo, davvero un bel lavoro.\">>","\n","ev","str","^Grazie!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non pensavo di averlo dentro.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Credo che Simoon senta i pesci anche lei.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Yoshi liquida i miei ringraziamenti con un gesto.","\n","^<<\"Grazie <i>a te</i>. Fidati, Sable. Tante Glider <i>pensano</i> di voler pescare, o credono di poterlo fare. Poche se la cavano come te. È stato bello vederti fiorire.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Cosa che probabilmente ti rende aperta alle possibilità, meglio della troppa sicurezza che la maggior parte delle Glider porta in tavola.\">>","\n","^Yoshi scuote la testa.","\n","^<<\"Non so dirti quanti giovani spavaldi mi abbiano detto che sarebbero diventati esperti Pescatori, solo per pescare niente altro che rocce. Tu sei la canna giusta.\">>","\n","^Fa una pausa.","\n","^<<\"Non so se si nota, ma intendevo <i>'canna'</i> come una canna da pesca. Umorismo da Pescatore.\">>","\n","^Gli dico che è una buona battuta e ridiamo, ma non troppo.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^Dico a Yoshi che credo Simoon a volte senta i pesci.","\n","^<<\"Senza dubbio.\">>","\n","^Mi sorprende quanto la prenda con calma.","\n","^<<\"Ho sempre pensato che le sabbie custodiscano ricordi proprio come le macchine, e che i pesci vi scorrano dentro nel modo in cui lo fanno...\">>","\n","^<<\"Beh, ci dobbiamo connettere con <i>qualcosa</i>, no? Per me ha senso.\">>","\n","^Gli dico che sono d'accordo, e lo ringrazio della comprensione.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Si schiarisce la voce per renderla più ufficiale.","\n",{"#":"inventory_add: AnglerBadge"},"^<<\"E ora, ho il piacere di consegnarti questo.\">>","\n","^<<\"Spero tu continui a pescare per il resto del Volo, Sable. Che sia la tua vocazione o no, ti suggerisco di farne almeno un hobby. È un nobile passatempo... e tra te e me, una fonte di reddito molto sicura.\">>","\n","^Ringrazio Yoshi per tutto e mi metto in cammino.","\n",{"->":".^.^.^.^.end"},{"#f":5}]}],{"#f":1}],"go_to_vivarium":[["^<<\"Semplice! Puoi pescarli.\">>","\n","ev","str","^No, ho detto <i>imparare</i>.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Hmm...","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Per pescarli, devi osservarli. Impari come si <i>muovono</i>. Impari cosa vogliono, come <i>vivono</i>, come <i>superarli con l'astuzia</i>.\">>","\n","^Chiedo se i pesci siano davvero così furbi.","\n","^<<\"Pff. È come chiedere a un pesce se <i>tu</i> sei davvero così furba.\">>","\n","ev","str","^Davvero?","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Cosa direbbe, secondo te?","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Ooh. Immagina un pesce parlante.","/str","/ev",{"*":".^.c-4","flg":4},{"c-2":["^ ","\n","^Chiedo se sia davvero così.","\n","^<<\"È esattamente così. Perché non saprebbero rispondere! Per loro sei indecifrabile. E quindi l'osservazione è <i>fondamentale</i>.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n","^<<\"Non potresti immaginarlo.\">>","\n","^Chiedo se sia una battuta. Mi guarda con espressione vuota e spiego che forse 'immergere' era un riferimento alla profondità?","\n","^<<\"No. Sono mortalmente serio. Se entrassi nella testa di un pesce non ne caveresti un ragno dal buco. Sono misteri.\">>","\n","^<<\"Per questo l'osservazione è <i>fondamentale</i>.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n","^<<\"Non serve. I pesci <i>parlano</i>. Solo non con le parole.\">>","\n","^<<\"Parlano col movimento e con le reazioni. E quindi vanno <i>osservati</i>.\">>","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^Dico a Yoshi che mi piacerebbe davvero osservare di più, ma che <i>intendevo</i> un metodo di apprendimento più convenzionale.","\n","^Sento l'aria uscirgli dalle narici, una risata soffiata.","\n","^<<\"Sai cos'è buffo? Mi ricordi qualcuno. Cosa che sono sicuro ti dicano spesso, dato il tuo...\">>","\n","^Mi fa un cenno e aspetto. <i>Cosa sta per dire?</i> Dato il mio <i>cosa</i>?","\n","^<<\"Sai. Cosa. Comunque, mi ricordi una mia vecchia studentessa, Casii.\">>","\n","^Ride.","\n","^<<\"Povera ragazza, non sapeva pescare per salvarsi la vita, ma la <i>passione</i>. Li amava.\">>","\n","^<<\"Proprio perché era così appassionata, l'ho tenuta abbastanza a lungo da farle un corso di pesca, e l'ho persino portata in un viaggio a provare a catturare farfalle, per vedere se fosse più facile.\">>","\n","ev","str","^Lo è stato?","/str","/ev",{"*":".^.c-5","flg":4},{"c-5":["^ ","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":["^<<\"No! Ma ho visto che aveva un vero talento per la <i>ricerca</i>. Era quello che le piaceva <i>davvero</i>, e le ho detto: 'Fa' quello!'\">>","\n","^<<\"L'ultima volta che ho saputo, stava cercando di mettere su qualcosa nel Wash. Un centro di ricerca o cose così. Bene per lei, dico io.\">>","\n","^Annuisce.","\n","^<<\"Orgoglioso.\">>","\n","^<<\"Se la vedi nei tuoi viaggi, salutamela.\">>","\n",{"->":".^.^.^.^.choices"},{"#f":5}]}],{"#f":1}],"talk_about_casii":[["^<<\"Casii?\">>","\n","^Sento la ruga sulla sua fronte. Poi si illumina.","\n","^<<\"Casii! Conosci Casii? Come sta?\">>","\n","^Dico a Yoshi che Casii sta andando alla grande, e che il suo vivario è partito davvero bene.","\n","^<<\"È <i>fantastico</i> da sentire. Sai... hmm. Ha parlato di me, vero? Cos'ha detto?\">>","\n","ev","str","^Ha detto che sei stato molto gentile.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ha detto che sei un buon mentore.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Ha detto che hai la conoscenza.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Yoshi annuisce.","\n","^<<\"È gentile da parte sua. E onestamente? Sono felice di sentirlo. Mi ero sempre preoccupato che pensasse di avermi deluso o qualcosa, perché non era brava a pescare. A chi importa, dico io?\">>","\n","^<<\"Volevo solo che facesse quello che amava! E sembra che lo stia facendo.\">>","\n","^<<\"Credo che passerò al vivario un giorno, a salutarla di persona. Grazie, Glider.\">>","\n","^Gli dico che è un piacere.","\n",{"->":".^.^.^.^.choices"},{"#f":5}]}],{"#f":1}],"#f":1}],"player_has_fish_to_deliver":["ev",1,"/ev","~ret",{"#f":1}],"player_has_butterflies_to_deliver":["ev",1,"/ev","~ret",{"#f":1}],"player_has_delivered":[{"temp=":"itemName"},"ev",0,"/ev","~ret",{"#f":1}],"delivered_all_fish":["ev",0,"/ev","~ret",{"#f":1}],"delivered_all_butterflies":["ev",0,"/ev","~ret",{"#f":1}],"fish_count":["ev",0,"/ev","~ret",{"#f":1}],"butterfly_count":["ev",0,"/ev","~ret",{"#f":1}],"delivered":[{"temp=":"itemName"},"ev",{"VAR?":"itemName"},{"x()":"player_has_delivered","exArgs":1},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"delivered_string"},"/ev","~ret",{"->":".^.^.^.7"},null]}],[{"->":".^.b"},{"b":["\n","ev",{"VAR?":"missing_string"},"/ev","~ret",{"->":".^.^.^.7"},null]}],"nop","\n",{"#f":1}],"researcher_casii":["ev",{"VAR?":"speaker_casii"},"/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->":".^.^.^.first_greeting"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->":".^.^.^.default_greeting"},{"->":".^.^.17"},null],"#f":5}],"\n",{"default_greeting":["^<<\"Ciao di nuovo, Sable.\">>","\n",{"->":".^.^.choices"},{"#f":1}],"first_greeting":[["^Saluto la Ricercatrice Casii.","\n","^<<\"Benvenuta... al Grande Vivario!\">>","\n","^La persona al banco mi accoglie a braccia aperte, che abbassa con un piccolo svolazzo aviario. Mi sento molto benvenuta.","\n","^<<\"Sei una Glider, vero?\">>","\n","ev","str","^Sì!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Cosa mi ha tradita?","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"L'andatura.\">>","\n","^Interessante.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Ti piacerà questo posto, ne sono certa.\">>","\n","^Prende fiato, come se <i>non</i> ne fosse certa, e la lascio parlare.","\n","^<<\"Sono Casii, e sono la proprietaria di questo Vivario. Piacere di conoscerti...\">>","\n","ev","str","^Sable.","/str","/ev",{"*":".^.c-2","flg":4},{"c-2":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Sable. Bel nome. Io sono Casii! O — l'ho già detto, vero? Scusa. Dimenticalo.\">>","\n","^<<\"Benvenuta al Vivario! Una casa per animali piccoli e ancora più piccoli, dal pesce più elegante alla farfalla più fragile. E tutto ciò che sta in mezzo! Che è soprattutto piante e rocce.\">>","\n","^<<\"Lo so. C'è ancora un po' di lavoro da fare. Ma sono nuova del mestiere.\">>","\n","^Sembra che sorrida, anche se nervosamente.","\n","^<<\"Non molto tempo fa ho finito il <i>mio</i> Volo.\">>","\n","ev","str","^Congratulazioni!","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Non riesco a immaginare di finire il mio Volo.","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Sto per finire, credo.","/str","/ev",{"*":".^.c-5","flg":4},{"c-3":["^ ","\n","^Faccio le congratulazioni a Casii per aver finito il suo Volo, e per aver creato un Vivario così bello. È un posto che trasmette molta felicità.","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-4":["^ ","\n","^Dico a Casii che non riesco a immaginare di finire il mio Volo, ma spero di creare un giorno qualcosa di bello come il Vivario. Mi ringrazia, e poi sembra molto sincera.","\n","^<<\"Finirà prima che te ne accorga, quindi godilo finché puoi.\">>","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-5":["^ ","\n","^Le dico che credo finirò presto il mio Volo, e che posso solo sperare di creare un giorno qualcosa di bello come il suo Vivario.","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":["^Casii mi ringrazia, e mi guarda molto sinceramente.","\n","^<<\"Se posso darti un consiglio?\">>","\n","^<<\"Quando credi di aver finito di pensare a cosa vuoi fare, ripensaci. Perché io dovevo essere una <i>Pescatrice</i>. E ora eccomi qui in un vivario, a fare ricerca su tutti i pesci che ero troppo poco abile a pescare.\">>","\n","^<<\"Neanche con le farfalle ero un granché.\">>","\n","ev","str","^Lo terrò a mente.","/str","/ev",{"*":".^.c-6","flg":4},"ev","str","^Tranquilla. Sono brava a pensarci troppo.","/str","/ev",{"*":".^.c-7","flg":4},{"c-6":["^ ","\n",{"->":".^.^.^.g-3"},{"#f":5}],"c-7":["^ ","\n",{"->":".^.^.^.g-3"},{"#f":5}],"#f":5}],"g-3":["^Casii incrocia le braccia e mi osserva un momento... poi sembra avere un'idea.","\n","^<<\"Sai... forse mi sto portando avanti. Ma stavo pensando a come questo tipo di cosa — questa raccolta — potrebbe essere un buon compito per una Glider?\">>","\n","^<<\"Perché ho pensato a come la Peggior Pescatrice e Cacciatrice di Farfalle del Mondo — io — non possa davvero essere quella che riempie il Vivario per sempre.\">>","\n","^Le dico che sono interessata.","\n","^<<\"Beh, voglio dire, non ho distintivi da regalare, né una <i>maschera</i> o altro. Ma se lo facessimo... per divertimento?\">>","\n","^<<\"Tipo, se hai tempo libero e ti va di pescare, porta tutto quello che peschi! O se prendi una farfalla al volo? Perfetto. Le farò una casa.\">>","\n","^<<\"E poi chissà? Magari un giorno diventerà un <i>vero</i> compito da Glider!\">>","\n","ev","str","^Mi sembra bello!","/str","/ev",{"*":".^.c-8","flg":4},{"c-8":["^ ","\n",{"->":".^.^.^.g-4"},{"#f":5}],"#f":5}],"g-4":["^<<\"Perfetto! Allora... immagino... Avanti, Glider! Verso i pesci! E anche gli insetti!\">>","\n","^Una frase <i>classica</i> da Glider.","\n","^<<\"E se hai già qualcosa con te, sarei felice di darci un'occhiata.\">>","\n",{"->":".^.^.^.^.choices"},{"#f":5}]}],{"#f":1}],"choices":[["^Di cosa voglio parlare con Casii?","\n","ev","str","^Consegna dei pesci.","/str",{"x()":"player_has_fish_to_deliver"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Consegna delle farfalle.","/str",{"x()":"player_has_butterflies_to_deliver"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Come si pescano i pesci?","/str","str","^BasicFishingRod","/str",{"x()":"inventory_get_quantity","exArgs":1},0,"==","/ev",{"*":".^.c-2","flg":5},"ev","str","^Yoshi ti saluta!","/str",{"CNT?":"angler_yoshi"},"/ev",{"*":".^.c-3","flg":21},"ev","str","^Sai dove posso pescare?","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Quali pesci mi mancano?","/str","/ev",{"*":".^.c-5","flg":4},"ev","str","^Quali farfalle mi mancano?","/str","/ev",{"*":".^.c-6","flg":4},"ev","str","^Addio.","/str","/ev",{"*":".^.c-7","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.deliver_fish"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.deliver_butterflies"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.^.how_to_fish"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.^.^.talk_about_yoshi"},{"#f":5}],"c-4":["^ ","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^<<\"In generale! Ma ho qui i miei vecchi appunti da pescatrice. Sarei felice di scambiarli, se ti interessano.\">>","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n",{"#":"StartTrading"},"^<<\"Ecco cos'ho!\">>","\n",{"->":".^.^.^"},{"#f":5}],"c-5":["^ ","\n",{"->":".^.^.^.^.fish_report"},{"#f":5}],"c-6":["^ ","\n",{"->":".^.^.^.^.butterfly_report"},{"#f":5}],"c-7":["^ ","\n","^Saluto Casii.","\n","^<<\"Stammi bene, Sable! Goditi il tuo Volo!\">>","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"how_to_fish":["^Ammetto a Casii che, anche se lei è molto <i>scarsa</i> a pescare, io ho un problema diverso: non ho mai pescato. Le chiedo se ha consigli.","\n","^È un <i>rapido</i> no. Anzi, è:","\n","^<<\"No, no, nononò!\">>","\n","^<<\"Sono probabilmente la persona meno adatta a insegnarti. Ti farei prendere brutte abitudini.\">>","\n","^<<\"Avevo però un buon maestro. Yoshi il Pescatore, nel Sansee. Credo faccia ancora da mentore, se vuoi parlare con qualcuno che ne sa. Tipo gentile e pacato.\">>","\n","^<<\"Cerca un peschereccio. E se pensassi mai alla Maschera del Pescatore... scommetto che ti prenderebbe al volo, se davvero lo volessi.\">>","\n","^Dico a Casii che è bene saperlo e la ringrazio per il consiglio.","\n",{"->":".^.^.choices"},{"#f":1}],"talk_about_yoshi":[["^Dico a Casii che Yoshi le manda i saluti. Si illumina, e mi piace molto vederlo.","\n","^<<\"Yoshi! Oh no!\">>","\n","^Sta ridendo.","\n","^<<\"Oh no, sei... sei una sua apprendista? O no, tu... Oh no.\">>","\n","^<<\"Ti ha raccontato quanto fossi disastrosa quando cercava di insegnarmi?\">>","\n","ev","str","^Oh sì.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Beh...","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Dico a Casii che Yoshi l'ha detto, ma faccio in modo che il mio tono trasmetta il suo.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Ho imparato bene il potere di una frase non finita. Lascio sospeso in aria il mio \"Beh...\" e Casii capisce.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Beh, sono contenta che non sia cambiato. Onestamente sono felice che mandi saluti, perché in fondo... non è neanche che pensassi sarebbe stato deluso.\">>","\n","^<<\"Pensavo solo si sarebbe potuto dimenticare.\">>","\n","^Scuoto la testa e dico a Casii cosa mi ha detto Yoshi, e i complimenti la fanno rimpicciolire dietro le mani, ma vedo che la riempiono di una gioia particolare.","\n","^Scuote la testa e agita le mani quando le dico la parte peggiore: Yoshi è <i>orgoglioso</i> di lei.","\n","^<<\"Odio sentirlo!\">>","\n","^Ride.","\n","^<<\"O no. Non lo odio. È davvero — è bello, è davvero bello, sono solo... sai. È... è davvero bello. Uff.\">>","\n","^<<\"Ti capita mai di trovare difficile sentire cose belle su di te?\">>","\n","ev","str","^Sempre.","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Sì.","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Estremamente.","/str","/ev",{"*":".^.c-4","flg":4},{"c-2":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^Casii annuisce e sospira, più calma di prima.","\n","^<<\"Sono felice tu capisca. E grazie, Sable. Mi hai davvero rallegrato la giornata.\">>","\n",{"->":".^.^.^.^.choices"},{"#f":5}]}],{"#f":1}],"deliver_fish":[{"#":"deliver_all_fish"},"^Le consegno i pesci, e Casii si illumina.","\n","^<<\"Grazie, Sable. Roba buona. Li metto nelle vasche!\">>","\n","ev",{"x()":"fish_count"},10,">=","/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"CNT?":".^.^.^.^.give_second_rod"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.^.^.^.give_second_rod"},{"->":".^.^.^.6"},null]}],"nop","\n",{"->":".^.^.^.^.choices"},{"->":".^.^.^.11"},null]}],"nop","\n","ev",{"x()":"fish_count"},5,">=",{"CNT?":".^.^.give_first_rod"},"!","&&","/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.^.give_first_rod"},{"->":".^.^.^.22"},null]}],"nop","\n",{"->":".^.^.choices"},{"#f":1}],"give_first_rod":["^<<\"Oh! Bene! Pare tu sia già più competente come pescatrice di <i>questo</i> disastro!\">>","\n","^Indica sé stessa. In qualche modo mi ricorda... me.","\n",{"#":"inventory_add: CactusSpineRod"},"^<<\"Anzi! Ho qualcosa. Tieni. Prendi questa canna. Ha un'azione molto più fluida di quella vecchia. Credo sia pensata per aiutarti con le creature più <i>combattive</i>.\">>","\n","^Prendo la nuova canna e ringrazio Casii.","\n",{"->":".^.^.choices"},{"#f":1}],"give_second_rod":[["^<<\"Sable! Buone notizie! L'altro giorno ho trovato un'altra vecchia canna in deposito. Tipo... <i>qui</i>, in una delle vecchie stanze sul retro su cui stavo lavorando.\">>","\n","^Casii poi tira fuori quella che sembra la canna più vecchia possibile.","\n","^<<\"So che sembra antichissima, ma è in buone condizioni, ed è fatta di un materiale incredibilmente resistente. Deve esserlo, per essere sopravvissuta tanto.\">>","\n",{"#":"inventory_add: TricksterAtomicRod"},"^<<\"Credo che debba averla tu. Adoro quanto sei diventata brava! Mi conferma che ho fatto la scelta giusta.\">>","\n","^Dico a Casii che credo abbia decisamente <i>fatto</i> la scelta giusta.","\n","^Casii fa un gesto timido intorno a sé.","\n","^<<\"È un posto speciale, vero?\">>","\n","^Per risposta, faccio un cenno di approvazione, e vedo che la rilassa.","\n","ev","str","^Lo è.","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.choices"},{"#f":5}]}],{"#f":1}],"deliver_butterflies":[{"#":"deliver_all_butterflies"},"^Consegno alcuni esemplari di farfalle a Casii.","\n","^<<\"Grazie, Sable! Le metto nelle vasche!\">>","\n",{"->":".^.^.choices"},{"#f":1}],"fish_report":["^<<\"Fammi controllare il computer.\">>","\n","ev",{"VAR?":"speaker_vivarium"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<RAPPORTO ESEMPLARI PESCI: <br>Guppy Mantice: ","ev","str","^BellowGuppy","/str",{"f()":"delivered"},"out","/ev","^ <br>Vongola Occhio Gonfio: ","ev","str","^BloatedEyeClam","/str",{"f()":"delivered"},"out","/ev","^ <br>Dardo Tonto: ","ev","str","^DopeyDart","/str",{"f()":"delivered"},"out","/ev","^>>","\n","^<<Pinna Frusta: ","ev","str","^FlutterThrust","/str",{"f()":"delivered"},"out","/ev","^ <br>Anima Spettrale: ","ev","str","^GhostSoul","/str",{"f()":"delivered"},"out","/ev","^ <br>Ronzante: ","ev","str","^Hummer","/str",{"f()":"delivered"},"out","/ev","^ <br>Koi Luce: ","ev","str","^LightKoi","/str",{"f()":"delivered"},"out","/ev","^>>","\n","^<<Calciatore: ","ev","str","^LittleKicker","/str",{"f()":"delivered"},"out","/ev","^ <br>Pesce Ciottolo: ","ev","str","^PebbleEye","/str",{"f()":"delivered"},"out","/ev","^ <br>Pesce Pillola: ","ev","str","^PillFish","/str",{"f()":"delivered"},"out","/ev","^ <br>Razza di Sabbia: ","ev","str","^SandRay","/str",{"f()":"delivered"},"out","/ev","^>>","\n","^<<Pesce Crostoso: ","ev","str","^ScabbyFish","/str",{"f()":"delivered"},"out","/ev","^ <br>Calice con Guscio: ","ev","str","^ShelledCup","/str",{"f()":"delivered"},"out","/ev","^ <br>Pesce Tempesta: ","ev","str","^StormFish","/str",{"f()":"delivered"},"out","/ev","^ <br>Pesce Risucchiatore: ","ev","str","^SuckerFish","/str",{"f()":"delivered"},"out","/ev","^>>","\n","^<<Pescatore Tazzina: ","ev","str","^TeacupAngler","/str",{"f()":"delivered"},"out","/ev","^ <br>Gelatina Inutile: ","ev","str","^TrifleJelly","/str",{"f()":"delivered"},"out","/ev","^ ","ev",{"x()":"delivered_all_fish"},"/ev",[{"->":".^.b","c":true},{"b":["^ <br>RACCOLTA ESEMPLARI COMPLETATA.",{"->":".^.^.^.155"},null]}],"nop","^ <br>FINE RAPPORTO.>>","\n","ev",{"VAR?":"speaker_casii"},"/ev",{"VAR=":"SpeakerName","re":true},{"->":".^.^.choices"},{"#f":1}],"butterfly_report":["^<<\"Do un'occhiata al computer.\">>","\n","ev",{"VAR?":"speaker_vivarium"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<RAPPORTO ESEMPLARI FARFALLE: <br>Farfalla del Gesso: ","ev","str","^ChalkButterfly","/str",{"f()":"delivered"},"out","/ev","^ <br>Farfalla di Cristallo: ","ev","str","^CrystalButterfly","/str",{"f()":"delivered"},"out","/ev","^ <br>Farfalla Nimoor: ","ev","str","^NimoorButterflies","/str",{"f()":"delivered"},"out","/ev","^>>","\n","^<<Libellula d'Oasi: ","ev","str","^OasisDragonfly","/str",{"f()":"delivered"},"out","/ev","^ <br>Farfalla del Sale: ","ev","str","^SaltButterfly","/str",{"f()":"delivered"},"out","/ev","^ <br>Farfalla Foglia Ombreggiata: ","ev","str","^ShadedLeafButterfly","/str",{"f()":"delivered"},"out","/ev","^>>","\n","^<<Libellula del Pozzo a Gradini: ","ev","str","^StepwellDragonfly","/str",{"f()":"delivered"},"out","/ev","^ <br>Farfalla del Sole: ","ev","str","^SunshineButterfly","/str",{"f()":"delivered"},"out","/ev","^ ","ev",{"x()":"delivered_all_butterflies"},"/ev",[{"->":".^.b","c":true},{"b":["^ <br>RACCOLTA ESEMPLARI COMPLETATA.",{"->":".^.^.^.79"},null]}],"nop","^ <br>FINE RAPPORTO.>>","\n","ev",{"VAR?":"speaker_casii"},"/ev",{"VAR=":"SpeakerName","re":true},{"->":".^.^.choices"},{"#f":1}],"#f":1}],"white_desert_vivarium_merchant_sola":[["ev","str","^Mercante Sola","/str","/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Ciao!\">>","\n","^Mi avvicino alla mercante, che sembra molto desiderosa di fare affari.","\n","ev","str","^Vorrei commerciare.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Cosa ti porta al Vivario?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Non ho bisogno di nulla.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^  ","\n",{"#":"StartTrading"},"^<<\"Dai un'occhiata alle mie creazioni!!\">>","\n",{"->":".^.^.^.conversation_end"},{"#f":5}],"c-1":["^  ","\n","^<<\"Hai visto questo posto? È spettacolare!\">>","\n","^<<\"Sono arrivata al Wash anni fa, perché questo posto semplicemente <i>grida</i> di essere studiato da occhi attenti e menti brillanti.\">>","\n","^<<\"Ma è il Vivario che potrebbe trattenermi. Sono entusiasta di tutte le opportunità qui.\">>","\n","^<<\"A volte realizzo abiti, gli insetti volanti qui... mi hanno ispirata!\">>","\n","^<<\"Ne ho realizzati alcuni di risposta... Creazioni artistiche. Oggetti splendenti, sontuosi e incredibili, di tipo mai visto prima a Midden!\">>","\n","^Sono sopraffatta dal suo entusiasmo chiaramente inarrestabile. Non posso fare a meno di sentire una scintilla di eccitazione.","\n",{"->":".^.^.^.conversation_end"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.conversation_end"},{"#f":5}]}],{"conversation_end":["^<<\"A presto!\">>","\n","end",{"#f":1}],"#f":1}],"global decl":["ev",{"list":{},"origins":["tower_of_steel"]},{"VAR=":"tower_of_steel"},"str","^Scalatrice Zayna","/str",{"VAR=":"speaker_zayna"},{"list":{},"origins":["sometimes_a_well_is_just_a_well"]},{"VAR=":"sometimes_a_well_is_just_a_well"},{"list":{},"origins":["santi_town_engineers"]},{"VAR=":"santi_town_engineers"},{"list":{"santi_town_engineers.HEARTBREAK_CLUE_MISSING_POWER_CORE":4,"santi_town_engineers.HEARTBREAK_CLUE_FEATHERS":5,"santi_town_engineers.HEARTBREAK_CLUE_BLOOD":6,"santi_town_engineers.HEARTBREAK_CLUE_GLASS":7,"santi_town_engineers.HEARTBREAK_CLUE_GLOVE":8}},{"VAR=":"heartbreak_clues"},{"list":{},"origins":["oasis_flower"]},{"VAR=":"oasis_flower"},"str","^Tej","/str",{"VAR=":"speaker_tej"},"str","^OasisFlower","/str",{"VAR=":"OASIS_FLOWER_ITEM"},0,{"VAR=":"oasis_flower_debug"},{"list":{},"origins":["smugglers_legacy"]},{"VAR=":"smugglers_legacy"},{"list":{},"origins":["hide_and_seek"]},{"VAR=":"hide_and_seek"},{"list":{},"origins":["shade_of_eccria"]},{"VAR=":"shade_of_eccria"},0,{"VAR=":"debug_shade_of_eccria_start"},"str","^Maz","/str",{"VAR=":"speaker_maz"},"str","^La Bambina","/str",{"VAR=":"speaker_shade_child"},"str","^Prima Guardia","/str",{"VAR=":"speaker_first_guard"},"str","^Seconda Guardia","/str",{"VAR=":"speaker_second_guard"},{"list":{},"origins":["searching_for_llhor"]},{"VAR=":"searching_for_llhor"},{"list":{},"origins":["nozis_nibbles"]},{"VAR=":"nozis_nibbles"},0,{"VAR=":"debug_glowworm_amount"},{"list":{},"origins":["atomic_heart"]},{"VAR=":"atomic_heart"},{"list":{"atomic_heart.ATOMIC_HEART_CLUE_GLASS":11,"atomic_heart.ATOMIC_HEART_CLUE_NOTE":12,"atomic_heart.ATOMIC_HEART_CLUE_SOCKET":13,"atomic_