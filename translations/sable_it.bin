_intro"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->t->":"sarin_ship_conversation.sarin_default_intro"},{"->":".^.^.17"},null],"#f":5}],"\n",["ev",{"f()":"completed_all_challenges"},{"VAR?":"HISTORICAL_RECONNECTION_MILESTONE_REACHED"},{"f()":"reached"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.unlock_clothing_and_bike_together"},{"->":".^.^.^.10"},null]}],["ev",{"f()":"completed_all_challenges"},{"VAR?":"HISTORICAL_RECONNECTION_QUEST_COMPLETED"},{"f()":"reached"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.unlock_atomic_bike"},{"->":".^.^.^.10"},null]}],["ev",{"f()":"completed_half_of_challenges"},{"VAR?":"HISTORICAL_RECONNECTION_MILESTONE_REACHED"},{"f()":"reached"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.unlock_atomic_clothing"},{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n",{"->":"sarin_ship_conversation.message_status"},{"->":".^.^.^.10"},null]}],"nop","\n",{"unlock_atomic_clothing":["ev",{"VAR?":"HISTORICAL_RECONNECTION_MILESTONE_REACHED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Grazie per il tuo aiuto nel recuperare i miei moduli dati. Ho aggiornato il tuo livello di accesso, Sable.\">>","\n","^<<\"Garantisco accesso di primo livello.\">>","\n","^>>> SCENA <<< ",{"#":"atomic_clothing_cutscene"},"\n","^Ringrazio Sarin profusamente. Spero capisca.","\n",{"->":"sarin_ship_conversation.done"},{"#f":1}],"unlock_atomic_bike":["ev",{"VAR?":"HISTORICAL_RECONNECTION_QUEST_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Hai recuperato i dati da tutte e sei le navi del pianeta. Grazie, Sable. Comincio a capire...\">>","\n","^Sarin si interrompe, un velo di dubbio tradisce la sua figura altrimenti priva di emozione.","\n","^<<\"Ora hai accesso completo, Sable.\">>","\n","^<<\"Ti garantisco accesso completo alla struttura della Whale.\">>","\n","^>>> SCENA <<< ",{"#":"atomic_bike_cutscene"},"\n","^La hoverbike nella camera sembra lucida e nuova, nonostante sia antichissima. Chiedo a Sarin se è davvero per me.","\n","^<<\"Sì, Sable. Non c'è... nulla che mi impedisca di concederti pieno accesso alle mie strutture. Ti prego, servi del questo veicolo di trasporto.\">>","\n","^Assicuro a Sarin che la userò per venire a trovarli il più spesso possibile.","\n",{"->":"sarin_ship_conversation.done"},{"#f":1}],"unlock_clothing_and_bike_together":["ev",{"list":{"historical_reconnection.HISTORICAL_RECONNECTION_MILESTONE_REACHED":8,"historical_reconnection.HISTORICAL_RECONNECTION_QUEST_COMPLETED":9}},{"f()":"activate"},"pop","/ev","\n","^<<\"Sembra che tu sia stata impegnata, Sable.\">>","\n","^Sarin offre la sua migliore rappresentazione di essere impressionato.","\n","^<<\"Hai recuperato... <i>tutti</i> i moduli dati disponibili. Grazie per la tua assistenza.\">>","\n","^<<\"Sto aggiornando il tuo livello di accesso.\">>","\n","^<<\"Garantisco accesso di primo livello ora.\">>","\n","^>>> SCENA <<< ",{"#":"atomic_clothing_cutscene"},"\n","^<<\"Sto aumentando il livello di accesso.\">>","\n","^>>> SCENA <<< ",{"#":"atomic_bike_cutscene"},"\n","^Faccio fatica a credere alla mia fortuna. Chiedo a Sarin se sono davvero per me.","\n","^<<\"Puoi farne ciò che vuoi, Sable. Non vedo motivo di preservarli oltre.\">>","\n","^Ringrazio Sarin per tutto.","\n",{"->":"sarin_ship_conversation.done"},{"#f":1}],"#f":1}],"sarin_ship_conversation":["ev",{"VAR?":"speaker_sarin"},"/ev",{"VAR=":"SpeakerName","re":true},["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->t->":".^.^.^.sarin_first_intro"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->t->":".^.^.^.sarin_default_intro"},{"->":".^.^.17"},null],"#f":5}],"\n","ev",{"f()":"go_to_the_whale"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.whale_ship_reminder"},{"->":".^.^.^.10"},null]}],"nop","\n",{"->":".^.message_status"},{"->":"END_SCENE"},{"sarin_first_intro":["ev",{"VAR?":"HISTORICAL_RECONNECTION_QUEST_STARTED"},{"f()":"activate"},"pop","/ev","\n","^Incontro una strana figura luminosa. Mi saluta prima ancora che possa spaventarmi.","\n","^<<\"Nuovo utente trovato. Salve, inserisci il tuo nuovo nome utente...\">>","\n","^Mi ritrovo a sussurrare il mio nome. All'improvviso suona strano in bocca... come se fosse la prima volta che lo dico ad alta voce.","\n","^<<\"Benvenuta, Sable. Ho creato un nuovo account per te.\">>","\n","^Chiedo alla misteriosa figura di sé stessa.","\n","^<<\"Sono il Registro Antropomorfo Simulato e Nesso Informativo di questa nave... ma puoi chiamarmi Sarin.\">>","\n","^Chiedo a Sarin cosa ci faccia qui.","\n","^<<\"Non ne sono del tutto sicuro, Sable. La maggior parte dei miei moduli dati sembra corrotta. Sto tentando di accedere ai registri della nave...\">>","\n","^Sarin si immobilizza per un momento.","\n","^<<\"Trasferimento del diario di bordo alla tua casella in corso.\">>","\n","ev","void","/ev","->->",{"#f":1}],"sarin_default_intro":["^Saluto Sarin.","\n","ev","void","/ev","->->",{"#f":1}],"whale_ship_reminder":["^<<\"Sable, il tuo livello di accesso è stato aggiornato. Procedi alla Whale per autenticarti.\">>","\n","ev","void","/ev","->->",{"#f":1}],"message_status":[["ev",{"f()":"has_unread_messages"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"message_stop"},"^<<\"Hai messaggi non letti, Sable.\">>","\n",{"->":".^.^.^.5"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"message_stop"},"^<<\"Nessun messaggio non letto.\">>","\n",{"->":".^.^.^.5"},null]}],"nop","\n","ev","str","^Messaggi Non Letti","/str",{"f()":"has_unread_messages"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Messaggi Archiviati","/str",{"f()":"has_read_messages"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Addio","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.unread_messages"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.read_messages"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.^.^.done"},{"#f":5}]}],{"#f":1}],"unread_messages":[["ev",{"f()":"get_number_of_completed_challenges"},"/ev",{"temp=":"num_ships"},"\n",{"#":"message_stop"},"^<<\"Ecco i tuoi messaggi non letti.\">>","\n","ev","str","^Registrazione 01","/str",{"VAR?":"num_ships"},1,">=",{"CNT?":"sarin_recordings.part_one"},"!","&&","/ev",{"*":".^.c-0","flg":5},"ev","str","^Registrazione 02","/str",{"VAR?":"num_ships"},2,">=",{"CNT?":"sarin_recordings.part_two"},"!","&&","/ev",{"*":".^.c-1","flg":5},"ev","str","^Registrazione 03","/str",{"VAR?":"num_ships"},3,">=",{"CNT?":"sarin_recordings.part_three"},"!","&&","/ev",{"*":".^.c-2","flg":5},"ev","str","^Registrazione 04","/str",{"VAR?":"num_ships"},4,">=",{"CNT?":"sarin_recordings.part_four"},"!","&&","/ev",{"*":".^.c-3","flg":5},"ev","str","^Registrazione 05","/str",{"VAR?":"num_ships"},5,">=",{"CNT?":"sarin_recordings.part_five"},"!","&&","/ev",{"*":".^.c-4","flg":5},"ev","str","^Registrazione 06","/str",{"VAR?":"num_ships"},6,">=",{"CNT?":"sarin_recordings.part_six"},"!","&&","/ev",{"*":".^.c-5","flg":5},"ev","str","^Indietro","/str","/ev",{"*":".^.c-6","flg":4},{"c-0":["^ ","\n",{"->t->":"sarin_recordings.part_one"},{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->t->":"sarin_recordings.part_two"},{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->t->":"sarin_recordings.part_three"},{"->":".^.^.g-0"},{"#f":5}],"c-3":["^ ","\n",{"->t->":"sarin_recordings.part_four"},{"->":".^.^.g-0"},{"#f":5}],"c-4":["^ ","\n",{"->t->":"sarin_recordings.part_five"},{"->":".^.^.g-0"},{"#f":5}],"c-5":["^ ","\n",{"->t->":"sarin_recordings.part_six"},{"->":".^.^.g-0"},{"#f":5}],"c-6":["^ ","\n",{"->":".^.^.^.^.message_status"},{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev",{"f()":"has_unread_messages"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.^.^"},{"->":".^.^.^.5"},null]}],[{"->":".^.b"},{"b":["\n",{"->":".^.^.^.^.^.^.message_status"},{"->":".^.^.^.5"},null]}],"nop","\n",{"#f":5}]}],{"#f":1}],"read_messages":[[{"#":"message_stop"},"^<<\"Ecco i tuoi messaggi archiviati.\">>","\n","ev","str","^Registrazione 01","/str",{"CNT?":"sarin_recordings.part_one"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Registrazione 02","/str",{"CNT?":"sarin_recordings.part_two"},"/ev",{"*":".^.c-1","flg":5},"ev","str","^Registrazione 03","/str",{"CNT?":"sarin_recordings.part_three"},"/ev",{"*":".^.c-2","flg":5},"ev","str","^Registrazione 04","/str",{"CNT?":"sarin_recordings.part_four"},"/ev",{"*":".^.c-3","flg":5},"ev","str","^Registrazione 05","/str",{"CNT?":"sarin_recordings.part_five"},"/ev",{"*":".^.c-4","flg":5},"ev","str","^Registrazione 06","/str",{"CNT?":"sarin_recordings.part_six"},"/ev",{"*":".^.c-5","flg":5},"ev","str","^Indietro","/str","/ev",{"*":".^.c-6","flg":4},{"c-0":["^ ","\n",{"->t->":"sarin_recordings.part_one"},{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->t->":"sarin_recordings.part_two"},{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->t->":"sarin_recordings.part_three"},{"->":".^.^.g-0"},{"#f":5}],"c-3":["^ ","\n",{"->t->":"sarin_recordings.part_four"},{"->":".^.^.g-0"},{"#f":5}],"c-4":["^ ","\n",{"->t->":"sarin_recordings.part_five"},{"->":".^.^.g-0"},{"#f":5}],"c-5":["^ ","\n",{"->t->":"sarin_recordings.part_six"},{"->":".^.^.g-0"},{"#f":5}],"c-6":["^ ","\n",{"->":".^.^.^.^.message_status"},{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^"},{"#f":5}]}],{"#f":1}],"done":["^Saluto Sarin.","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"sarin_recordings":[{"->":".^.part_one"},{"part_one":[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Il pannello si accende. Strani segni e simboli che presumo siano testi antichi scorrono sullo schermo mentre i colori di sfondo lampeggiano selvaggiamente.","\n",{"#":"gesture_sable: surprised"},"^E poi, con uno strano ronzio come di vecchi tessuti che si lacerano... ci sono voci:","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev",{"VAR?":"speaker_first_voice"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"message_start"},"^<<\"--dentro il raggio dei sensori a lungo raggio, Capitano. Stiamo ricevendo letture anomale dalla parte alta dell'atmosfera. Potrebbe essere una tempesta di plasma, ma la firma di radiazione non corrisponde proprio...\">>","\n","ev",{"VAR?":"speaker_captain"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Hmm. Mantieni l'avvicinamento alla velocità attuale. Quanto manca a destinazione?\">>","\n","ev",{"VAR?":"speaker_first_voice"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Quarantasei ore terrestri. Più o meno.\">>","\n","ev",{"VAR?":"speaker_captain"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Bene. Tieni d'occhio quelle firme energetiche. E coinvolgi anche Sarin, per il riconoscimento dei pattern.\">>","\n","ev",{"VAR?":"speaker_second_voice"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Capitano? Dobbiamo purgare il reattore presto, altrimenti--\">>","\n","ev",{"VAR?":"speaker_captain"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Lo so. Sono... sono consapevole dei rischi, Ellis. Ma non purgo nel mezzo dello spazio. Seguiamo il protocollo e--\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^La registrazione si interrompe, e il fruscio continua.","\n",{"#":"gesture_sable: thinking"},"^Pochi tasti premuti portano silenzio e una schermata che sembra in qualche modo navigabile, ma non riesco a decifrare nulla.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev","void","/ev","->->",{"#f":1}],"part_two":[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Un altro terminale si accende. La stessa lingua che ho già visto lampeggia sullo schermo prima...","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev",{"VAR?":"speaker_sarin"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"message_start"},"^<<\"Capitano Singh.\">>","\n","ev",{"VAR?":"speaker_captain"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Sì, Sarin?\">>","\n","ev",{"VAR?":"speaker_sarin"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Ho rilevato un possibile pattern nell'anomalia planetaria. C'è qualcosa di strano. <i>Dovrebbe</i> iterare in un sistema caotico...\">>","\n","ev",{"VAR?":"speaker_sarin"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"...ma sembra esserci un pattern che si ripete con costanza.\">>","\n","ev",{"VAR?":"speaker_captain"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Cosa significa?\">>","\n","ev",{"VAR?":"speaker_sarin"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Sembra che ci sia qualcosa a sostenerlo, Capitano. Non siamo in grado di determinare la fonte di questo... perpetuo--\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"#":"gesture_sable: thinking"},"^Finisce qui. Premo qualche altro tasto, ma non riesco a far tornare la registrazione.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev","void","/ev","->->",{"#f":1}],"part_three":["ev",{"VAR?":"speaker_unknown"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"message_start"},"^<<\"Dai, Singh; sai contro cosa siamo. Se purghiamo i motori qui fuori, non abbiamo nulla per i terraformatori. Dobbiamo atterrare <i>adesso</i>.\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Stai zitto, Deacon.\">>","\n","ev",{"VAR?":"speaker_deacon"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Wow.\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Senti. Ogni giorno la radiazione peggiora. Non posso continuare a vendere queste cazzate all'equipaggio!\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"E no-- non atterro neanche su quel pianeta. Non atterriamo da nessuna parte finché non sappiamo di più di queste anomalie atmosferiche. Possono esserci segni di vita in superficie ma non vuol dire che siano ospitali. Ma dobbiamo togliere quella roba dalla nave, Deacon. Alla malora la missione.\">>","\n","ev",{"VAR?":"speaker_deacon"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Quel pianeta è l'intera ragione per cui siamo qui. Se non rendiamo i terraformatori operativi, siamo venuti per niente. Come <i>apparirà</i>?\"","\n","ev",{"VAR?":"speaker_deacon"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Se torniamo senza completare l'obiettivo, puoi scordarti la promozione. Ti manderanno su un sasso esterno a monitorare una stazione relè, <i>Capitano</i>.\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^C'è un po' di silenzio teso dopo l'enfasi su \"capitano\", e mi sembra di stare ascoltando qualcosa che non dovrei. Quella chiamata Singh parla di nuovo.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Va bene. Solo-- una volta nel raggio del pianeta, diamo a Sarin altri due giorni per capire cosa causa il disturbo. Non voglio attraversarlo se non sappiamo cosa sia, ma potremmo non avere scelta.\">>","\n","ev",{"VAR?":"speaker_deacon"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Bravo, Singh. Sapevo che avresti fatto la cosa giusta. Dai, siediti e bevi qualcosa con me--\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Sparisci dalla mia stanza, Deacon.\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^C'è del silenzio, qualche movimento, e un sibilo lieve d'aria. Poi è di nuovo solo la voce solitaria del Capitano. Mi chiedo quanto tempo fa sia successo.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Sarin, scavalca il protocollo privacy sull'Ufficiale Finanziario Deacon. Voglio che lo tenga d'occhio.\">>","\n","ev",{"VAR?":"speaker_sarin"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Sì, Capitano.\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"#":"gesture_sable: thinking"},"^E poi, nulla.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev","void","/ev","->->",{"#f":1}],"part_four":[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Sarin appare davanti ai miei occhi. Per un momento mi sembra di riconoscere del testo, ma sparisce subito.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev",{"VAR?":"speaker_ellis"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"message_start"},"^<<\"--guasto catastrofico nei reattori da uno a cinque, l'alimentazione ausiliaria è ancora attiva ma i sistemi di navigazione cedono. Capitano, stiamo precipitando. Dobbiamo fare qualcosa, adesso.\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Devia l'alimentazione ausiliaria ai moduli di atterraggio, e di' alle altre navi di fare lo stesso. Non credo che recupereremo i reattori a breve, ma... non smettete di provarci. Dai tutto quello che hai.\">>","\n","ev",{"VAR?":"speaker_new_voice"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Signore, i sistemi del reattore non rispondono da quando siamo entrati nell'atmosfera. Qualunque cosa sia, sta creando parecchia interferenza.\">>","\n","ev",{"VAR?":"speaker_sarin"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Corretto. La firma energetica è cambiata, Capitano. Si è quietata. Sembra quasi che stia... rispondendo alla nostra presenza.\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Non ora, Sarin. Tracciami una rotta per atterrare in un posto sicuro. Priorità uno, capiremo il resto una volta a terra.\">>","\n","ev",{"VAR?":"speaker_sarin"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Navigazione offline, Capitano. Vuoi che--\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"No. Lo... farò io stesso.\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"#":"gesture_sable: sad"},"^La registrazione finisce lì e sento una stretta allo stomaco, per persone che non ho mai incontrato. E che so essere morte da tempo.","\n","^Strano, preoccuparsi per le vite dei morti.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev","void","/ev","->->",{"#f":1}],"part_five":[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"#":"gesture_sable: arms_crossed"},"^Mi ritrovo a battere il piede per l'attesa mentre avvio la postazione.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev",{"VAR?":"speaker_sarin"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"message_start"},"^<<\"--le comunicazioni a lungo raggio sono ancora disturbate dal perpetuo. L'Ufficiale Ellis vuole tornare a concentrarsi sullo schermare i reattori dall'interferenza. Permesso?\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Concesso. Sarin, voglio che tu resti sull'array di comunicazione e provi a tirar fuori qualcosa senza che venga rispedito indietro.\">>","\n","ev",{"VAR?":"speaker_sarin"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Sì, Capitano.\">>","\n","ev",{"VAR?":"speaker_deacon"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Beh, allora tanto vale far partire i terraformatori, no?\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Deacon, se non la smetti con quei terraformatori...\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Lascia la frase in sospeso, ma riprende prima di terminare quella che posso solo immaginare sarebbe una minaccia molto puntuta.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Se non avessi parlato a vanvera, saremmo ancora in orbita a negoziare un atterraggio con questo pianeta dimenticato dagli dei. Non possiamo nemmeno respirare l'aria là fuori e--\">>","\n","ev",{"VAR?":"speaker_deacon"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Ragione in più per iniziare a terraformare adesso. Qual è il tuo <i>punto</i>, Capitano?\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Deacon. Ascoltami. Non possiamo. Quell'atterraggio è stato un inferno per quelle cose; lo schermo radiazioni è irreparabile al momento.\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Se mettiamo in moto queste cose, immetteranno radiazioni nell'atmosfera per <i>cento anni</i>. Anni terrestri. Non è un'opzione per noi, Deacon.\">>","\n","ev",{"VAR?":"speaker_deacon"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"E allora forse non lo facciamo per noi.\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"#":"gesture_sable: thinking"},"^La registrazione tace.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev","void","/ev","->->",{"#f":1}],"part_six":[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Il testo a schermo resta un mistero, ma stavolta lo guardo a malapena. Se è perduto per me, sia. Voglio sentire altro.","\n","^Stavolta il Capitano Singh suona diverso. Più vecchio?","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"message_start"},"^<<\"--operativi da quindici anni locali, credo siano circa venti in tempo terrestre. I livelli di radiazione si avvicinano al critico, e salgono soltanto. Tra quello e la mancanza di aria respirabile, anche i nipoti dei nostri figli dovranno usare attrezzatura protettiva anche solo per camminare tra le navi.\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Deacon... finalmente è morto la settimana scorsa. Età, niente di più. Solo tempo. Siamo stati fortunati così, credo. Il tipo non ha mai mollato la missione di salvataggio aziendale, glielo concedo.\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"È... stupido. Anche se ci <i>fossero</i> davvero là sopra, non hanno modo di scendere qui, per quanto ne sappiamo. Quella roba nell'atmosfera... chissà?\">>","\n","^Singh fa una pausa, e sospira tra sé.","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Sarin, spegnerò le tue funzioni primarie per conservare energia. Verrai avviato una volta ogni qualche anno per tentare comunicazioni a lungo raggio, ma è un compito che lascio alle generazioni future.\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Ma in questo modo avrai abbastanza energia per sostenerti per qualche centinaio di giri attorno a questa stella. Magari di più se qualcuno riuscirà a capirti.\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^C'è una pausa, e penso che sia finita, ma...","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Mi dispiace che le cose siano finite così. Speravo in qualcosa di meglio per noi che restare bloccati su un pianeta che vuole ucciderci, ma... non ci lascia andare. Magari un giorno riuscirai a darci un senso. Ma se qualcuno chiede... in qualunque secolo... digli che ho fatto del mio meglio.\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Ora devo andare a prendermi cura della mia gente.\">>","\n","ev",{"VAR?":"speaker_sarin"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Per quel che vale, Signore, le maschere mi piacciono parecchio.\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^Singh ride ed è triste, ma dolce.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Grazie, Sarin... Grazie di essere qui.\">>","\n","ev",{"VAR?":"speaker_singh"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Addio...\">>","\n",["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","^La registrazione si spegne all'improvviso, lasciandomi a riflettere.","\n",{"#":"gesture_sable: thinking"},"^Mi prendo un minuto per riordinare i pensieri, e poi saluto anch'io.","\n",{"->":".^.^.17"},null],"s1":["pop",{"->":".^.^.17"},null],"#f":5}],"\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"historical_reconnection_quest_debug":[["ev","str","^Parla con Sarin (Whale Ship)","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Parla con Sarin (Trellicks)","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Parla con Sarin (The Dunboyne)","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Parla con Sarin (Rowley's Way)","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Parla con Sarin (The Brunswick)","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Parla con Sarin (Balfron Connection)","/str","/ev",{"*":".^.c-5","flg":4},"ev","str","^Parla con Sarin (Shadow Of Neave)","/str","/ev",{"*":".^.c-6","flg":4},{"c-0":["^ ",{"->t->":"sarin_conversation"},"\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ",{"->t->":"sarin_at_trellicks_conversation"},"\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ",{"->t->":"sarin_at_dunboyne_conversation"},"\n",{"->":".^.^.g-0"},{"#f":5}],"c-3":["^ ",{"->t->":"sarin_at_rowleys_way_conversation"},"\n",{"->":".^.^.g-0"},{"#f":5}],"c-4":["^ ",{"->t->":"sarin_at_brunswick_conversation"},"\n",{"->":".^.^.g-0"},{"#f":5}],"c-5":["^ ",{"->t->":"sarin_at_balfron_conversation"},"\n",{"->":".^.^.g-0"},{"#f":5}],"c-6":["^ ",{"->t->":"sarin_at_shadow_of_neave_conversation"},"\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev","void","/ev","->->",{"#f":5}]}],{"#f":3}],"historical_reconnection_quest_definition":[{"#":"name"},"^Riconnessione Storica","\n",{"#":"locations"},"^the_whale","\n",{"#":"status"},["ev",{"VAR?":"HISTORICAL_RECONNECTION_QUEST_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"HISTORICAL_RECONNECTION_QUEST_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"HISTORICAL_RECONNECTION_QUEST_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"f()":"completed_any_challenges"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho incontrato un'IA di nome Sarin. Mi ha riprodotto un messaggio di tanto tempo fa.","\n",{"->":".^.^.^.6"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho incontrato un'IA di nome Sarin dentro la Whale.","\n",{"->":".^.^.^.6"},null]}],"nop","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"HISTORICAL_RECONNECTION_MILESTONE_REACHED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sarin mi ha concesso accesso a uno strano set di vestiti da una camera della Whale.","\n",{"->":".^.^.^.24"},null]}],"nop","\n","ev",{"f()":"completed_all_challenges"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Dovrei cercare altri terminali di Sarin.","\n",{"->":".^.^.^.31"},null]}],"nop","\n","ev",{"f()":"go_to_the_whale"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: the_whale"},{"#":"status: active"},"^Dovrei andare a trovare il terminale di Sarin dentro la Whale.","\n",{"->":".^.^.^.37"},null]}],"nop","\n","ev",{"VAR?":"HISTORICAL_RECONNECTION_QUEST_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sarin mi ha anche concesso accesso a un set di pezzi di hoverbike molto antichi.","\n",{"->":".^.^.^.44"},null]}],"nop","\n","end",{"#f":1}],"an_eye_to_the_sky_content":[["ev",{"VAR?":"AN_EYE_TO_THE_SKY_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.2"},null]}],["ev",{"VAR?":"AN_EYE_TO_THE_SKY_STARTED"},{"VAR?":"AN_EYE_TO_THE_SKY_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_in_progress"},{"->":".^.^.^.2"},null]}],"nop","\n","ev","void","/ev","->->",{"quest_start":[["ev","str","^Cosa vuoi che faccia?","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["^ ","\n",{"#":"gesture_partner: talking"},"^<<\"Beh, voglio che tu riceva un Distintivo del Macchinista e per quello vorrei che tu, beh, mi riferissi qualcosa per me. Pensala come una missione! Non è divertente? Più o meno?\">>","\n","^Prendo fiato per parlare, ma Kaalan non ha tempo.","\n",{"#":"gesture_partner: explaining"},"^<<\"Dovrai usare la testa per questa. Voglio che tu vada alla Vedetta e prenda una lettura del sole.\">>","\n","^<<\"Troverai l'attrezzatura un po'... beh, sai. Datata. Mal progettata. Ingombrante. Arcaica, forse? Qualunque parola sia, <i>funziona ancora tutta</i> ed è ciò che conta.\">>","\n",{"#":"gesture_partner: talking"},"^<<\"Prendi la lettura e, se lo fai bene, la porta dei volti nella camera centrale dovrebbe aprirsi. Quando avrai visto cosa c'è dentro, torna qui e raccontamelo. Va bene?\">>","\n","^Apro la bocca per il più breve istante possibile e non ottengo spazio per parlare.","\n",{"#":"gesture_partner: talking"},"^<<\"Perfetto, sì, grazie. E grazie anche a me, perché ti sarai più che meritata un Distintivo. Vai! A presto. Non vedo l'ora di sentirne.\">>","\n","^Kaalan mi congeda con un gesto.","\n","ev",{"VAR?":"AN_EYE_TO_THE_SKY_STARTED"},{"f()":"activate"},"pop","/ev","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_in_progress":[["^<<\"Hai preso la lettura, Glider?\">>","\n","ev","str","^Sì, ho aperto la porta.","/str",{"VAR?":"AN_EYE_TO_THE_SKY_OPENED_FACE_DOOR"},{"f()":"reached"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Non ancora.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"#":"gesture_partner: talking"},"^<<\"E hai visto cosa c'è dentro? Sì?\">>","\n",["ev","str","^C'era un modello.","/str",{"VAR?":"AN_EYE_TO_THE_SKY_SEEN_CHAMBER"},{"f()":"reached"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Non l'ho visto.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->t->":".^.^.^.^.^.^.quest_complete"},{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_partner: explaining"},"^<<\"Aspetta. No. Cosa? Mi stai dicendo che hai aperto la porta ma non hai guardato nella camera dietro? Allora torna là!\">>","\n",{"#":"gesture_partner: talking"},"^<<\"Torna quando saprai cosa c'è nella camera, così saprò che la tua lettura è corretta. Per favore.\">>","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_partner: talking"},"^<<\"Cosa aspetti? Vai! Torna da me quando ci sarai arrivata.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_complete":[["ev",{"VAR?":"AN_EYE_TO_THE_SKY_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_partner: talking"},"^<<\"Sì! Sì, oh, è proprio quello che speravo dicessi. Che soluzione! Ben fatto, Glider, devi essere tremendamente fiera di te. Usando quella mentina da glider.\">>","\n","^Passo oltre il \"piccolina\" e chiedo se quello che ho visto la aiuta.","\n",{"#":"gesture_partner: talking"},"^<<\"Immensamente. Più di quanto tu sappia. Per motivi che-- beh, basti dire che mi aiuta. Con qualche calcolo e considerazione mia. Ma perché stai chiedendo di <i>me</i>?\">>","\n",{"#":"gesture_partner: thinking"},"^<<\"<i>Tu</i> hai imparato qualcosa?\">>","\n","ev","str","^Ho riflettuto sul Perpetuo.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Sono stata un po' impaurita dalla Fauce.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Ho immaginato tutti gli scarabei su Carab.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_sable: talking"},"^Dico che mi sono ritrovata perplessa dal Perpetuo, a considerare la sua relazione con noi.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_sable: talking"},"^Dico che ho provato una strana repulsione verso la Fauce e la sua magnitudine. C'era qualcosa che mi metteva così a disagio da costringermi a distogliere lo sguardo.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_sable: talking"},"^Dico che non riuscivo a togliermi dalla testa l'idea di tutti gli scarabei su Carab, prima di ricordarmi che non c'è molta base per questo tipo di ragionamento.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"gesture_partner: talking"},"^<<\"Affascinante!\">>","\n","^Capisco che Kaalan è già altrove. Non so bene perché mi chieda qualcosa, davvero, ma sono felice di vederli tirare fuori il premio.","\n",{"#":"inventory_add: MachinistBadge"},{"#":"gesture_sable: thanks"},"^<<\"Ecco il distintivo. Indossalo con orgoglio per la tua piccola mente brillante e forse ti vedrò in una Maschera del Macchinista presto.\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"chamber_dialogue":[["ev",{"VAR?":"AN_EYE_TO_THE_SKY_SEEN_CHAMBER"},{"f()":"activate"},"pop","/ev","\n","^Davanti a me, una specie di proiezione appare come per magia, e nella sua geometria fluttuante vedo le luci che brillano nel cielo notturno.","\n","^Vedo... da dove veniamo.","\n","^Mentre mi concentro su ciascun elemento di questa complessa visualizzazione, mi accorgo che mi viene trasmesso qualcosa — che sto <i>leggendo</i> e <i>capendo</i> cose.","\n","^La conoscenza arriva nuova eppure sembra innata, come se mi venisse ricordata anziché insegnata.","\n",[{"#":"watch_cam_reset"},"^Decido di concentrarmi su...","\n","ev","str","^Il Sole","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Il piccolo pianeta più vicino al Sole","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Il secondo pianeta","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Una geometria sconosciuta","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^L'anello scintillante","/str","/ev",{"*":".^.c-4","flg":4},"ev","str","^Il pianeta con gli anelli","/str","/ev",{"*":".^.c-5","flg":4},"ev","str","^I pianeti gemelli","/str","/ev",{"*":".^.c-6","flg":4},"ev","str","^Credo di aver finito qui","/str","/ev",{"*":".^.c-7","flg":4},{"c-0":["^ ","\n",{"#":"sun_cam"},"^Vedo chiaramente che la grande orbe luminosa al centro è il nostro Sole, così accecante che non riesco a guardarlo direttamente senza sentirne il calore irradiarsi nel cranio.","\n","^Attorno, i corpi celesti si muovono in una danza ritmica.","\n",{"->":".^.^"},{"#f":5}],"c-1":["^ ","\n",{"#":"emis_cam"},"^Emis e le sue due lune svolazzano attorno al sole come falene che danzano sopra una fiamma. La dea dalla testa di capra, patrona degli Ibexii.","\n","^La sua saggezza e determinazione hanno reso alcune delle mie storie preferite mentre crescevo. Mi è sempre sembrata più accessibile degli altri dei.","\n","^I miei insegnanti dicevano che è a Emis che guardiamo quando Rohana è troppo occupato per noi. La immaginavo sulla sua scogliera sopra l'Ewer, sempre paziente, sempre aperta.","\n","^Dicevano anche che attraverso certe maschere si poteva vedere la sua ombra sul Sole.","\n",{"->":".^.^"},{"#f":5}],"c-2":["^ ","\n",{"#":"midden_cam"},"^Il secondo pianeta è Midden, la nostra piccola casa sabbiosa di una roccia insignificante, resa calda e vibrante dal potere e dall'energia del Perpetuo.","\n","^Guardandolo così vedo un altro lato del Perpetuo, e non posso fare a meno di notare che sembriamo intrappolati e imprigionati da esso, tenuti nella sua morsa.","\n","^Un vento freddo passa, ma si scalda quando mi ricordo di no. Non siamo posseduti; siamo protetti.","\n","^Offro a me stessa quel conforto.","\n",{"->":".^.^"},{"#f":5}],"c-3":["^ ","\n",{"#":"maw_cam"},"^Guardo una forma che faccio fatica a descrivere. È geometria pura e strana, così bizzarra eppure così ordinata da non poter essere organica.","\n","^Capisco subito che è La Fauce. È la cosa impossibile che ha generato la Whale.","\n","^So dalle storie, dalla storia, e dalla conoscenza che mi penetra nel cervello qui che è stata creata da esseri viventi — esseri senzienti con piani e intenzioni.","\n","^Ma anche se lo so, non riesco a comprenderla. La sua scala è incomprensibile. La sua magnitudine è tale che, anche in replica, non riesco a guardarla a lungo.","\n","^Qualcosa in me la detesta. Non so perché.","\n",{"->":".^.^"},{"#f":5}],"c-4":["^ ","\n",{"#":"aoelion_cam"},"^Aoelion, un anello scintillante di polvere dorata. Ogni piccolo granello sembra fluttuare in una brezza, dolcemente, nel cielo. Sono questi a comporre le stelle?","\n",{"->":".^.^"},{"#f":5}],"c-5":["^ ","\n",{"#":"carab_cam"},"^Carab e le sue ali! Quando me lo immagino, il pianeta con gli anelli è popolato interamente da scarabei, viventi in una società decisamente avanzata.","\n","^Sarebbe il posto perfetto per Saima, penso, ma a me l'idea non piace. Sembra più grande degli altri pianeti. Sarebbero <i>tanti</i> scarabei.","\n","^È ora di andare oltre.","\n",{"->":".^.^"},{"#f":5}],"c-6":["^ ","\n",{"#":"twins_cam"},"^I pesci gemelli, Coral e Cobalt. Sembra ci siano piccole lune catturate nelle loro correnti. Il modo in cui si muovono è ipnotico, e fatico a distogliere lo sguardo.","\n","^Si dice che questi due siano i più dispettosi degli dei, e ricordo le leggende in cui si travestivano da bambini per attirare i nomadi gentili nella corrente sotto le dune.","\n","^Tra gli Ibexii, queste storie dei gemelli sono perfette per spaventare i troppo audaci e troppo giovani dall'avventurarsi lontano da casa. È un miracolo che si parta mai per il Volo.","\n","^Una parte di me vorrebbe non averli ricordati, però, e sarà una sfida non guardare di traverso il prossimo bambino randagio che incontro.","\n",{"->":".^.^"},{"#f":5}],"c-7":["^ ","\n","^Strappo gli occhi allo spettacolo. Sono grata di averlo visto, ma felice di andare oltre.","\n",{"->":"END_SCENE"},{"#f":5}],"#f":5,"#n":"solar_system_learning"}],null],{"#f":1}],"#f":3}],"an_eye_to_the_sky_quest_debug":[["ev","str","^Apri il tetto","/str",{"VAR?":"AN_EYE_TO_THE_SKY_OPENED_FACE_DOOR"},{"f()":"reached"},"!","/ev",{"*":".^.c-0","flg":5},"ev","str","^Indaga sulla camera","/str",{"VAR?":"AN_EYE_TO_THE_SKY_OPENED_FACE_DOOR"},{"f()":"reached"},"/ev",{"*":".^.c-1","flg":5},{"c-0":["\n","^Mi metto su un interruttore e il tetto della Vedetta si apre. Il meccanismo al centro della camera inizia a oscillare in posizione.","\n",["ev","str","^Prendi una lettura del sole","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["\n","ev",{"VAR?":"AN_EYE_TO_THE_SKY_OPENED_FACE_DOOR"},{"f()":"activate"},"pop","/ev","\n","^Allineo il meccanismo e prendo una lettura della posizione del Sole. Quando inserisco la lettura nella macchina, una grande porta si apre, conducendo a una piccola camera.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["\n",{"->":"an_eye_to_the_sky_content.chamber_dialogue"},{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev","void","/ev","->->",{"#f":5}]}],{"#f":3}],"an_eye_to_the_sky_quest_definition":[{"#":"name"},"^Un Occhio al Cielo","\n",{"#":"locations"},"^quest_giver, observatory, observatory_chamber","\n",{"#":"status"},["ev",{"VAR?":"AN_EYE_TO_THE_SKY_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"AN_EYE_TO_THE_SKY_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"AN_EYE_TO_THE_SKY_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Kaalan mi ha detto di andare alla Vedetta e prendere una lettura del sole.","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"AN_EYE_TO_THE_SKY_STARTED"},{"VAR?":"AN_EYE_TO_THE_SKY_OPENED_FACE_DOOR"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: observatory"},{"#":"status: active"},"^Devo usare la vecchia attrezzatura della Vedetta per prendere una lettura.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"AN_EYE_TO_THE_SKY_OPENED_FACE_DOOR"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho preso una lettura e una porta nella camera principale si è aperta.","\n",{"->":".^.^.^.32"},null]}],"nop","\n","ev",{"VAR?":"AN_EYE_TO_THE_SKY_OPENED_FACE_DOOR"},{"VAR?":"AN_EYE_TO_THE_SKY_SEEN_CHAMBER"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: observatory_chamber"},{"#":"status: active"},"^Dovrei indagare su cosa c'è nella camera.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","ev",{"VAR?":"AN_EYE_TO_THE_SKY_SEEN_CHAMBER"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato un vecchio modello del sistema solare nella camera.","\n",{"->":".^.^.^.47"},null]}],"nop","\n","ev",{"VAR?":"AN_EYE_TO_THE_SKY_SEEN_CHAMBER"},{"VAR?":"AN_EYE_TO_THE_SKY_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: quest_giver"},"^Dovrei tornare da Kaalan al campo.","\n",{"->":".^.^.^.55"},null]}],"nop","\n","ev",{"VAR?":"AN_EYE_TO_THE_SKY_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Kaalan è rimasto impressionato e mi ha dato un Distintivo del Macchinista.","\n",{"->":".^.^.^.62"},null]}],"nop","\n","end",{"#f":1}],"riding_the_wave_got_egg":["ev","str","^PinkNeckEggs","/str",{"x()":"inventory_get_quantity","exArgs":1},0,">","/ev","~ret","\n",{"#f":1}],"zebi_conversation":["ev",{"VAR?":"speaker_zebi"},"/ev",{"VAR=":"SpeakerName","re":true},["ev",{"VAR?":"RIDING_THE_WAVE_COMPLETED"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_completed"},{"->":".^.^.^.7"},null]}],["ev",{"VAR?":"RIDING_THE_WAVE_MET_ZEBI"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.met_zebi"},{"->":".^.^.^.7"},null]}],["ev",{"VAR?":"RIDING_THE_WAVE_STARTED"},{"VAR?":"RIDING_THE_WAVE_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_active"},{"->":".^.^.^.7"},null]}],"nop","\n",{"->":".^.done"},{"met_zebi":[["ev",{"list":{"riding_the_wave.RIDING_THE_WAVE_STARTED":1,"riding_the_wave.RIDING_THE_WAVE_MET_ZEBI":3}},{"f()":"activate"},"pop","/ev","\n",{"#":"riding_the_wave_quest_start"},"^Prima che li saluti, il Cacciatore emette dei rumori di respiro: forti espirazioni a labbra quasi serrate e piccoli, faticosi 'uff'.","\n","^Si passano la mano dietro la nuca e guardano in alto e lontano per brevi istanti prima di tornare nella mia direzione con uno scuotimento di testa.","\n","^Non è come sono abituata a vedere i Cacciatori, che ho imparato ad associare alla calma perfetta.","\n","^<<\"Glider!\">>","\n","^Capisco che <i>stanno provando</i> a infondere calma nella voce, ma non funziona.","\n",{"#":"cut_to_dilhan"},"^<<\"Puoi aiutarmi? Mi chiamo Zebi. Sono qui fuori da un po', e il mio compagno Dilhan-- compagno <i>di viaggio</i>, intendo-- gli è venuto in mente di arrampicarsi lassù in cerca di uova di uccello.\">>","\n","ev","str","^È piuttosto alto...","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ci sono uova lassù?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^È un problema?","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Non credo di suonare spaventata mentre commento quanto sia in alto, ma Zebi sembra pensare che stia esprimendo solidarietà.","\n","^<<\"Lo so! È-- non uso spesso questa parola, e non mi piace farlo, ma è... è <i>assurdo</i>, ecco cos'è!\">>","\n",["ev","str","^Non ti piace dire 'assurdo'?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Puoi dirlo forte!","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^<<\"Sono un Cacciatore! Se il tuo successo si misurasse su lunghezza, peso e maestosità della preda, anche tu odieresti l'iperbole. Ma questa situazione la richiede.\">>","\n","^Gli dico che capisco, ma... non davvero.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^<<\"Capisci.\">>","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"c-1":["^ ","\n","^<<\"Sì! Certo. Ma sai cos'altro c'è lassù? Dilhan.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^<<\"Per Dilhan? No, per Dilhan è probabilmente una gioia assoluta frugare tra gli avanzi degli uccelli. Ma è un <i>grosso</i> problema per me.\">>","\n","^Decido di non suggerire che le uova non sono proprio \"<i>avanzi</i>\".","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Zebi sbuffa.","\n","^<<\"Non sono felice di ammetterlo, ma... non amo troppo le altezze. Qualcuno direbbe che ne ho un po' paura. O parecchio.\">>","\n","^<<\"Se potessi salire lassù e recuperarmi Dilhan, e dirgli che lo ammazzerò quando scenderà, mi saresti davvero d'aiuto.\">>","\n",{"#":"end_scene"},"^Dico a Zebi che sono felice di fare la maggior parte di tutto ciò, e accetto il compito.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_active":["^<<\"Grazie per essere salita lassù per me. Davvero non sopporto di farlo io stesso.\">>","\n","ev","void","/ev","->->",{"#f":1}],"quest_completed":[["^Zebi non è affannato come quando l'avevo incontrato. Mi saluta calorosamente, e sento il suo sollievo nelle <i>mie</i> spalle.","\n","^<<\"Grazie mille per aver recuperato Dilhan per me, Glider.\">>","\n","ev","str","^Nessun problema.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non è stato facile, ma ce l'ho fatta!","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Gli piacciono proprio le uova, eh?","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Dico a Zebi che non è stato un problema e protesta sbuffando.","\n","^<<\"Non fare la modesta! Hai fatto qualcosa di gentile per un'estranea e hai mostrato un'atletica notevole, oltretutto. Sei impressionante! Non seppellire tutta quella brillantezza.\">>","\n","^Lo ringrazio, cercando di farlo con fermezza.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Dico a Zebi che salire lassù non è stato facile, ma me ne sono occupata.","\n","^<<\"Questo lo rende ancora più impressionante! Il tuo Volo sarà una passeggiata.\">>","\n","^Lo ringrazio con una piccola risata, e dico che spero abbia ragione.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^Faccio notare a Zebi quanto a Dilhan sembrassero piacere le uova.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Beh, perché tu lo sappia, l'avventura non è proprio finita. Vedi, Dilhan non ha intenzione di <i>mangiarsele</i> quelle uova, spero tu lo sappia.\">>","\n","^<<\"Gli piacciono molto gli uccelli e... beh, sembra che alla fine di tutto questo lui e io ci ritroveremo con tre cinguettanti gemellini.\">>","\n","^<<\"Magari ne chiameremo uno come te.\">>","\n","^Dico a Zebi che mi farebbe piacere, e gli faccio le congratulazioni di commiato.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"done":["^Saluto Zebi.","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"dilhan_conversation":["ev",{"VAR?":"speaker_dilhan"},"/ev",{"VAR=":"SpeakerName","re":true},["ev",{"VAR?":"RIDING_THE_WAVE_COMPLETED"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.post_quest"},{"->":".^.^.^.9"},null]}],["ev",{"f()":"riding_the_wave_got_egg"},{"VAR?":"RIDING_THE_WAVE_MET_DILHAN"},{"f()":"reached"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.deliver_eggs_alt"},{"->":".^.^.^.9"},null]}],["ev",{"f()":"riding_the_wave_got_egg"},{"VAR?":"RIDING_THE_WAVE_COMPLETED"},{"f()":"reached"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.deliver_eggs"},{"->":".^.^.^.9"},null]}],["ev",{"VAR?":"RIDING_THE_WAVE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.9"},null]}],["ev",{"list":{"riding_the_wave.RIDING_THE_WAVE_STARTED":1,"riding_the_wave.RIDING_THE_WAVE_MET_ZEBI":3}},{"VAR?":"RIDING_THE_WAVE_MET_DILHAN"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.met_dilhan"},{"->":".^.^.^.9"},null]}],"nop","\n",{"->":".^.done"},{"quest_start":[["ev",{"list":{"riding_the_wave.RIDING_THE_WAVE_STARTED":1,"riding_the_wave.RIDING_THE_WAVE_MET_DILHAN":4}},{"f()":"activate"},"pop","/ev","\n","^<<\"Ah! Salve, Glider.\">>","\n","^<<\"Devo dire, quando ti ho sentita avvicinarti mi aspettavo di vedere un'altra Scalatrice!\">>","\n","^<<\"Anche se voglio dire, se sei una Glider... non sei <i>non</i> scalatrice, no? Solo non sei nulla in particolare!\">","\n","ev","str","^Sono io! Niente di particolare!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Una Glider è una cosa a sé.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^È troppo a cui pensare adesso.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Dilhan emette un respiro simile a una risata educata, ma capisco che è distratto.","\n",{"->":".^.^.^.^.dilhan_shared_intro"},{"#f":5}]}],{"#f":1}],"met_dilhan":[["ev",{"VAR?":"RIDING_THE_WAVE_MET_DILHAN"},{"f()":"activate"},"pop","/ev","\n","^<<\"Salve, Glider! Che vista, eh?\">>","\n","^Dilhan sembra perfettamente sereno, persino felice, ad assorbire il panorama da solo. Guardo brevemente l'orizzonte. È <i>davvero</i> una bella vista.","\n","ev","str","^Che ci fai quassù?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Bel posticino!","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Sono qui per portarti giù.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Ride.","\n","^<<\"Sembra cosa?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Annuisce in segno di apprezzamento.","\n","^<<\"Più che bella. Mozzafiato.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n","^Si volta verso di me con un'allarme improvviso e indietreggia con cautela.","\n","^<<\"Cosa? Perché?\">>","\n",["ev","str","^Cosa?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Potrei essermi espressa male.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^<<\"Perché vuoi 'portarmi giù'? Non ho fatto niente, e--\">>","\n","^Spiego che intendevo a terra. E poi che intendo accompagnarti.","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"g-0":["^Dico a Dilhan che mi ha mandato Zebi per convincerlo a scendere e continuare il loro viaggio insieme da altezze meno spaventose. Dilhan scuote la testa.","\n","^<<\"Zebi. Che guastafeste! Tieni, guarda qui e dimmi <i>tu</i> se scenderesti.\">>","\n",{"->":".^.^.^.^.dilhan_shared_intro"},{"#f":5}]}],{"#f":1}],"dilhan_shared_intro":[[{"#":"PinkNeckCameraOn"},"^<<\"Guarda quella bestia bellissima...\">>","\n","^<<\"Si chiama Collo Rosa, mai sentito? Originari del Sodic Waste. Si dice siano discendenti diretti delle creature arrivate sulla Whale.\">>","\n","^<<\"Quella ha un'intera covata di uova pronta da raccogliere.\">>","\n",{"#":"PinkNeckCameraOff"},"^Dilhan annuisce con risolutezza.","\n","^<<\"Devo solo capire come prenderle.\">>","\n","ev","str","^Come si fa?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Posso aiutarti?","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Chiedo come si possano procurare uova del genere, oltre alla semplice scalata.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Chiedo se c'è qualcosa con cui posso aiutare, dato il mio stato.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Stavo pensando che il modo migliore sia spaventare la madre con qualcosa di lucente, e poi prendere le uova quando se ne va.\">>","\n","^<<\"Stai collezionando maschere, no? Se hai qualcosa... lucente e metallica, potrebbe funzionare?\">>","\n","^Gli dico che ci penserò e cercherò di essergli d'aiuto. Mi ringrazia e torna al suo bird-watching.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"deliver_eggs":[["ev",{"VAR?":"RIDING_THE_WAVE_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"#":"inventory_remove: PinkNeckEggs"},"^Cerco di non sembrare troppo stanca mentre porgo le uova a Dilhan, che sembra completamente entusiasta.","\n","^<<\"Ma guarda un po'! Detesto ammetterlo, ma potresti essere una Scalatrice migliore di me! Almeno una <i>migliore</i> spaventa-uccelli.\">>","\n","ev","str","^Gli uccelli tremano davanti a me.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Per favore, ora scendi.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Mm, immagino dovrei tornare da Zebi...\">>","\n","^<<\"Ma prima di farlo, ti meriti questo. Non ho mai visto una scalata simile. Certo non da una dilettante.\">>","\n",{"#":"inventory_add: ClimbingBadge"},"^Dilhan mi porge un Distintivo dell'Arrampicata, e lo ringrazio.","\n","^<<\"Ci si rivede, Glider. E grazie!\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"deliver_eggs_alt":["ev",{"VAR?":"RIDING_THE_WAVE_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Salve, Glider! Mi chiamo Dilhan, come stai?\">>","\n","^<<\"Non ho potuto non notare la tua scalata fino al nido del Collo Rosa. Davvero incredibile. Come guardare un'esperta!\">>","\n","^Lo ringrazio, anche se la lode esuberante mi rende leggermente nervosa. Sarà un problema per un altro giorno.","\n","^<<\"Per caso hai raccolto delle uova mentre eri lassù? Se sì, vorrei--\"","\n","^Gli consegno le uova velocemente. Non ha bisogno di sapere che, da quando le porto, ho silenziosamente avuto paura che si schiudessero e dovessi essere al contempo Glider e Madre di alcuni Colli Rosa confusi.","\n","^<<\"Davvero? Grazie! Che fortuna incredibile. Mi hai fatto risparmiare un sacco di tempo...\">>","\n",{"#":"inventory_add: ClimbingBadge"},"^<<\"Tieni. Per una scalata del genere, ti meriti un distintivo.\">>","\n","^Prendo il distintivo e lo ringrazio sinceramente per il riconoscimento.","\n","^<<\"Saresti una brava Scalatrice un giorno, Glider. Spero ci pensi.\">>","\n","^Gli dico che lo farò, e lo saluto.","\n","ev","void","/ev","->->",{"#f":1}],"post_quest":["^<<\"Ehilà! Ci rincontriamo su terreno meno infido!\">>","\n","^Dilhan sembra di buon umore ora che il temerario dentro di lui è stato soddisfatto.","\n","^<<\"Magari ti rivedo a un altro punto alto, eh?\">>","\n","ev","void","/ev","->->",{"#f":1}],"done":["^Saluto Dilhan.","\n",{"->":"END_SCENE"},{"#f":1}],"#f":1}],"riding_the_wave_quest_definition":[{"#":"name"},"^Cavalcare l'Onda","\n",{"#":"locations"},"^dilhan, nest","\n",{"#":"items"},"ev","str","^PinkNeckEggs","/str","out","/ev","\n",{"#":"status"},["ev",{"VAR?":"RIDING_THE_WAVE_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.18"},null]}],["ev",{"VAR?":"RIDING_THE_WAVE_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.18"},null]}],["ev",{"VAR?":"RIDING_THE_WAVE_COMPLETED"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n","^completed","\n",{"->":".^.^.^.18"},null]}],"nop","\n","ev",{"list":{"riding_the_wave.RIDING_THE_WAVE_STARTED":1,"riding_the_wave.RIDING_THE_WAVE_MET_ZEBI":3}},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Un cacciatore di nome Zebi mi ha chiesto di salire sulla Torre dei Geyser e recuperare il suo compagno, Dilhan.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"list":{"riding_the_wave.RIDING_THE_WAVE_STARTED":1,"riding_the_wave.RIDING_THE_WAVE_MET_ZEBI":3}},{"VAR?":"RIDING_THE_WAVE_MET_DILHAN"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: dilhan"},{"#":"status: active"},"^Dovrei arrampicarmi in cima alla Torre dei Geyser e portare giù Dilhan.","\n",{"->":".^.^.^.33"},null]}],"nop","\n","ev",{"VAR?":"RIDING_THE_WAVE_MET_DILHAN"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Sono salita sulla Torre dei Geyser e ho incontrato Dilhan. Mi ha chiesto di recuperargli delle uova dal nido in cima alla torre.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","ev",{"VAR?":"RIDING_THE_WAVE_MET_DILHAN"},{"f()":"reached"},{"f()":"riding_the_wave_got_egg"},"!","&&","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: nest"},{"#":"status: active"},"^Devo allontanare il Collo Rosa dal nido per rubarne le uova. Dilhan dice che l'uccello ha paura delle maschere lucenti.","\n",{"->":".^.^.^.50"},null]}],"nop","\n","ev",{"f()":"riding_the_wave_got_egg"},{"VAR?":"RIDING_THE_WAVE_COMPLETED"},{"f()":"reached"},"!","&&","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: dilhan"},{"#":"status: active"},"^Dovrei portare le uova di Collo Rosa a Dilhan.","\n",{"->":".^.^.^.60"},null]}],"nop","\n","ev",{"VAR?":"RIDING_THE_WAVE_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"