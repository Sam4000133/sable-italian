,{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"HIDE_AND_SEEK_FOUND_ONE"},{"f()":"activate"},"pop","/ev","\n","ev",{"VAR?":"speaker_nezz"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"gesture_partner: sad"},{"#":"gesture_sable: fist_pump"},"^<<\"Aww, mi hai trovato!\">>","\n",{"->t->":"hide_and_seek_content.complete_check"},{"->":".^.^.^.3"},null]}],[{"->":".^.b"},{"b":["\n","ev",{"VAR?":"speaker_nezz"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Nascondino è così noioso! Dovremmo giocare a qualcos'altro!\">>","\n",{"->":".^.^.^.3"},null]}],"nop","\n",{"->":"END_SCENE"},{"#f":1}],"hide_and_seek_pala":[["ev",{"VAR?":"HIDE_AND_SEEK_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":"hide_and_seek_content.start"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"HIDE_AND_SEEK_STARTED"},{"VAR?":"HIDE_AND_SEEK_FOUND_TWO"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"HIDE_AND_SEEK_FOUND_TWO"},{"f()":"activate"},"pop","/ev","\n","ev",{"VAR?":"speaker_pala"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"gesture_partner: thinking"},{"#":"gesture_sable: fist_pump"},"^<<\"Oh, mi hai trovato. Sei <i>sicura</i> di aver contato <i>davvero</i> fino a cento?\">>","\n",{"->t->":"hide_and_seek_content.complete_check"},{"->":".^.^.^.3"},null]}],[{"->":".^.b"},{"b":["\n","ev",{"VAR?":"speaker_pala"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Quali altri giochi conosci?\">>","\n",{"->":".^.^.^.3"},null]}],"nop","\n",{"->":"END_SCENE"},{"#f":1}],"hide_and_seek_jef":[["ev",{"VAR?":"HIDE_AND_SEEK_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->":"hide_and_seek_content.start"},{"->":".^.^.^.3"},null]}],["ev",{"VAR?":"HIDE_AND_SEEK_STARTED"},{"VAR?":"HIDE_AND_SEEK_FOUND_THREE"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"HIDE_AND_SEEK_FOUND_THREE"},{"f()":"activate"},"pop","/ev","\n","ev",{"VAR?":"speaker_jef"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"gesture_partner: thinking"},{"#":"gesture_sable: fist_pump"},"^<<\"Pensavo fosse un nascondiglio davvero buono. Sei in gamba per essere una grande.\">>","\n","^Prendo il complimento.","\n",{"->t->":"hide_and_seek_content.complete_check"},{"->":".^.^.^.3"},null]}],[{"->":".^.b"},{"b":["\n","ev",{"VAR?":"speaker_jef"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Puoi unirti alla nostra banda, se vuoi.\">>","\n",{"->":".^.^.^.3"},null]}],"nop","\n",{"->":"END_SCENE"},{"#f":1}],"hide_and_seek_content":[{"->":".^.start"},{"start":[[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->t->":".^.^.^.^.^.first_time"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->t->":".^.^.^.^.^.repeat"},{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Certo!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ehm, forse più tardi.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.quest_accepted"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.quest_declined"},{"#f":5}]}],{"#f":1}],"first_time":[[{"#":"gesture_sable: greeting"},"^I bambini stretti insieme ridacchiano mentre mi avvicino, come fanno i bambini. Non si capisce mai bene se siano divertiti, nervosi o in canzonatura. Decido di non lasciarmi sentire giudicata.","\n","ev",{"VAR?":"speaker_first_child"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"nezz_explaining"},"^<<\"Sei una Glider!\">>","\n","ev","str","^Esattamente!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Assolutamente no!","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Come lo sai?","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Si eccitano a questa risposta, e fanno piccoli versi tra di loro. Anche io trovavo i Glider entusiasmanti da bambina, ma in qualche modo mi sento un po' un'impostora... e un po' fiera.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"nezz_explaining"},"^<<\"Sì che lo sei!\">>","\n","ev",{"VAR?":"speaker_second_child"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"pala_talking"},"^<<\"Si capisce dai tuoi vestiti!\">>","\n","ev",{"VAR?":"speaker_third_child"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"jef_ecstatic"},"^<<\"Dov'è la tua hoverbike? Possiamo cavalcarla?\">>","\n","^Sgamata, mi confesso... e nego gentilmente la richiesta della hoverbike. La questione viene rapidamente dimenticata.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"nezz_explaining"},"^<<\"Ho visto la tua hoverbike!\">>","\n","ev",{"VAR?":"speaker_second_child"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"pala_talking"},"^<<\"Si capisce dai tuoi vestiti!\">>","\n","ev",{"VAR?":"speaker_third_child"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"jef_ecstatic"},"^<<\"Sono telepatica!\">>","\n",["ev","str","^Mi hai beccata!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Siete bambini in gamba!","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.^.^.g-0"},{"#f":5}]}],{"#f":5}],"g-0":["ev",{"VAR?":"speaker_first_child"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Vuoi giocare con noi?\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"repeat":["ev",{"VAR?":"speaker_first_child"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Puoi ancora giocare con noi, se vuoi.\">>","\n","ev","void","/ev","->->",{"#f":1}],"quest_declined":[{"#":"nezz_dismissive"},{"#":"pala_shrug"},{"#":"jef_angry"},"^Sbuffano in coro.","\n","ev",{"VAR?":"speaker_third_child"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"jef_sad"},"^<<\"Che noia!\">>","\n",{"->":"END_SCENE"},{"#f":1}],"quest_accepted":[["ev",{"VAR?":"HIDE_AND_SEEK_STARTED"},{"f()":"activate"},"pop","/ev","\n",{"#":"nezz_ecstatic"},{"#":"pala_ecstatic"},{"#":"jef_ecstatic"},"^<<\"Evviva! Il gioco è a nascondino, lo conosci?\">>","\n","ev","str","^Credo di conoscerlo!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Ci ho giocato parecchio.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Gli dico che ci giocavo con un mio giovane amico, a casa. Non sembrano particolarmente interessati alla storia. Non mi sono mai sentita così vecchia...","\n","ev",{"VAR?":"speaker_third_child"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"gesture_sable: surprised_1"},{"#":"pala_talking"},"^<<\"Bene! Tocca a te! Andiamo a nasconderci e tu devi trovarci!\">>","\n","^Gli dico di aspettare — una volta che io, la grande Glider esperta, li avrò scovati con astuzia, come potrei chiamarli se non so i loro nomi?","\n","ev",{"VAR?":"speaker_first_child"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"nezz_dismissive"},"^<<\"Ah, non essere così sicura di trovarci! Questa è la <i>nostra</i> città, ricordi.\">>","\n","ev",{"VAR?":"speaker_pala"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"pala_greeting"},"^<<\"Comunque, io sono Pala!\">>","\n","ev",{"VAR?":"speaker_jef"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"jef_ecstatic"},"^<<\"Io sono Jef!\">>","\n","ev",{"VAR?":"speaker_nezz"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"nezz_speaking"},"^<<\"E io sono Nezz.\">>","\n","^Gli dico il mio nome, poi Pala mi punta il dito addosso.","\n","ev",{"VAR?":"speaker_pala"},"/ev",{"VAR=":"SpeakerName","re":true},{"#":"pala_explaining"},"^<<\"Sei pronta, Sable? Devi chiudere gli occhi e contare fino a cento! Non barare, e <i>niente</i> salti! E conta LENTAMENTE!\">>","\n","ev","str","^È un numero altissimo!","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Cosa?! Io non barerei mai!","/str","/ev",{"*":".^.c-3","flg":4},{"c-2":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":[{"#":"hide_and_seek_start"},{"#":"pala_talking"},"^<<\"Inizia a contare e basta!\">>","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"count":["^Chiudo gli occhi e inizio a contare.","\n","^Uno, due, tre...","\n","^...","\n","^cinquantasette, cinquantotto...","\n","^...","\n","^Novantasette, novantotto, novantanove...","\n",{"#":"hundred"},"^Cento!","\n",{"->":"END_SCENE"},{"#f":1}],"complete_check":[["ev",{"list":{"hide_and_seek.HIDE_AND_SEEK_FOUND_ONE":2,"hide_and_seek.HIDE_AND_SEEK_FOUND_TWO":3,"hide_and_seek.HIDE_AND_SEEK_FOUND_THREE":4}},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["^ ","ev","void","/ev","->->",{"->":".^.^.^.6"},null]}],"nop","\n","ev",{"VAR?":"HIDE_AND_SEEK_COMPLETED"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_partner: ecstatic"},"^<<Hai trovato prima gli altri? Sì! Vuol dire che ho vinto io!>>","\n","ev","str","^La vera vittoria è il divertimento che fai con i tuoi amici.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Vi ho trovati tutti. Non vuol dire che ho vinto io?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Ci ho messo un'eternità! Come ti sei nascosto così bene?!","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"#":"gesture_partner: fist_pump"},{"#":"gesture_sable: surprised_2"},"^<<\"No, è così.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"gesture_partner: thinking"},"^<<\"Mmm, no. Non credo. Ho vinto io di sicuro.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"#":"gesture_partner: explaining"},"^<<\"Mi alleno da tanto tempo. Mia madre mi aveva chiesto di fare delle faccende e mi sono nascosto da lei per tutto il pomeriggio! Mi sto nascondendo anche adesso!\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"#":"inventory_add: EntertainersBadge"},"^<<\"Comunque, sei piuttosto divertente per essere una grande, quindi puoi avere questo distintivo. Te ne servono tre poi potrai indossare la Maschera dell'Intrattenitore!\">>","\n","^Li ringrazio per il gioco e il distintivo e li saluto.","\n","^Mentre me ne vado, sento una piccola fitta al cuore. Mi mancano Saima e il resto del clan. Chissà cosa penserebbe lei del fatto che indossi la Maschera dell'Intrattenitore?","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"#f":1}],"hide_and_seek_quest_definition":[{"#":"name"},"^Plana e Cerca","\n",{"#":"locations"},"^quest_giver","\n",{"#":"status"},["ev",{"VAR?":"HIDE_AND_SEEK_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"HIDE_AND_SEEK_STARTED"},{"VAR?":"HIDE_AND_SEEK_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"HIDE_AND_SEEK_COMPLETED"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"HIDE_AND_SEEK_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Dei bambini eccrini hanno insistito perché mi unissi al loro gioco di nascondino.","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"HIDE_AND_SEEK_STARTED"},{"VAR?":"HIDE_AND_SEEK_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"HIDE_AND_SEEK_FOUND_ONE"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato Nezz.","\n",{"->":".^.^.^.6"},null]}],"nop","\n","ev",{"VAR?":"HIDE_AND_SEEK_FOUND_TWO"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato Pala.","\n",{"->":".^.^.^.13"},null]}],"nop","\n","ev",{"VAR?":"HIDE_AND_SEEK_FOUND_THREE"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato Jef.","\n",{"->":".^.^.^.20"},null]}],"nop","\n","ev",{"VAR?":"HIDE_AND_SEEK_FOUND_ONE"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Devo trovare Nezz.","\n",{"->":".^.^.^.28"},null]}],"nop","\n","ev",{"VAR?":"HIDE_AND_SEEK_FOUND_TWO"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Devo trovare Pala.","\n",{"->":".^.^.^.36"},null]}],"nop","\n","ev",{"VAR?":"HIDE_AND_SEEK_FOUND_THREE"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Devo trovare Jef.","\n",{"->":".^.^.^.44"},null]}],"nop","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"HIDE_AND_SEEK_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato tutti i bambini. Mi hanno dato un Distintivo dell'Intrattenitore come premio.","\n",{"->":".^.^.^.32"},null]}],"nop","\n","end",{"#f":1}],"wearing_shade_mask":["ev",{"x()":"current_mask"},"str","^ShadeOfEccriaMask","/str","==","/ev","~ret","\n",{"#f":1}],"shade_of_eccria_alternate_start":["ev",{"f()":"wearing_shade_mask"},{"VAR?":"SHADE_OF_ECCRIA_STARTED"},{"f()":"reached"},"!","&&","/ev","~ret","\n",{"#f":1}],"maz_conversation":["ev",{"VAR?":"speaker_maz"},"/ev",{"VAR=":"SpeakerName","re":true},{"->t->":"shade_of_eccria_content"},"^<<\"Addio, Glider.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"shade_of_eccria_content":[["ev",{"f()":"shade_of_eccria_alternate_start"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.alternate_start"},{"->":".^.^.^.7"},null]}],["ev",{"VAR?":"SHADE_OF_ECCRIA_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_start"},{"->":".^.^.^.7"},null]}],["ev",{"VAR?":"SHADE_OF_ECCRIA_STARTED"},{"VAR?":"SHADE_OF_ECCRIA_FOUND_MASK"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.waiting_for_mask"},{"->":".^.^.^.7"},null]}],["ev",{"VAR?":"SHADE_OF_ECCRIA_FOUND_MASK"},{"VAR?":"SHADE_OF_ECCRIA_RETURNED_MASK"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.return_the_mask"},{"->":".^.^.^.7"},null]}],["ev",{"VAR?":"SHADE_OF_ECCRIA_FORMED_PLAN"},{"VAR?":"SHADE_OF_ECCRIA_EXECUTED_PLAN"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.ready_to_go"},{"->":".^.^.^.7"},null]}],["ev",{"VAR?":"SHADE_OF_ECCRIA_EXECUTED_PLAN"},{"VAR?":"SHADE_OF_ECCRIA_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"->t->":".^.^.^.quest_complete"},{"->":".^.^.^.7"},null]}],[{"->":".^.b"},{"b":["\n",{"->t->":".^.^.^.post_quest_chat"},{"->":".^.^.^.7"},null]}],"nop","\n","ev","void","/ev","->->",{"quest_start":[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n",{"->":".^.^.^.^.quest_start_first"},{"->":".^.^.17"},null],"s1":["pop","\n",{"->":".^.^.^.^.quest_start_repeat"},{"->":".^.^.17"},null],"#f":5}],"\n",{"#f":1}],"quest_start_first":[["^<<\"Tu! Glider! Mi chiamo Maz. Ho un problema, e mi chiedo se potresti aiutarmi.\">>","\n","^Ha una voce di acciaio brunito, nonostante la dolcezza che cerca di iniettare nella supplica. Il tono di un uomo più abituato agli ordini che alle richieste.","\n","^Gli faccio cenno di continuare: almeno posso ascoltarlo.","\n","^<<\"È mio figlio.\">>","\n","^Sospira.","\n","^<<\"Lo tiene in custodia la Guardia Eccrina. L'hanno beccato a manomettere l'approvvigionamento idrico.\">>","\n","^Alza una mano per rassicurarmi, prima che possa esprimere dubbi.","\n","^<<\"Voleva solo deviare la condotta, non contaminarla. Mirava a portarci una fonte d'acqua migliore; una che ci avrebbe giovato... immensamente.\">>","\n","ev","str","^Mi sembra un crimine.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^È davvero un crimine?","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^  ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Per la legge eccrina è illegale, sì, ma... se seguissimo la legge eccrina moriremmo tutti di sete in attesa che un funzionario qualunque faccia il minimo sforzo.\">>","\n","^Sospira e incrocia le braccia, facendo un passo indietro. È difficile capire se sia già sconfitto, o se stia solo cercando di soffocare una speranza che sale.","\n","^<<\"Non insisterò per convincerti. Se ti sembra troppo, capisco. Ma qualcuno deve opporsi. E per diversi motivi, non posso essere io. Non questa volta. Puoi aiutarmi?\">>","\n",{"->":".^.^.^.^.quest_choice"},{"#f":5}]}],{"#f":1}],"quest_start_repeat":["^<<\"Avrei ancora bisogno del tuo aiuto con mio figlio, Glider.\">>","\n",{"->":".^.^.quest_choice"},{"#f":1}],"quest_choice":[["ev","str","^Ti aiuto!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Sono occupata al momento.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.^.^.quest_accepted"},{"#f":5}],"c-1":["^ ","\n","^<<\"Sarò qui se cambi idea.\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_accepted":[["ev",{"VAR?":"SHADE_OF_ECCRIA_STARTED"},{"f()":"activate"},"pop","/ev","\n","^Non so bene cosa mi aspetto, ma il cenno solenne che ricevo mi coglie impreparata. Si avvicina di più, e mi posa una mano sulla spalla.","\n","^<<\"C'è dell'altro. Qualcosa che devi sapere, e che spero non spezzi il legame che abbiamo creato.\">>","\n","^<<\"Hai mai sentito parlare... dell'Ombra di Eccria?\">>","\n","ev","str","^No. Cos'è?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Mi pare di averne sentito una storia o due.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^<<\"L'Ombra di Eccria? Un eroe del popolo. E un flagello per chi voleva sottometterlo. Scuro come la notte stessa, fluido come seta nera, alimentato dalle fiamme della vendetta. Una leggenda, in questa città maledetta.\">>","\n","^<<\"Anche se a chiederlo alla Guardia, o a chi gli foraggia le tasche, l'Ombra è una minaccia e un contrabbandiere.\">>","\n","^Gli chiedo cosa ne pensa lui.","\n","^<<\"Penso che fosse un uomo che faceva del suo meglio per riparare i torti dei potenti. Ma potrei essere di parte.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Gli dico che da bambina ho sentito storie sull'Ombra di Eccria, un ladro e contrabbandiere che tormentava la brava gente della città con furti, scassi e borseggi.","\n","^Tra alcuni Ibexii più anziani, l'Ombra rappresentava la vaga minaccia di Eccria: un altro motivo per schioccare la lingua davanti a bambini che parlavano in modo troppo sognante della grande città.","\n","^Maz ride asciutto, più un latrato che una risata.","\n","^<<\"Beh... Cosa pensi di lui ora, visto che ti sta di fronte?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"Sono l'Ombra di Eccria.\">>","\n","^Faccio appena in tempo a sembrare colpita prima che aggiunga:","\n","^<<\"E per oggi, lo sei anche tu.\">>","\n","^Cosa?","\n","^<<\"Quando mi sono ritirato, ho nascosto la Maschera dell'Ombra. Ma anche se l'Ombra non c'era più, le voci— la leggenda— sono rimaste.\">>","\n","^<<\"Una Glider non riuscirebbe a convincere le guardie a liberare mio figlio. Ma l'Ombra? Oh, alla sua sola vista, sono pronte a darti qualunque cosa.\">>","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_FOUND_MASK"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"->":".^.^.^.^.^.^.already_found_the_mask"},{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_LOOK_FOR_MASK"},{"f()":"activate"},"pop","/ev","\n",{"#":"shade_of_eccria_marking"},"^Maz indica un segno su un muro vicino.","\n","^<<\"Vedi questo? Vai al cancello della città e cerca questo simbolo. Ti porterà alla maschera.\">>","\n",{"#":"cam_reset"},"^<<\"Recupera la Maschera e tornami. Poi metteremo in scena il salvataggio.\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"waiting_for_mask":["^<<\"Aspetterò qui che recuperi la Maschera. Servirà nuotare un po', ma... sembri capace.\">>","\n","ev","void","/ev","->->",{"#f":1}],"already_found_the_mask":[["^Sento il cuore vibrare di una specie di eccitazione. In parte, è l'eccitazione di poter fare la vigilante, per un'avventura mozzafiato.","\n","^Ma soprattutto è perché sto per stupire l'Ombra di Eccria in persona. Sto sorridendo dietro la maschera, e spero che non lo senta nella mia voce:","\n","ev","str","^Oh, intendi questa?","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^È questa che cercavi?","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Sorpresa!","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Sollevo la Maschera dell'Ombra.","\n","^<<\"No! Era il mio nascondiglio migliore! Devi essere proprio una contrabbandiera.\">>","\n",{"->":".^.^.^.^.hatch_a_plan"},{"#f":5}]}],{"#f":1}],"alternate_start":[["ev",{"list":{"shade_of_eccria.SHADE_OF_ECCRIA_STARTED":1,"shade_of_eccria.SHADE_OF_ECCRIA_LOOK_FOR_MASK":2,"shade_of_eccria.SHADE_OF_ECCRIA_FOUND_MASK":3}},{"f()":"activate"},"pop","/ev","\n","^<<\"Quella maschera! Era mia tanto tempo fa! È l'Ombra di Eccria.\">>","\n","^<<\"Stavo per chiederti di recuperarmela per aiutarmi a liberare mio figlio. Ci hai fatto risparmiare un po' di tempo.\">>","\n","^<<\"Ti prego. Ora che abbiamo la maschera-- devi aiutarmi.\">>","\n","ev","str","^Certo che ti aiuto.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non ho davvero scelta.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":".^.^.^.^.hatch_a_plan"},{"#f":5}]}],{"#f":1}],"return_the_mask":[["ev",{"f()":"wearing_shade_mask"},"/ev",{"->":".^.b","c":true},{"b":["\n","^<<\"È un sacco di tempo che non vedevo quel vecchio coso.\">>","\n",{"->":".^.^.^.2"},null]}],[{"->":".^.b"},{"b":["\n","^Mostro a Maz la sua vecchia Maschera. A malapena reagisce, ma poi me la prende delicatamente e la solleva, così che lui e il suo io più giovane siano naso contro naso. Ridacchia.","\n","^<<\"Capisco perché mi temessero. È... bellissima.\">>","\n","^Me la restituisce più velocemente di quanto l'abbia presa, fermando una fantasia prima che cominci.","\n",{"->":".^.^.^.2"},null]}],"nop","\n",{"->":".^.^.hatch_a_plan"},{"#f":1}],"hatch_a_plan":["^<<\"Quando indossi la Maschera dell'Ombra, non c'è alleato migliore dell'oscurità e del terrore. Aspetta che faccia notte, poi vai alla guarnigione delle Guardie. Sii silenziosa il più possibile, e sfuggi ai loro occhi fino al momento di colpire...\">>","\n","^<<\"Poi... quando sarà il momento giusto...\">>","\n","^Sibila l'ultima parte, gocciolante di veleno:","\n","^<<\"Mostragli l'Ombra.\">>","\n","^Rabbrividisco.","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_RETURNED_MASK"},{"f()":"activate"},"pop","/ev","\n",{"->":".^.^.ready_to_go"},{"#f":1}],"ready_to_go":[["ev",{"f()":"wearing_shade_mask"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"SHADE_OF_ECCRIA_FORMED_PLAN"},{"f()":"activate"},"pop","/ev","\n","^<<\"Metti la maschera dell'Ombra e fammi sapere quando sei pronta.\">>","\n","ev","void","/ev","->->",{"->":".^.^.^.5"},null]}],"nop","\n","^<<\"Sei pronta a farlo, Glider?\">>","\n","ev","str","^Sono pronta!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Non ancora. Presto.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",1,"/ev",{"VAR=":"debug_shade_of_eccria_start","re":true},{"#":"shade_of_eccria_breakout"},"^<<\"Bene. Allora cominciamo.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_FORMED_PLAN"},{"f()":"activate"},"pop","/ev","\n","^<<\"Allora ti aspetterò qui.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"guard_conversation":[["ev",{"VAR?":"speaker_first_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Sai, stavo pensando...\">>","\n","ev",{"VAR?":"speaker_second_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Oh no, una di quelle volte...\">>","\n","ev",{"VAR?":"speaker_first_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"No! Questa è interessante!\">>","\n","ev",{"VAR?":"speaker_second_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Ne dubito. Ma... boh, dimmi lo stesso. Ascoltarti è marginalmente meglio del vento.\">>","\n",{"->t->":".^.^.^.interrupt_choice"},"ev",{"CNT?":".^.^.^.interrupt_choice.0.c-0"},"/ev",[{"->":".^.b","c":true},{"b":["^ ",{"->":".^.^.^.end"},{"->":".^.^.^.29"},null]}],"nop","\n","ev",{"VAR?":"speaker_first_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Grazie. Stavo pensando a come ho visto un sacco di piante Nimoor, ma... non ho mai pensato a cosa ci sia dentro! Sai? Cosa c'è dentro una pianta Nimoor?\">>","\n","ev",{"VAR?":"speaker_second_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Brilla.\">>","\n","ev",{"VAR?":"speaker_first_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Sì, ovvio. So che brilla, ma perché? Cosa causa la luce?\">>","\n","ev",{"VAR?":"speaker_second_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Non lo so. Roba luminosa. Perché pensi a queste cose? A che pro?\">>","\n",{"->t->":".^.^.^.interrupt_choice"},"ev",{"CNT?":".^.^.^.interrupt_choice.0.c-0"},"/ev",[{"->":".^.b","c":true},{"b":["^ ",{"->":".^.^.^.end"},{"->":".^.^.^.60"},null]}],"nop","\n","ev",{"VAR?":"speaker_first_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Non so. Tu a cosa pensi?\">>","\n","ev",{"VAR?":"speaker_second_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"A cose normali!\">>","\n","ev",{"VAR?":"speaker_first_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Cose noiose, piuttosto.\">>","\n","^Le guardie cadono in silenzio. È ora di farmi notare.","\n",[{"->":"END_SCENE"},{"#f":5,"#n":"end"}],null],{"#f":1}],"interrupt_choice":[["ev","str","^Interrompi.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Continua ad ascoltare.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Questo è il mio momento. Faccio un respiro e divento l'Ombra.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"guard_run_away":["ev",{"VAR?":"speaker_first_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"No! No, è l'Ombra!\">>","\n","ev",{"VAR?":"speaker_second_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Scappa!\">>","\n","ev",{"VAR?":"speaker_first_guard"},"/ev",{"VAR=":"SpeakerName","re":true},"^<<\"Via via via!\">>","\n",{"->":"END_SCENE"},{"#f":1}],"rescue_conversation":[["ev",{"VAR?":"speaker_shade_child"},"/ev",{"VAR=":"SpeakerName","re":true},"^Vibro di nervosa eccitazione. E forse un pizzico di potere. Ma mi dico che è solo per assicurarmi di restituire la Maschera e continuare il mio Volo. Non è il momento di indossare il mantello della vigilante.","\n","^Mi avvicino al ragazzo, che sembra non aver patito affatto, e forse persino divertito dalla reazione delle guardie. Saluta con la mano.","\n","^Quando parlo, mantengo l'illusione. La mia voce non è proprio così infuocata come doveva essere quella dell'Ombra, ma è un effetto degno.","\n","^A voce alta lo chiamo Figlio di Maz e dichiaro che è libero di andare e tornare da suo padre.","\n","^<<\"Cosa? Chi-- chi sei?\">>","\n","^Gli dico che sono l'Ombra di Eccria e prendo una posa che potrebbe aiutarlo a capire.","\n","^<<\"No! Maz è l'Ombra di Eccria. E non è mio padre. Mio padre è morto.\">>","\n","^Il cuore mi si ferma.","\n","^<<\"Ma Maz si prende cura di me. Si prende cura di tutti noi.\">>","\n","^Il cuore riprende a battere.","\n","^<<\"Ti ha mandato lui?\">>","\n","ev","str","^L'Ombra invia sé stessa.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Sì, mi ha mandato Maz.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^<<\"E ha davvero detto che ero suo figlio?\">>","\n","^Annuisco.","\n","^Il ragazzo ride un po', con qualcosa di simile al sollievo.","\n","^<<\"Lo dice a tutti noi. Ci chiama figli e figlie, ma... non sapevo se lo dicesse davvero. Grazie. Adesso torno da lui.\">>","\n","^Senza un'altra parola, se ne va.","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"quest_complete":["ev",{"VAR?":"SHADE_OF_ECCRIA_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^La postura di Maz si è ammorbidita quando lo rivedo, come se il peso fosse andato. È felice. Chiedo se il ragazzo è tornato da lui e annuisce.","\n","^<<\"Grazie. È al sicuro con i suoi fratelli e sorelle.\">>","\n","^Gli chiedo quanti siano.","\n","^<<\"Quasi una dozzina. Tutti orfani, e i giovani più gentili che potresti mai conoscere. Essendo l'Ombra, ho visto molto del vero volto della città e... credo di aver trovato un ruolo ancora più importante da svolgere.\">>","\n","^<<\"Mi sarei rimesso la Maschera di nuovo, ma... se mi avessero scoperto, cosa sarebbe successo a loro, capisci?\">>","\n","^Gli dico che capisco, e che secondo me Maz è molto più utile dell'Ombra. Scrolla le spalle.","\n","^<<\"Forse. Ma... perché non tieni tu la maschera?\">>","\n","^<<\"Potrebbe ancora servire l'Ombra.\">>","\n","ev","void","/ev","->->",{"#f":1}],"post_quest_chat":["^Faccio una bella chiacchierata con Maz.","\n","ev","void","/ev","->->",{"#f":1}],"#f":1}],"shade_of_eccria_quest_debug":[["ev","str","^Trova la Maschera dell'Ombra di Eccria","/str",{"VAR?":"SHADE_OF_ECCRIA_FOUND_MASK"},{"f()":"reached"},"!","/ev",{"*":".^.c-0","flg":5},"ev","str","^Indossa la Maschera dell'Ombra di Eccria","/str",{"VAR?":"SHADE_OF_ECCRIA_FOUND_MASK"},{"VAR?":"SHADE_OF_ECCRIA_EXECUTED_PLAN"},{"f()":"between"},{"f()":"wearing_shade_mask"},"!","&&","/ev",{"*":".^.c-1","flg":5},{"c-0":["\n","ev",{"VAR?":"SHADE_OF_ECCRIA_FOUND_MASK"},{"f()":"activate"},"pop","/ev","\n","^Trovi la Maschera dell'Ombra di Eccria in una grotta nell'Oasi.","\n","ev","void","/ev","->->",{"#f":5}],"c-1":["\n","ev","str","^ShadeOfEccriaMask","/str","/ev",{"VAR=":"debug_current_mask","re":true},"^Indossi la Maschera dell'Ombra di Eccria.","\n","ev","void","/ev","->->",{"#f":5}]}],{"cutscene":["^*** DISSOLVENZA AL NERO. È NOTTE. DUE GUARDIE SORVEGLIANO UN BAMBINO. SABLE È NASCOSTA NEI PARAGGI, IN ASCOLTO. INDOSSA LA MASCHERA DELL'OMBRA DI ECCRIA. ***","\n",{"->t->":"shade_of_eccria_content.guard_conversation"},"^*** SABLE SALTA FUORI DAL NASCONDIGLIO, SPAVENTANDO LE GUARDIE. ***","\n",{"->t->":"shade_of_eccria_content.guard_run_away"},"^*** LE GUARDIE FUGGONO. SABLE VA A PARLARE CON IL BAMBINO. ***","\n",{"->t->":"shade_of_eccria_content.rescue_conversation"},"^*** IL RAGAZZO SCAPPA VIA. FINE DELLA SCENA. ***","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_EXECUTED_PLAN"},{"f()":"activate"},"pop","/ev","\n","ev","void","/ev","->->",{"#f":1}],"#f":3}],"shade_of_eccria_quest_definition":[{"#":"name"},"^L'Ombra di Eccria","\n",{"#":"locations"},"^quest_giver, mask_hiding_place","\n",{"#":"status"},["ev",{"VAR?":"SHADE_OF_ECCRIA_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"SHADE_OF_ECCRIA_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho parlato con Maz, il cui alter ego l'Ombra di Eccria era un tempo il terrore della città. Uno dei bambini di cui si prende cura è stato imprigionato dalle Guardie Eccrine per aver deviato illegalmente la condotta dell'acqua. Mi sono offerta di aiutarlo a liberarlo.","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_LOOK_FOR_MASK"},{"VAR?":"SHADE_OF_ECCRIA_FOUND_MASK"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Maz mi ha mostrato il segno dell'Ombra. Mi ha detto di andare al cancello della città e cercare il segno. Mi porterà alla maschera dell'Ombra.","\n",{"#":"stage"},{"#":"status: active"},"^Dovrei andare a recuperare la maschera.","\n",{"->":".^.^.^.25"},null]}],"nop","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_FOUND_MASK"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho trovato la maschera in una grotta in mezzo all'Oasi.","\n",{"->":".^.^.^.32"},null]}],"nop","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_FOUND_MASK"},{"VAR?":"SHADE_OF_ECCRIA_RETURNED_MASK"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: quest_giver"},"^Dovrei riportare la maschera a Maz.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_FORMED_PLAN"},{"VAR?":"SHADE_OF_ECCRIA_EXECUTED_PLAN"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: quest_giver"},"^Insieme, Maz e io abbiamo formulato un piano per liberare il ragazzo. Dovrei parlare con Maz quando sono pronta per procedere.","\n",{"->":".^.^.^.48"},null]}],"nop","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_EXECUTED_PLAN"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Mi sono avvicinata di soppiatto alle guardie di notte e le ho spaventate via con la maschera dell'Ombra di Eccria. Il ragazzo è scappato in fretta dopo che le guardie sono fuggite.","\n",{"->":".^.^.^.55"},null]}],"nop","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_EXECUTED_PLAN"},{"VAR?":"SHADE_OF_ECCRIA_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: quest_giver"},"^Dovrei tornare da Maz per fargli sapere che tutto è andato secondo il piano.","\n",{"->":".^.^.^.63"},null]}],"nop","\n","ev",{"VAR?":"SHADE_OF_ECCRIA_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Maz è stato molto grato del mio aiuto. Mi ha lasciato tenere la maschera.","\n",{"->":".^.^.^.70"},null]}],"nop","\n","end",{"#f":1}],"searching_for_llhor_content":[{"->":".^.quest_start"},{"quest_start":[["ev",{"VAR?":"LLHOR_STARTED"},{"f()":"activate"},"pop","/ev","\n","^Il Sacerdote Atomico si china in avanti in un modo che ritiene invitante.","\n","^E suppongo che abbia ragione, perché eccomi qui.","\n",{"#":"gesture_partner: greeting"},{"#":"gesture_sable: greeting"},"^<<\"Glider! Abbiamo un compito per te, se puoi. E se ti interessa, ovviamente.\">>","\n","^<<\"Le Glider tendono a essere interessate ai <i>compiti</i>.\">>","\n","^Non ho mai saputo bene come sentirmi riguardo al Sacerdozio Atomico.","\n","^Da bambina ne ero al tempo stesso impaurita e affascinata, guardandoli svolgere i loro misteriosi affari e inventandomi ogni sorta di cose su di loro nella mia testa.","\n","^Oggi capisco che sono un ordine come qualunque altro...","\n","^...solo più severo, più insulare e dedito a una cautela collettiva che sempre più sembra paranoia che ragione.","\n","^Eppure, in genere mi piace un compito.","\n",{"#":"gesture_partner: talking"},"^<<\"Conosci Llhor la Favolatrice?\">>","\n","ev",{"VAR?":"LLHOR_FOUND"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev","str","^Sì!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Mai sentita!","/str","/ev",{"*":".^.c-1","flg":4},{"->":".^.^.^.35"},{"c-0":["^ ","\n","^Gli dico che ho già incontrato Llhor, al suo campo.","\n","^<<\"Perfetto! Eri la scelta giusta per il compito, credo.\">>","\n",{"->":".^.^.^.^.continue"},{"#f":5}],"c-1":["^ ","\n","^Mento dicendo di non averla mai sentita nominare.","\n","^<<\"È vero?\">>","\n",{"#":"gesture_partner: yes"},"^Il Sacerdote Atomico annuisce e tace per un momento.","\n","^<<\"Spiacevole.\">>","\n","^<<\"Ma non importa! Il compito è ancora necessario.\">>","\n",{"->":".^.^.^.^.continue"},{"#f":5}]}]}],[{"->":".^.b"},{"b":["\n",{"#":"gesture_sable: talking"},"^Dico al Sacerdote che non ho mai sentito parlare di Llhor la Favolatrice.","\n","^<<\"Allora è il compito perfetto per te! Perché alla fine <i>conoscerai</i> Llhor la Favolatrice.\">>","\n","^Mi sembra ragionevole. Chiedo qual è il compito.","\n",{"->":".^.^.^.35"},null]}],"nop","\n",["^<<\"Vogliamo che tu trovi Llhor. E quando lo farai, comunicale che vorremmo invitarla a tornare a Eccria.\">>","\n","^<<\"Ci... manca. Parecchio, in realtà.\">>","\n","^Potrebbe essere la più grande emozione che abbia mai sentito da un membro del Sacerdozio, e sembra autentica. Mi chiedo che rapporto abbia Llhor con loro.","\n","ev","str","^Dimmi di più su Llhor!","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Perché se n'è andata?","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","^Gli chiedo di dirmi di più su Llhor.","\n","^<<\"È stata tra le nostre voci più forti, trasformando l'avvertimento in fantasia e la sicurezza in canzone. Parla la lingua del popolo, per trasmettere le parole dei saggi.\">>","\n",{"->":".^.^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Chiedo perché Llhor abbia lasciato Eccria in primo luogo.","\n","^<<\"Secondo lei, voleva 'schiarirsi le idee'. Non siamo sicuri di cosa intenda con questo, ma speriamo non si schiarisca le idee da tutto quello che ha fatto per noi.\">>","\n","^Chiedo cosa abbia fatto.","\n","^<<\"Ha diffuso il nostro messaggio nei luoghi dove noi che non siamo lei non possiamo arrivare. Una voce forte nel Sacerdozio Atomico.\">>","\n",{"->":".^.^.^.g-0"},{"#f":5}],"#f":5,"#n":"continue"}],{"g-0":["ev","str","^Perfetto. Vado!","/str","/ev",{"*":".^.c-2","flg":4},"ev","str","^Dove pensi che sia Llhor?","/str","/ev",{"*":".^.c-3","flg":4},{"c-2":["^ ","\n","^Dico al Sacerdote Atomico che proverò a trovare Llhor e mi accingo ad andare. Il Sacerdote si inchina in congedo.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-3":["^ ","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["^<<\"Se non sei sicura da dove iniziare, può essere saggio parlare con i locandieri delle Stazioni degli Scarabei. Llhor porta i nostri messaggi in tutto il mondo.\">>","\n",{"#":"gesture_sable: thanks"},"^Lo ringrazio per il consiglio e lo saluto.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":1}],"quest_in_progress":["^<<\"Progressi sulla ricerca di Llhor, Glider? Davvero ci manca.\">>","\n","^Gli dico che ci sto ancora lavorando.","\n","ev","void","/ev","->->",{"#f":1}],"quest_complete":["ev",{"VAR?":"LLHOR_COMPLETED"},{"f()":"activate"},"pop","/ev","\n","^<<\"Non sappiamo cosa le hai detto, Glider. Ma siamo grati che gliel'abbia detto.\">>","\n","^<<\"Llhor è tornata con rinnovata passione. E il merito è tuo.\">>","\n","^<<\"Quindi grazie, Glider. E mettiti al sicuro.\">>","\n","ev","void","/ev","->->",{"#f":1}],"first_clue":[["ev","str","^Sai dove si trovi Llhor?","/str",{"VAR?":"LLHOR_STARTED"},{"VAR?":"LLHOR_FIRST_CLUE"},{"f()":"between"},"/ev",{"*":".^.c-0","flg":5},{"c-0":["^ ","\n","ev",{"VAR?":"LLHOR_FIRST_CLUE"},{"f()":"activate"},"pop","/ev","\n","^<<\"Ah! Cerchi Llhor? La adoro, è fantastica. Mi pare che l'ultima volta fosse diretta verso i Sodici. Posto grande. Buon posto per svuotare il vecchio secchio dei pensieri.\">>","\n",{"#":"gesture_sable: thanks"},"^La ringrazio per l'aiuto.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":3}],"second_clue":[["ev","str","^Sai dove si trovi Llhor?","/str",{"VAR?":"LLHOR_STARTED"},{"VAR?":"LLHOR_SECOND_CLUE"},{"f()":"between"},"/ev",{"*":".^.c-0","flg":5},{"c-0":["^ ","\n","ev",{"VAR?":"LLHOR_SECOND_CLUE"},{"f()":"activate"},"pop","/ev","\n","^<<\"Non posso dirti dove sia adesso, ma quando l'ho vista cercava i Cantori Dormienti. Sono delle balene di pietra, impossibile non vederle.\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":3}],"third_clue":[["ev","str","^Sai dove si trovi Llhor?","/str",{"VAR?":"LLHOR_STARTED"},{"VAR?":"LLHOR_THIRD_CLUE"},{"f()":"between"},"/ev",{"*":".^.c-0","flg":5},{"c-0":["^ ","\n","ev",{"VAR?":"LLHOR_THIRD_CLUE"},{"f()":"activate"},"pop","/ev","\n","^<<\"Llhor? Non la vedo da <i>secoli</i>. Cioè, anni veri. Mi pare che all'epoca seguisse la via dell'Arciere.\">>","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":3}],"llhor_main_encounter":[["^Se avevo dei dubbi sul fatto di riconoscere la mitica Llhor, sono svaniti alla vista della sua maschera.","\n","^Un volto si volta.","\n",{"#":"llhor_sad"},"^<<\"Mi stai cercando, vero?\">>","\n","ev","str","^Il Sacerdozio Atomico ti sta cercando.","/str","/ev",{"*":".^.c-0","flg":4},"ev","str","^Volevo conoscerti. Sono una fan.","/str","/ev",{"*":".^.c-1","flg":4},"ev","str","^Solo una compagna di viaggio.","/str","/ev",{"*":".^.c-2","flg":4},{"c-0":["^ ","\n","^Dico a Llhor che sono qui per conto del Sacerdozio Atomico.","\n",{"#":"llhor_confused"},"^<<\"Vedo allora, Glider, sei venuta qui,<br>a portarmi via.<br>A fermare il mio cammino,<br>farmi parlare,<br>di come mi sono smarrita.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n",{"#":"llhor_happy"},"^<<\"Ho un'ammiratrice? chiese la poetessa. Beh, almeno una buona notizia.<br>Ma nel tuo occhio,<br>vedo la menzogna.<br>Stai chiedendo per il Sacerdote.\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["^  ","\n",{"#":"llhor_angry"},"^<<\"Vorrei poterti credere, ma<br>ho un certo fiuto.<br>La richiesta del Sacerdozio<br>è il compito della Glider.<br>Perché non dici la verità?\">>","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^Non so cosa dire dopo, e certamente non <i>in rima</i>, quindi faccio una specie di spallucce scherzose.","\n",{"#":"llhor_sad"},"^Llhor scuote la testa e guarda i cieli, la maschera si sposta di lato.","\n","^<<\"So perché il Sacerdozio mi vuole.\">>","\n","^<<\"A dirla tutta, mi mancano anche.\">>","\n","^Aspetto il prossimo verso, ma a quanto pare questo è solo parlare.","\n","ev","str","^Cosa fai per loro?","/str","/ev",{"*":".^.c-3","flg":4},"ev","str","^Perché hai lasciato Eccria?","/str","/ev",{"*":".^.c-4","flg":4},{"c-3":["^ ","\n",{"#":"llhor_happy"},"^<<\"Sono una favolatrice errante, vita di poeta è la mia scelta.<br>I Sacerdoti mi chiedono<br>di spargere sicurezza,<br>e dare voce alla loro saggezza.\">>","\n","^Sospira.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"c-4":["^ ","\n",{"#":"llhor_confused"},"^<<\"La città è grande, l'amo così, ma qualcosa mi turba.<br>Mi sono affezionata<br>al mondo oltre i suoi confini.<br>C'è molto di più da vedere.\">>","\n","^Fa spallucce.","\n",{"->":".^.^.^.g-1"},{"#f":5}],"#f":5}],"g-1":["ev","str","^Belle rime. Niente male.","/str","/ev",{"*":".^.c-5","flg":4},"ev","str","^Tornerai, allora?","/str","/ev",{"*":".^.c-6","flg":4},{"c-5":["^ ","\n","^Dico a Llhor che mi piacciono le sue rime.","\n",{"#":"llhor_happy"},"^Mi ringrazia con un piccolo inchino.","\n",{"->":".^.^.^.g-2"},{"#f":5}],"c-6":["^ ","\n","^Chiedo a Llhor se tornerà a casa, allora.","\n",{"->":".^.^.^.g-2"},{"#f":5}],"#f":5}],"g-2":[{"#":"llhor_sad"},"^<<\"I Sacerdoti mi danno una bella vita. Spargo la loro parola, mi trattano come una regina. Ma... c'è ancora qualcosa che non va. Sono a un punto morto.\">>","\n","^Chiedo di che tipo e non risponde.","\n","^<<\"Come ti chiami?\">>","\n","^Le dico che mi chiamo Sable.","\n","^<<\"Sable, come Glider... potresti avere una particolare visione di ciò che cerco.\">>","\n",{"#":"llhor_confused"},"^<<\"Perché ciò che desidero è scegliere una via, e tu sei più o meno nello stesso viaggio. Credi di potermi aiutare?\">>","\n","^Le dico di sì, ma è un assoluto 'forse' segreto, al limite del 'ne dubito'.","\n","^<<\"Il Sacerdozio Atomico, per quanto strano e severo, mi ha dato una vita molto confortevole. Parlo la loro verità, spargo la loro parola e...\">>","\n",{"#":"llhor_angry"},"^<<\"Beh, francamente, evito che siano sempre così dannatamente <i>noiosi</i>.\">>","\n","^Incrocia le braccia.","\n","^<<\"Per questo mi trattano meravigliosamente. Ottengo qualsiasi cosa voglia, purché usi i miei doni per trasmettere il loro messaggio.\">>","\n","ev","str","^Sembra fantastico.","/str","/ev",{"*":".^.c-7","flg":4},"ev","str","^Sembra soffocante.","/str","/ev",{"*":".^.c-8","flg":4},{"c-7":["^ ","\n","^<<\"È vero! È vero, è vero, è vero.\">>","\n",{"#":"llhor_angry"},"^<<\"Ma vuol dire anche che non posso parlare di molto altro. E mi chiedo cos'altro potrei fare. Potrei essere più stravagante? O più divertente? Buffa, persino?\">>","\n",{"->":".^.^.^.g-3"},{"#f":5}],"c-8":["^ ","\n","^<<\"È vero! È vero, è vero, è vero.\">>","\n",{"#":"llhor_sad"},"^<<\"Ma vuol dire anche che vivo una vita incantata, certamente più incantata di chi si guadagna da vivere raccontando storie e cantando. È meraviglioso, davvero.\">>","\n",{"->":".^.^.^.g-3"},{"#f":5}],"#f":5}],"g-3":["^<<\"Quindi ora mi chiedo: dovrei tornare a Eccria?\">>","\n","ev","str","^Sì!","/str","/ev",{"*":".^.c-9","flg":4},"ev","str","^No!","/str","/ev",{"*":".^.c-10","flg":4},{"c-9":["^ ","\n",{"->":".^.^.^.g-4"},{"#f":5}],"c-10":["^ ","\n",{"->":".^.^.^.g-4"},{"#f":5}],"#f":5}],"g-4":["^Llhor mi liquida di nuovo.","\n",{"#":"llhor_angry"},"^<<\"No, no, no, non è così <i>facile</i>, Sable! Non capisci?\">>","\n","^<<\"Ho passato queste settimane errando nella vastità del deserto, attraversando città e accampamenti, rovine e meraviglie... ponendomi domande.\">>","\n",{"#":"llhor_confused"},"^<<\"E le ho ristrette alle tre domande più significative, per le quali non ho risposte. Forse se puoi aiutarmi...\">>","\n","^Le dico sì, certo, ovviamente, prego.","\n",{"#":"llhor_happy"},"^<<\"Grazie. Hai la saggezza di una Glider.\">>","\n","^Llhor mi attira più vicino e guardo profondamente negli occhi della sua maschera.","\n",{"#":"llhor_confused"},"^<<\"Sable. Glider. Qual è il valore dell'arte? Diffondere verità, o diffondere gioia?\">>","\n","^È un bell'inizio. Le dico che il valore dell'arte è...","\n","ev","str","^Verità?","/str","/ev",{"*":".^.c-11","flg":4},"ev","str","^Gioia?","/str","/ev",{"*":".^.c-12","flg":4},{"c-11":["^ ","\n","^Dico che è la verità e Llhor annuisce con vigore.","\n",{"#":"llhor_angry"},"^<<\"Una favolatrice in parole rozze è chi spaccia menzogne.<br>Ma io ho trovato<br>una via di mezzo.<br>Dare avvertimenti ai saggi.\">>","\n",{"->":".^.^.^.g-5"},{"#f":5}],"c-12":["^ ","\n","^Le dico che è gioia e annuisce con vigore.","\n",{"#":"llhor_happy"},"^<<\"Se tutto ciò che otteniamo è una sola vita da vivere per un po',<br>allora sembrerebbe<br>un nobile sogno,<br>regalare al mondo un sorriso.\">>","\n",{"->":".^.^.^.g-5"},{"#f":5}],"#f":5}],"g-5":["^<<\"Affascinante, Sable. Davvero utile.\">>","\n","^Lo è stato?","\n",{"#":"llhor_confused"},"^<<\"Prossima domanda. Davanti a una sfida, come l'affronti? Dai più valore alla cautela o alla sicurezza?\">>","\n","^Beh, ciò che di certo non dirò è che le credevo praticamente la stessa cosa. Invece...","\n","ev","str","^Cautela.","/str","/ev",{"*":".^.c-13","flg":4},"ev","str","^Sicurezza.","/str","/ev",{"*":".^.c-14","flg":4},{"c-13":["^ ","\n","^Le dico che credo che la cautela sia più importante della sicurezza.","\n",{"#":"llhor_happy"},"^<<\"Cautela! Interessante. E non hai neanche dovuto pensarci. Perfetto.\">>","\n","^Llhor si schiarisce la voce.","\n",{"#":"llhor_angry"},"^<<\"Quando lasciai casa mia, diretta alle sabbie,<br>non sapevo cosa avrei trovato in queste terre vaste.<br>Ma sapevo che andando, rischiavo anima e pelle,<br>quindi indossai cautela fuori, e accesi il fuoco dentro.\">>","\n",{"->":".^.^.^.g-6"},{"#f":5}],"c-14":["^ ","\n","^Le dico che credo che la sicurezza sia più importante della cautela.","\n",{"#":"llhor_happy"},"^<<\"Sicurezza! Affascinante. E hai risposto così rapidamente.\">>","\n","^Llhor si schiarisce la voce.","\n",{"#":"llhor_confused"},"^<<\"Quando lasciai la vocazione, mi sentivo persa.<br>Dovevo andare altrove, a qualsiasi costo.<br>Così lontana ora, mi chiedo cosa speravo di trovare.<br>Per questo pezzo di me, ho perso la pace della mente?\">>","\n",{"->":".^.^.^.g-6"},{"#f":5}],"#f":5}],"g-6":["ev","str","^Nuovo schema di rime, mi piace.","/str","/ev",{"*":".^.c-15","flg":4},"ev","str","^Qual è l'ultima domanda?","/str","/ev",{"*":".^.c-16","flg":4},{"c-15":["^ ","\n","^Llhor annuisce.","\n","^<<\"Versatilità.\">>","\n",{"->":".^.^.^.g-7"},{"#f":5}],"c-16":["^ ","\n",{"->":".^.^.^.g-7"},{"#f":5}],"#f":5}],"g-7":["^<<\"Mi sei stata d'aiuto, Sable. Grazie. L'ultima domanda è probabilmente facile per te, ancora in Volo.\">>","\n",{"#":"llhor_confused"},"^<<\"Perché esploriamo? Cosa ci spinge? Cerchiamo il nostro scopo? O ci concediamo la nostra libertà?\">>","\n","^Per essere giusti con Llhor, questa mi fa fermare.","\n","^Mi è girata in mente di tanto in tanto, ma non con queste parole. Mi chiedo, il mio scopo come Glider è vedere tutti i luoghi? O trovare il <i>mio</i> posto?","\n","^Ci penso e offro una risposta. Lo scopo di questa esplorazione è...","\n","ev","str","^Trovare il proprio scopo.","/str","/ev",{"*":".^.c-17","flg":4},"ev","str","^Concedersi la libertà.","/str","/ev",{"*":".^.c-18","flg":4},{"c-17":["^ ","\n","^Dico a Llhor che il punto è trovare il nostro scopo.","\n","^<<\"Affascinante. Siamo creature così strane...\">>","\n","^Inspira.","\n",{"#":"llhor_sad"},"^<<\"In ognuna di noi c'è un fiore. La risposta al nostro bisogno.<br>Ma non possiamo aspettare,<br>quindi contempliamo<br>il mistero del seme.\">>","\n",{"->":".^.^.^.g-8"},{"#f":5}],"c-18":["^ ","\n","^Dico a Llhor che il punto è concedersi la libertà.","\n","^<<\"Affascinante.\">>","\n","^Inspira.","\n",{"#":"llhor_sad"},"^<<\"I nostri cuori sono cose così impazienti. Odiano sentirsi dire 'no'.<br>Quindi cerchiamo tempo,<br>nel fiore degli anni.<br>Ma è <i>spazio</i> che ci serve per crescere.\">>","\n",{"->":".^.^.^.g-8"},{"#f":5}],"#f":5}],"g-8":["^Llhor si ferma dopo questo ultimo.","\n","^Sento il vento passare, e poi all'improvviso lei batte le mani.","\n",{"#":"llhor_happy"},"^<<\"Bene. È deciso!\">>","\n","^<<\"Credo di aver deciso. Ma mi servirà un'altra notte o due per pensarci.\">>","\n","^Chiedo a Llhor se tornerà a Eccria o no e ride. Mi accorgo che la sua risata mi piace parecchio.","\n",{"#":"llhor_confused"},"^<<\"Lo scoprirò domani.\">>","\n",{"#":"llhor_happy"},"^<<\"Grazie, Sable, di avermi ascoltata. Sei stata una collaboratrice molto generosa oggi, e mi sento piuttosto rinfrescata.\">>","\n",{"#":"inventory_add: EntertainersBadge"},"^<<\"Prendi questo distintivo — un segno del tuo contributo.\">>","\n","^Si raddrizza.","\n","^<<\"Una Glider di nome Sable, la Favolatrice Llhor,<br>oggi sulle sabbie hanno condiviso qualcosa.<br>Ho fiducia nel suo giudizio, fiducia nella sua mente,<br>e il mio destino nelle sue mani capaci.\">>","\n","^Llhor s'inchina e devo ammetterlo... mi sento piuttosto bene dopo averlo sentito.","\n","^<<\"Grazie, Sable. So che ci incontreremo di nuovo.\">>","\n","^Auguro il meglio a Llhor, e poi la saluto.<br>Non so se ho aiutato, ma ci ho provato.","\n","^Oh no, mi ha contagiata.","\n","ev",{"VAR?":"LLHOR_RETURNED"},{"f()":"activate"},"pop","/ev","\n",{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"#f":1}],"searching_for_llhor_quest_definition":[{"#":"name"},"^In Cerca di Llhor","\n",{"#":"locations"},"^quest_giver, hercules_beetle, parasite_beetle, slicer_beetle, llhors_camp","\n",{"#":"status"},["ev",{"VAR?":"LLHOR_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.10"},null]}],["ev",{"VAR?":"LLHOR_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.10"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.10"},null]}],"nop","\n","ev",{"VAR?":"LLHOR_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Shar Varana a Eccria voleva che rintracciassi Llhor, la leggendaria favolatrice. Mi ha detto di chiedere ai locandieri delle stazioni degli scarabei se sanno qualcosa su dove si trovi Llhor.","\n",{"->":".^.^.^.17"},null]}],"nop","\n","ev",{"VAR?":"LLHOR_FIRST_CLUE"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ifaa alla Burnt Oak Station ha detto che Llhor cercava 'un posto desolato, un posto vasto'. Ha suggerito il Sodic Waste.","\n",{"->":".^.^.^.24"},null]}],"nop","\n","ev",{"VAR?":"LLHOR_SECOND_CLUE"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ofuu alla Marrow Bone Station mi ha detto di cercare i Cantori Dormienti, delle balene di pietra.","\n",{"->":".^.^.^.31"},null]}],"nop","\n","ev",{"VAR?":"LLHOR_THIRD_CLUE"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Afii alla Stazione Sette Sorelle ha detto che Llhor cercava di seguire la via dell'Arciere.","\n",{"->":".^.^.^.38"},null]}],"nop","\n","ev",{"VAR?":"LLHOR_STARTED"},{"VAR?":"LLHOR_FOUND"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"LLHOR_FIRST_CLUE"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: hercules_beetle"},"^Chiedi di Llhor alla Burnt Oak Station.","\n",{"->":".^.^.^.7"},null]}],"nop","\n","ev",{"VAR?":"LLHOR_SECOND_CLUE"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: parasite_beetle"},"^Chiedi di Llhor alla Marrow Bone Station.","\n",{"->":".^.^.^.15"},null]}],"nop","\n","ev",{"VAR?":"LLHOR_THIRD_CLUE"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: slicer_beetle"},"^Chiedi di Llhor alla Stazione Sette Sorelle.","\n",{"->":".^.^.^.23"},null]}],"nop","\n",{"->":".^.^.^.46"},null]}],"nop","\n","ev",{"VAR?":"LLHOR_STARTED"},{"VAR?":"LLHOR_FOUND"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Trova Llhor.","\n",{"->":".^.^.^.54"},null]}],"nop","\n","ev",{"VAR?":"LLHOR_FOUND"},{"VAR?":"LLHOR_RETURNED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: llhors_camp"},"^Ho trovato Llhor accampata nelle Saline. Dovrei andare a dirle che la vogliono a Eccria.","\n",{"->":".^.^.^.62"},null]}],"nop","\n","ev",{"VAR?":"LLHOR_RETURNED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Dopo aver passato la sera al campo di Llhor, l'ho convinta a tornare a Eccria.","\n",{"->":".^.^.^.69"},null]}],"nop","\n",["ev",{"VAR?":"LLHOR_RETURNED"},{"VAR?":"LLHOR_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: quest_giver"},"^Dovrei parlare con Shar Varana ora che Llhor è tornata.","\n",{"->":".^.^.^.73"},null]}],["ev",{"VAR?":"LLHOR_COMPLETED"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Shar Varana è stato molto grato per il mio aiuto nel convincere Llhor.","\n",{"->":".^.^.^.73"},null]}],"nop","\n","end",{"#f":1}],"num_glowworms":[["ev",{"VAR?":"DEBUG"},"/ev",{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"debug_glowworm_amount"},"/ev","~ret",{"->":".^.^.^.2"},null]}],[{"->":".^.b"},{"b":["\n","ev","str","^Verme Luminoso","/str",{"x()":"inventory_get_quantity","exArgs":1},"/ev","~ret","\n",{"->":".^.^.^.2"},null]}],"nop","\n",{"#f":1}],"have_enough_glowworms":["ev",{"f()":"num_glowworms"},5,">=","/ev","~ret","\n",{"#f":1}],"nozis_nibbles_content":[{"->":".^.investigation"},{"investigation":[["ev",{"^->":"slicer_innkeeper_conversation"},{"f()":"came_from"},"/ev",{"temp=":"came_from_innkeeper"},"\n","ev","str","^Sai dove posso trovare dei vermi luminosi?","/str",{"VAR?":"NOZIS_NIBBLES_STARTED"},{"VAR?":"NOZIS_NIBBLES_LEARNED_HOW_TO_CATCH"},{"f()":"between"},"/ev",{"*":".^.c-0","flg":5},{"c-0":["^ ","\n","ev",{"VAR?":"came_from_innkeeper"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"NOZIS_NIBBLES_LEARNED_HOW_TO_CATCH"},{"f()":"activate"},"pop","/ev","\n","^<<\"Sì, sì, certo che lo so! C'è una grotta molto a sud di qui, piena zeppa di quei piccoli sinistri viscidi.\">>","\n","^Sinistri piccoli viscidi.","\n","^<<\"Li odio. Sono... ugh, orribili! Ma purtroppo a volte tornano utili, quindi mi sono fatta piuttosto pratica a catturarli.\">>","\n","^Le chiedo se potrebbe aiutare e la risposta è un brivido.","\n","^<<\"Assolutamente no. Ma posso consigliare: devi farli scendere da dove si annidano sul soffitto della grotta. Per farlo, cerca rocce sulfuree in giro lì vicino. Vuoi prendere appunti?\">>","\n","^Le dico che sto prendendo appunti mentali.","\n","^<<\"Bene, devi cercare rocce sulfuree e bagnarle. Inizieranno a fumare, e dovrebbe bastare per stordire i vermi luminosi e portarti la tua orribile, viscida preda.\">>","\n","^Per non farla soffrire ulteriormente, le porgo i miei ringraziamenti e proseguo.","\n",{"->":".^.^.^.7"},null]}],[{"->":".^.b"},{"b":["\n","^<<\"Non lo so, mi spiace. Forse il locandiere lo sa!\">>","\n",{"->":".^.^.^.7"},null]}],"nop","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":3}],"#f":1}],"nozis_nibbles_quest_debug":[["ev","str","^Raccogli vermi luminosi","/str","/ev",{"*":".^.c-0","flg":4},{"c-0":["\n","ev",{"VAR?":"debug_glowworm_amount"},5,"+",{"VAR=":"debug_glowworm_amount","re":true},"/ev","^Più che soddisfatta del mio successo, raccolgo i vermi luminosi e li metto via. Vermi per un wyrm.","\n","ev","void","/ev","->->",{"#f":5}]}],{"#f":3}],"nozis_nibbles_quest_definition":[{"#":"name"},"^Gli Spuntini di Nozi","\n",{"#":"locations"},"^quest_giver, slicer_camp, glow_worm_cave","\n",{"#":"items"},"ev","str","^Verme Luminoso","/str","out","/ev","\n",{"#":"status"},["ev",{"VAR?":"NOZIS_NIBBLES_STARTED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^inactive","\n",{"->":".^.^.^.18"},null]}],["ev",{"VAR?":"NOZIS_NIBBLES_COMPLETED"},{"f()":"reached"},"!","/ev",{"->":".^.b","c":true},{"b":["\n","^active","\n",{"->":".^.^.^.18"},null]}],[{"->":".^.b"},{"b":["\n","^completed","\n",{"->":".^.^.^.18"},null]}],"nop","\n","ev",{"VAR?":"NOZIS_NIBBLES_STARTED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Citra mi ha chiesto di raccogliere dei vermi luminosi.","\n",{"->":".^.^.^.25"},null]}],"nop","\n",["ev",{"VAR?":"NOZIS_NIBBLES_STARTED"},{"VAR?":"NOZIS_NIBBLES_LEARNED_HOW_TO_CATCH"},{"f()":"between"},{"f()":"have_enough_glowworms"},"!","&&","/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: slicer_camp"},{"#":"status: active"},"^Chiedere in giro alla Stazione Sette Sorelle come catturare i vermi luminosi.","\n",{"->":".^.^.^.29"},null]}],["ev",{"VAR?":"NOZIS_NIBBLES_LEARNED_HOW_TO_CATCH"},{"f()":"reached"},"/ev",{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho chiesto in giro e ho scoperto che i vermi si annidano in una grotta a Hakoa. Devo affumicarli lanciando le rocce della grotta nell'acqua.","\n",{"->":".^.^.^.29"},null]}],"nop","\n","ev",{"VAR?":"NOZIS_NIBBLES_LEARNED_HOW_TO_CATCH"},{"VAR?":"NOZIS_NIBBLES_COMPLETED"},{"f()":"between"},{"f()":"have_enough_glowworms"},"!","&&","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},{"#":"locations: glow_worm_cave"},"^Vai alla grotta.","\n",{"->":".^.^.^.40"},null]}],"nop","\n","ev",{"VAR?":"NOZIS_NIBBLES_STARTED"},{"VAR?":"NOZIS_NIBBLES_COMPLETED"},{"f()":"between"},"/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"f()":"num_glowworms"},"/ev",{"temp=":"numGlowworms"},"\n","ev",{"VAR?":"numGlowworms"},5,"<","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: active"},"^Raccogli vermi luminosi - ","ev",{"VAR?":"numGlowworms"},"out","/ev","^/","ev",5,"out","/ev","\n",{"->":".^.^.^.13"},null]}],[{"->":".^.b"},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Raccogli vermi luminosi - ","ev",5,"out","/ev","^/","ev",5,"out","/ev","\n","ev",{"VAR?":"NOZIS_NIBBLES_COMPLETED"},{"f()":"reached"},"!","/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"locations: quest_giver"},{"#":"status: active"},"^Consegna i vermi luminosi a Citra.","\n",{"->":".^.^.^.20"},null]}],"nop","\n",{"->":".^.^.^.13"},null]}],"nop","\n",{"->":".^.^.^.48"},null]}],"nop","\n","ev",{"VAR?":"NOZIS_NIBBLES_COMPLETED"},{"f()":"reached"},"/ev",[{"->":".^.b","c":true},{"b":["\n",{"#":"stage"},{"#":"status: completed"},"^Ho consegnato i vermi luminosi a Citra.","\n",{"->":".^.^.^.55"},null]}],"nop","\n","end",{"#f":1}],"atomic_heart_ready_to_accuse":["ev",{"VAR?":"ATOMIC_HEART_RETURNED_AFTER_FIXING"},{"VAR?":"ATOMIC_HEART_COMPLETED"},{"f()":"between"},{"f()":"atomic_heart_num_suspects"},0,">","&&","/ev","~ret","\n",{"#f":1}],"atomic_heart_in_progress":["ev",{"VAR?":"ATOMIC_HEART_STARTED"},{"VAR?":"ATOMIC_HEART_COMPLETED"},{"f()":"between"},"/ev","~ret","\n",{"#f":1}],"atomic_heart_num_suspects":["ev",{"VAR?":"ATOMIC_HEART_SUSPECT_HAMZA"},{"f()":"reached"},{"VAR?":"ATOMIC_HEART_SUSPECT_IRIA"},{"f()":"reached"},"+",{"VAR?":"ATOMIC_HEART_SUSPECT_GARAY"},{"f()":"reached"},"+","/ev","~ret","\n",{"#f":1}],"player_wearing_guard_mask":["ev",{"x()":"current_mask"},"str","^GuardMask","/str","==","/ev","~ret","\n",{"#f":1}],"atomic_heart_content":[{"->":".^.should_return_to_sandip"},{"should_return_to_sandip":["ev",{"VAR?":"ATOMIC_HEART_DELIVERED_SPARE_PART"},{"VAR?":"ATOMIC_HEART_SPARE_PART_READY"},{"f()":"between"},{"VAR?":"atomic_heart_interviewed_characters"},"LIST_COUNT",1,">","&&","/ev",[{"->":".^.b","c":true},{"b":["\n","ev",{"VAR?":"ATOMIC_HEART_SPARE_PART_READY"},{"f()":"activate"},"pop","/ev","\n","^Forse dovrei tornare da Sandip per vedere se il nuovo nucleo di potenza è pronto.","\n",{"->":".^.^.^.11"},null]}],"nop","\n","ev","void","/ev","->->",{"#f":1}],"keycard_terminal":[["^C'è una fessura per una tessera sul terminale. Forse sbloccherà la porta?","\n","ev","str","^Inserisci la tessera.","/str","str","^AtomicHeartKeycard","/str",{"x()":"inventory_get_quantity","exArgs":1},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Non fare nulla.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"ATOMIC_HEART_UNLOCKED_DOOR"},{"f()":"activate"},"pop","/ev","\n","^Inserisco la tessera e la porta si sblocca.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Forse è meglio lasciar perdere.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"garay_arrested":["^<<\"Tu! Sei stata tu!\">>","\n","^Sono leggermente scossa dalla forza dell'accusa, per quanto possa essere vera.","\n","^Posso solo restare a fissarlo in un silenzio scioccato. Sembra averla passata male. Ha resistito alle Guardie?","\n","^<<\"Si capisce solo guardandoti, sei <i>tu</i> che mi hai messo qui! Te l'ho detto! Ero al Caffè, Rita deve averlo confermato.\">>","\n","^<<\"Mi ci hai messo lo stesso... a nessuno importa se un vecchio Scalatore del Serai finisce davanti ai Testimoni. A nessuno.\">>","\n","^<<\"Mi hai dannato, hai incastrato un innocente.\">>","\n","^<<\"Spero che tu riesca a convivere con te stessa, Glider.\">>","\n","^Mi pervade una sensazione di freddo, ho commesso un errore? Non mi sento bene. Sandip non andrebbe certo dietro a ciò che ho detto se fosse sbagliato, vero?","\n",{"->":"END_SCENE"},{"#f":1}],"hamza_arrested":["^Hamza sembra leggermente provato, non l'hanno trattato con i guanti, a quanto pare.","\n","^Non capisco se si accorga del mio avvicinarmi. Se anche lo nota, non lo dà a vedere.","\n","^<<\"Ciao, Glider. Sable, giusto?\">>","\n","^<<\"Quindi ci sei arrivata, eh? Ti senti bene con te stessa, immagino. Anch'io sarei piuttosto compiaciuto, spero almeno che sia stata una bella sfida.\">>","\n","^Pare almeno che abbia preso l'uomo giusto. Il suo atteggiamento rassegnato però mi fa chiedere se sia stato giusto denunciarlo.","\n","^<<\"Beh, Iria si è ripresa i suoi soldi e qualcosa di più togliendomi di mezzo. Buona fortuna alla povera anima che porteranno a sostituirmi: se non è una delle sue raccomandate, avrà i suoi artigli addosso presto.\">>","\n","^L'aria si riempie di nuovo di silenzio. Sembra aver detto la sua.","\n","^Mi volto finalmente per lasciarlo, i Testimoni saranno i giudici del suo destino da qui in poi. Mentre lo faccio un luccichio nell'aria mi attira lo sguardo e istintivamente lo afferro.","\n","^Un oggetto metallico, pesante in mano. Capisco cos'è dopo un momento. ",{"#":"inventory_add: MachinistBadge"},"\n","^Alzo lo sguardo sorpresa, Hamza mi fissa e annuisce in silenzio.","\n",{"->":"END_SCENE"},{"#f":1}],"yannis_arrested":["^Yannis sembra sorprendentemente in forma per essere uno che si sta chiaramente accollando le colpe di qualcun altro. È un po' inquietante.","\n","^<<\"Oh, ciao amica mia.\">>","\n","^Qualcosa nel modo in cui pronuncia la parola 'amica' mi fa sentire che è insincero.","\n","^<<\"Un piccolo consiglio per una buona amica.\">>","\n","^<<\"Valuterei con molta attenzione quanto tempo restare a Eccria, Sable.\">>","\n","^Il suono del mio nome che echeggia contro il metallo della sua maschera mi manda un brivido immediato lungo il corpo. Comincio a sentire che potrei aver commesso un enorme errore.","\n","^Almeno i Testimoni dovrebbero tenerlo occupato mentre sono in Volo. Dovrò però pensarci bene prima di tornare in futuro.","\n","^Decido di non passare con lui più tempo del necessario.","\n",{"->":"END_SCENE"},{"#f":1}],"smashed_window":[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","ev",{"VAR?":"ATOMIC_HEART_CLUE_GLASS"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_sable: thinking"},{"#":"inventory_add: AtomicHeartSmashedGlass"},"^Chiaro come il sole, si vede che la finestra alta è stata frantumata, ed è abbastanza larga perché ci passi un adulto-- anche se dovrebbe essere piuttosto atletico. La maggior parte del vetro è all'esterno della camera: potrebbe essere stata rotta dall'interno.","\n",{"->":".^.^.17"},null],"s1":["pop","\n",{"#":"gesture_sable: thinking"},"^Chiaro come il sole, si vede che la finestra alta è stata frantumata, ed è abbastanza larga perché ci passi un adulto-- anche se dovrebbe essere piuttosto atletico. La maggior parte del vetro è all'esterno della camera: potrebbe essere stata rotta dall'interno.","\n",{"->":".^.^.17"},null],"#f":5}],"\n",{"->":"END_SCENE"},{"#f":1}],"feather":[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","ev",{"VAR?":"ATOMIC_HEART_CLUE_FEATHER"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_sable: thinking"},"^C'è un ciuffo di piume sul pavimento. Strano.","\n",{"#":"gesture_sable: thinking"},{"#":"inventory_add: AtomicHeartFeather"},"^Cerco di immaginare un uccello abbastanza grande e potente da portare via il nucleo di potenza, e decido che è un sospetto che posso assolutamente escludere. Anche se mi piacerebbe molto vederlo.","\n",{"->":".^.^.17"},null],"s1":["pop","\n",{"#":"gesture_sable: thinking"},"^C'è un ciuffo di piume sul pavimento. Strano.","\n",{"#":"gesture_sable: thinking"},"^Cerco di immaginare un uccello abbastanza grande e potente da portare via il nucleo di potenza, e decido che è un sospetto che posso assolutamente escludere. Anche se mi piacerebbe molto vederlo.","\n",{"->":".^.^.17"},null],"#f":5}],"\n",{"->":"END_SCENE"},{"#f":1}],"note":[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","ev",{"VAR?":"ATOMIC_HEART_CLUE_NOTE"},{"f()":"activate"},"pop","/ev","\n",{"#":"gesture_sable: thinking"},"^Adesso sì che è un indizio!","\n",{"#":"gesture_sable: thinking"},"^Un pezzetto di carta giace abbandonato sul pavimento, e quando lo raccolgo vedo che è un pagherò: qualcuno, forse il colpevole, deve dei soldi ai Mercanti.","\n",{"#":"gesture_sable: thinking"},{"#":"inventory_add: AtomicHeartDebtNote"},"^È possibile che il colpevole l'abbia perso, ma chi potrebbe essere così sbadato sulla scena del proprio crimine? Mi chiedo se sia un'esca, lasciata per depistarmi.","\n",{"->":".^.^.17"},null],"s1":["pop","\n",{"#":"gesture_sable: thinking"},"^Adesso sì che è un indizio!","\n",{"#":"gesture_sable: thinking"},"^Un pezzetto di carta giace abbandonato sul pavimento, e quando lo raccolgo vedo che è un pagherò: qualcuno, forse il colpevole, deve dei soldi ai Mercanti.","\n",{"#":"gesture_sable: thinking"},"^È possibile che il colpevole l'abbia perso, ma chi potrebbe essere così sbadato sulla scena del proprio crimine? Mi chiedo se sia un'esca, lasciata per depistarmi.","\n",{"->":".^.^.17"},null],"#f":5}],"\n",{"->":"END_SCENE"},{"#f":1}],"install_the_core":[[["ev","visit",1,"MIN","/ev","ev","du",0,"==","/ev",{"->":".^.s0","c":true},"ev","du",1,"==","/ev",{"->":".^.s1","c":true},"nop",{"s0":["pop","\n","ev",{"VAR?":"ATOMIC_HEART_CLUE_SOCKET"},{"f()":"activate"},"pop","/ev","\n","^Scintille schizzano dai cavi attorno all'alloggiamento, ma il danno all'alloggiamento vuoto in sé è inesistente, per quanto posso giudicare.","\n",{"#":"gesture_sable: thinking"},{"#":"inventory_add: AtomicHeartEmptySocket"},"^Il colpevole ha rimosso il nucleo con cura. Ha senso. Se dovessi rubare qualcosa di così prezioso, anch'io sarei delicata. Ma perché i cavi strappati? Mi sembra quasi una messinscena.","\n",{"->":".^.^.17"},null],"s1":["pop","\n","^Non ci sono segni di danno all'alloggiamento, per quanto posso vedere. Il colpevole ha rimosso il nucleo con cura. Ha senso. Se dovessi rubare qualcosa di così prezioso, anch'io sarei delicata.","\n",{"->":".^.^.17"},null],"#f":5}],"\n","ev","str","^Installa il nuovo nucleo.","/str","str","^AtomicHeartPowerCoreRepaired","/str",{"x()":"inventory_get_quantity","exArgs":1},0,">","/ev",{"*":".^.c-0","flg":5},"ev","str","^Allontanati.","/str","/ev",{"*":".^.c-1","flg":4},{"c-0":["^ ","\n","ev",{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"activate"},"pop","/ev","\n",{"#":"inventory_remove: AtomicHeartPowerCoreRepaired"},"^Inserisco il nuovo nucleo nell'alloggiamento. Il suono è appagante.","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["^ ","\n","^Mi allontano dall'alloggiamento.","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":[{"->":"END_SCENE"},{"#f":5}]}],{"#f":1}],"#f":1}],"atomic_heart_quest_debug":[["ev","str","^Ispeziona l'alloggiamento del Nucleo","/str",{"VAR?":"ATOMIC_HEART_SPARE_PART_READY"},{"VAR?":"ATOMIC_HEART_FIXED"},{"f()":"between"},"/ev",{"*":".^.c-0","flg":5},"ev","str","^Ispeziona la finestra rotta","/str",{"VAR?":"ATOMIC_HEART_COMPLETED"},{"f()":"reached"},"!","/ev",{"*":".^.c-1","flg":5},"ev","str","^Ispeziona le piume sul pavimento","/str",{"VAR?":"ATOMIC_HEART_COMPLETED"},{"f()":"reached"},"!",