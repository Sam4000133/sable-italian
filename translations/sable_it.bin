,{"VAR=":"SpeakerName","re":true},"^Un'onda di conoscenza esplode nella mia coscienza.","\n","^<<\"Dove la forma del sole prende forma dalle ombre, voltati verso la luce.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"moon_shadow_face_door_clue":["ev",{"VAR?":"speaker_puzzle_clue"},"/ev",{"VAR=":"SpeakerName","re":true},"^Sento un messaggio arrivarmi nella testa come un'onda sulla riva.","\n","^<<\"Cerca la falce nella luce argentea e raggiungila dove cade.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"face_door_temple_atomic_priest_puzzle_room":["ev",{"VAR?":"speaker_puzzle_clue"},"/ev",{"VAR=":"SpeakerName","re":true},"^Sento un frammento di informazione pulsare dietro gli occhi.","\n","^<<\"I Sacerdoti Atomici sono i veri portatori dello scopo della Spedizione.\">>","\n","^<<\"I primi tra i Sacerdoti hanno dato la caccia agli scarti, riunendoli in obelischi d'acciaio. Trasportandoli a nord-est.\">>","\n","^<<\"Dipingendo avvertimenti del sorriso della morte e usando le sabbie della terra, hanno seppellito i monoliti di scorie.\">>","\n","^<<\"Per sempre avvertono: coprite il sorriso della morte.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"face_door_temple_nomad_puzzle_room":["ev",{"VAR?":"speaker_puzzle_clue"},"/ev",{"VAR=":"SpeakerName","re":true},"^Le parole si formano nella mia mente come sabbia soffiata dolcemente dal vento.","\n","^<<\"I primi Nomadi, chiaro che il pianeta non potesse sostenerci come la casa, hanno percorso le dune.\">>","\n","^<<\"Ripercorrendo spesso vecchi sentieri, un viaggio iniziato a sud, hanno trovato un nuovo modo di vivere.\">>","\n",{"->":"END_SCENE"},{"#f":1}],"face_door_temple_architect_puzzle_room":[["ev",{"VAR?":"speaker_puzzle_clue"},"/ev",{"VAR=":"SpeakerName","re":true},"^Ricordo vagamente qualcosa che non mi è mai stato raccontato.","\n","^<<\"L'Architetto ha preso le macchine per costruire. Le sabbie hanno sopraffatto i primi insediamenti. È stata tentata una struttura finale.\">>","\n","^<<\"Ospitare gli umani in modo permanente si era rivelato difficile. Così l'Architetto cercò un modo di trattenere le poche acque che si potevano raccogliere dal deserto.\">>","\n","^<<\"Costruirono una grande cisterna, Eccria. Realizzata nei vecchi modi e con i materiali della terra, fu collocata a nord-ovest di qui.\">>","\n",[{"->":"END_SCENE"},{"#f":5,"#n":"g-0"}],null],{"#f":1}],"fishing_quest_has_all_sansee":["ev",{"VAR?":"sansee_fish_one"},{"x()":"inventory_get_quantity","exArgs":1},{"VAR?":"sansee_fish_two"},{"x()":"inventory_get_quantity","exArgs":1},"&&",{"VAR?":"sansee_fish_three"},{"x()":"inventory_get_quantity","exArgs":1},"&&","/ev","~ret","\n",{"#f":1}],"fishing_quest_has_all_wash":["ev",{"VAR?":"wash_fish_one"},{"x()":"inventory_get_quantity","exArgs":1},{"VAR?":"wash_fish_two"},{"x()":"inventory_get_quantity","exArgs":1},"&&",{"VAR?":"wash_fish_three"},{"x()":"inventory_get_quantity","exArgs":1},"&&","/ev","~ret","\n",{"#f":1}],"fishing_quest_has_all_redsee":["ev",{"VAR?":"redsee_fish_one"},{"x()":"inventory_get_quantity","exArgs":1},{"VAR?":"redsee_fish_two"},{"x()":"inventory_get_quantity","exArgs":1},"&&",{"VAR?":"redsee_fish_three"},{"x()":"inventory_get_quantity","exArgs":1},"&&","/ev","~ret","\n",{"#f":1}],"fishing_quest_ready_to_deliver":[["ev",{"VAR?":"FISHING_QUEST_STARTED"},{"VAR?":"FISHING_QUEST_GOT_FIRST_BADGE"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n","ev",{"f()":"fishing_quest_has_all_sansee"},"/ev","~ret","\n",{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"FISHING_QUEST_GOT_FIRST_BADGE"},{"VAR?":"FISHING_QUEST_GOT_SECOND_BADGE"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n","ev",{"f()":"fishing_quest_has_all_wash"},"/ev","~ret","\n",{"->":".^.^.^.4"},null]}],["ev",{"VAR?":"FISHING_QUEST_GOT_SECOND_BADGE"},{"VAR?":"FISHING_QUEST_COMPLETED"},{"f()":"between"},"/ev",{"->":".^.b","c":true},{"b":["\n","ev",{"f()":"fishing_quest_has_all_redsee"},"/ev","~ret","\n",{"->":".^.^.^.4"},null]}],[{"->":".^.b"},{"b":["\n","ev",0,"/ev","~ret",{"->":".^.^.^.4"},null]}],"nop","